                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Background="#FFB060" CornerRadius="14" Width="28" Height="28" VerticalAlignment="Center">
                                    <TextBlock x:Name="QuickDriverUpdatesCountText"
                                               Text="0"
                                               FontSize="13"
                                               FontWeight="Bold"
                                               Foreground="#1A1A1A"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Border>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="QuickDriverUpdatesTitleText"
                                               Text="Driver updates available"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#F0F0F0"/>
                                    <TextBlock Text="Tap to view on the Controller tab"
                                               FontSize="11"
                                               Foreground="#A0A0A0"/>
                                </StackPanel>
                                <FontIcon Grid.Column="2" Glyph="&#xE76C;" FontSize="12" Foreground="#A0A0A0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <!-- GoTweaks self-update banner: helper pushes GoTweaksUpdate
                             after its startup probe. Tap to trigger the install (the
                             helper downloads the signed .msixbundle and runs
                             Add-AppxPackage). Hidden when no update or when the user
                             opted into "Hide update banner". -->
                        <Button x:Name="QuickGoTweaksUpdateTile"
                                Visibility="Collapsed"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Padding="14,10"
                                Margin="0,0,0,8"
                                Background="#202A38"
                                BorderBrush="#7EB6FF"
                                BorderThickness="1"
                                CornerRadius="12"
                                Click="QuickGoTweaksUpdateTile_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="&#xE896;" FontSize="20" Foreground="#7EB6FF" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock x:Name="QuickGoTweaksTitleText"
                                               Text="GoTweaks update available"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#F0F0F0"/>
                                    <TextBlock x:Name="QuickGoTweaksSubtitleText"
                                               Text="Tap to install"
                                               FontSize="11"
                                               Foreground="#A0A0A0"/>
                                </StackPanel>
                                <FontIcon Grid.Column="2" Glyph="&#xE896;" FontSize="12" Foreground="#A0A0A0" VerticalAlignment="Center"/>
                            </Grid>
                        </Button>

                        <!-- Quick Metrics Row -->
                        <Border x:Name="QuickMetricsRow"
                                Margin="0,0,0,8"
                                Background="#1A1C1E"
                                CornerRadius="12"
                                Padding="12,8"
                                BorderBrush="#50555C"
                                BorderThickness="1"
                                Visibility="Collapsed">
                            <Grid x:Name="QuickMetricsGrid"/>
                        </Border>

                        <!-- Dynamic Tiles Container - tiles generated in code-behind -->
                        <StackPanel x:Name="QuickSettingsTilesContainer"/>

                        <!-- Customize Button -->
                        <Button x:Name="QuickSettingsCustomizeButton"
                                HorizontalAlignment="Stretch"
                                Margin="0,16,0,0"
                                Style="{StaticResource StandaloneButtonStyle}"
                                Click="QuickSettingsCustomize_Click">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                                <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xEC7A;" FontSize="15" VerticalAlignment="Center"/>
                                <TextBlock Text="Customize Tiles and Hotkeys" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Customization Panel (hidden by default) -->
                        <Border x:Name="QuickSettingsCustomizePanel"
                                Style="{StaticResource CardStyle}"
                                Visibility="Collapsed"
                                Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Customize Tiles and Hotkeys" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="Tap a tile to select it, then tap another to swap positions. Use Show/Hide to toggle visibility. You can create custom tiles for any action — including OS shortcuts, TDP steps, and FPS limiter cycling — and assign controller button combinations to trigger or cycle through them directly without opening the widget."
                                           Style="{StaticResource CardCaptionStyle}"
                                           Margin="0,0,0,8"
                                           TextWrapping="Wrap"/>

                                <!-- Sortable Tile Grid - generated in code-behind -->
                                <StackPanel x:Name="TileSortableGrid"/>

                                <!-- Selected tile indicator -->
                                <Border x:Name="SelectedTileIndicator"
                                        Visibility="Collapsed"
                                        Background="#1A2530"
                                        CornerRadius="4"
                                        Padding="8"
                                        Margin="0,8,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedTileText"
                                                   Foreground="#00C8FF"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                        <Button x:Name="DeleteSelectedTileButton"
                                                Grid.Column="1"
                                                Visibility="Collapsed"
                                                Background="#662020"
                                                Foreground="White"
                                                Margin="8,0,0,0"
                                                Padding="12,6"
                                                Click="DeleteSelectedTile_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <FontIcon Glyph="&#xE74D;" FontSize="14" Margin="0,0,6,0"/>
                                                <TextBlock Text="Delete"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Close customizations (no save — just closes the panel). Mirrors the
                                     button at the very bottom; placed here too so the user doesn't have to
                                     scroll all the way down to close the customize area. -->
                                <Button x:Name="QuickSettingsCustomizeCloseTopButton"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,16,0,0"
                                        Style="{StaticResource StandaloneButtonStyle}"
                                        Click="QuickSettingsCustomizeDone_Click">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE711;" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="Close Customizations" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- Add Custom Shortcut/Tile Section -->
                                <TextBlock Text="Add Custom Shortcut/Tile"
                                           Style="{StaticResource CardTitleStyle}"
                                           Margin="0,16,0,8"/>

                                <!-- Type selector: Keyboard shortcut vs. predefined Action -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button x:Name="TileTypeKeyboardButton"
                                            Grid.Column="0"
                                            Background="#1A6A9A"
                                            BorderBrush="#2288CC"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            HorizontalAlignment="Stretch"
                                            Padding="8,6"
                                            UseSystemFocusVisuals="True"
                                            Click="TileTypeKeyboard_Click">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <FontIcon Glyph="&#xE765;" FontSize="13" Margin="0,0,6,0"/>
                                            <TextBlock Text="Keyboard" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button x:Name="TileTypeActionButton"
                                            Grid.Column="2"
                                            Background="#1A1C1E"
                                            BorderBrush="#50555C"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            HorizontalAlignment="Stretch"
                                            Padding="8,6"
                                            UseSystemFocusVisuals="True"
                                            Click="TileTypeAction_Click">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                            <FontIcon Glyph="&#xE945;" FontSize="13" Margin="0,0,6,0"/>
                                            <TextBlock Text="Action" FontSize="12" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>

                                <!-- Tile name — only shown for Keyboard mode (Action derives name automatically) -->
                                <TextBox x:Name="CustomShortcutNameBox"
                                         PlaceholderText="Tile Name"
                                         Margin="0,0,0,8"/>

                                <!-- Keyboard section (default visible) -->
                                <StackPanel x:Name="TileKeyboardSection">
                                    <StackPanel Orientation="Horizontal">
                                        <ItemsControl x:Name="CustomShortcutKeyTags">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                        <Button x:Name="CustomShortcutKeyPickerButton" Tag="CustomShortcut" Width="90" Content="+ Key  &#x25BE;" Click="ExtraKeyPicker_Click" Style="{StaticResource KeyPickerButtonStyle}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Action section (collapsed by default, populated in code-behind) -->
                                <ComboBox x:Name="CustomActionTypeComboBox"
                                          HorizontalAlignment="Stretch"
                                          Margin="0,0,0,4"
                                          Visibility="Collapsed"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          PlaceholderText="Select action..."/>

                                <Button x:Name="AddCustomShortcutButton"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,8,0,0"
                                        Style="{StaticResource StandaloneButtonStyle}"
                                        Click="AddCustomShortcut_Click">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                                        <FontIcon Glyph="&#xE710;" FontSize="15" VerticalAlignment="Center"/>
                                        <TextBlock Text="Add Tile" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>

                                <!-- Separator -->
                                <Border Height="1" Background="#30444444" Margin="0,12,0,12"/>

                                <!-- Column Count Toggle -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Columns:"
                                               VerticalAlignment="Center"
                                               Foreground="#AAAAAA"
                                               FontSize="13"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button x:Name="Column3Button"
                                                Content="3"
                                                MinWidth="40"
                                                Margin="0,0,4,0"
                                                Click="ColumnCount3_Click"/>
                                        <Button x:Name="Column4Button"
                                                Content="4"
                                                MinWidth="40"
                                                Margin="0,0,4,0"
                                                Click="ColumnCount4_Click"/>
                                        <Button x:Name="Column5Button"
                                                Content="5"
                                                MinWidth="40"
                                                Click="ColumnCount5_Click"/>
                                    </StackPanel>
                                </Grid>

                                <!-- ===== Program Actions management (moved here from Settings) ===== -->
                                <TextBlock Text="PROGRAM ACTIONS" Style="{StaticResource SectionHeaderStyle}" Margin="0,4,0,0"/>
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Manage Program Actions" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Add .exe or .ps1 files. They appear under &quot;Program Actions (User)&quot; when assigning tiles or the front buttons."
                                                   Style="{StaticResource CardCaptionStyle}" TextWrapping="Wrap"/>

                                        <ItemsControl x:Name="ProgramActionsItemsControl" Margin="0,8,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding DisplayName}" FontSize="14" Foreground="#FFFFFF"/>
                                                            <TextBlock Text="{Binding Path}" FontSize="11" Foreground="{StaticResource HintTextBrush}" TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="1" FontSize="12" Padding="8,4" Background="#2A2A2A"
                                                                Click="ProgramActionDeleteButton_Click" Tag="{Binding}"
                                                                VerticalAlignment="Center">
                                                            <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="#FF6B6B"/>
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="ProgramActionPathTextBox" Grid.Column="0"
                                                     PlaceholderText="Path to .exe or .ps1"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Button x:Name="ProgramActionBrowseButton" Grid.Column="1" Content="Browse…"
                                                    FontSize="13" Padding="10,6" Margin="0,0,8,0" Background="#2A2A2A"
                                                    Click="BrowseProgramAction_Click"/>
                                            <Button x:Name="ProgramActionAddButton" Grid.Column="2" Content="Add"
                                                    FontSize="13" Padding="12,6" Background="#2A2A2A"
                                                    Click="AddProgramAction_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- ===== URL Actions management (moved here from Settings) ===== -->
                                <TextBlock Text="URL ACTIONS" Style="{StaticResource SectionHeaderStyle}" Margin="0,4,0,0"/>
                                <Border Style="{StaticResource CardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="Manage URL Actions" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Add websites. They appear under &quot;Launch Website (User)&quot; when assigning tiles or the front buttons."
                                                   Style="{StaticResource CardCaptionStyle}" TextWrapping="Wrap"/>

                                        <ItemsControl x:Name="UrlActionsItemsControl" Margin="0,8,0,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Text="{Binding Url}" FontSize="14" Foreground="#FFFFFF"
                                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                                        <Button Grid.Column="1" FontSize="12" Padding="8,4" Background="#2A2A2A"
                                                                Click="UrlActionDeleteButton_Click" Tag="{Binding}"
                                                                VerticalAlignment="Center">
                                                            <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="#FF6B6B"/>
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="UrlActionTextBox" Grid.Column="0"
                                                     PlaceholderText="https://example.com"
                                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                                            <Button x:Name="UrlActionAddButton" Grid.Column="1" Content="Add"
                                                    FontSize="13" Padding="12,6" Background="#2A2A2A"
                                                    Click="AddUrlAction_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                                <!-- Separator -->
                                <Border Height="1" Background="#30444444" Margin="0,12,0,12"/>

                                <!-- Show Metrics Row Toggle -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Show Metrics Row"
                                                   Foreground="#FFFFFF"
                                                   FontSize="13"/>
                                        <TextBlock Text="Select up to 6 metrics below"
                                                   Foreground="#666666"
                                                   FontSize="11"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="QuickMetricsToggle"
                                                  Grid.Column="1"
                                                  OffContent=""
                                                  OnContent=""
                                                  Toggled="QuickMetricsToggle_Toggled"/>
                                </Grid>

                                <!-- Metrics Selection (visible when toggle is on) -->
                                <Border x:Name="MetricsSelectionPanel"
                                        Background="#15171A"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,12"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="Select Metrics (max 6)"
                                                   Foreground="#AAAAAA"
                                                   FontSize="11"
                                                   Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- Row 0 -->
                                            <CheckBox x:Name="MetricCheck_BatteryDrain" Content="Battery Drain" Grid.Row="0" Grid.Column="0" Foreground="White" FontSize="12" Margin="0,2" Checked="MetricCheckBox_Changed" Unchecked="MetricCheckBox_Changed"/>
                                            <CheckBox x:Name="MetricCheck_BatteryLevel" Content="Battery Level" Grid.Row="0" Grid.Column="1" Foreground="White" FontSize="12" Margin="0,2" Checked="MetricCheckBox_Changed" Unchecked="MetricCheckBox_Changed"/>
                                            <!-- Row 1 -->
                                            <CheckBox x:Name="MetricCheck_CPUUsage" Content="CPU Usage" Grid.Row="1" Grid.Column="0" Foreground="White" FontSize="12" Margin="0,2" Checked="MetricCheckBox_Changed" Unchecked="MetricCheckBox_Changed"/>
                                            <CheckBox x:Name="MetricCheck_CPUTemp" Content="CPU Temp" Grid.Row="1" Grid.Column="1" Foreground="White" FontSize="12" Margin="0,2" Checked="MetricCheckBox_Changed" Unchecked="MetricCheckBox_Changed"/>
                                            <!-- Row 2 -->
                                            <CheckBox x:Name="MetricCheck_CPUWattage" Content="CPU Wattage" Grid.Row="2" Grid.Column="0" Foreground="White" FontSize="12" Margin="0,2" Checked="MetricCheckBox_Changed" Unchecked="MetricCheckBox_Changed"/>
                                            <CheckBox x:Name="MetricCheck_GPUUsage" Content="GPU Usage" Grid.Row="2" Grid.Column="1" Foreground="White" FontSize="12" Margin="0,2" Checked="MetricCheckBox_Changed" Unchecked="MetricCheckBox_Changed"/>
                                            <!-- Row 3 -->
                                            <CheckBox x:Name="MetricCheck_GPUTemp" Content="GPU Temp" Grid.Row="3" Grid.Column="0" Foreground="White" FontSize="12" Margin="0,2" Checked="MetricCheckBox_Changed" Unchecked="MetricCheckBox_Changed"/>
                                            <CheckBox x:Name="MetricCheck_GPUWattage" Content="GPU Wattage" Grid.Row="3" Grid.Column="1" Foreground="White" FontSize="12" Margin="0,2" Checked="MetricCheckBox_Changed" Unchecked="MetricCheckBox_Changed"/>
                                            <!-- Row 4 -->
                                            <CheckBox x:Name="MetricCheck_MemoryUsage" Content="Memory Usage" Grid.Row="4" Grid.Column="0" Foreground="White" FontSize="12" Margin="0,2" Checked="MetricCheckBox_Changed" Unchecked="MetricCheckBox_Changed"/>
                                            <CheckBox x:Name="MetricCheck_TimeRemaining" Content="Time Remaining" Grid.Row="4" Grid.Column="1" Foreground="White" FontSize="12" Margin="0,2" Checked="MetricCheckBox_Changed" Unchecked="MetricCheckBox_Changed"/>
                                        </Grid>
                                        <TextBlock x:Name="MetricsSelectionCount" Text="0/6 selected" Foreground="#666666" FontSize="11" Margin="0,6,0,0" HorizontalAlignment="Right"/>

                                        <!-- Reorder Section -->
                                        <Border x:Name="MetricsReorderSection"
                                                Background="#1A1C1E"
                                                CornerRadius="6"
                                                Padding="8"
                                                Margin="0,10,0,0"
                                                Visibility="Collapsed">
                                            <StackPanel>
                                                <TextBlock Text="Reorder (drag or use arrows)"
                                                           Foreground="{StaticResource HintTextBrush}"
                                                           FontSize="10"
                                                           Margin="0,0,0,6"/>
                                                <StackPanel x:Name="MetricsReorderList" Spacing="4"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Close customizations (no save — just closes the panel). -->
                                <Button HorizontalAlignment="Stretch"
                                        Margin="0,4,0,0"
                                        Style="{StaticResource StandaloneButtonStyle}"
                                        Click="QuickSettingsCustomizeDone_Click">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8">
                                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE711;" FontSize="14" VerticalAlignment="Center"/>
                                        <TextBlock Text="Close Customizations" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- PERFORMANCE TAB -->
                <ScrollViewer x:Name="PerformanceScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Default Game Profile Card (Preview) - Hidden when no profile available -->
                        <Border x:Name="DefaultGameProfileCard"
                                Style="{StaticResource CardStyle}"
                                Visibility="Collapsed">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#40C04040" Offset="0.0"/>
                                    <GradientStop Color="#40408050" Offset="0.35"/>
                                    <GradientStop Color="#40405080" Offset="0.65"/>
                                    <GradientStop Color="#40804060" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Game Icon -->
                                <Image x:Name="DefaultProfileGameIcon"
                                       Grid.Column="0"
                                       Width="36" Height="36"
                                       Margin="0,0,10,0"
                                       Stretch="UniformToFill"
                                       VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <!-- Game Name + Title -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="DefaultProfileGameName"
                                                   Text=""
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text=" - "
                                                   FontSize="14"
                                                   Foreground="{StaticResource HintTextBrush}"
                                                   VerticalAlignment="Center"
                                                   x:Name="DefaultProfileSeparator"
                                                   Visibility="Collapsed"/>
                                        <TextBlock x:Name="DefaultProfileOptimizingText"
                                                   Text="Optimizing for Z2 Extreme"
                                                   FontSize="11"
                                                   Foreground="#80FFFFFF"
                                                   VerticalAlignment="Center"
                                                   Visibility="Collapsed"/>
                                    </StackPanel>
                                    <TextBlock Text="Default Game Profile (Preview)"
                                               FontSize="13"
                                               Foreground="#AAAAAA"/>
                                    <TextBlock Text="Automatically applies optimized settings"
                                               FontSize="10"
                                               Foreground="#666666"/>
                                    <TextBlock x:Name="DefaultProfileSettingsText"
                                               Text="17W - 60fps"
                                               FontSize="12"
                                               Foreground="#00C8FF"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="DefaultProfileToggle"
                                              Grid.Column="2"
                                              Style="{StaticResource ModernToggleStyle}"
                                              XYFocusUp="{x:Bind PerformanceNavItem}"/>
                            </Grid>
                        </Border>

                        <!-- Active Profile Indicator -->
                        <Border x:Name="ActiveProfileCard" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Far-left: game icon in its own column, sized to the card.
                                     Collapsed (zero width) when no game runs, so the text gets
                                     the full width. -->
                                <Image x:Name="PerGamePerformanceProfileGameIcon"
                                       Grid.Column="0"
                                       Width="48" Height="48"
                                       Margin="0,0,12,0"
                                       Stretch="UniformToFill"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>

                                <!-- Middle: label + active profile name + game detection -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                    <TextBlock Text="Per Game performance &amp; display profile"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#FFFFFF"/>
                                    <!-- Badge + detected game on one row: badge left, game status to
                                         its right (uses the freed vertical space). -->
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0" VerticalAlignment="Center">
                                        <!-- Status badge: orange = global, green = per-game active. -->
                                        <Border x:Name="ActiveProfileBadge"
                                                Background="#37260C" BorderBrush="#A06E28" BorderThickness="1"
                                                CornerRadius="4" Padding="8,2"
                                                VerticalAlignment="Center" HorizontalAlignment="Left">
                                            <TextBlock x:Name="ActiveProfileText"
                                                       Text="Editing Global Profile"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="#FFAA46"/>
                                        </Border>
                                        <!-- Detected game name — shown when game runs -->
                                        <Canvas x:Name="DetectedGameTextCanvas"
                                                Height="14"
                                                Margin="10,0,0,0"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
                                            <Canvas.Clip>
                                                <RectangleGeometry Rect="0,0,200,14"/>
                                            </Canvas.Clip>
                                            <TextBlock x:Name="DetectedGameText"
                                                       Text="No app/game detected"
                                                       FontSize="11"
                                                       Foreground="{StaticResource HintTextBrush}">
                                                <TextBlock.RenderTransform>
                                                    <TranslateTransform x:Name="DetectedGameTextTransform"/>
                                                </TextBlock.RenderTransform>
                                            </TextBlock>
                                        </Canvas>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Right: toggle top-aligned -->
                                <ToggleSwitch x:Name="PerGameProfileToggle"
                                              Grid.Column="2"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsEnabled="False"
                                              VerticalAlignment="Top"
                                              KeyDown="PerGameProfileToggle_KeyDown"/>
                            </Grid>
                        </Border>

                        <!-- FPS Limit card relocated below the TDP Power Limit card (see "FPS Limiter (NEW)").
                             This is the test layout requested: rebuild the FPS controls fresh in a
                             location where vertical D-Pad navigation is proven to work (TDP → TDP Boost). -->
                        <!-- Hidden legacy elements: retained for settings/profile compat; never shown.
                             Kept here (above) so x:Bind / FindName resolve regardless of card order. -->
                        <ToggleSwitch x:Name="FPSLimitToggle"      Visibility="Collapsed" IsTabStop="False"/>
                        <RadioButton  x:Name="FPSModeRTSSRadio"    Visibility="Collapsed" IsChecked="True" IsTabStop="False"/>
                        <RadioButton  x:Name="FPSModeIntelRadio"   Visibility="Collapsed" IsTabStop="False"/>
                        <ComboBox     x:Name="IntelFpsTierComboBox" Visibility="Collapsed" IsTabStop="False">
                            <ComboBoxItem Content="Off"                  Tag="0"/>
                            <ComboBoxItem Content="Performance  60 FPS" Tag="1"/>
                            <ComboBoxItem Content="Balanced  40 FPS"    Tag="2"/>
                            <ComboBoxItem Content="Efficiency  30 FPS"  Tag="3"/>
                        </ComboBox>
                        <StackPanel x:Name="FPSLimiterModePanel"  Visibility="Collapsed"/>
                        <StackPanel x:Name="FPSLimiterRTSSPanel"  Visibility="Collapsed"/>
                        <StackPanel x:Name="FPSLimiterIntelPanel" Visibility="Collapsed"/>
                        <TextBlock  x:Name="FPSLimitCaption" Text="" Style="{StaticResource CardCaptionStyle}" Visibility="Collapsed"/>

                        <!-- ════════════════════════════════════════════════════════════════════
                             FPS Limiter — first card (spine position 1, after Per-Game profile).
                             3-part split: [ slider (left) | Mode toggle (middle) | On/Off toggle (right) ].
                             Both toggles are DIRECT Grid children (the structure that receives D-pad
                             focus). Vertical spine targets only the On/Off toggle; Mode + slider are
                             reached via D-pad Left. Spine: PerGameProfile → FPS On/Off → TDPSlider.
                             ════════════════════════════════════════════════════════════════════ -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Row 0: labels -->
                                <Grid Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="FPS Limit"
                                               Style="{StaticResource CardTitleStyle}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock x:Name="FPSLimitValue" Grid.Column="1"
                                               Text="" FontSize="14" Foreground="#4CAF50"
                                               FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </Grid>
                                <TextBlock x:Name="FPSStateCycleText" Grid.Row="0" Grid.Column="2"
                                           Text="RTSS" FontSize="11" Foreground="#A0A0A0"
                                           HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                           Margin="0,0,0,4"/>
                                <TextBlock Grid.Row="0" Grid.Column="4"
                                           Text="On / Off" FontSize="11" Foreground="#A0A0A0"
                                           HorizontalAlignment="Center" VerticalAlignment="Bottom"
                                           Margin="0,0,0,4"/>

                                <!-- Row 1, Col 0: limiter slider (far left) + per-step FPS scale labels -->
                                <StackPanel Grid.Row="1" Grid.Column="0" VerticalAlignment="Center">
                                    <Slider x:Name="FPSLimitSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="20" Maximum="120"
                                            StepFrequency="1"
                                            IsEnabled="False"
                                            IsThumbToolTipEnabled="False"
                                            XYFocusUp="{x:Bind FPSModeToggle}"
                                            XYFocusDown="{x:Bind FpsSteplessCheckBox}"
                                            XYFocusRight="{x:Bind FPSModeToggle}"/>
                                    <Grid x:Name="FPSLimitScaleLabels" Margin="0,2,0,0"/>
                                </StackPanel>

                                <!-- Row 1, Col 2: mode toggle (middle) — DIRECT Grid child.
                                     Deliberately a DIFFERENT colour/look from the accent-coloured
                                     On/Off toggle so the two read as distinct controls: this one is
                                     a violet "mode" switch (RTSS ↔ Intel). Local resources override
                                     the shared accent brushes for this instance only. -->
                                <ToggleSwitch x:Name="FPSModeToggle" Grid.Row="1" Grid.Column="2"
                                              Style="{StaticResource ModernToggleStyle}"
                                              Width="52" VerticalAlignment="Center"
                                              IsTabStop="True"
                                              XYFocusLeft="{x:Bind FPSLimitSlider}"
                                              XYFocusRight="{x:Bind FPSStateCycleButton}"
                                              XYFocusUp="{x:Bind FPSStateCycleButton}"
                                              XYFocusDown="{x:Bind FPSStateCycleButton}"
                                              Toggled="FPSModeToggle_Toggled"
                                              KeyDown="FPSModeToggle_KeyDown">
                                    <ToggleSwitch.Resources>
                                        <!-- ON state: violet (distinct from the accent On/Off toggle) -->
                                        <SolidColorBrush x:Key="ToggleSwitchFillOn"              Color="#9B6CF0"/>
                                        <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver"   Color="#AB80F4"/>
                                        <SolidColorBrush x:Key="ToggleSwitchFillOnPressed"       Color="#8A5BE0"/>
                                        <SolidColorBrush x:Key="ToggleSwitchStrokeOn"            Color="#9B6CF0"/>
                                        <SolidColorBrush x:Key="ToggleSwitchStrokeOnPointerOver" Color="#AB80F4"/>
                                        <SolidColorBrush x:Key="ToggleSwitchStrokeOnPressed"     Color="#8A5BE0"/>
                                        <!-- OFF state: muted violet-tinted track so it differs even when off -->
                                        <SolidColorBrush x:Key="ToggleSwitchFillOff"             Color="#3A335A"/>
                                        <SolidColorBrush x:Key="ToggleSwitchFillOffPointerOver"  Color="#463E6B"/>
                                        <SolidColorBrush x:Key="ToggleSwitchStrokeOff"           Color="#6B5FA0"/>
                                    </ToggleSwitch.Resources>
                                </ToggleSwitch>

                                <!-- Row 1, Col 4: on/off toggle (far right) — DIRECT Grid child.
                                     Spine: Up → Per-Game profile (or nav), Down → TDP slider. -->
                                <ToggleSwitch x:Name="FPSStateCycleButton" Grid.Row="1" Grid.Column="4"
                                              Style="{StaticResource ModernToggleStyle}"
                                              Width="52" VerticalAlignment="Center"
                                              IsTabStop="True"
                                              XYFocusUp="{x:Bind PerGameProfileToggle}"
                                              XYFocusDown="{x:Bind TDPSlider}"
                                              XYFocusLeft="{x:Bind FPSModeToggle}"
                                              Toggled="FPSStateCycleButton_Toggled"
                                              KeyDown="FPSStateCycleButton_KeyDown"/>

                                <!-- Row 2: stepless option — when off the slider snaps to 24/30/40/45/60/…;
                                     when on it moves in 1-FPS steps. Global (widget-local) preference. -->
                                <CheckBox x:Name="FpsSteplessCheckBox" Grid.Row="2" Grid.Column="0"
                                          Content="Stepless (1 FPS steps)"
                                          FontSize="12" Margin="0,8,0,0"
                                          Checked="FpsSteplessCheckBox_Toggled"
                                          Unchecked="FpsSteplessCheckBox_Toggled"
                                          XYFocusUp="{x:Bind FPSLimitSlider}"
                                          XYFocusRight="{x:Bind FPSStateCycleButton}"/>
                            </Grid>
                        </Border>

                        <!-- TDP Mode Card (Legion only) — hidden for MSI Claw -->
                        <Border x:Name="TDPModeCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <!-- Header: title + ComboBox always visible + expand toggle -->
                                <!-- TDP Mode row hidden — only Slider/Custom mode used; ComboBox kept for code-behind compat -->
                                <Grid Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="TDP Mode" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Controls power and thermal profile"
                                                   Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ComboBox x:Name="TDPModeComboBox"
                                              MinWidth="140"
                                              Grid.Column="1"
                                              Margin="0,0,8,0"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              SelectedIndex="5"
                                              SelectionChanged="TDPModeComboBox_SelectionChanged"
                                              XYFocusUp="{x:Bind PerformanceOverlayComboBox}"
                                              XYFocusDown="{x:Bind TDPSlider}"
                                              XYFocusRight="{x:Bind TDPSettingsExpandButton}">
                                        <ComboBoxItem Content="Max (30W)"          Tag="0"/>
                                        <ComboBoxItem Content="Standard (25W)"     Tag="1"/>
                                        <ComboBoxItem Content="Balanced (17W)"     Tag="2"/>
                                        <ComboBoxItem Content="Battery (12W)"      Tag="3"/>
                                        <ComboBoxItem Content="Super Battery (8W)" Tag="4"/>
                                        <ComboBoxItem Content="Slider"             Tag="255"/>
                                    </ComboBox>
                                    <ToggleButton x:Name="TDPSettingsExpandButton"
                                                  Grid.Column="2"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="TDPSettingsExpandButton_Click"
                                                  XYFocusUp="{x:Bind OSDCustomizeExpandButton}"
                                                  XYFocusDown="{x:Bind TDPSlider}"
                                                  XYFocusLeft="{x:Bind TDPModeComboBox}"
                                                  UseSystemFocusVisuals="True">
                                        <FontIcon x:Name="TDPSettingsExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <!-- Collapsible TDP Settings Content -->
                                <StackPanel x:Name="TDPSettingsContent" Visibility="Collapsed" Margin="0,12,0,0">

                                    <!-- Separator -->
                                    <Border Height="1" Background="#3A3A3A" Margin="0,16,0,16"/>

                                    <!-- Device TDP Limits Section -->
                                    <TextBlock Text="Device TDP Limits" FontSize="13" FontWeight="SemiBold" Foreground="#AAAAAA" Margin="0,0,0,8"/>

                                    <!-- Warning -->
                                    <Border Background="#3D2A1A" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE7BA;"
                                                       Grid.Column="0"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="16"
                                                       Foreground="#FFA500"
                                                       VerticalAlignment="Top"
                                                       Margin="0,2,8,0"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="Increasing TDP beyond your device's thermal limits may cause overheating or throttling."
                                                       Foreground="#FFB74D"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>

                                    <!-- Minimum TDP -->
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Minimum TDP"
                                                   FontSize="14"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TDPLimitsMinValue"
                                                   Text="4W"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="TDPLimitsMinSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="4" Maximum="30"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            Value="4"
                                            ValueChanged="TDPLimitsMinSlider_ValueChanged"
                                            XYFocusUp="{x:Bind TDPSettingsExpandButton}"
                                            XYFocusDown="{x:Bind TDPLimitsMaxSlider}"
                                            />

                                    <!-- Maximum TDP -->
                                    <Grid Margin="0,12,0,8">
                                        <TextBlock Text="Maximum TDP"
                                                   FontSize="14"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TDPLimitsMaxValue"
                                                   Text="30W"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="TDPLimitsMaxSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="4" Maximum="30"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            Value="30"
                                            ValueChanged="TDPLimitsMaxSlider_ValueChanged"
                                            XYFocusUp="{x:Bind TDPLimitsMinSlider}"
                                            XYFocusDown="{x:Bind TDPBoostFPPTSlider}"
                                            />

                                    <!-- Separator -->
                                    <Border Height="1" Background="#3A3A3A" Margin="0,16,0,16"/>

                                    <!-- TDP Boost Settings Section -->
                                    <TextBlock Text="TDP Boost Settings" FontSize="13" FontWeight="SemiBold" Foreground="#AAAAAA" Margin="0,0,0,8"/>

                                    <!-- Info -->
                                    <Border Background="#1A2A3D" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE946;"
                                                       Grid.Column="0"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="16"
                                                       Foreground="#4CAF50"
                                                       VerticalAlignment="Top"
                                                       Margin="0,2,8,0"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="Sets PL2 (boost limit) directly to the chosen wattage. Must be higher than PL1 — automatically raised to PL1+1W if set too low."
                                                       Foreground="#A0D4A0"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>

                                    <!-- PL2-Boost -->
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="PL2-Boost"
                                                   FontSize="14"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TDPBoostFPPTValue"
                                                   Text="3W"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="TDPBoostFPPTSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="10" Maximum="37"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            ValueChanged="TDPBoostFPPTSlider_ValueChanged"
                                            XYFocusUp="{x:Bind TDPLimitsMaxSlider}"
                                            XYFocusDown="{x:Bind UseCustomTDPPresetsToggle}"
                                            />

                                    <!-- Separator -->
                                    <Border Height="1" Background="#3A3A3A" Margin="0,16,0,16"/>

                                    <!-- Custom TDP Presets Section -->
                                    <TextBlock Text="Custom TDP Presets" FontSize="13" FontWeight="SemiBold" Foreground="#AAAAAA" Margin="0,0,0,8"/>

                                    <!-- Use Custom Presets Toggle -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Use Custom Presets" FontSize="14" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Override default TDP values for modes"
                                                       FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="UseCustomTDPPresetsToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      Toggled="UseCustomTDPPresetsToggle_Toggled"
                                                      XYFocusUp="{x:Bind TDPBoostFPPTSlider}"/>
                                    </Grid>

                                    <!-- Presets List (shown when custom presets enabled) -->
                                    <StackPanel x:Name="TDPPresetsListPanel" Spacing="8" Visibility="Collapsed" Margin="0,12,0,0">
                                        <!-- Use Lenovo Modes checkbox (Legion devices only) -->
                                        <Grid x:Name="UseLenovoModesPanel" Visibility="Collapsed" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Use Lenovo Modes" FontSize="13" Foreground="#FFFFFF"/>
                                                <TextBlock Text="Use hardware modes for Quiet/Balanced/Performance"
                                                           FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                            </StackPanel>
                                            <ToggleSwitch x:Name="UseLenovoModesToggle"
                                                          Grid.Column="1"
                                                          IsOn="True"
                                                          Style="{StaticResource ModernToggleStyle}"
                                                          Toggled="UseLenovoModesToggle_Toggled"/>
                                        </Grid>
                                        <!-- Preset items will be dynamically generated -->
                                        <ItemsControl x:Name="TDPPresetsItemsControl">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="60"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Name}"
                                                                   FontSize="14"
                                                                   Foreground="#FFFFFF"
                                                                   VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding TdpWatts}"
                                                                       FontSize="14"
                                                                       Foreground="#4CAF50"
                                                                       FontWeight="SemiBold"/>
                                                            <TextBlock Text="W"
                                                                       FontSize="14"
                                                                       Foreground="#4CAF50"
                                                                       FontWeight="SemiBold"
                                                                       Margin="2,0,0,0"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="2"
                                                                Content="Edit"
                                                                FontSize="12"
                                                                Padding="8,4"
                                                                Margin="4,0"
                                                                Background="#2A2A2A"
                                                                Foreground="#FFFFFF"
                                                                Click="TDPPresetEditButton_Click"
                                                                Tag="{Binding}"/>
                                                        <Button Grid.Column="3"
                                                                FontSize="12"
                                                                Padding="8,4"
                                                                Background="#2A2A2A"
                                                                Click="TDPPresetDeleteButton_Click"
                                                                Tag="{Binding}"
                                                                Visibility="{Binding IsBuiltIn, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                            <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="#FF6B6B"/>
                                                        </Button>
                                                        <TextBlock Grid.Column="3"
                                                                   Text="Default"
                                                                   FontSize="11"
                                                                   Foreground="{StaticResource HintTextBrush}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="8,0"
                                                                   Visibility="{Binding IsBuiltIn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Add Preset Section -->
                                        <Border Background="#1A1A1A" CornerRadius="4" Padding="12" Margin="0,8,0,0">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="Add New Preset" FontSize="13" Foreground="#A0A0A0"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="NewPresetNameTextBox"
                                                             Grid.Column="0"
                                                             PlaceholderText="Preset name"
                                                             FontSize="13"
                                                             Padding="8,6"
                                                             Margin="0,0,8,0"/>
                                                    <muxc:NumberBox x:Name="NewPresetTDPNumberBox"
                                                               Grid.Column="1"
                                                               Value="30"
                                                               Minimum="4"
                                                               Maximum="100"
                                                               SpinButtonPlacementMode="Compact"
                                                               FontSize="13"/>
                                                </Grid>
                                                <CheckBox x:Name="NewPresetTDPBoostCheckBox"
                                                          Content="Enable TDP Boost"
                                                          FontSize="13"
                                                          Foreground="#FFFFFF"/>
                                                <Button x:Name="AddPresetButton"
                                                        Content="Add Preset"
                                                        FontSize="13"
                                                        Padding="16,6"
                                                        HorizontalAlignment="Left"
                                                        Background="#4CAF50"
                                                        Foreground="#FFFFFF"
                                                        Click="AddPresetButton_Click"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Reset to Defaults Button -->
                                        <Button x:Name="ResetTDPPresetsButton"
                                                Content="Reset to Defaults"
                                                FontSize="12"
                                                Padding="12,6"
                                                HorizontalAlignment="Left"
                                                Background="#2A2A2A"
                                                Foreground="#A0A0A0"
                                                Click="ResetTDPPresetsButton_Click"/>
                                    </StackPanel>

                                    <!-- Edit Preset Dialog (inline, hidden by default) -->
                                    <Border x:Name="EditPresetDialog"
                                            Background="#252525"
                                            CornerRadius="4"
                                            Padding="12"
                                            Margin="0,12,0,0"
                                            Visibility="Collapsed">
                                        <StackPanel Spacing="12">
                                            <TextBlock Text="Edit Preset" FontSize="14" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Name:" FontSize="14" Foreground="#A0A0A0" VerticalAlignment="Center"/>
                                                <TextBox x:Name="EditPresetNameTextBox"
                                                         Grid.Column="1"
                                                         FontSize="13"
                                                         Padding="8,6"/>
                                            </Grid>
                                            <Grid x:Name="EditPresetTDPPanel">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="TDP (W):" FontSize="14" Foreground="#A0A0A0" VerticalAlignment="Center"/>
                                                <muxc:NumberBox x:Name="EditPresetTDPNumberBox"
                                                           Grid.Column="1"
                                                           Minimum="4"
                                                           Maximum="100"
                                                           SpinButtonPlacementMode="Compact"
                                                           FontSize="13"/>
                                            </Grid>
                                            <Grid x:Name="EditPresetTDPBoostPanel">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="TDP Boost:" FontSize="14" Foreground="#A0A0A0" VerticalAlignment="Center"/>
                                                <CheckBox x:Name="EditPresetTDPBoostCheckBox"
                                                          Grid.Column="1"
                                                          Content="Enable TDP Boost"
                                                          FontSize="13"
                                                          Foreground="#FFFFFF"/>
                                            </Grid>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                                <Button Content="Cancel"
                                                        FontSize="13"
                                                        Padding="16,6"
                                                        Background="#2A2A2A"
                                                        Foreground="#A0A0A0"
                                                        Click="EditPresetCancelButton_Click"/>
                                                <Button Content="Save"
                                                        FontSize="13"
                                                        Padding="16,6"
                                                        Background="#4CAF50"
                                                        Foreground="#FFFFFF"
                                                        Click="EditPresetSaveButton_Click"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- TDP Power Limit Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="TDP Power Limit" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock x:Name="TDPValueText"
                                               Text="--"
                                               Style="{StaticResource CardValueStyle}"/>
                                </Grid>
                                <!-- MSI Center M warning — shown inline when Center M is active -->
                                <Border x:Name="MsiCenterTDPWarning"
                                        Background="#2A1800"
                                        BorderBrush="#FFA500"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="10,8"
                                        Margin="0,8,0,0"
                                        Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE7BA;" FontSize="14" Foreground="#FFA500" VerticalAlignment="Top" Margin="0,1,0,0"/>
                                        <TextBlock Text="MSI Center M is active — TDP control unavailable. Disable it via the MSI Center tile in the Quick Tab."
                                                   FontSize="11" Foreground="#FFA500" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <Slider x:Name="TDPSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="7" Maximum="30"
                                        TickFrequency="1"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False" Value="-5"
                                        XYFocusUp="{x:Bind FPSStateCycleButton}"
                                        XYFocusDown="{x:Bind TDPBoostToggle}"
                                        ValueChanged="TDPSlider_ValueChanged_UpdateDisplay"
                                        KeyDown="TDPSlider_KeyDown"/>
                                <Grid Margin="0,4,0,0">
                                    <TextBlock x:Name="CurrentTDPText"
                                               Text="Limits:"
                                               FontSize="12"
                                               Foreground="#A0A0A0"/>
                                    <TextBlock x:Name="CurrentTDPValueText"
                                               Text="-- W"
                                               FontSize="12"
                                               Foreground="#A0A0A0"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <!-- Hint shown when TDP Mode is not set to Slider -->
                                <TextBlock x:Name="TDPSliderModeHint"
                                           Text="Set TDP Mode to &#x22;Slider&#x22; to enable manual TDP control."
                                           FontSize="11"
                                           Foreground="#FF8C00"
                                           Margin="0,6,0,0"
                                           TextWrapping="Wrap"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                        <!-- TDP Overboost Card (PL2 boost) — 2-column: slider (4*) left | toggle (*) right -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="4*"/>
                                    <ColumnDefinition Width="16"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Left: title + caption + slider label/value + slider -->
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Overboost (PL2)" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Sets PL2 directly. Must be higher than PL1. Capped at 37W."
                                               Style="{StaticResource CardCaptionStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0"/>
                                    <!-- Slider + value: only shown while Overboost is ON. Collapsed when off so
                                         the card stays compact (just title + caption + toggle). Driven from
                                         TDPBoostToggle_Toggled. -->
                                    <StackPanel x:Name="TDPBoostSliderArea" Visibility="Collapsed" Margin="0,10,0,0">
                                        <Grid Margin="0,0,0,4">
                                            <TextBlock Text="PL2-Boost"
                                                       FontSize="13" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TDPBoostFPPTValueInCard"
                                                       FontSize="13" Foreground="#4CAF50" FontWeight="SemiBold"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       Text="3W"/>
                                        </Grid>
                                        <Slider x:Name="TDPBoostFPPTSliderCard"
                                                Style="{StaticResource ModernSliderStyle}"
                                                Minimum="10" Maximum="37"
                                                TickFrequency="1" SnapsTo="Ticks"
                                                Value="3"
                                                IsEnabled="False"
                                                XYFocusUp="{x:Bind TDPBoostToggle}"
                                                XYFocusDown="{x:Bind TDPBoostToggle}"
                                                ValueChanged="TDPBoostFPPTSlider_ValueChanged"
                                                KeyDown="TDPBoostFPPTSliderCard_KeyDown"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Right: on/off toggle -->
                                <ToggleSwitch x:Name="TDPBoostToggle"
                                              Grid.Column="2"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsEnabled="True" Width="52"
                                              VerticalAlignment="Center"
                                              XYFocusUp="{x:Bind TDPSlider}"
                                              XYFocusDown="{x:Bind OSPowerModeComboBox}"
                                              Toggled="TDPBoostToggle_Toggled"
                                              KeyDown="TDPBoostToggle_KeyDown"/>
                            </Grid>
                        </Border>

                        <!-- OS Power Mode Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="OS Power Mode" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Windows power slider setting"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <TextBlock x:Name="OSPowerModeValue"
                                               Grid.Column="1"
                                               Text="Balanced"
                                               FontSize="14"
                                               Foreground="#4CAF50"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="0,0,0,0"/>
                                </Grid>
                                <ComboBox x:Name="OSPowerModeComboBox"
                                          Margin="0,12,0,0"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectedIndex="1"
                                          SelectionChanged="OSPowerModeComboBox_SelectionChanged"
                                          XYFocusDown="{x:Bind SchedulingPolicyComboBox}"
                                          KeyDown="OSPowerModeComboBox_KeyDown">
                                    <ComboBoxItem Content="Best Power Efficiency"/>
                                    <ComboBoxItem Content="Balanced"/>
                                    <ComboBoxItem Content="Best Performance"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- CPU Boost Card -->
                        <!-- Hidden stubs kept for code-behind compat (removed UI elements) -->
                        <ToggleButton x:Name="CPUExtrasExpandToggle" Visibility="Collapsed"/>
                        <StackPanel x:Name="CPUExtrasContent" Visibility="Collapsed"/>
                        <FontIcon x:Name="CPUExtrasExpandIcon" Visibility="Collapsed" Glyph="&#xE70D;"/>
                        <ToggleButton x:Name="TDPExtrasExpandToggle" Visibility="Collapsed"/>
                        <StackPanel x:Name="TDPExtrasContent" Visibility="Collapsed"/>
                        <FontIcon x:Name="TDPExtrasExpandIcon" Visibility="Collapsed" Glyph="&#xE70D;"/>
                        <!-- Stubs for the removed CPU "More settings" expander — kept so the existing
                             code-behind references (focus/keydown handlers) still compile; never shown. -->
                        <ToggleButton x:Name="CpuSectionExpandButton" Visibility="Collapsed"/>
                        <FontIcon x:Name="CpuSectionExpandIcon" Visibility="Collapsed" Glyph="&#xE70D;"/>
                        <!-- TDPBoostToggle is now a real card (Overboost) above — no stub needed -->
                        <ToggleSwitch x:Name="LegionFanFullSpeedToggle" Visibility="Collapsed"/>
                        <!-- Overlay Card (merged Performance Overlay + OSD Customization) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header: title + overlay level dropdown (always visible) + expand toggle -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Overlay"
                                               Style="{StaticResource CardTitleStyle}"
                                               VerticalAlignment="Center"
                                               Grid.Column="0"/>
                                    <ComboBox x:Name="PerformanceOverlayComboBox"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              Width="120"
                                              Grid.Column="1"
                                              Margin="0,0,8,0"
                                              SelectionChanged="PerformanceOverlayComboBox_SelectionChanged"
                                              KeyDown="PerformanceOverlayComboBox_KeyDown"
                                              XYFocusLeft="{x:Bind PerformanceNavItem}"
                                              XYFocusDown="{x:Bind CpuCardExpandButton}">
                                        <ComboBoxItem Content="Off" Tag="0" IsSelected="True"/>
                                        <ComboBoxItem Content="Basic" Tag="1"/>
                                        <ComboBoxItem Content="Horizontal" Tag="2"/>
                                        <ComboBoxItem Content="H. Detailed" Tag="3"/>
                                        <ComboBoxItem Content="Full" Tag="4"/>
                                    </ComboBox>
                                    <ToggleButton x:Name="OSDCustomizeExpandButton"
                                                  Grid.Column="2"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="OSDCustomizeExpandButton_Click"
                                                  KeyDown="OSDCustomizeExpandButton_KeyDown"
                                                  UseSystemFocusVisuals="True">
                                        <FontIcon x:Name="OSDCustomizeExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <!-- Hidden slider for property system compatibility -->
                                <Slider x:Name="PerformanceOverlaySlider"
                                        Visibility="Collapsed"
                                        Minimum="0" Maximum="4"
                                        Value="0"
                                        ValueChanged="PerformanceOverlaySlider_ValueChanged"/>

                                <!-- Collapsible Content -->
                                <StackPanel x:Name="OSDCustomizeContent" Visibility="Collapsed" Margin="0,12,0,0">

                                    <!-- OSD Provider and Overlay Level hidden — kept for code-behind compat -->
                                    <ComboBox x:Name="OSDProviderComboBox" Visibility="Collapsed"
                                              SelectionChanged="OSDProviderComboBox_SelectionChanged">
                                        <ComboBoxItem Content="RTSS" Tag="0" IsSelected="True"/>
                                        <ComboBoxItem Content="AMD" Tag="1"/>
                                    </ComboBox>
                                    <StackPanel x:Name="RTSSOptionsPanel">
                                        <ComboBox x:Name="OSDCustomizeLevelComboBox" Visibility="Collapsed"
                                                  SelectionChanged="OSDCustomizeLevelComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Basic" Tag="1"/>
                                            <ComboBoxItem Content="Horizontal" Tag="2"/>
                                            <ComboBoxItem Content="H. Detailed" Tag="3"/>
                                            <ComboBoxItem Content="Full" Tag="4" IsSelected="True"/>
                                        </ComboBox>

                                        <!-- Layout Settings Section -->
                                    <TextBlock Text="Layout"
                                               Style="{StaticResource CardTitleStyle}"
                                               Margin="0,0,0,8"/>

                                    <!-- Columns (hidden — Full overlay is fixed to a 1-column vertical list) -->
                                    <Grid Margin="0,0,0,8" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Columns"
                                                       Foreground="#B0B0B0"
                                                       FontSize="13"/>
                                            <TextBlock Text="Items per row (1 = vertical list)"
                                                       Foreground="#707070"
                                                       FontSize="11"/>
                                        </StackPanel>
                                        <ComboBox x:Name="OSDColumnsComboBox"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  Width="80"
                                                  Grid.Column="1"
                                                  SelectionChanged="OSDLayoutOption_Changed"
                                                  KeyDown="OsdPanelNav_KeyDown"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White">
                                            <ComboBoxItem Content="1" Tag="1"/>
                                            <ComboBoxItem Content="2" Tag="2"/>
                                            <ComboBoxItem Content="3" Tag="3" IsSelected="True"/>
                                            <ComboBoxItem Content="4" Tag="4"/>
                                            <ComboBoxItem Content="5" Tag="5"/>
                                            <ComboBoxItem Content="6" Tag="6"/>
                                            <ComboBoxItem Content="7" Tag="7"/>
                                            <ComboBoxItem Content="8" Tag="8"/>
                                            <ComboBoxItem Content="9" Tag="9"/>
                                            <ComboBoxItem Content="10" Tag="10"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Overlay Size (scales the whole overlay proportionally) -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Overlay Size"
                                                   Foreground="#B0B0B0"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"/>
                                        <ComboBox x:Name="OSDTextSizeComboBox"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  Width="100"
                                                  Grid.Column="1"
                                                  SelectionChanged="OSDLayoutOption_Changed"
                                                  KeyDown="OsdPanelNav_KeyDown"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White">
                                            <ComboBoxItem Content="Small" Tag="50"/>
                                            <ComboBoxItem Content="Medium" Tag="100"/>
                                            <ComboBoxItem Content="Medium-Large" Tag="125"/>
                                            <ComboBoxItem Content="Default" Tag="150" IsSelected="True"/>
                                            <ComboBoxItem Content="Large" Tag="175"/>
                                            <ComboBoxItem Content="X-Large" Tag="200"/>
                                            <ComboBoxItem Content="XX-Large" Tag="250"/>
                                            <ComboBoxItem Content="XXX-Large" Tag="300"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Overlay Font (applied to the RTSS Global profile; helper restarts RTSS briefly) -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Overlay Font"
                                                   Foreground="#B0B0B0"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"/>
                                        <ComboBox x:Name="OSDFontComboBox"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  Width="190"
                                                  Grid.Column="1"
                                                  SelectionChanged="OSDFontComboBox_SelectionChanged"
                                                  KeyDown="OsdPanelNav_KeyDown"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White">
                                            <!-- Bahnschrift named instances. The weight is baked into the
                                                 face name, so all use RTSS Weight 400. Each item is rendered
                                                 in its own variant for a live preview. Falls back to RTSS's
                                                 Unispace helper-side if a face isn't installed. -->
                                            <ComboBoxItem Content="Bahnschrift" Tag="Bahnschrift|400" IsSelected="True" FontFamily="Bahnschrift"/>
                                            <ComboBoxItem Content="Bahnschrift Light" Tag="Bahnschrift Light|400" FontFamily="Bahnschrift Light"/>
                                            <ComboBoxItem Content="Bahnschrift SemiLight" Tag="Bahnschrift SemiLight|400" FontFamily="Bahnschrift SemiLight"/>
                                            <ComboBoxItem Content="Bahnschrift SemiBold" Tag="Bahnschrift SemiBold|400" FontFamily="Bahnschrift SemiBold"/>
                                            <ComboBoxItem Content="Bahnschrift Condensed" Tag="Bahnschrift Condensed|400" FontFamily="Bahnschrift Condensed"/>
                                            <ComboBoxItem Content="Bahnschrift SemiCondensed" Tag="Bahnschrift SemiCondensed|400" FontFamily="Bahnschrift SemiCondensed"/>
                                            <ComboBoxItem Content="Bahnschrift Light Condensed" Tag="Bahnschrift Light Condensed|400" FontFamily="Bahnschrift Light Condensed"/>
                                            <ComboBoxItem Content="Bahnschrift Light SemiCondensed" Tag="Bahnschrift Light SemiCondensed|400" FontFamily="Bahnschrift Light SemiCondensed"/>
                                            <ComboBoxItem Content="Bahnschrift SemiLight Condensed" Tag="Bahnschrift SemiLight Condensed|400" FontFamily="Bahnschrift SemiLight Condensed"/>
                                            <ComboBoxItem Content="Bahnschrift SemiLight SemiCondensed" Tag="Bahnschrift SemiLight SemiCondensed|400" FontFamily="Bahnschrift SemiLight SemiCondensed"/>
                                            <ComboBoxItem Content="Bahnschrift SemiBold Condensed" Tag="Bahnschrift SemiBold Condensed|400" FontFamily="Bahnschrift SemiBold Condensed"/>
                                            <ComboBoxItem Content="Bahnschrift SemiBold SemiCondensed" Tag="Bahnschrift SemiBold SemiCondensed|400" FontFamily="Bahnschrift SemiBold SemiCondensed"/>
                                            <ComboBoxItem Content="RTSS default (Unispace)" Tag="Unispace|400"/>
                                        </ComboBox>
                                    </Grid>
                                    <TextBlock Text="Changing the font briefly restarts RTSS (a short overlay blink). It only happens when you actually change the font, not on every boot."
                                               Foreground="#707070" FontSize="11" TextWrapping="Wrap" Margin="0,-2,0,8"/>

                                    <!-- Colors Section -->
                                    <TextBlock Text="Colors"
                                               Style="{StaticResource CardTitleStyle}"
                                               Margin="0,12,0,8"/>

                                    <!-- Text Color -->
                                    <StackPanel x:Name="OSDTextColorCard" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Text Color" Grid.Column="0" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="13"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <CheckBox x:Name="OSDTextColorDynamicCheckBox"
                                                          Content="Dynamic"
                                                          IsChecked="True"
                                                          Foreground="#AAAAAA"
                                                          FontSize="11"
                                                          Margin="0,0,8,0"
                                                          KeyDown="OsdPanelNav_KeyDown"
                                                          Checked="OSDTextColorDynamic_Changed"
                                                          Unchecked="OSDTextColorDynamic_Changed"/>
                                                <Border x:Name="OSDTextColorPreview"
                                                        Width="24" Height="24"
                                                        CornerRadius="4"
                                                        Background="White"
                                                        BorderBrush="#50555C"
                                                        BorderThickness="1"
                                                        Margin="0,0,8,0"/>
                                                <Button x:Name="OSDTextColorExpandButton"
                                                        Content="&#xE70D;"
                                                        FontFamily="Segoe MDL2 Assets"
                                                        FontSize="12"
                                                        Padding="8,4"
                                                        Background="Transparent"
                                                        Click="OSDTextColorExpandButton_Click"
                                                        UseSystemFocusVisuals="True"
                                                        FocusVisualPrimaryBrush="White"/>
                                            </StackPanel>
                                        </Grid>
                                        <muxc:ColorPicker x:Name="OSDTextColorPicker"
                                                     Visibility="Collapsed"
                                                     Margin="0,12,0,0"
                                                     Color="White"
                                                     ColorSpectrumShape="Box"
                                                     IsMoreButtonVisible="False"
                                                     IsColorSliderVisible="False"
                                                     IsColorChannelTextInputVisible="False"
                                                     IsHexInputVisible="False"
                                                     IsAlphaEnabled="False"
                                                     IsAlphaSliderVisible="False"
                                                     IsAlphaTextInputVisible="False"
                                                     ColorChanged="OSDTextColorPicker_ColorChanged"/>
                                    </StackPanel>

                                    <!-- Label Color (Global) -->
                                    <StackPanel x:Name="OSDLabelColorCard" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Label Color" Grid.Column="0" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="13"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <CheckBox x:Name="OSDLabelColorDefaultCheckBox"
                                                          Content="Default"
                                                          IsChecked="True"
                                                          Foreground="#AAAAAA"
                                                          FontSize="11"
                                                          Margin="0,0,8,0"
                                                          KeyDown="OsdPanelNav_KeyDown"
                                                          Checked="OSDLabelColorDefault_Changed"
                                                          Unchecked="OSDLabelColorDefault_Changed"/>
                                                <Border x:Name="OSDLabelColorPreview"
                                                        Width="24" Height="24"
                                                        CornerRadius="4"
                                                        Background="#00FFFF"
                                                        BorderBrush="#50555C"
                                                        BorderThickness="1"
                                                        Margin="0,0,8,0"/>
                                                <Button x:Name="OSDLabelColorExpandButton"
                                                        Content="&#xE70D;"
                                                        FontFamily="Segoe MDL2 Assets"
                                                        FontSize="12"
                                                        Padding="8,4"
                                                        Background="Transparent"
                                                        Click="OSDLabelColorExpandButton_Click"
                                                        UseSystemFocusVisuals="True"
                                                        FocusVisualPrimaryBrush="White"/>
                                            </StackPanel>
                                        </Grid>
                                        <muxc:ColorPicker x:Name="OSDLabelColorPicker"
                                                     Visibility="Collapsed"
                                                     Margin="0,12,0,0"
                                                     Color="#00FFFF"
                                                     ColorSpectrumShape="Box"
                                                     IsMoreButtonVisible="False"
                                                     IsColorSliderVisible="False"
                                                     IsColorChannelTextInputVisible="False"
                                                     IsHexInputVisible="False"
                                                     IsAlphaEnabled="False"
                                                     IsAlphaSliderVisible="False"
                                                     IsAlphaTextInputVisible="False"
                                                     ColorChanged="OSDLabelColorPicker_ColorChanged"/>
                                    </StackPanel>

                                    <!-- OSD Opacity Slider (for OLED protection) -->
                                    <StackPanel Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="OSD Opacity" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="13"/>
                                            <TextBlock x:Name="OSDOpacityValue"
                                                       Grid.Column="1"
                                                       Text="100%" FontSize="13" Foreground="#4CAF50"
                                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </Grid>
                                        <TextBlock Text="Reduce OSD brightness to protect OLED pixels" Foreground="#707070" FontSize="11" Margin="0,2,0,4"/>
                                        <Slider x:Name="OSDOpacitySlider"
                                                Style="{StaticResource ModernSliderStyle}"
                                                Minimum="10" Maximum="100"
                                                TickFrequency="5"
                                                SnapsTo="Ticks"
                                                Value="100"
                                                XYFocusUp="{x:Bind OSDLabelColorDefaultCheckBox}"
                                                XYFocusDown="{x:Bind OSDBackgroundToggle}"
                                                ValueChanged="OSDOpacitySlider_ValueChanged"/>
                                    </StackPanel>

                                    <!-- Background: RTSS's native OSD fill (a real backdrop box behind the
                                         text, rendered/sized by RTSS itself — works with every overlay
                                         level/layout since it's not a per-line tag). Boxed separately so
                                         it doesn't visually blend with the OSD Opacity slider above. -->
                                    <Border Background="#20203A" BorderBrush="#3A3A5C" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,0,0,8">
                                    <StackPanel x:Name="OSDBackgroundCard">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                                <TextBlock Text="Background" Foreground="#AAAAAA" FontSize="13"/>
                                                <TextBlock Text="Adds a dark backdrop behind the overlay for better contrast" Foreground="#707070" FontSize="11" TextWrapping="Wrap"/>
                                            </StackPanel>
                                            <ToggleSwitch x:Name="OSDBackgroundToggle"
                                                          Grid.Column="1"
                                                          Style="{StaticResource ModernToggleStyle}"
                                                          KeyDown="OsdPanelNav_KeyDown"
                                                          Toggled="OSDBackgroundToggle_Toggled"/>
                                        </Grid>
                                        <StackPanel x:Name="OSDBackgroundOpacityPanel" Margin="0,8,0,0" Visibility="Collapsed">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Background Opacity" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="13"/>
                                                <TextBlock x:Name="OSDBackgroundOpacityValue"
                                                           Grid.Column="1"
                                                           Text="60%" FontSize="13" Foreground="#4CAF50"
                                                           FontWeight="SemiBold" VerticalAlignment="Center"/>
                                            </Grid>
                                            <Slider x:Name="OSDBackgroundOpacitySlider"
                                                    Style="{StaticResource ModernSliderStyle}"
                                                    Minimum="10" Maximum="100"
                                                    TickFrequency="5"
                                                    SnapsTo="Ticks"
                                                    Value="60"
                                                    Margin="0,2,0,0"
                                                    XYFocusUp="{x:Bind OSDBackgroundToggle}"
                                                    XYFocusDown="{x:Bind OSDPositionShiftToggle}"
                                                    ValueChanged="OSDBackgroundOpacitySlider_ValueChanged"/>
                                        </StackPanel>
                                    </StackPanel>
                                    </Border>

                                    <!-- Position Shift Toggle (OLED burn-in protection) — hidden -->
                                    <Grid Margin="0,4,0,8" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Position Shift" Foreground="#AAAAAA" FontSize="13"/>
                                            <TextBlock Text="Shifts OSD every minute to prevent burn-in" Foreground="#707070" FontSize="11"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="OSDPositionShiftToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      KeyDown="OsdPanelNav_KeyDown"
                                                      Toggled="OSDPositionShiftToggle_Toggled"/>
                                    </Grid>

                                    <!-- Frametime Graph Pinned Toggle — hidden -->
                                    <Grid Margin="0,4,0,8" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Pin Frametime Graph" Foreground="#AAAAAA" FontSize="13"/>
                                            <TextBlock Text="Always display graph on its own row at bottom" Foreground="#707070" FontSize="11"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="FrametimeGraphPinnedToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      KeyDown="OsdPanelNav_KeyDown"
                                                      Toggled="FrametimeGraphPinnedToggle_Toggled"/>
                                    </Grid>

                                        <!-- Items Section -->
                                        <TextBlock Text="Items to Display — Full Overlay"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   Margin="0,12,0,2"/>
                                        <TextBlock Text="Everything is on by default — remove what you don't want and reorder. The smaller overlay presets are preset by ClawTweaks."
                                                   Foreground="#707070" FontSize="11" TextWrapping="Wrap"
                                                   Margin="0,0,0,8"/>

                                        <!-- OSD Items with reordering -->
                                        <ItemsControl x:Name="OSDItemsControl">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <CheckBox Grid.Column="0"
                                                                  Content="{Binding DisplayName}"
                                                                  IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                                                  Foreground="#FFFFFF"
                                                                  Tag="{Binding Id}"
                                                                  UseSystemFocusVisuals="True"
                                                                  FocusVisualPrimaryBrush="White"
                                                                  FocusVisualSecondaryBrush="Transparent"
                                                                  Checked="OSDItemCheckBox_Changed"
                                                                  Unchecked="OSDItemCheckBox_Changed"/>

                                                        <Button Grid.Column="1"
                                                                Content="&#xE70E;"
                                                                FontFamily="Segoe MDL2 Assets"
                                                                FontSize="10"
                                                                Width="28" Height="24"
                                                                Padding="0"
                                                                Margin="4,0,0,0"
                                                                Background="Transparent"
                                                                Tag="{Binding Id}"
                                                                IsEnabled="{Binding CanMoveUp}"
                                                                Click="OSDItemMoveUp_Click"/>

                                                        <Button Grid.Column="2"
                                                                Content="&#xE70D;"
                                                                FontFamily="Segoe MDL2 Assets"
                                                                FontSize="10"
                                                                Width="28" Height="24"
                                                                Padding="0"
                                                                Margin="4,0,0,0"
                                                                Background="Transparent"
                                                                Tag="{Binding Id}"
                                                                IsEnabled="{Binding CanMoveDown}"
                                                                Click="OSDItemMoveDown_Click"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Custom RTSS Tags Section -->
                                        <TextBlock Text="Custom RTSS Tags"
