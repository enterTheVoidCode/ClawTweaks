                                </Border>
                                <!-- Header with expand toggle -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Fan Curve" Style="{StaticResource CardTitleStyle}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Fan: " Style="{StaticResource CardCaptionStyle}"/>
                                            <TextBlock x:Name="FanRPMLabel" Text="-- RPM" Style="{StaticResource CardCaptionStyle}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="FanCurveActiveModeLabel"
                                                   FontSize="10" Foreground="#88B0E0" Margin="0,2,0,0"
