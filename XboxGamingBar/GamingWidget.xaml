                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Power Curve" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="0.1 = aggressive, 1.0 = linear, 4.0 = relaxed" FontSize="11" Foreground="#888888"/>
                                        </StackPanel>
                                        <TextBlock x:Name="StickPowerCurveValueText" Grid.Column="1" Text="1.0"
                                                   FontSize="13" Foreground="#4CAF50" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="StickPowerCurveSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="10" Maximum="400" TickFrequency="1" SnapsTo="Ticks" Value="100"
                                            IsEnabled="False" ValueChanged="StickPowerCurveSlider_ValueChanged"/>

                                    <!-- Gyro Speed Deadzone -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Gyro Speed Deadzone" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Smooth recovery above threshold" FontSize="11" Foreground="#888888"/>
                                        </StackPanel>
                                        <TextBlock x:Name="StickDeadzoneValueText" Grid.Column="1" Text="2°/s"
                                                   FontSize="13" Foreground="#4CAF50" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="StickDeadzoneSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="50" TickFrequency="1" SnapsTo="Ticks" Value="2"
                                            IsEnabled="False" ValueChanged="StickDeadzoneSlider_ValueChanged"/>

                                    <!-- Precision Speed -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Precision Speed" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Reduces sensitivity below this speed" FontSize="11" Foreground="#888888"/>
                                        </StackPanel>
                                        <TextBlock x:Name="StickPrecisionSpeedValueText" Grid.Column="1" Text="Off"
                                                   FontSize="13" Foreground="#4CAF50" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="StickPrecisionSpeedSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="100" TickFrequency="1" SnapsTo="Ticks" Value="0"
                                            IsEnabled="False" ValueChanged="StickPrecisionSpeedSlider_ValueChanged"/>

                                    <!-- Output Mix -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Output Mix" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Balance between vertical and horizontal output" FontSize="11" Foreground="#888888"/>
                                        </StackPanel>
                                        <TextBlock x:Name="StickOutputMixValueText" Grid.Column="1" Text="Balanced"
                                                   FontSize="13" Foreground="#4CAF50" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="StickOutputMixSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="-100" Maximum="100" TickFrequency="1" SnapsTo="Ticks" Value="0"
                                            IsEnabled="False" ValueChanged="StickOutputMixSlider_ValueChanged"/>

                                    <!-- Reset to recommended defaults (issue #79: vvalente30 asked for a
                                         reset button after experimenting and getting lost in the settings).
                                         Drives the same controls the VIIPER reset button does — they share
                                         LocalSettings keys, so one handler is enough. -->
                                    <Button x:Name="StickGyroLegacyResetButton" Content="Reset gyro settings to recommended defaults"
                                            HorizontalAlignment="Stretch" Margin="0,8,0,0"
                                            Click="StickGyroLegacyResetButton_Click"
                                            Background="#2A2A2A" BorderBrush="#444444" BorderThickness="1" Foreground="#CCCCCC"/>
                                </StackPanel>

                            </StackPanel>

                            <!-- VIIPER emulation content — replaces ControllerEmulationContent when
                                 the VIIPER backend toggle (under Debug panel) is on. Only one of the
                                 two bodies is visible at a time; they are not run concurrently. -->
                            <StackPanel x:Name="ViiperEmulationContent" Visibility="Collapsed" Margin="0,12,0,0">
                                <Border Background="#1E2A3E" BorderBrush="#3D5A80" BorderThickness="1" CornerRadius="6" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="VIIPER Device Configuration" FontSize="13" FontWeight="SemiBold" Foreground="#4AB3F4"/>
                                        <TextBlock Text="Active backend: VIIPER (USBIP). Changes take effect immediately (hot-swap)." FontSize="11" Foreground="#888888" Margin="0,2,0,10" TextWrapping="Wrap"/>

                                        <TextBlock Text="Virtual device" FontSize="12" Foreground="#CCCCCC" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="ViiperDeviceTypeComboBox" HorizontalAlignment="Stretch">
                                            <ComboBoxItem Content="Xbox 360" Tag="xbox360"/>
                                            <ComboBoxItem Content="DualShock 4" Tag="dualshock4"/>
                                            <ComboBoxItem Content="DualSense Edge" Tag="dualsenseedge"/>
                                            <ComboBoxItem Content="Xbox Elite 2" Tag="xboxelite2"/>
                                            <ComboBoxItem Content="Steam Controller" Tag="steam-generic"/>
                                            <ComboBoxItem Content="Switch Pro" Tag="switchpro"/>
                                        </ComboBox>

                                        <StackPanel x:Name="ViiperSteamSubDevicePanel" Visibility="Collapsed" Margin="0,12,0,0">
                                            <TextBlock Text="Steam sub-device" FontSize="12" Foreground="#CCCCCC" Margin="0,0,0,4"/>
                                            <ComboBox x:Name="ViiperSteamSubDeviceComboBox" HorizontalAlignment="Stretch">
                                                <ComboBoxItem Content="Generic" Tag="generic"/>
                                                <ComboBoxItem Content="Steam Deck" Tag="steam-deck"/>
                                                <ComboBoxItem Content="Legion Go" Tag="legion-go"/>
                                                <ComboBoxItem Content="Legion Go S" Tag="legion-go-s"/>
                                                <ComboBoxItem Content="Legion Go 2" Tag="legion-go-2"/>
                                                <ComboBoxItem Content="ROG Ally" Tag="rog-ally"/>
                                                <ComboBoxItem Content="MSI Claw" Tag="msi-claw"/>
                                                <ComboBoxItem Content="Zotac Zone" Tag="zotac-zone"/>
                                            </ComboBox>
                                        </StackPanel>

                                        <TextBlock Text="Input source" FontSize="12" Foreground="#CCCCCC" Margin="0,12,0,4"/>
                                        <ComboBox x:Name="ViiperInputSourceComboBox" HorizontalAlignment="Stretch">
                                            <ComboBoxItem Content="XInput (any controller)" Tag="XInput"/>
                                            <ComboBoxItem Content="Legion Go HID (native)" Tag="LegionHid"/>
                                        </ComboBox>

                                        <TextBlock Text="Gyro source" FontSize="12" Foreground="#CCCCCC" Margin="0,12,0,4"/>
                                        <ComboBox x:Name="ViiperGyroSourceComboBox" HorizontalAlignment="Stretch">
                                            <ComboBoxItem Content="None" Tag="None"/>
                                            <ComboBoxItem Content="Left controller" Tag="Left"/>
                                            <ComboBoxItem Content="Right controller" Tag="Right"/>
                                            <ComboBoxItem Content="Mixed (L+R averaged)" Tag="Mixed"/>
                                            <ComboBoxItem Content="Handheld (device IMU)" Tag="Handheld"/>
                                        </ComboBox>

                                        <!-- IMU Axis Mapping — per-axis source selector (with optional flip).
                                             Applies to both gyro and accel so the output vectors stay coherent. -->
                                        <TextBlock Text="IMU axis mapping" FontSize="12" Foreground="#CCCCCC" Margin="0,12,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="X→" FontSize="11" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <ComboBox x:Name="ViiperGyroAxisMapXComboBox" Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,0,6,0" FontSize="12">
                                                <ComboBoxItem Content="X"  Tag="X"/>
                                                <ComboBoxItem Content="Y"  Tag="Y"/>
                                                <ComboBoxItem Content="Z"  Tag="Z"/>
                                                <ComboBoxItem Content="-X" Tag="-X"/>
                                                <ComboBoxItem Content="-Y" Tag="-Y"/>
                                                <ComboBoxItem Content="-Z" Tag="-Z"/>
                                            </ComboBox>
                                            <TextBlock Grid.Column="2" Text="Y→" FontSize="11" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <ComboBox x:Name="ViiperGyroAxisMapYComboBox" Grid.Column="3" HorizontalAlignment="Stretch" Margin="0,0,6,0" FontSize="12">
                                                <ComboBoxItem Content="X"  Tag="X"/>
                                                <ComboBoxItem Content="Y"  Tag="Y"/>
                                                <ComboBoxItem Content="Z"  Tag="Z"/>
                                                <ComboBoxItem Content="-X" Tag="-X"/>
                                                <ComboBoxItem Content="-Y" Tag="-Y"/>
                                                <ComboBoxItem Content="-Z" Tag="-Z"/>
                                            </ComboBox>
                                            <TextBlock Grid.Column="4" Text="Z→" FontSize="11" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <ComboBox x:Name="ViiperGyroAxisMapZComboBox" Grid.Column="5" HorizontalAlignment="Stretch" FontSize="12">
                                                <ComboBoxItem Content="X"  Tag="X"/>
                                                <ComboBoxItem Content="Y"  Tag="Y"/>
                                                <ComboBoxItem Content="Z"  Tag="Z"/>
                                                <ComboBoxItem Content="-X" Tag="-X"/>
                                                <ComboBoxItem Content="-Y" Tag="-Y"/>
                                                <ComboBoxItem Content="-Z" Tag="-Z"/>
                                            </ComboBox>
                                        </Grid>

                                        <!-- Gyro → Right Stick (synthesized).
                                             Visible only when targetType has no native motion field
                                             (xbox360, xboxelite2, switchpro family, etc.) — see
                                             ViiperStickGyroProcessor.IsApplicableForTarget. The four
                                             controls below mirror the legacy ControllerEmulation
                                             stick-gyro controls so the same widget property pushes
                                             values to the helper; no separate property surface. -->
                                        <StackPanel x:Name="ViiperStickGyroSection" Visibility="Collapsed" Margin="0,12,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Header text is dynamic: reflects "Gyro → Left Stick" or "Gyro → Right
                                                     Stick" based on the Send-to-joystick setting so the title doesn't lie
                                                     when stickSelect is flipped. Driven from C# whenever the routing changes. -->
                                                <TextBlock x:Name="ViiperStickGyroSectionHeader"
                                                           Grid.Column="0"
                                                           Text="Gyro → Right Stick"
                                                           FontSize="13" FontWeight="SemiBold" Foreground="#4AB3F4"
                                                           VerticalAlignment="Center"/>
                                                <!-- Configuration summary badge: at-a-glance "ON: Hold RT" / "ON: Always" /
                                                     "OFF" so first-time users can verify activation without expanding any
                                                     groups. Pure widget-side computation; no helper round-trip. -->
                                                <Border x:Name="ViiperStickGyroStatusBadge"
                                                        Grid.Column="1"
                                                        Background="#1F2A3D"
                                                        BorderBrush="#3D5A80"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="6,2"
                                                        VerticalAlignment="Center">
                                                    <TextBlock x:Name="ViiperStickGyroStatusBadgeText"
                                                               Text="OFF"
                                                               FontSize="10"
                                                               Foreground="#AAAAAA"/>
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="Synthesizes a stick contribution from gyro motion for emulated targets without a native motion field (Xbox 360, Xbox Elite 2, Switch Pro)."
                                                       FontSize="11" Foreground="#888888" TextWrapping="Wrap" Margin="0,2,0,8"/>

                                            <!-- Master enable.
                                                 Off = raw stick passthrough (legacy behavior pre-2152). On = synthesize gyro
                                                 contribution into the chosen stick. Default true. -->
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="Enable gyro → stick" FontSize="13" Foreground="#FFFFFF"/>
                                                    <TextBlock Text="Off = raw stick passthrough; processor short-circuits."
                                                               FontSize="11" Foreground="#888888" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <ToggleSwitch x:Name="ViiperStickGyroEnabledToggle"
                                                              Grid.Column="1"
                                                              Style="{StaticResource ModernToggleStyle}"/>
                                            </Grid>

                                            <TextBlock Text="Activation mode" FontSize="12" Foreground="#CCCCCC" Margin="0,0,0,4"/>
                                            <ComboBox x:Name="ViiperStickGyroActivationModeComboBox" HorizontalAlignment="Stretch"
                                                      SelectionChanged="ViiperStickGyroActivationModeComboBox_SelectionChanged">
                                                <ComboBoxItem Content="Always On" Tag="0" IsSelected="True"/>
                                                <ComboBoxItem Content="Hold" Tag="1"/>
                                                <ComboBoxItem Content="Toggle" Tag="2"/>
                                            </ComboBox>

                                            <TextBlock Text="Activation button" FontSize="12" Foreground="#CCCCCC" Margin="0,8,0,4"/>
                                            <ComboBox x:Name="ViiperStickGyroActivationButtonComboBox" HorizontalAlignment="Stretch"
                                                      SelectionChanged="ViiperStickGyroActivationButtonComboBox_SelectionChanged">
                                                <ComboBoxItem Content="None" Tag="0"/>
                                                <ComboBoxItem Content="Right Trigger" Tag="1" IsSelected="True"/>
                                                <ComboBoxItem Content="Left Trigger" Tag="2"/>
                                                <ComboBoxItem Content="Right Bumper" Tag="3"/>
                                                <ComboBoxItem Content="Left Bumper" Tag="4"/>
                                                <ComboBoxItem Content="A" Tag="5"/>
                                                <ComboBoxItem Content="B" Tag="6"/>
                                                <ComboBoxItem Content="X" Tag="7"/>
                                                <ComboBoxItem Content="Y" Tag="8"/>
                                                <ComboBoxItem Content="Right Stick Click" Tag="9"/>
                                                <ComboBoxItem Content="Left Stick Click" Tag="10"/>
                                                <ComboBoxItem Content="D-Pad Up" Tag="11"/>
                                                <ComboBoxItem Content="D-Pad Down" Tag="12"/>
                                                <ComboBoxItem Content="D-Pad Left" Tag="13"/>
                                                <ComboBoxItem Content="D-Pad Right" Tag="14"/>
                                                <ComboBoxItem Content="Start" Tag="15"/>
                                                <ComboBoxItem Content="Back" Tag="16"/>
                                                <ComboBoxItem Content="M3 (back R lower)" Tag="17"/>
                                                <ComboBoxItem Content="M1 (side grip L)" Tag="18"/>
                                                <ComboBoxItem Content="M2 (side grip R)" Tag="19"/>
                                                <ComboBoxItem Content="Y1 (back L upper)" Tag="20"/>
                                                <ComboBoxItem Content="Y2 (back L lower)" Tag="21"/>
                                                <ComboBoxItem Content="Y3 (back R upper)" Tag="22"/>
                                            </ComboBox>

                                            <Grid Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Sensitivity" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Foreground="#CCCCCC"/>
                                                <TextBlock x:Name="ViiperStickGyroSensitivityValueText" Grid.Column="1" Text="1.00x" FontSize="12" Foreground="#888888"/>
                                            </Grid>
                                            <Slider x:Name="ViiperStickGyroSensitivitySlider"
                                                    Minimum="1" Maximum="400" StepFrequency="1" SmallChange="5" LargeChange="25"
                                                    ValueChanged="ViiperStickGyroSensitivitySlider_ValueChanged"/>

                                            <Grid Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Deadzone" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Foreground="#CCCCCC"/>
                                                <TextBlock x:Name="ViiperStickGyroDeadzoneValueText" Grid.Column="1" Text="2°/s" FontSize="12" Foreground="#888888"/>
                                            </Grid>
                                            <Slider x:Name="ViiperStickGyroDeadzoneSlider"
                                                    Minimum="0" Maximum="50" StepFrequency="1" SmallChange="1" LargeChange="5"
                                                    ValueChanged="ViiperStickGyroDeadzoneSlider_ValueChanged"/>

                                            <!-- Advanced expander.
                                                 Each control mirrors a legacy ControllerEmulation* control via
                                                 GamingWidget.ViiperStickGyro.cs, so the same widget property
                                                 pushes values to the helper. Defaults match vvalente30's
                                                 recommended SteamOS-aligned settings (issue #79). -->
                                            <Grid Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Advanced gyro → stick options" FontSize="12" Foreground="#AAAAAA"
                                                           VerticalAlignment="Center"/>
                                                <ToggleButton x:Name="ViiperStickGyroAdvancedToggle"
                                                              Grid.Column="1" IsChecked="False"
                                                              VerticalAlignment="Center" Background="Transparent" BorderThickness="0"
                                                              Padding="8,4" Click="ViiperStickGyroAdvancedToggle_Click">
                                                    <FontIcon x:Name="ViiperStickGyroAdvancedIcon" Glyph="&#xE70D;" FontSize="12"/>
                                                </ToggleButton>
                                            </Grid>
                                            <StackPanel x:Name="ViiperStickGyroAdvancedContent" Spacing="8" Margin="0,8,0,0" Visibility="Collapsed">

                                                <!-- Send to joystick -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="Send to joystick" FontSize="12" Foreground="#CCCCCC"/>
                                                        <TextBlock Text="Which emulated stick receives the gyro contribution." FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <ComboBox x:Name="ViiperStickGyroSelectComboBox"
                                                              Grid.Column="1" Width="160"
                                                              SelectionChanged="ViiperStickGyroSelectComboBox_SelectionChanged">
                                                        <ComboBoxItem Content="Left" Tag="0"/>
                                                        <ComboBoxItem Content="Right" Tag="1" IsSelected="True"/>
                                                    </ComboBox>
                                                </Grid>

                                                <!-- 3DOF to 2D conversion -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="3DOF to 2D conversion" FontSize="12" Foreground="#CCCCCC"/>
                                                        <TextBlock Text="Which gyro axes drive the stick. Yaw = look L/R, Roll = tilt L/R, Yaw+Roll = both." FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <ComboBox x:Name="ViiperStickGyroConversionComboBox"
                                                              Grid.Column="1" Width="160"
                                                              SelectionChanged="ViiperStickGyroConversionComboBox_SelectionChanged">
                                                        <ComboBoxItem Content="Yaw" Tag="0"/>
                                                        <ComboBoxItem Content="Roll" Tag="1"/>
                                                        <ComboBoxItem Content="Yaw + Roll" Tag="2" IsSelected="True"/>
                                                    </ComboBox>
                                                </Grid>

                                                <!-- Gyro orientation -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="Gyro orientation" FontSize="12" Foreground="#CCCCCC"/>
                                                        <TextBlock Text="Handheld posture. Switch to Orthogonal if your IMU axes feel rotated 90°." FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <ComboBox x:Name="ViiperStickGyroOrientationComboBox"
                                                              Grid.Column="1" Width="160"
                                                              SelectionChanged="ViiperStickGyroOrientationComboBox_SelectionChanged">
                                                        <ComboBoxItem Content="Parallel" Tag="0" IsSelected="True"/>
                                                        <ComboBoxItem Content="Orthogonal" Tag="1"/>
                                                    </ComboBox>
                                                </Grid>

                                                <!-- Invert toggles -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Invert X output" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Foreground="#CCCCCC"/>
                                                    <ToggleSwitch x:Name="ViiperStickGyroInvertXToggle"
                                                                  Grid.Column="1"
                                                                  Style="{StaticResource ModernToggleStyle}"
                                                                  Toggled="ViiperStickGyroInvertXToggle_Toggled"/>
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Invert Y output" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Foreground="#CCCCCC"/>
                                                    <ToggleSwitch x:Name="ViiperStickGyroInvertYToggle"
                                                                  Grid.Column="1"
                                                                  Style="{StaticResource ModernToggleStyle}"
                                                                  Toggled="ViiperStickGyroInvertYToggle_Toggled"/>
                                                </Grid>

                                                <!-- Min gyro input speed -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="Min gyro input speed" FontSize="12" Foreground="#CCCCCC"/>
                                                        <TextBlock Text="Ignore motion below this speed (filters drift / micro-shake)." FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="ViiperStickGyroMinGyroSpeedValueText" Grid.Column="1" VerticalAlignment="Center" Text="0°/s" FontSize="12" Foreground="#888888"/>
                                                </Grid>
                                                <Slider x:Name="ViiperStickGyroMinGyroSpeedSlider"
                                                        Minimum="0" Maximum="100" StepFrequency="1" SmallChange="1" LargeChange="5"
                                                        ValueChanged="ViiperStickGyroMinGyroSpeedSlider_ValueChanged"/>

                                                <!-- Max gyro input speed -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="Max gyro input speed" FontSize="12" Foreground="#CCCCCC"/>
                                                        <TextBlock Text="Speed at which the stick reaches full deflection." FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="ViiperStickGyroMaxGyroSpeedValueText" Grid.Column="1" VerticalAlignment="Center" Text="220°/s" FontSize="12" Foreground="#888888"/>
                                                </Grid>
                                                <Slider x:Name="ViiperStickGyroMaxGyroSpeedSlider"
                                                        Minimum="50" Maximum="720" StepFrequency="1" SmallChange="5" LargeChange="50"
                                                        ValueChanged="ViiperStickGyroMaxGyroSpeedSlider_ValueChanged"/>

                                                <!-- Min joystick output -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="Min joystick output" FontSize="12" Foreground="#CCCCCC"/>
                                                        <TextBlock Text="Anti-deadzone: minimum stick magnitude when any motion is detected." FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="ViiperStickGyroMinOutputValueText" Grid.Column="1" VerticalAlignment="Center" Text="0%" FontSize="12" Foreground="#888888"/>
                                                </Grid>
                                                <Slider x:Name="ViiperStickGyroMinOutputSlider"
                                                        Minimum="0" Maximum="100" StepFrequency="1" SmallChange="1" LargeChange="5"
                                                        ValueChanged="ViiperStickGyroMinOutputSlider_ValueChanged"/>

                                                <!-- Max joystick output -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="Max joystick output" FontSize="12" Foreground="#CCCCCC"/>
                                                        <TextBlock Text="Cap the synthesized stick magnitude. Lower for slower, calmer aim." FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="ViiperStickGyroMaxOutputValueText" Grid.Column="1" VerticalAlignment="Center" Text="100%" FontSize="12" Foreground="#888888"/>
                                                </Grid>
                                                <Slider x:Name="ViiperStickGyroMaxOutputSlider"
                                                        Minimum="1" Maximum="100" StepFrequency="1" SmallChange="1" LargeChange="5"
                                                        ValueChanged="ViiperStickGyroMaxOutputSlider_ValueChanged"/>

                                                <!-- Power curve -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="Power curve" FontSize="12" Foreground="#CCCCCC"/>
                                                        <TextBlock Text="0.1 = aggressive (small motion → big stick), 1.0 = linear, 4.0 = relaxed." FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="ViiperStickGyroPowerCurveValueText" Grid.Column="1" VerticalAlignment="Center" Text="1.0" FontSize="12" Foreground="#888888"/>
                                                </Grid>
                                                <Slider x:Name="ViiperStickGyroPowerCurveSlider"
                                                        Minimum="10" Maximum="400" StepFrequency="1" SmallChange="5" LargeChange="25"
                                                        ValueChanged="ViiperStickGyroPowerCurveSlider_ValueChanged"/>

                                                <!-- Precision speed -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="Precision speed" FontSize="12" Foreground="#CCCCCC"/>
                                                        <TextBlock Text="Slow-tilt damping. 0 = off." FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="ViiperStickGyroPrecisionSpeedValueText" Grid.Column="1" VerticalAlignment="Center" Text="Off" FontSize="12" Foreground="#888888"/>
                                                </Grid>
                                                <Slider x:Name="ViiperStickGyroPrecisionSpeedSlider"
                                                        Minimum="0" Maximum="100" StepFrequency="1" SmallChange="1" LargeChange="5"
                                                        ValueChanged="ViiperStickGyroPrecisionSpeedSlider_ValueChanged"/>

                                                <!-- Output mix -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="Output mix" FontSize="12" Foreground="#CCCCCC"/>
                                                        <TextBlock Text="Negative bias = vertical, positive = horizontal, 0 = balanced." FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="ViiperStickGyroOutputMixValueText" Grid.Column="1" VerticalAlignment="Center" Text="Balanced" FontSize="12" Foreground="#888888"/>
                                                </Grid>
                                                <Slider x:Name="ViiperStickGyroOutputMixSlider"
                                                        Minimum="-100" Maximum="100" StepFrequency="1" SmallChange="5" LargeChange="25"
                                                        ValueChanged="ViiperStickGyroOutputMixSlider_ValueChanged"/>

                                                <!-- Reset to vvalente30's recommended SteamOS-aligned defaults. Each
                                                     value mirrors over to the legacy CE control via the existing
                                                     property pipe path; no separate save logic. -->
                                                <Button x:Name="ViiperStickGyroResetButton"
                                                        Content="Reset to recommended defaults"
                                                        Margin="0,12,0,0"
                                                        HorizontalAlignment="Stretch"
                                                        Style="{StaticResource ModernButtonStyle}"
                                                        Click="ViiperStickGyroResetButton_Click"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <TextBlock Text="Guide/Mode button" FontSize="12" Foreground="#CCCCCC" Margin="0,12,0,4"/>
                                        <ComboBox x:Name="ViiperGuideButtonModeComboBox" HorizontalAlignment="Stretch">
                                            <ComboBoxItem Content="Native (emulated device Guide/PS)" Tag="Native"/>
                                            <ComboBoxItem Content="Open Xbox Game Bar (Win+G)" Tag="GameBar"/>
                                        </ComboBox>
                                        <TextBlock x:Name="ViiperLegionLDisabledHint"
                                                   Text="Legion L is disabled in Special Remapping — set it to &quot;Guide&quot; to route the Xbox button through the emulated device."
                                                   FontSize="11"
                                                   Foreground="#FFB060"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0"
                                                   Visibility="Collapsed"/>

                                        <!-- Swap rumble motors -->
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Swap rumble motors"
                                                       Grid.Column="0"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"
                                                       Foreground="#CCCCCC"/>
                                            <ToggleSwitch x:Name="ViiperSwapRumbleMotorsToggle"
                                                          Grid.Column="1"
                                                          Style="{StaticResource ModernToggleStyle}"
                                                          IsOn="False"/>
                                        </Grid>

                                        <!-- Mirror emulated lightbar (DS4 / DualSense Edge) onto Legion stick lights -->
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Mirror emulated lightbar to stick lights"
                                                           FontSize="13"
                                                           Foreground="#CCCCCC"/>
                                                <TextBlock Text="DualShock 4 / DualSense Edge only — when on, game-driven LED color overrides the picker color you chose for the Legion Go sticks. Off keeps your saved stick color."
                                                           FontSize="11"
                                                           Foreground="#888888"
                                                           TextWrapping="Wrap"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <ToggleSwitch x:Name="ViiperMirrorLightbarToStickToggle"
                                                          Grid.Column="1"
                                                          VerticalAlignment="Center"
                                                          Style="{StaticResource ModernToggleStyle}"
                                                          IsOn="False"/>
                                        </Grid>

                                        <!-- Rumble intensity -->
                                        <StackPanel Margin="0,8,0,0">
                                            <Grid>
                                                <TextBlock Text="Rumble intensity" FontSize="13" Foreground="#CCCCCC"/>
                                                <TextBlock x:Name="ViiperRumbleIntensityValue"
                                                           Text="100%"
                                                           Style="{StaticResource CardValueStyle}"/>
                                            </Grid>
                                            <Slider x:Name="ViiperRumbleIntensitySlider"
                                                    Style="{StaticResource ModernSliderStyle}"
                                                    Minimum="0" Maximum="200"
                                                    Value="100"
                                                    StepFrequency="5"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        </Border>


                        <!-- Touchpad & Vibration Card (hidden on devices without HID touchpad support) -->
                        <StackPanel x:Name="TouchpadVibrationSection">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Touchpad &amp; Vibration" Style="{StaticResource CardTitleStyle}"/>
                                            <TextBlock Text="Touchpad and haptic feedback settings"
                                                       Style="{StaticResource CardCaptionStyle}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="TouchpadVibrationExpandToggle"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="TouchpadVibrationExpandToggle_Click"
                                                  XYFocusUp="{x:Bind LegionNavItem}">
                                        <FontIcon x:Name="TouchpadVibrationExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>
                                <StackPanel x:Name="TouchpadVibrationContent" Spacing="12" Margin="0,12,0,0" Visibility="Collapsed">
                                    <!-- Touchpad Toggle -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Touchpad Enabled" Grid.Column="0" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
                                        <ToggleSwitch x:Name="LegionTouchpadToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      IsOn="True"
                                                      XYFocusUp="{x:Bind LegionNavItem}"
                                                      XYFocusDown="{x:Bind LegionVibrationComboBox}"/>
                                    </Grid>

                                    <!-- Vibration Intensity -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Vibration Intensity" Grid.Column="0" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
                                        <ComboBox x:Name="LegionVibrationComboBox"
                                                  Grid.Column="1"
                                                  Width="100"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  SelectedIndex="2">
                                            <x:String>Off</x:String>
                                            <x:String>Weak</x:String>
                                            <x:String>Medium</x:String>
                                            <x:String>Strong</x:String>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Vibration Mode -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Vibration Mode" Grid.Column="0" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
                                        <ComboBox x:Name="LegionVibrationModeComboBox"
                                                  Grid.Column="1"
                                                  Width="100"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  SelectedIndex="0">
                                            <x:String>FPS</x:String>
                                            <x:String>Racing</x:String>
                                            <x:String>AVG</x:String>
                                            <x:String>SPG</x:String>
                                            <x:String>RPG</x:String>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Touchpad Haptics Dropdown -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Touchpad Haptics" Grid.Column="0" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
                                        <ComboBox x:Name="LegionTouchpadVibrationComboBox"
                                                  Grid.Column="1"
                                                  SelectedIndex="2"
                                                  Width="100"
                                                  Style="{StaticResource ModernComboBoxStyle}">
                                            <x:String>Off</x:String>
                                            <x:String>Low</x:String>
                                            <x:String>Medium</x:String>
                                            <x:String>High</x:String>
                                        </ComboBox>
                                    </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Controller Remapping Section (hidden on devices without HID controller remap support) -->
                        <StackPanel x:Name="ControllerRemappingSection">

                        <!-- Per-Game Controller Profile Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Per-Game Controller Profile" Style="{StaticResource CardTitleStyle}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <Image x:Name="LegionControllerProfileGameIcon"
                                                   Width="16" Height="16"
                                                   Margin="0,0,6,0"
                                                   Stretch="UniformToFill"
                                                   VerticalAlignment="Center"
                                                   Visibility="Collapsed"/>
                                            <TextBlock x:Name="LegionControllerProfileGameText"
                                                       Text="No game detected"
                                                       Style="{StaticResource CardCaptionStyle}"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LegionControllerProfileToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsOn="False"
                                                  IsEnabled="False"
                                                  Toggled="LegionControllerProfileToggle_Toggled"/>
                                </Grid>
                                <!-- Active profile mode badge -->
                                <Border x:Name="ControllerProfileModeBadge"
                                        Background="#37260C"
                                        BorderBrush="#A06E28"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        Padding="8,3"
                                        Margin="0,8,0,0"
                                        HorizontalAlignment="Left">
                                    <TextBlock x:Name="ControllerProfileModeText"
                                               Text="Editing Global Profile"
                                               FontSize="11"
                                               Foreground="#FFAA46"/>
                                </Border>
                                <TextBlock x:Name="PerGameProfileHelpText"
                                           Text="Start a game to enable a per-game controller profile."
                                           Style="{StaticResource CardCaptionStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0"
                                           Visibility="Collapsed"/>

                                <!-- Shown while a per-game profile exists (toggle locked on): the profile's
                                     existence IS the on/off state, so the only way to turn it off is to delete it. -->
                                <TextBlock x:Name="LegionControllerProfileLockHint"
                                           Text="This game has its own controller profile, so it stays active automatically. To switch back to the global profile, delete it under Saved Profiles."
                                           Style="{StaticResource CardCaptionStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0"
                                           Visibility="Collapsed"/>

                                <!-- Per-game capture scope: user picks which categories the per-game
                                     profile should override. Unchecked categories stay global even
                                     when the master Per-Game Controller Profile toggle is on. -->
                                <!-- Per-game capture checkboxes: hidden on MSI Claw.
                                     NintendoLayout + ButtonMappings are forced to true in code (ProfileCustomization.cs).
                                     Named controls kept for code-behind compat. -->
                                <StackPanel Visibility="Collapsed">
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Customize per-game capture"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   VerticalAlignment="Center"/>
                                        <ToggleButton x:Name="LegionControllerProfileScopeExpandToggle"
                                                      Grid.Column="1"
                                                      IsChecked="False"
                                                      VerticalAlignment="Center"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      Padding="8,4"
                                                      Click="LegionControllerProfileScopeExpandToggle_Click">
                                            <FontIcon x:Name="LegionControllerProfileScopeExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                        </ToggleButton>
                                    </Grid>
                                    <StackPanel x:Name="LegionControllerProfileScopeContent" Margin="0,8,0,0">
                                        <CheckBox x:Name="ProfileSaveNintendoLayoutCheckBox"
                                                  Content="Nintendo Layout" IsChecked="True"
                                                  Checked="ProfileSettingsCheckBox_Changed"
                                                  Unchecked="ProfileSettingsCheckBox_Changed"/>
                                        <CheckBox x:Name="ProfileSaveVibrationCheckBox"
                                                  Content="Vibration" IsChecked="False"
                                                  Checked="ProfileSettingsCheckBox_Changed"
                                                  Unchecked="ProfileSettingsCheckBox_Changed"/>
                                        <CheckBox x:Name="ProfileSaveLightingCheckBox"
                                                  Content="Lighting" IsChecked="False"
                                                  Checked="ProfileSettingsCheckBox_Changed"
                                                  Unchecked="ProfileSettingsCheckBox_Changed"/>
                                        <CheckBox x:Name="ProfileSaveButtonMappingsCheckBox"
                                                  Content="Button Mappings" IsChecked="True"
                                                  Checked="ProfileSettingsCheckBox_Changed"
                                                  Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- No-game notice: collapsed by default, only shown for per-game hint when needed -->
                        <Border x:Name="ControllerNoGameNotice"
                                Background="#1A1A1A"
                                BorderBrush="#333333"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="14,10"
                                Margin="0,4,0,8"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE7C1;" FontSize="16"
                                          Foreground="#666666" VerticalAlignment="Center"/>
                                <TextBlock Text="Editing global controller profile. Launch a game to use per-game settings."
                                           Foreground="#888888" FontSize="12"
                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Editable controller content — always enabled (global profile editable without a game) -->
                        <StackPanel x:Name="ControllerEditableContentPanel">

                        <!-- Gyro Settings Section (hidden on devices without HID gyro support) -->
                        <StackPanel x:Name="GyroSection">
                        <!-- Gyro Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Gyro" Style="{StaticResource CardTitleStyle}" Grid.Column="0"/>
                                    <!-- Expand toggle: only visible when per-game profile is active -->
                                    <ToggleButton x:Name="GyroSettingsExpandToggle"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Visibility="Collapsed"
                                                  Click="GyroSettingsExpandToggle_Click">
                                        <FontIcon x:Name="GyroSettingsExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>
                                <!-- Hint: shown when global profile is active (gyro is per-game only) -->
                                <TextBlock x:Name="GyroPerGameOnlyHint"
                                           Text="Gyro is only available in per-game profiles."
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           FontSize="12"
                                           Margin="0,8,0,0"
                                           Visibility="Visible"
                                           TextWrapping="Wrap"/>
                                <StackPanel x:Name="GyroSettingsContent" Spacing="12" Margin="0,12,0,0" Visibility="Collapsed">
                                    <!-- Gyro Target -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Target" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
                                    <ComboBox x:Name="LegionGyroTargetComboBox"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              HorizontalAlignment="Stretch"
                                              SelectedIndex="0">
                                        <x:String>Disabled</x:String>
                                        <x:String>Right Stick</x:String>
                                        <x:String>Left Stick</x:String>
                                        <x:String>Mouse</x:String>
                                    </ComboBox>
                                </Grid>

                                <!-- Gyro Mapping Type -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Mapping" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
                                    <ComboBox x:Name="LegionGyroMappingTypeComboBox"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              HorizontalAlignment="Stretch"
                                              SelectedIndex="0">
                                        <x:String>Instant</x:String>
                                        <x:String>Continuous</x:String>
                                    </ComboBox>
                                </Grid>

                                <!-- Gyro Activation Button -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Button" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
                                    <ComboBox x:Name="LegionGyroActivationButtonComboBox"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              HorizontalAlignment="Stretch"
                                              SelectedIndex="0">
                                        <x:String>None</x:String>
                                        <x:String>LB</x:String>
                                        <x:String>LT</x:String>
                                        <x:String>RB</x:String>
                                        <x:String>RT</x:String>
                                        <x:String>Y1</x:String>
                                        <x:String>Y2</x:String>
                                        <x:String>M2</x:String>
                                        <x:String>M3</x:String>
                                    </ComboBox>
                                </Grid>

                                <!-- Gyro Activation Mode -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Activation" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
                                    <ComboBox x:Name="LegionGyroActivationModeComboBox"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              HorizontalAlignment="Stretch"
                                              SelectedIndex="0">
                                        <x:String>Hold</x:String>
                                        <x:String>Toggle</x:String>
                                    </ComboBox>
                                </Grid>

                                <!-- Gyro Sensitivity X -->
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="Sensitivity X" FontSize="13" Foreground="#AAAAAA"/>
                                        <TextBlock x:Name="LegionGyroSensitivityXValue"
                                                   Text="50"
                                                   Style="{StaticResource CardValueStyle}"/>
                                    </Grid>
                                    <Slider x:Name="LegionGyroSensitivityXSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="1" Maximum="100"
                                            Value="50"
                                            StepFrequency="1"/>
                                </StackPanel>

                                <!-- Gyro Sensitivity Y -->
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="Sensitivity Y" FontSize="13" Foreground="#AAAAAA"/>
                                        <TextBlock x:Name="LegionGyroSensitivityYValue"
                                                   Text="50"
                                                   Style="{StaticResource CardValueStyle}"/>
                                    </Grid>
                                    <Slider x:Name="LegionGyroSensitivityYSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="1" Maximum="100"
                                            Value="50"
                                            StepFrequency="1"/>
                                </StackPanel>

                                <!-- Gyro Deadzone -->
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="Deadzone" FontSize="13" Foreground="#AAAAAA"/>
                                        <TextBlock x:Name="LegionGyroDeadzoneValue"
                                                   Text="10"
                                                   Style="{StaticResource CardValueStyle}"/>
                                    </Grid>
                                    <Slider x:Name="LegionGyroDeadzoneSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="1" Maximum="100"
                                            Value="10"
                                            StepFrequency="1"/>
                                </StackPanel>

                                <!-- Gyro Invert X/Y Toggles -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="Invert X" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14" Margin="0,0,12,0"/>
                                        <ToggleSwitch x:Name="LegionGyroInvertXToggle"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      IsOn="False"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="Invert Y" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14" Margin="0,0,12,0"/>
                                        <ToggleSwitch x:Name="LegionGyroInvertYToggle"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      IsOn="False"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Gyro Calibration -->
                                <StackPanel Margin="0,4,0,0">
                                    <Button x:Name="LegionCalibrateGyroButton"
                                            Content="Calibrate gyro"
                                            Style="{StaticResource ModernButtonStyle}"
                                            HorizontalAlignment="Stretch"
                                            Click="LegionCalibrateGyroButton_Click"/>
                                    <TextBlock x:Name="LegionCalibrateGyroStatus"
                                               Text="Hold the controllers still and press the button — bias is captured by the controller firmware."
                                               FontSize="11"
                                               Foreground="#888888"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        </StackPanel>
                        <!-- End Gyro Section -->

                        <!-- Button Remapping Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Button Remapping" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Map buttons to gamepad, keyboard, or mouse"
                                                   Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="ButtonRemappingExpandToggle"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="ButtonRemappingExpandToggle_Click">
                                        <FontIcon x:Name="ButtonRemappingExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>
                                <StackPanel x:Name="ButtonRemappingContent" Margin="0,12,0,0" Visibility="Collapsed">
                                    <!-- Back Buttons Section -->
                                    <TextBlock Text="Back Buttons" FontSize="12" Foreground="#666666" Margin="0,0,0,8"/>

                                    <!-- Y1 Button — hidden on MSI Claw (button does not exist) -->
                                <StackPanel Margin="0,0,0,12" Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Y1" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
                                        <ComboBox x:Name="LegionButtonY1TypeComboBox" Grid.Column="1" Margin="0,0,8,0"
                                                  Style="{StaticResource ModernComboBoxStyle}" SelectedIndex="0">
                                            <x:String>Gamepad</x:String>
                                            <x:String>Keyboard</x:String>
                                            <x:String>Mouse</x:String>
                                        </ComboBox>
                                        <ComboBox x:Name="LegionButtonY1ComboBox" Grid.Column="2"
                                                  Style="{StaticResource ModernComboBoxStyle}" SelectedIndex="0">
                                            <x:String>Disabled</x:String>
                                            <x:String>LS Click</x:String><x:String>LS Up</x:String><x:String>LS Down</x:String><x:String>LS Left</x:String><x:String>LS Right</x:String>
