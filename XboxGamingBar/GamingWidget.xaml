                                        <FontIcon x:Name="FanCurveExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <Border x:Name="FanCurveHelperDisconnectedWarning"
                                        Background="#3D2A1A" CornerRadius="4" Padding="10" Margin="0,8,0,0"
                                        Visibility="Collapsed">
                                    <TextBlock Foreground="#FFB060" FontSize="11" TextWrapping="Wrap"
                                               Text="&#x26A0; Helper disconnected with EC override active. Fan may be stuck at the last RPM until the helper reconnects, or reboot to clear."/>
                                </Border>

                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Unlock Fan Curve Override" FontSize="13" Foreground="#FFFFFF"/>
                                        <TextBlock Text="Bypass firmware minimums via direct EC write (per-mode)"
                                                   FontSize="11" Foreground="#A0A0A0" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LegionUnlockFanCurveToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsOn="False"
                                                  Toggled="LegionUnlockFanCurveToggle_Toggled"/>
                                </Grid>

                                <muxc:Expander x:Name="FanCurveInfoExpander"
                                               Margin="0,8,0,0"
                                               HorizontalAlignment="Stretch"
                                               HorizontalContentAlignment="Stretch"
                                               IsExpanded="False">
                                    <muxc:Expander.Header>
                                        <TextBlock Text="Info &amp; safety notes" FontSize="12" Foreground="#C0C8D0"/>
                                    </muxc:Expander.Header>
                                    <StackPanel>
                                        <Border Background="#3D2A1A" CornerRadius="4" Padding="10"
                                                x:Name="UnlockFanCurveWarningBorder">
                                            <StackPanel>
                                                <TextBlock Foreground="#FFB060" FontWeight="SemiBold" FontSize="12">
                                                    &#x26A0; Aggressive curves can damage hardware
                                                </TextBlock>
                                                <TextBlock Foreground="#DDB890" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"
                                                           Text="&#x2022; Never 0% above ~50&#xB0;C&#x0a;&#x2022; 101&#xB0;C software failsafe forces max RPM"/>
                                            </StackPanel>
                                        </Border>

                                        <TextBlock FontSize="11" Foreground="#9098A0" TextWrapping="Wrap" Margin="0,8,0,0"
                                                   Text="&#x2022; Curves &amp; unlock state save per power mode&#x0a;&#x2022; Dropdown selects which mode to edit, not the active one&#x0a;&#x2022; Unlock OFF: firmware drives the fan (Custom only via WMI, with firmware-enforced floors)&#x0a;&#x2022; Unlock ON: helper writes the curve directly to EC every 3s, in any mode&#x0a;&#x2022; Axis labels (10&#xB0;C&#x2013;100&#xB0;C) are how the curve is stored; firmware modes may map temps differently"/>

                                        <TextBlock FontSize="10" Foreground="#707880" TextWrapping="Wrap" Margin="0,8,0,0">
                                            Credits:
                                            <Hyperlink NavigateUri="https://github.com/Rodpad/LeGo2-Fan-Control">Rodpad/LeGo2-Fan-Control</Hyperlink>
                                            &#xB7;
                                            <Hyperlink NavigateUri="https://github.com/Undervoltologist/legiongo2_ec_reverse_engineer">Undervoltologist EC RE</Hyperlink>
                                            &#xB7;
                                            <Hyperlink NavigateUri="https://github.com/namazso/PawnIO.Modules">namazso/PawnIO.Modules</Hyperlink>
                                        </TextBlock>
                                    </StackPanel>
                                </muxc:Expander>

                                <StackPanel x:Name="FanCurveContent" Margin="0,12,0,0" Visibility="Collapsed">
                                    <TextBlock Text="Fan %" FontSize="11" Foreground="#999999" Margin="0,0,0,4"/>
                                    <Grid Height="150">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Stretch">
                                            <TextBlock Text="100" FontSize="10" Foreground="#666666" VerticalAlignment="Top"/>
                                            <TextBlock Text="75" FontSize="10" Foreground="#666666" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                            <TextBlock Text="50" FontSize="10" Foreground="#666666" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                            <TextBlock Text="25" FontSize="10" Foreground="#666666" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                            <TextBlock Text="0" FontSize="10" Foreground="#666666" VerticalAlignment="Bottom"/>
                                        </StackPanel>
                                        <Canvas x:Name="FanCurveCanvas"
                                                Grid.Column="1"
                                                Background="#1A1A1A"
                                                PointerPressed="FanCurveCanvas_PointerPressed"
                                                PointerMoved="FanCurveCanvas_PointerMoved"
                                                PointerReleased="FanCurveCanvas_PointerReleased"
                                                PointerCaptureLost="FanCurveCanvas_PointerReleased"
                                                SizeChanged="FanCurveCanvas_SizeChanged">
                                            <Polygon x:Name="FanCurveFill"
                                                     Fill="#3300AAFF"
                                                     Stroke="Transparent"/>
                                            <Polyline x:Name="ECFloorPolyline"
                                                      Stroke="#FF6600"
                                                      StrokeThickness="1.5"
                                                      StrokeDashArray="4,2"
                                                      Opacity="0.7"/>
                                            <Polyline x:Name="FanCurvePolyline"
                                                      Stroke="#00AAFF"
                                                      StrokeThickness="2"
                                                      StrokeLineJoin="Round"/>
                                            <Line x:Name="TempIndicatorLine"
                                                  Y1="0" Y2="150"
                                                  Stroke="#FF8800"
                                                  StrokeThickness="2"
                                                  StrokeDashArray="4,2"
                                                  Visibility="Collapsed"/>
                                            <Line x:Name="RPMIndicatorLine"
                                                  X1="0" X2="300"
                                                  Stroke="#00FF88"
                                                  StrokeThickness="2"
                                                  StrokeDashArray="4,2"
                                                  Visibility="Collapsed"/>
                                        </Canvas>
                                    </Grid>
                                    <Grid x:Name="FanCurveTempAxisGrid" Margin="30,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="10&#xB0;C" FontSize="9"  Foreground="#666666" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="1" Text="20"   FontSize="9"  Foreground="#666666" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="2" Text="30"   FontSize="9"  Foreground="#666666" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="3" Text="40"   FontSize="9"  Foreground="#666666" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="4" Text="50"   FontSize="9"  Foreground="#666666" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="5" Text="60"   FontSize="9"  Foreground="#666666" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="6" Text="70"   FontSize="9"  Foreground="#666666" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="7" Text="80"   FontSize="9"  Foreground="#666666" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="8" Text="90"   FontSize="9"  Foreground="#666666" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="8" Text="100&#xB0;C" FontSize="9" Foreground="#666666" HorizontalAlignment="Right"/>
                                    </Grid>
                                    <TextBlock x:Name="FanCurveLockedAxisHint"
                                               Visibility="Collapsed"
                                               FontSize="9" Foreground="#666666"
                                               HorizontalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Center">
                                        <TextBlock x:Name="CurrentTempPrefixLabel" Text="Fan Sensor Temp: " FontSize="12" Foreground="#999999"/>
                                        <TextBlock x:Name="CurrentTempLabel" Text="--&#xB0;C" FontSize="12" Foreground="#FF8800" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <StackPanel x:Name="ECFloorLegendPanel" Orientation="Horizontal" Margin="0,4,0,0" HorizontalAlignment="Center">
                                        <Line X1="0" Y1="0" X2="20" Y2="0" Stroke="#FF8800" StrokeThickness="2" StrokeDashArray="4,2" VerticalAlignment="Center"/>
                                        <TextBlock Text=" EC Protection Floor" FontSize="10" Foreground="{StaticResource HintTextBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- CPU (collapsible, EXPERIMENTAL) — moved to the bottom of the Performance tab: boost on/off, scheduling policy (Only P / Only E), P/E max freq (ToothNClaw port) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header: title + caption. The Boost toggle (on/off, the only boost control now)
                                     sits on top-right, the "More settings" expander directly BELOW it opens the
                                     advanced submenu (scheduling policy, P/E max freq). -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="CPU" Style="{StaticResource CardTitleStyle}" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="CpuBoostStatusText" Text="Boost" Foreground="#4CAF50" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock x:Name="CpuCardCaptionText"
                                                   Text="Toggle enables/disables CPU Boost. Expand for scheduling policy and P/E core max frequency."
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,12,0"/>
                                    </StackPanel>

                                    <!-- Boost on/off — the ONLY boost control (modes removed; no meaningful
                                         difference between Enabled/Aggressive/etc. in practice, and having two
                                         separate writers for one Windows setting caused repeated desync bugs). -->
                                    <ToggleSwitch x:Name="CPUBoostToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  MinWidth="0"
                                                  Margin="0,0,12,0"
                                                  KeyDown="CPUBoostToggle_KeyDown"
                                                  Toggled="CPUBoostToggle_StatusChanged"/>
                                    <!-- Collapse/expand chevron (collapsed by default) -->
                                    <ToggleButton x:Name="CpuCardExpandButton" Grid.Column="2" IsChecked="False"
                                                  VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Padding="8,4"
                                                  XYFocusUp="{x:Bind PerformanceOverlayComboBox}"
                                                  KeyDown="CpuCardExpandButton_KeyDown"
                                                  Click="CpuCardExpandButton_Click" UseSystemFocusVisuals="True">
                                        <FontIcon x:Name="CpuCardExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <!-- Collapsible content (collapsed by default). -->
                                <StackPanel x:Name="CpuSectionContent" Visibility="Collapsed" Margin="0,12,0,0" Spacing="10">
                                    <!-- Scheduling Policy -->
                                    <StackPanel>
                                        <TextBlock Text="Processor Scheduling Policy" Style="{StaticResource CardCaptionStyle}" Margin="0"/>
                                        <ComboBox x:Name="SchedulingPolicyComboBox"
                                                  Margin="0,4,0,0"
                                                  HorizontalAlignment="Stretch"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  KeyDown="CpuAdvancedCombo_KeyDown">
                                            <!-- On Lunar Lake only Auto (default) and Only E-Cores are useful/safe:
                                                 Prefer P/E are hard to verify and Only-P can't park the LP-E island
                                                 without stalling the system. Kept Tag values (0, 4) unchanged. -->
                                            <ComboBoxItem Content="Auto (default)" Tag="0" IsSelected="True"/>
                                            <ComboBoxItem Content="Only E-Cores" Tag="4"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- P-Core Max Frequency -->
                                    <StackPanel>
                                        <TextBlock Text="P-Core Max Frequency" Style="{StaticResource CardCaptionStyle}" Margin="0"/>
                                        <ComboBox x:Name="MaxPCoreFreqComboBox"
                                                  Margin="0,4,0,0"
                                                  HorizontalAlignment="Stretch"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  KeyDown="CpuAdvancedCombo_KeyDown">
                                            <ComboBoxItem Content="Unlimited" Tag="0" IsSelected="True"/>
                                            <ComboBoxItem Content="4800 MHz" Tag="4800"/>
                                            <ComboBoxItem Content="4200 MHz" Tag="4200"/>
                                            <ComboBoxItem Content="3600 MHz" Tag="3600"/>
                                            <ComboBoxItem Content="3000 MHz" Tag="3000"/>
                                            <ComboBoxItem Content="2400 MHz" Tag="2400"/>
                                            <ComboBoxItem Content="1800 MHz" Tag="1800"/>
                                            <ComboBoxItem Content="1200 MHz" Tag="1200"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- E-Core Max Frequency -->
                                    <StackPanel>
                                        <TextBlock Text="E-Core Max Frequency" Style="{StaticResource CardCaptionStyle}" Margin="0"/>
                                        <ComboBox x:Name="MaxECoreFreqComboBox"
                                                  Margin="0,4,0,0"
                                                  HorizontalAlignment="Stretch"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  KeyDown="CpuAdvancedCombo_KeyDown">
                                            <ComboBoxItem Content="Unlimited" Tag="0" IsSelected="True"/>
                                            <ComboBoxItem Content="2900 MHz" Tag="2900"/>
                                            <ComboBoxItem Content="2400 MHz" Tag="2400"/>
                                            <ComboBoxItem Content="1800 MHz" Tag="1800"/>
                                            <ComboBoxItem Content="1200 MHz" Tag="1200"/>
                                            <ComboBoxItem Content="800 MHz" Tag="800"/>
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Global Profile Card -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,16,0,0">
                            <StackPanel>
                                <!-- Orange framed title (matches the "Editing Global Profile" badge) -->
                                <Border Background="#37260C" BorderBrush="#A06E28" BorderThickness="1"
                                        CornerRadius="4" Padding="8,3" Margin="0,0,0,4" HorizontalAlignment="Left">
                                    <TextBlock Text="Global performance &amp; display profile"
                                               Foreground="#FFAA46" FontSize="14" FontWeight="Bold"/>
                                </Border>

                                <!-- Simple Mode (Power Source Toggle OFF) -->
                                <Grid x:Name="GlobalProfileSimple" Margin="0,8,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" x:Name="GlobalProfileTDPModeLabel" Text="TDP Mode" FontSize="11" Foreground="#AAAAAA" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="GlobalProfileTDPModeText" Text="Balanced" FontSize="11" Foreground="#FFFFFF" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" x:Name="GlobalProfileTDPLabel" Text="TDP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="GlobalProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" x:Name="GlobalProfileCPUStateLabel" Text="TDP Overboost" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="GlobalProfileCPUStateText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" x:Name="GlobalProfilePL2Label" Text="  PL2" FontSize="11" Foreground="{StaticResource HintTextBrush}" Margin="0,2,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="GlobalProfilePL2Text" Text="37W" FontSize="11" Foreground="{StaticResource HintTextBrush}" Margin="0,2,0,0" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" x:Name="GlobalProfileCPUBoostLabel" Text="CPU Boost" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="GlobalProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" x:Name="GlobalProfileCPUEPPLabel" Text="FPS Mode" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="GlobalProfileCPUEPPText" Text="RTSS" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="6" Grid.Column="0" x:Name="GlobalProfileFPSLimitLabel" Text="FPS Limit" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" x:Name="GlobalProfileFPSLimitText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="7" Grid.Column="0" x:Name="GlobalProfileAutoTDPLabel" Text="AutoTDP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="7" Grid.Column="1" x:Name="GlobalProfileAutoTDPText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="8" Grid.Column="0" x:Name="GlobalProfilePowerModeLabel" Text="Power Mode" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="8" Grid.Column="1" x:Name="GlobalProfilePowerModeText" Text="Balanced" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="9" Grid.Column="0" x:Name="GlobalProfileAMDLabel" Text="AMD" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="9" Grid.Column="1" x:Name="GlobalProfileAMDText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="10" Grid.Column="0" x:Name="GlobalProfileHDRLabel" Text="HDR" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="10" Grid.Column="1" x:Name="GlobalProfileHDRText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="11" Grid.Column="0" x:Name="GlobalProfileResolutionLabel" Text="Resolution" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="11" Grid.Column="1" x:Name="GlobalProfileResolutionText" Text="Native" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="12" Grid.Column="0" x:Name="GlobalProfileStickyTDPLabel" Text="Sticky TDP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="12" Grid.Column="1" x:Name="GlobalProfileStickyTDPText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="13" Grid.Column="0" x:Name="GlobalProfileCpuAdvLabel" Text="CPU" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="13" Grid.Column="1" x:Name="GlobalProfileCpuAdvText" Text="" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="14" Grid.Column="0" x:Name="GlobalProfileDisplayLabel" Text="Display" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="14" Grid.Column="1" x:Name="GlobalProfileDisplayText" Text="" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                                </Grid>
                                <!-- Multi-column rendering of the simple global profile (replaces the single-column grid above) -->
                                <StackPanel x:Name="GlobalProfilePairs" Margin="0,8,0,0"/>

                                <!-- AC/DC Mode (Power Source Toggle ON) -->
                                <Grid x:Name="GlobalProfileACDC" Margin="0,8,0,0" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Header -->
