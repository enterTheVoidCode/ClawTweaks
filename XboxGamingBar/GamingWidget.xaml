                                            <x:String>RS Click</x:String><x:String>RS Up</x:String><x:String>RS Down</x:String><x:String>RS Left</x:String><x:String>RS Right</x:String>
                                            <x:String>D-Pad Up</x:String><x:String>D-Pad Down</x:String><x:String>D-Pad Left</x:String><x:String>D-Pad Right</x:String>
                                            <x:String>A</x:String><x:String>B</x:String><x:String>X</x:String><x:String>Y</x:String>
                                            <x:String>LB</x:String><x:String>LT</x:String><x:String>RB</x:String><x:String>RT</x:String>
                                            <x:String>Select</x:String><x:String>Start</x:String>
                                            <x:String>Xbox Button</x:String>
                                        </ComboBox>
                                        <ComboBox x:Name="LegionButtonM3MouseComboBox" Grid.Column="2" Visibility="Collapsed"
                                                  Style="{StaticResource ModernComboBoxStyle}" SelectedIndex="0">
                                            <x:String>Left Click</x:String><x:String>Right Click</x:String><x:String>Middle Click</x:String>
                                            <x:String>Scroll Up</x:String><x:String>Scroll Down</x:String><x:String>Scroll Left</x:String><x:String>Scroll Right</x:String>
                                        </ComboBox>
                                    </Grid>
                                    <StackPanel x:Name="LegionButtonM3KeyboardPanel" Visibility="Collapsed" Margin="40,8,0,0" Orientation="Horizontal">
                                        <StackPanel x:Name="LegionButtonM3KeyTags" Orientation="Horizontal"/>
                                        <Button x:Name="LegionButtonM3KeyPickerButton" Width="100" Content="+ Key  &#x25BE;" Style="{StaticResource KeyPickerButtonStyle}"/>
                                    </StackPanel>
                                </StackPanel>

                                <!-- Front Buttons moved to Controller Emulation section -->
                                <!-- Front Buttons moved to Controller Emulation section (ControllerEmulationContent) -->

                                <!-- Gamepad Button Remapping -->
                                <Grid Margin="0,16,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Re-Map Specific Buttons to Another Button" FontSize="14" Foreground="{StaticResource HintTextBrush}"
                                               TextWrapping="Wrap" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <Button x:Name="LegionGamepadResetAllButton" Grid.Column="1" Content="Reset All Re-Mappings Below"
                                            Style="{StaticResource ModernButtonStyle}" Padding="8,4" FontSize="11"
                                            Background="#3C3C3C" Foreground="#AAAAAA"/>
                                </Grid>

                                <!-- Existing remappings (framed, visually separated from the create area below) -->
                                <Border Background="#1E2A3E" BorderBrush="#3D5A80" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,12">
                                <StackPanel x:Name="LegionGamepadRemappedSummary">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Remapped: " FontSize="13" FontWeight="SemiBold" Foreground="#4AB3F4" VerticalAlignment="Center"
                                                   x:Name="LegionGamepadRemappedLabel" Visibility="Collapsed"/>
                                        <TextBlock Text="None" FontSize="12" Foreground="#555555" VerticalAlignment="Center"
                                                   x:Name="LegionGamepadNoRemapsLabel"/>
                                    </StackPanel>
                                    <!-- Non-virtualizing StackPanel (rows built in code). The old
                                         ItemsControl+ItemsWrapGrid virtualized; clearing it on every
                                         edit tore down the gamepad focus scope and bounced focus to the
                                         tab strip. Plain StackPanel .Children (like the key-tag panels)
                                         does not. -->
                                    <StackPanel x:Name="LegionGamepadRemappedTags" Margin="0,4,0,0"/>
                                </StackPanel>
                                </Border>

                                <!-- Create new remappings (framed) -->
                                <Border Background="#1E2A3E" BorderBrush="#3D5A80" BorderThickness="1" CornerRadius="6" Padding="10">
                                <StackPanel>
                                    <TextBlock Text="Create new remappings" FontSize="13" FontWeight="SemiBold" Foreground="#4AB3F4" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <!-- Button selector -->
                                        <ComboBox x:Name="LegionGamepadButtonSelectorComboBox" Width="100" Margin="0,0,8,0" ItemTemplate="{StaticResource GamepadActionItemTemplate}"
                                                  Style="{StaticResource ModernComboBoxStyle}" SelectedIndex="0">
                                            <x:String>LS Click</x:String><x:String>LS Up</x:String><x:String>LS Down</x:String><x:String>LS Left</x:String><x:String>LS Right</x:String>
                                            <x:String>RS Click</x:String><x:String>RS Up</x:String><x:String>RS Down</x:String><x:String>RS Left</x:String><x:String>RS Right</x:String>
                                            <x:String>D-Pad Up</x:String><x:String>D-Pad Down</x:String><x:String>D-Pad Left</x:String><x:String>D-Pad Right</x:String>
                                            <x:String>A</x:String><x:String>B</x:String><x:String>X</x:String><x:String>Y</x:String>
                                            <x:String>LB</x:String><x:String>LT</x:String><x:String>RB</x:String><x:String>RT</x:String>
                                            <x:String>Start</x:String><x:String>Select</x:String>
                                        </ComboBox>
                                        <!-- Type dropdown -->
                                        <ComboBox x:Name="LegionGamepadTypeComboBox" Grid.Column="1" Margin="0,0,8,0"
                                                  Style="{StaticResource ModernComboBoxStyle}" SelectedIndex="0">
                                            <x:String>Gamepad</x:String><x:String>Keyboard</x:String><x:String>Mouse</x:String>
                                        </ComboBox>
                                        <!-- Gamepad action dropdown -->
                                        <ComboBox x:Name="LegionGamepadActionComboBox" Grid.Column="2" ItemTemplate="{StaticResource GamepadActionItemTemplate}"
                                                  Style="{StaticResource ModernComboBoxStyle}" SelectedIndex="0">
                                            <x:String>Disabled</x:String>
                                            <x:String>LS Click</x:String><x:String>LS Up</x:String><x:String>LS Down</x:String><x:String>LS Left</x:String><x:String>LS Right</x:String>
                                            <x:String>RS Click</x:String><x:String>RS Up</x:String><x:String>RS Down</x:String><x:String>RS Left</x:String><x:String>RS Right</x:String>
                                            <x:String>D-Pad Up</x:String><x:String>D-Pad Down</x:String><x:String>D-Pad Left</x:String><x:String>D-Pad Right</x:String>
                                            <x:String>A</x:String><x:String>B</x:String><x:String>X</x:String><x:String>Y</x:String>
                                            <x:String>LB</x:String><x:String>LT</x:String><x:String>RB</x:String><x:String>RT</x:String>
                                            <x:String>Select</x:String><x:String>Start</x:String>
                                            <x:String>Xbox Button</x:String>
                                        </ComboBox>
                                        <!-- Mouse action dropdown (hidden by default) -->
                                        <ComboBox x:Name="LegionGamepadMouseComboBox" Grid.Column="2" Visibility="Collapsed"
                                                  Style="{StaticResource ModernComboBoxStyle}" SelectedIndex="0">
                                            <x:String>Left Click</x:String><x:String>Right Click</x:String><x:String>Middle Click</x:String>
                                            <x:String>Scroll Up</x:String><x:String>Scroll Down</x:String><x:String>Scroll Left</x:String><x:String>Scroll Right</x:String>
                                        </ComboBox>
                                    </Grid>
                                    <!-- Keyboard panel (shown when Keyboard type selected) -->
                                    <StackPanel x:Name="LegionGamepadKeyboardPanel" Visibility="Collapsed" Margin="0,8,0,0" Orientation="Horizontal">
                                        <StackPanel x:Name="LegionGamepadKeyTags" Orientation="Horizontal"/>
                                        <Button x:Name="LegionGamepadKeyPickerButton" Width="100" Content="+ Key  &#x25BE;" Click="LegionGamepadKeyPicker_Click" Style="{StaticResource KeyPickerButtonStyle}"/>
                                    </StackPanel>
                                </StackPanel>
                                </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Gyro Settings Section (hidden on devices without HID gyro support) -->
                        <StackPanel x:Name="GyroSection">
                        <!-- Gyro Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Grid.Column="0">
                                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE7AD;" FontSize="16"
                                                  Foreground="{StaticResource ThemeAccentBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Gyro" Style="{StaticResource CardTitleStyle}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <!-- Expand toggle: only visible when per-game profile is active -->
                                    <ToggleButton x:Name="GyroSettingsExpandToggle"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Visibility="Collapsed"
                                                  Click="GyroSettingsExpandToggle_Click">
                                        <FontIcon x:Name="GyroSettingsExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>
                                <!-- Hint: shown when global profile is active (gyro is per-game only) -->
                                <TextBlock x:Name="GyroPerGameOnlyHint"
                                           Text="Gyro is only available in per-game profiles."
                                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                                           FontSize="12"
                                           Margin="0,8,0,0"
                                           Visibility="Visible"
                                           TextWrapping="Wrap"/>
                                <StackPanel x:Name="GyroSettingsContent" Spacing="12" Margin="0,12,0,0" Visibility="Collapsed">
                                    <!-- Gyro Target -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Target" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
                                    <ComboBox x:Name="LegionGyroTargetComboBox"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              HorizontalAlignment="Stretch"
                                              SelectedIndex="0">
                                        <x:String>Disabled</x:String>
                                        <x:String>Left Stick</x:String>
                                        <x:String>Right Stick</x:String>
                                        <x:String>Mouse</x:String>
                                    </ComboBox>
                                </Grid>

                                <!-- Gyro Engine — repurposed from the old Legion "Mapping" (Instant/Continuous)
                                     control. On the MSI Claw the Legion firmware command is a no-op, so this
                                     channel (LegionGyroMappingType, still persisted per controller-profile) now
                                     selects the software gyro→stick engine in ClawButtonMonitor.ApplyGyroToStick:
                                       0 = Adaptive (ClawTweaks)        → One-Euro speed-adaptive smoothing
                                       1 = Direct (HandheldCompanion)   → HC 1:1, no software low-pass -->
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Gyro Engine" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
                                        <ComboBox x:Name="LegionGyroMappingTypeComboBox"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  HorizontalAlignment="Stretch"
                                                  SelectedIndex="0">
                                            <x:String>Adaptive (ClawTweaks)</x:String>
                                            <x:String>Direct (HandheldCompanion)</x:String>
                                        </ComboBox>
                                    </Grid>
                                    <TextBlock Text="Adaptive = smoothed (less jitter) · Direct = HC 1:1, raw and most responsive"
                                               Foreground="#777777" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>

                                <!-- Gyro Activation Button -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Button" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
                                    <ComboBox x:Name="LegionGyroActivationButtonComboBox"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              HorizontalAlignment="Stretch"
                                              SelectedIndex="0">
                                        <x:String>None</x:String>
                                        <x:String>LB</x:String>
                                        <x:String>LT</x:String>
                                        <x:String>RB</x:String>
                                        <x:String>RT</x:String>
                                        <x:String>Y1</x:String>
                                        <x:String>Y2</x:String>
                                        <x:String>M2</x:String>
                                        <x:String>M3</x:String>
                                    </ComboBox>
                                </Grid>

                                <!-- Gyro Activation Mode -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Activation" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
                                    <ComboBox x:Name="LegionGyroActivationModeComboBox"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              HorizontalAlignment="Stretch"
                                              SelectedIndex="0">
                                        <x:String>Hold</x:String>
                                        <x:String>Toggle</x:String>
                                    </ComboBox>
                                </Grid>

                                <!-- Gyro Sensitivity X -->
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="Sensitivity X" FontSize="13" Foreground="#AAAAAA"/>
                                        <TextBlock x:Name="LegionGyroSensitivityXValue"
                                                   Text="70"
                                                   Style="{StaticResource CardValueStyle}"/>
                                    </Grid>
                                    <Slider x:Name="LegionGyroSensitivityXSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="1" Maximum="100"
                                            Value="70"
                                            StepFrequency="1"
                                            XYFocusUp="{x:Bind LegionGyroActivationModeComboBox}"/>
                                </StackPanel>

                                <!-- Gyro Sensitivity Y -->
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="Sensitivity Y" FontSize="13" Foreground="#AAAAAA"/>
                                        <TextBlock x:Name="LegionGyroSensitivityYValue"
                                                   Text="70"
                                                   Style="{StaticResource CardValueStyle}"/>
                                    </Grid>
                                    <Slider x:Name="LegionGyroSensitivityYSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="1" Maximum="100"
                                            Value="70"
                                            StepFrequency="1"
                                            XYFocusUp="{x:Bind LegionGyroSensitivityXSlider}"/>
                                </StackPanel>

                                <!-- Gyro Deadzone -->
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="Deadzone" FontSize="13" Foreground="#AAAAAA"/>
                                        <TextBlock x:Name="LegionGyroDeadzoneValue"
                                                   Text="1"
                                                   Style="{StaticResource CardValueStyle}"/>
                                    </Grid>
                                    <Slider x:Name="LegionGyroDeadzoneSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="1" Maximum="100"
                                            Value="1"
                                            StepFrequency="1"
                                            XYFocusUp="{x:Bind LegionGyroSensitivityYSlider}"/>
                                </StackPanel>

                                <!-- Gyro Invert X/Y Toggles -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <TextBlock Text="Invert X" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14" Margin="0,0,12,0"/>
                                        <ToggleSwitch x:Name="LegionGyroInvertXToggle"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      IsOn="False"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock Text="Invert Y" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14" Margin="0,0,12,0"/>
                                        <ToggleSwitch x:Name="LegionGyroInvertYToggle"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      IsOn="False"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Gyro Calibration -->
                                <StackPanel Margin="0,4,0,0">
                                    <Button x:Name="LegionCalibrateGyroButton"
                                            Content="Calibrate gyro"
                                            Style="{StaticResource ModernButtonStyle}"
                                            HorizontalAlignment="Stretch"
                                            Click="LegionCalibrateGyroButton_Click"/>
                                    <TextBlock x:Name="LegionCalibrateGyroStatus"
                                               Text="Hold the controllers still and press the button — bias is captured by the controller firmware."
                                               FontSize="11"
                                               Foreground="{StaticResource HintTextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,6,0,0"/>
                                </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        </StackPanel>
                        <!-- End Gyro Section -->

                        <!-- Vibration & Deadzone Card (collapsible; placed below Button Remapping
                             for a clean vertical controller flow). Shown on MSI Claw via
                             InitializeMsiClawSettings; content collapsed by default like the others. -->
                        <Border x:Name="ControllerFeedbackCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE877;" FontSize="16"
                                                      Foreground="{StaticResource ThemeAccentBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Vibration &amp; Deadzone" Style="{StaticResource CardTitleStyle}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="Rumble strength + stick deadzones" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="ControllerFeedbackExpandToggle"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="ControllerFeedbackExpandToggle_Click">
                                        <FontIcon x:Name="ControllerFeedbackExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>
                                <StackPanel x:Name="ControllerFeedbackContent" Spacing="12" Margin="0,12,0,0" Visibility="Collapsed">
                                    <!-- Vibration Intensity -->
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="Vibration Intensity" FontSize="13" Foreground="#AAAAAA"/>
                                            <TextBlock x:Name="VibrationIntensityValue" Text="100%" Style="{StaticResource CardValueStyle}"/>
                                        </Grid>
                                        <Slider x:Name="VibrationIntensitySlider" Style="{StaticResource ModernSliderStyle}" Minimum="0" Maximum="100" Value="100" StepFrequency="1"
                                                XYFocusUp="{x:Bind ControllerFeedbackExpandToggle}"/>
                                        <!-- Test pulse: feel the current vibration intensity without a game -->
                                        <Button x:Name="TestVibrationButton"
                                                Content="Test Vibration"
                                                Style="{StaticResource StandaloneButtonStyle}"
                                                HorizontalAlignment="Left"
                                                Margin="0,8,0,0"
                                                Click="TestVibrationButton_Click"/>
                                    </StackPanel>
                                    <!-- Stick Deadzones -->
                                    <TextBlock Text="Stick Deadzones" FontSize="12" Foreground="{StaticResource HintTextBrush}" Margin="0,4,0,0"/>
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="Left Stick" FontSize="13" Foreground="#AAAAAA"/>
                                            <TextBlock x:Name="LegionLeftStickDeadzoneValue" Text="4%" Style="{StaticResource CardValueStyle}"/>
                                        </Grid>
                                        <Slider x:Name="LegionLeftStickDeadzoneSlider" Style="{StaticResource ModernSliderStyle}" Minimum="0" Maximum="50" Value="4" StepFrequency="1"
                                                XYFocusUp="{x:Bind TestVibrationButton}"/>
                                    </StackPanel>
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="Right Stick" FontSize="13" Foreground="#AAAAAA"/>
                                            <TextBlock x:Name="LegionRightStickDeadzoneValue" Text="4%" Style="{StaticResource CardValueStyle}"/>
                                        </Grid>
                                        <Slider x:Name="LegionRightStickDeadzoneSlider" Style="{StaticResource ModernSliderStyle}" Minimum="0" Maximum="50" Value="4" StepFrequency="1"
                                                XYFocusUp="{x:Bind LegionLeftStickDeadzoneSlider}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Nintendo Layout Card — hidden on MSI Claw (vorerst deaktiviert) -->
                        <Border Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Nintendo Layout" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Swap A↔B and X↔Y face buttons"
                                               Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="LegionNintendoLayoutToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsOn="False"/>
                            </Grid>
                        </Border>

                        <!-- Desktop Controls Card — hidden on MSI Claw (not used) -->
                        <Border Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Desktop Controls" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="RS→Mouse, DPAD/LS→Arrows, A→Enter, B→Esc (Ctrl+Shift+D)"
                                               Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="LegionDesktopControlsToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsOn="False"/>
                            </Grid>
                        </Border>

                        <!-- Joystick as Mouse Card — hidden on MSI Claw (not used) -->
                        <Border Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Joystick as Mouse" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="Use a joystick to control mouse cursor"
                                           Style="{StaticResource CardCaptionStyle}"/>

                                <!-- Mode Selection -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Stick" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
                                    <ComboBox x:Name="LegionJoystickAsMouseComboBox" Grid.Column="1"
                                              Width="120" HorizontalAlignment="Left"
                                              Style="{StaticResource ModernComboBoxStyle}">
                                        <ComboBoxItem Content="Disabled" Tag="0"/>
                                        <ComboBoxItem Content="Left Stick" Tag="1"/>
                                        <ComboBoxItem Content="Right Stick" Tag="2"/>
                                    </ComboBox>
                                </Grid>

                                <!-- Sensitivity (shown when not disabled) -->
                                <Grid x:Name="LegionJoystickMouseSensGrid" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Sensitivity" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Slider x:Name="LegionJoystickMouseSensSlider"
                                                Width="120" Minimum="10" Maximum="100" Value="50"
                                                Style="{StaticResource ModernSliderStyle}"/>
                                        <TextBlock x:Name="LegionJoystickMouseSensValue"
                                                   Text="50" Width="30" Margin="8,0,0,0"
                                                   VerticalAlignment="Center" Foreground="#AAAAAA"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Deadzones Card — hidden on MSI Claw (not used) -->
                        <Border Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Deadzones" Style="{StaticResource CardTitleStyle}" Grid.Column="0"/>
                                    <ToggleButton x:Name="StickDeadzonesExpandToggle"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="StickDeadzonesExpandToggle_Click">
                                        <FontIcon x:Name="StickDeadzonesExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>
                                <StackPanel x:Name="StickDeadzonesContent" Spacing="12" Margin="0,12,0,0" Visibility="Collapsed">
                                    <!-- Stick deadzone sliders moved to the MSI-Claw "Vibration & Deadzone"
                                         (ControllerFeedbackCard) above. This legacy card keeps only Trigger Travel
                                         and stays collapsed (not wired on MSI Claw). -->

                                    <!-- Trigger Travel Section -->
                                    <TextBlock Text="Trigger Travel" FontSize="12" Foreground="{StaticResource HintTextBrush}" Margin="0,16,0,4"/>

                                    <!-- Hair Triggers Toggle -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Hair Triggers" FontSize="13" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                        <ToggleSwitch x:Name="LegionHairTriggersToggle" Grid.Column="1" OnContent="" OffContent="" Margin="0,0,-8,0"/>
                                    </Grid>

                                    <!-- Left Trigger -->
                                    <StackPanel x:Name="LeftTriggerPanel">
                                        <TextBlock Text="Left Trigger" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="Dead Zone" FontSize="13" Foreground="#AAAAAA"/>
                                                <TextBlock x:Name="LegionLeftTriggerStartValue"
                                                           Text="0%"
                                                           Style="{StaticResource CardValueStyle}"/>
                                            </Grid>
                                            <Slider x:Name="LegionLeftTriggerStartSlider"
                                                    Style="{StaticResource ModernSliderStyle}"
                                                    Minimum="0" Maximum="50"
                                                    Value="0"
                                                    StepFrequency="1"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="Full Press" FontSize="13" Foreground="#AAAAAA"/>
                                                <TextBlock x:Name="LegionLeftTriggerEndValue"
                                                           Text="0%"
                                                           Style="{StaticResource CardValueStyle}"/>
                                            </Grid>
                                            <Slider x:Name="LegionLeftTriggerEndSlider"
                                                    Style="{StaticResource ModernSliderStyle}"
                                                    Minimum="0" Maximum="99"
                                                    Value="0"
                                                    StepFrequency="1"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Right Trigger -->
                                    <StackPanel x:Name="RightTriggerPanel">
                                        <TextBlock Text="Right Trigger" FontSize="12" Foreground="#666666" Margin="0,0,0,4"/>
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="Dead Zone" FontSize="13" Foreground="#AAAAAA"/>
                                                <TextBlock x:Name="LegionRightTriggerStartValue"
                                                           Text="0%"
                                                           Style="{StaticResource CardValueStyle}"/>
                                            </Grid>
                                            <Slider x:Name="LegionRightTriggerStartSlider"
                                                    Style="{StaticResource ModernSliderStyle}"
                                                    Minimum="0" Maximum="50"
                                                    Value="0"
                                                    StepFrequency="1"/>
                                        </StackPanel>
                                        <StackPanel>
                                            <Grid>
                                                <TextBlock Text="Full Press" FontSize="13" Foreground="#AAAAAA"/>
                                                <TextBlock x:Name="LegionRightTriggerEndValue"
                                                           Text="0%"
                                                           Style="{StaticResource CardValueStyle}"/>
                                            </Grid>
                                            <Slider x:Name="LegionRightTriggerEndSlider"
                                                    Style="{StaticResource ModernSliderStyle}"
                                                    Minimum="0" Maximum="99"
                                                    Value="0"
                                                    StepFrequency="1"/>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        </StackPanel>
                        <!-- End ControllerEditableContentPanel -->
                        </StackPanel>
                        <!-- End Controller Remapping Section -->

                        <!-- Saved Profiles Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Spacing="8" Grid.Column="0">
                                        <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE74E;" FontSize="16"
                                                  Foreground="{StaticResource ThemeAccentBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="Saved Controller Profiles" Style="{StaticResource CardTitleStyle}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="SavedProfilesExpandToggle"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="SavedProfilesExpandToggle_Click">
                                        <FontIcon x:Name="SavedProfilesExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>
                                <StackPanel x:Name="SavedProfilesContent" Spacing="8" Margin="0,12,0,0" Visibility="Collapsed">
                                    <!-- No profiles message -->
                                    <TextBlock x:Name="NoSavedProfilesText"
                                               Text="No saved game profiles"
                                               Foreground="#666666"
                                               FontSize="13"
                                               FontStyle="Italic"
                                               Visibility="Visible"/>

                                    <!-- Saved profiles list -->
                                    <ItemsControl x:Name="SavedProfilesList">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#2A2A2A" CornerRadius="6" Padding="12,8" Margin="0,4">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <!-- Game Icon -->
                                                        <Image Grid.Column="0"
                                                               Source="{Binding IconSource}"
                                                               Width="28" Height="28"
                                                               Margin="0,0,10,0"
                                                               Stretch="UniformToFill"
                                                               VerticalAlignment="Center"
                                                               Visibility="{Binding IconVisibility}"/>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding GameName}"
                                                                       Foreground="White"
                                                                       FontSize="14"
                                                                       FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding SettingsSummary}"
                                                                       Foreground="{StaticResource HintTextBrush}"
                                                                       FontSize="11"
                                                                       TextWrapping="NoWrap"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="2"
                                                                Background="Transparent"
                                                                Foreground="{StaticResource HintTextBrush}"
                                                                BorderThickness="0"
                                                                Padding="10,6"
                                                                VerticalAlignment="Center"
                                                                IsTabStop="True"
                                                                UseSystemFocusVisuals="True"
                                                                Tag="{Binding ProfileKey}"
                                                                Visibility="{Binding CanDelete}"
                                                                Click="DeleteSavedProfile_Click"
                                                                ToolTipService.ToolTip="Delete profile">
                                                            <FontIcon Glyph="&#xE74D;" FontSize="14"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Special Remapping Card (hidden) -->
                        <Border Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Special Remapping" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Map Legion L/R buttons and scroll wheel to custom actions"
                                                   Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="SpecialRemappingExpandButton"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="SpecialRemappingExpandButton_Click">
                                        <FontIcon x:Name="SpecialRemappingExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <StackPanel x:Name="SpecialRemappingContent" Visibility="Collapsed" Margin="0,12,0,0">
                                    <!-- Legion Buttons Section -->
                                    <TextBlock Text="LEGION BUTTONS" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource HintTextBrush}" Margin="0,0,0,8"/>

                                    <!-- Legion L Row -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="85"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Legion L:"
                                                   Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   FontSize="14"
                                                   Foreground="#E0E0E0"/>
                                        <ComboBox x:Name="LegionLActionComboBox"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernComboBoxStyle}">
                                            <ComboBoxItem Content="Disabled" IsSelected="True"/>
                                            <ComboBoxItem Content="Guide"/>
                                            <ComboBoxItem Content="Keyboard Shortcut"/>
                                            <ComboBoxItem Content="Run Command"/>
                                            <ComboBoxItem Content="Focus GoTweaks"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Legion L Shortcut Input (hidden by default) -->
                                    <StackPanel x:Name="LegionLShortcutPanel" Margin="85,8,0,0" Visibility="Collapsed" Orientation="Horizontal">
                                        <ItemsControl x:Name="LegionLKeyTags">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                        <Button x:Name="LegionLKeyPickerButton" Tag="LegionL" Width="90" Content="+ Key  &#x25BE;" Click="ExtraKeyPicker_Click" Style="{StaticResource KeyPickerButtonStyle}"/>
                                    </StackPanel>

                                    <!-- Legion L Command Input (hidden by default) -->
                                    <Grid x:Name="LegionLCommandGrid" Margin="85,8,0,0" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="LegionLCommandTextBox"
                                                 Grid.Column="0"
                                                 PlaceholderText="e.g. C:\path\app.exe -arg1"/>
                                        <Button x:Name="LegionLCommandApplyButton"
                                                Grid.Column="1"
                                                Content="Apply"
                                                Style="{StaticResource ModernButtonStyle}"
                                                Margin="8,0,0,0"
                                                Click="LegionLCommandApplyButton_Click"/>
                                    </Grid>

                                    <!-- Legion R Row -->
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="85"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Legion R:"
                                                   Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   FontSize="14"
                                                   Foreground="#E0E0E0"/>
                                        <ComboBox x:Name="LegionRActionComboBox"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernComboBoxStyle}">
                                            <ComboBoxItem Content="Disabled" IsSelected="True"/>
                                            <ComboBoxItem Content="Xbox Guide"/>
                                            <ComboBoxItem Content="Keyboard Shortcut"/>
                                            <ComboBoxItem Content="Run Command"/>
                                            <ComboBoxItem Content="Focus GoTweaks"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Legion R Shortcut Input (hidden by default) -->
                                    <StackPanel x:Name="LegionRShortcutPanel" Margin="85,8,0,0" Visibility="Collapsed" Orientation="Horizontal">
                                        <ItemsControl x:Name="LegionRKeyTags">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                        <Button x:Name="LegionRKeyPickerButton" Tag="LegionR" Width="90" Content="+ Key  &#x25BE;" Click="ExtraKeyPicker_Click" Style="{StaticResource KeyPickerButtonStyle}"/>
                                    </StackPanel>

                                    <!-- Legion R Command Input (hidden by default) -->
                                    <Grid x:Name="LegionRCommandGrid" Margin="85,8,0,0" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="LegionRCommandTextBox"
                                                 Grid.Column="0"
                                                 PlaceholderText="e.g. C:\path\app.exe -arg1"/>
                                        <Button x:Name="LegionRCommandApplyButton"
                                                Grid.Column="1"
                                                Content="Apply"
                                                Style="{StaticResource ModernButtonStyle}"
                                                Margin="8,0,0,0"
                                                Click="LegionRCommandApplyButton_Click"/>
                                    </Grid>

                                    <!-- Status Text for Legion buttons -->
                                    <TextBlock x:Name="LegionRemapStatusText"
                                               Text=""
                                               FontSize="12"
                                               Foreground="#A0A0A0"
                                               Margin="0,8,0,0"/>

                                    <!-- Scroll Wheel Section (hidden on devices without scroll wheel) -->
                                    <StackPanel x:Name="ScrollWheelSection">
                                        <!-- Divider -->
                                        <Border Background="#333333" Height="1" Margin="0,16,0,16"/>

                                        <!-- Scroll Wheel Header -->
                                        <TextBlock Text="SCROLL WHEEL" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource HintTextBrush}" Margin="0,0,0,8"/>

                                    <!-- Scroll Wheel Row (unified - direction not available) -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="85"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Scroll:"
                                                   Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   FontSize="14"
                                                   Foreground="#E0E0E0"/>
                                        <ComboBox x:Name="ScrollActionComboBox"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  SelectionChanged="ScrollActionComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Disabled" IsSelected="True"/>
                                            <ComboBoxItem Content="Xbox Guide"/>
                                            <ComboBoxItem Content="Keyboard Shortcut"/>
                                            <ComboBoxItem Content="Run Command"/>
                                            <ComboBoxItem Content="Focus GoTweaks"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Scroll Shortcut Input (hidden by default) -->
                                    <StackPanel x:Name="ScrollShortcutPanel" Margin="85,8,0,0" Visibility="Collapsed" Orientation="Horizontal">
                                        <ItemsControl x:Name="ScrollKeyTags">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                        <Button x:Name="ScrollKeyPickerButton" Tag="Scroll" Width="90" Content="+ Key  &#x25BE;" Click="ExtraKeyPicker_Click" Style="{StaticResource KeyPickerButtonStyle}"/>
                                    </StackPanel>

                                    <!-- Scroll Command Input (hidden by default) -->
                                    <Grid x:Name="ScrollCommandGrid" Margin="85,8,0,0" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ScrollCommandTextBox"
                                                 Grid.Column="0"
                                                 PlaceholderText="e.g. C:\path\app.exe -arg1"/>
                                        <Button x:Name="ScrollCommandApplyButton"
                                                Grid.Column="1"
                                                Content="Apply"
                                                Style="{StaticResource ModernButtonStyle}"
                                                Margin="8,0,0,0"
                                                Click="ScrollCommandApplyButton_Click"/>
                                    </Grid>

                                    <!-- Scroll Click Row -->
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="85"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Scroll Click:"
                                                   Grid.Column="0"
                                                   VerticalAlignment="Center"
                                                   FontSize="14"
                                                   Foreground="#E0E0E0"/>
                                        <ComboBox x:Name="ScrollClickActionComboBox"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  SelectionChanged="ScrollClickActionComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Disabled" IsSelected="True"/>
                                            <ComboBoxItem Content="Xbox Guide"/>
                                            <ComboBoxItem Content="Keyboard Shortcut"/>
                                            <ComboBoxItem Content="Run Command"/>
                                            <ComboBoxItem Content="Focus GoTweaks"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Scroll Click Shortcut Input (hidden by default) -->
                                    <StackPanel x:Name="ScrollClickShortcutPanel" Margin="85,8,0,0" Visibility="Collapsed" Orientation="Horizontal">
                                        <ItemsControl x:Name="ScrollClickKeyTags">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                        </ItemsControl>
                                        <Button x:Name="ScrollClickKeyPickerButton" Tag="ScrollClick" Width="90" Content="+ Key  &#x25BE;" Click="ExtraKeyPicker_Click" Style="{StaticResource KeyPickerButtonStyle}"/>
                                    </StackPanel>

                                    <!-- Scroll Click Command Input (hidden by default) -->
                                    <Grid x:Name="ScrollClickCommandGrid" Margin="85,8,0,0" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="ScrollClickCommandTextBox"
                                                 Grid.Column="0"
                                                 PlaceholderText="e.g. C:\path\app.exe -arg1"/>
                                        <Button x:Name="ScrollClickCommandApplyButton"
                                                Grid.Column="1"
                                                Content="Apply"
                                                Style="{StaticResource ModernButtonStyle}"
                                                Margin="8,0,0,0"
                                                Click="ScrollClickCommandApplyButton_Click"/>
                                    </Grid>

                                        <!-- Status Text for Scroll wheel -->
                                        <TextBlock x:Name="ScrollRemapStatusText"
                                                   Text=""
                                                   FontSize="12"
                                                   Foreground="#A0A0A0"
                                                   Margin="0,8,0,0"/>
                                    </StackPanel>

                                    <!-- ViGEmBus Note -->
                                    <Border Background="#1A1A2E" CornerRadius="4" Padding="10" Margin="0,16,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Xbox Guide remap requires ViGEmBus driver"
                                                       FontSize="11" Foreground="#AAAAAA" TextWrapping="Wrap"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <TextBlock x:Name="ViGEmBusStatusText" Text="Status: Checking..."
                                                           FontSize="11" Foreground="{StaticResource HintTextBrush}" VerticalAlignment="Center"/>
                                                <Button x:Name="ViGEmBusInstallButton" Content="Install ViGEmBus"
                                                        Style="{StaticResource ModernButtonStyle}"
                                                        FontSize="11" Padding="10,4" Margin="12,0,0,0"
                                                        Click="ViGEmBusInstallButton_Click"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Lighting Section — REMOVED from the Controller tab (duplicate of the System
                             tab's "Controller LED Color"). Kept hidden (not deleted) because ~17 files
                             reference its named controls; SetLightingSectionVisibility() forces it off. -->
                        <StackPanel x:Name="LightingSection" Visibility="Collapsed">
                        <!-- Lighting Section Header -->
                        <TextBlock Text="LIGHTING" Style="{StaticResource SectionHeaderStyle}"/>

                        <!-- Lighting Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Lighting" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Controller RGB and power button lighting"
                                                   Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="LightingExpandToggle"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="LightingExpandToggle_Click">
                                        <FontIcon x:Name="LightingExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>
                                <StackPanel x:Name="LightingContent" Spacing="12" Margin="0,12,0,0" Visibility="Collapsed">
                                    <!-- Light Mode -->
                                    <StackPanel>
                                        <TextBlock Text="Light Mode" FontSize="13" Foreground="#AAAAAA" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="LegionLightModeComboBox"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  HorizontalAlignment="Stretch"
                                                  SelectedIndex="1"
                                                  SelectionChanged="LegionLightModeComboBox_SelectionChanged">
                                            <x:String>Off</x:String>
                                            <x:String>Solid</x:String>
                                            <x:String>Pulse</x:String>
                                            <x:String>Dynamic</x:String>
                                            <x:String>Spiral</x:String>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- Light Color (Solid, Pulse only) -->
                                    <StackPanel x:Name="LegionColorCard">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Light Color" Grid.Column="0" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="13"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border x:Name="LegionColorPreview"
                                                        Width="24" Height="24"
                                                        CornerRadius="4"
                                                        Background="White"
                                                        BorderBrush="#50555C"
                                                        BorderThickness="1"
                                                        Margin="0,0,8,0"/>
                                                <Button x:Name="LegionColorExpandButton"
                                                        Content="&#xE70D;"
                                                        FontFamily="Segoe MDL2 Assets"
                                                        FontSize="12"
                                                        Padding="8,4"
                                                        Background="Transparent"
                                                        Click="LegionColorExpandButton_Click"
                                                        UseSystemFocusVisuals="True"
                                                        FocusVisualPrimaryBrush="White"/>
                                            </StackPanel>
                                        </Grid>
                                        <muxc:ColorPicker x:Name="LegionColorPicker"
                                                     Visibility="Collapsed"
                                                     Margin="0,12,0,0"
                                                     Color="White"
                                                     ColorSpectrumShape="Box"
                                                     IsMoreButtonVisible="False"
                                                     IsColorSliderVisible="False"
                                                     IsColorChannelTextInputVisible="False"
                                                     IsHexInputVisible="False"
                                                     IsAlphaEnabled="False"
                                                     IsAlphaSliderVisible="False"
                                                     IsAlphaTextInputVisible="False"
                                                     ColorChanged="LegionColorPicker_ColorChanged"/>
                                    </StackPanel>

                                    <!-- Brightness (all modes except Off) -->
                                    <StackPanel x:Name="LegionBrightnessCard">
                                        <Grid>
                                            <TextBlock Text="Brightness" FontSize="13" Foreground="#AAAAAA"/>
                                            <TextBlock x:Name="LegionBrightnessValue"
                                                       Text="100%"
                                                       Style="{StaticResource CardValueStyle}"/>
                                        </Grid>
                                        <Slider x:Name="LegionBrightnessSlider"
                                                Style="{StaticResource ModernSliderStyle}"
                                                Minimum="0" Maximum="100"
                                                Value="100"
                                                ValueChanged="LegionBrightnessSlider_ValueChanged"/>
                                    </StackPanel>

                                    <!-- Speed (Pulse, Dynamic, Spiral only) -->
                                    <StackPanel x:Name="LegionSpeedCard" Visibility="Collapsed">
                                        <Grid>
                                            <TextBlock Text="Speed" FontSize="13" Foreground="#AAAAAA"/>
                                            <TextBlock x:Name="LegionSpeedValue"
                                                       Text="50%"
                                                       Style="{StaticResource CardValueStyle}"/>
                                        </Grid>
                                        <Slider x:Name="LegionSpeedSlider"
                                                Style="{StaticResource ModernSliderStyle}"
                                                Minimum="0" Maximum="100"
                                                Value="50"
                                                ValueChanged="LegionSpeedSlider_ValueChanged"/>
                                    </StackPanel>

                                    <!-- Power Light Toggle -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Power Light" Grid.Column="0" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
                                        <ToggleSwitch x:Name="LegionPowerLightToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      IsOn="True"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        </StackPanel>
                        <!-- End Lighting Section -->

                        <!-- Performance Mode section hidden: duplicate of Performance tab -->
                        <StackPanel Visibility="Collapsed">
                        <TextBlock Text="PERFORMANCE MODE" Style="{StaticResource SectionHeaderStyle}"/>
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Power Profile" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Controls TDP and thermal limits"
                                               Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ComboBox x:Name="LegionPerformanceModeComboBox"
                                          Width="140"
                                          Grid.Column="1"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectedIndex="1"
                                          SelectionChanged="LegionPerformanceModeComboBox_SelectionChanged"
                                          XYFocusDown="{x:Bind LegionCustomTDPSlowSlider}">
                                    <ComboBoxItem Content="Quiet" Tag="1"/>
                                    <ComboBoxItem Content="Balanced" Tag="2"/>
                                    <ComboBoxItem Content="Performance" Tag="3"/>
                                    <ComboBoxItem Content="Slider" Tag="255"/>
                                </ComboBox>
                            </Grid>
                        </Border>
                        <StackPanel x:Name="LegionCustomTDPCard" Visibility="Collapsed">
                            <!-- Slow TDP (SPL) Card -->
                            <Border x:Name="LegionCustomTDPSlowCard" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="Slow TDP (SPL)"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="LegionCustomTDPSlowValue"
                                                   Text="15W"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="LegionCustomTDPSlowSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="5" Maximum="45"
                                            Value="15"
                                            Margin="0,4,0,0"
                                            ValueChanged="LegionCustomTDPSlider_ValueChanged"
                                            XYFocusUp="{x:Bind LegionPerformanceModeComboBox}"
                                            XYFocusDown="{x:Bind LegionCustomTDPFastSlider}"/>
                                </StackPanel>
                            </Border>

                            <!-- Fast TDP (SPPL) Card -->
                            <Border x:Name="LegionCustomTDPFastCard" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="Fast TDP (SPPL)"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="LegionCustomTDPFastValue"
                                                   Text="25W"
                                                   FontSize="14"
                                                   Foreground="#FFA500"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="LegionCustomTDPFastSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="5" Maximum="55"
                                            Value="25"
                                            Margin="0,4,0,0"
                                            ValueChanged="LegionCustomTDPSlider_ValueChanged"
                                            XYFocusUp="{x:Bind LegionCustomTDPSlowSlider}"
                                            XYFocusDown="{x:Bind LegionCustomTDPPeakSlider}"/>
                                </StackPanel>
                            </Border>

                            <!-- Peak TDP (FPPT) Card -->
                            <Border x:Name="LegionCustomTDPPeakCard" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="Peak TDP (FPPT)"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="LegionCustomTDPPeakValue"
                                                   Text="35W"
                                                   FontSize="14"
                                                   Foreground="#FF6B6B"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="LegionCustomTDPPeakSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="5" Maximum="65"
                                            Value="35"
                                            Margin="0,4,0,0"
                                            ValueChanged="LegionCustomTDPSlider_ValueChanged"
                                            XYFocusUp="{x:Bind LegionCustomTDPFastSlider}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        </StackPanel>
                        <!-- End hidden Performance Mode section -->

                        <!-- ── HW Controller Exception (per-game, MSI Claw) — bottom of Controller tab ──
                             Visible only while controller emulation is enabled AND a game is running
                             (gated in code-behind via UpdateHwControllerExceptionVisibility). When on,
                             the running game uses the native HW controller instead of the virtual
                             Viiper/ViGEm pad — fixes a few titles (e.g. NBA 2K26) that choke on the
                             Viiper usbip controller. The swap is applied at the next game start. -->
                        <Border x:Name="HwControllerExceptionCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock x:Name="HwControllerExceptionTitle" Text="Use Hardware Controller for this Game" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock x:Name="HwControllerExceptionSubtitle"
                                                   Text="Override the standard controller mode for this game only. Helps with titles that have issues with the virtual controller (e.g. NBA 2K26)."
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   Foreground="#C8C8C8"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="HwControllerExceptionToggle"
                                                  Grid.Column="1"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Right"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsOn="False"
                                                  Toggled="HwControllerExceptionToggle_Toggled"/>
                                </Grid>
                                <TextBlock x:Name="HwControllerExceptionHint"
                                           Text="Close and restart the game to apply — the controller is only swapped at game start."
                                           Style="{StaticResource CardCaptionStyle}"
                                           Foreground="#FFAA46"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0"
                                           Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                        <!-- ── Controller Status (read-only diagnostic, bottom of Controller tab) ──
                             Mirrors Diagnostics\Get-ControllerState.ps1. The elevated helper inspects
                             ViGEm + HidHide + MSI Claw PnP live and reports one of two main states.
                             Replaces the old device-info card (its x:Names live as stubs below). -->
                        <Border x:Name="ControllerStateCard" Style="{StaticResource CardStyle}" Visibility="Visible">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Controller Status" Style="{StaticResource CardTitleStyle}" Grid.Column="0"/>
                                    <Button x:Name="ControllerStateRefreshButton"
                                            Grid.Column="1"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            Padding="8,4"
                                            VerticalAlignment="Center"
                                            ToolTipService.ToolTip="Refresh"
                                            Click="ControllerStateRefreshButton_Click">
                                        <FontIcon Glyph="&#xE72C;" FontSize="14"/>
                                    </Button>
                                    <ToggleButton x:Name="ControllerStateDetailsToggle"
                                                  Grid.Column="2"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="ControllerStateDetailsToggle_Click">
                                        <FontIcon x:Name="ControllerStateDetailsIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <!-- Main status row: colored dot + state text -->
                                <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,12,0,0" VerticalAlignment="Center">
                                    <Ellipse x:Name="ControllerStateDot" Width="12" Height="12" Fill="#666666" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ControllerStateText"
                                               Text="Status unknown"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="#E0E0E0"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="ControllerStateCaption"
                                           Text="Tap Refresh to check the current state."
                                           Style="{StaticResource CardCaptionStyle}"
                                           TextWrapping="Wrap"
                                           Margin="22,4,0,0"/>


                                <!-- Details (collapsed by default) -->
                                <StackPanel x:Name="ControllerStateDetailsPanel" Spacing="8" Margin="0,14,0,0" Visibility="Collapsed">
                                    <!-- Console-style controller list -->
                                    <Border Background="#0D0D0D"
                                            BorderBrush="#333333"
                                            BorderThickness="1"
                                            CornerRadius="4"
                                            Padding="10,8"
                                            Margin="0,4,0,0">
                                        <StackPanel Spacing="2">
                                            <TextBlock Text="CONNECTED CONTROLLERS"
                                                       FontFamily="Consolas, Courier New"
                                                       FontSize="10"
                                                       Foreground="#555555"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock x:Name="ControllerListConsole"
                                                       Text="scanning..."
                                                       FontFamily="Consolas, Courier New"
                                                       FontSize="11"
                                                       Foreground="#DDDDDD"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                    <Grid>
                                        <TextBlock Text="Virtual ViGEm controller" FontSize="13" Foreground="#AAAAAA"/>
                                        <TextBlock x:Name="ControllerStateViGEmValue" Text="–" Style="{StaticResource CardValueStyle}"/>
                                    </Grid>
                                    <Grid>
                                        <TextBlock Text="Virtual VIIPER controller" FontSize="13" Foreground="#AAAAAA"/>
                                        <TextBlock x:Name="ControllerStateViiperValue" Text="–" Style="{StaticResource CardValueStyle}"/>
                                    </Grid>
                                    <Grid>
                                        <TextBlock Text="Game controllers" FontSize="13" Foreground="#AAAAAA"/>
                                        <TextBlock x:Name="ControllerStatePid1901Value" Text="–" Style="{StaticResource CardValueStyle}"/>
                                    </Grid>
                                    <Grid>
                                        <TextBlock Text="MSI Claw DInput (PID_1902)" FontSize="13" Foreground="#AAAAAA"/>
                                        <TextBlock x:Name="ControllerStatePid1902Value" Text="–" Style="{StaticResource CardValueStyle}"/>
                                    </Grid>
                                    <Grid>
                                        <TextBlock Text="HidHide blocked devices" FontSize="13" Foreground="#AAAAAA"/>
                                        <TextBlock x:Name="ControllerStateBlockedValue" Text="–" Style="{StaticResource CardValueStyle}"/>
                                    </Grid>
                                    <Grid>
                                        <TextBlock Text="XInput slots connected" FontSize="13" Foreground="#AAAAAA"/>
                                        <TextBlock x:Name="ControllerStateXInputValue" Text="–" Style="{StaticResource CardValueStyle}"/>
                                    </Grid>

                                <!-- VIIPER device picker (relocated here from the Controller Emulation card).
                                     On the MSI Claw only the virtual device TYPE is functional: VIIPER is fed
                                     from ClawButtonMonitor's submit point, so the GoTweaks forwarder settings
                                     (input/gyro source, IMU axis map, gyro→stick) don't apply and stay hidden in
                                     the (now never-shown) ViiperEmulationContent. Shown only while VIIPER is the
                                     active backend; placed at the bottom of the controller-status card. -->
                                <StackPanel x:Name="ViiperDeviceConfigPanel" Visibility="Collapsed" Margin="0,14,0,0">
                                    <Border Background="#1E2A3E" BorderBrush="#3D5A80" BorderThickness="1" CornerRadius="6" Padding="12">
                                        <StackPanel>
                                            <TextBlock Text="VIIPER Device" FontSize="13" FontWeight="SemiBold" Foreground="#4AB3F4"/>
                                            <TextBlock Text="Active backend: VIIPER (USBIP). Changes take effect immediately (hot-swap). Note: any virtual device other than Xbox 360 can cause problems due to Game Bar incompatibilities — please test it and report back with feedback." FontSize="11" Foreground="{StaticResource HintTextBrush}" Margin="0,2,0,10" TextWrapping="Wrap"/>

                                            <TextBlock Text="Virtual device" FontSize="12" Foreground="#CCCCCC" Margin="0,0,0,4"/>
                                            <ComboBox x:Name="ViiperDeviceTypeComboBox" HorizontalAlignment="Stretch">
                                                <ComboBoxItem Content="Xbox 360" Tag="xbox360"/>
                                                <ComboBoxItem Content="DualShock 4" Tag="dualshock4"/>
                                                <ComboBoxItem Content="DualSense Edge" Tag="dualsenseedge"/>
                                                <ComboBoxItem Content="Xbox Elite 2" Tag="xboxelite2"/>
                                                <ComboBoxItem Content="Steam Controller" Tag="steam-generic"/>
                                                <ComboBoxItem Content="Switch Pro" Tag="switchpro"/>
                                            </ComboBox>

                                            <StackPanel x:Name="ViiperSteamSubDevicePanel" Visibility="Collapsed" Margin="0,12,0,0">
                                                <TextBlock Text="Steam sub-device" FontSize="12" Foreground="#CCCCCC" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="ViiperSteamSubDeviceComboBox" HorizontalAlignment="Stretch">
                                                    <ComboBoxItem Content="Generic" Tag="generic"/>
                                                    <ComboBoxItem Content="Steam Deck" Tag="steam-deck"/>
                                                    <ComboBoxItem Content="Legion Go" Tag="legion-go"/>
                                                    <ComboBoxItem Content="Legion Go S" Tag="legion-go-s"/>
                                                    <ComboBoxItem Content="Legion Go 2" Tag="legion-go-2"/>
                                                    <ComboBoxItem Content="ROG Ally" Tag="rog-ally"/>
                                                    <ComboBoxItem Content="MSI Claw" Tag="msi-claw"/>
                                                    <ComboBoxItem Content="Zotac Zone" Tag="zotac-zone"/>
                                                </ComboBox>
                                            </StackPanel>

                                            <!-- Experimental: auto-swap a non-Xbox device to xbox360 while the Game Bar is open.
                                                 Relocated here from the (Claw-hidden) ViiperEmulationContent panel so it is
                                                 actually reachable; property wiring (viiperGameBarAutoXboxSwap) is unchanged. -->
                                            <Grid Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="Auto-switch to Xbox in Game Bar (experimental)"
                                                               FontSize="13"
                                                               Foreground="#CCCCCC"/>
                                                    <TextBlock Text="When a non-Xbox device (e.g. DualShock 4) is emulated, temporarily present it as an Xbox 360 pad while the Game Bar is open so the overlay navigates cleanly (some pads spam the right trigger). Swaps back on close. Briefly disconnects the virtual controller — a running game may notice."
                                                               FontSize="11"
                                                               Foreground="{StaticResource HintTextBrush}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>
                                                <ToggleSwitch x:Name="ViiperGameBarAutoXboxSwapToggle"
                                                              Grid.Column="1"
                                                              VerticalAlignment="Center"
                                                              Style="{StaticResource ModernToggleStyle}"
                                                              IsOn="False"/>
                                            </Grid>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                                </StackPanel>

                                <!-- Firmware keyboard-remap backend toggle (MSI Claw A2VM only; shown via
                                     DeviceSupportsFirmwareKeyboardRemap capability). Always visible at the
                                     bottom of the card (outside the collapsed details), per plan. -->
                                <StackPanel x:Name="FwKeyboardRemapPanel" Visibility="Collapsed" Margin="0,14,0,0">
                                    <Border Background="#1E2A3E" BorderBrush="#3D5A80" BorderThickness="1" CornerRadius="6" Padding="12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Keyboard remaps via firmware (works in games)"
                                                           FontSize="13" FontWeight="SemiBold" Foreground="#4AB3F4"/>
                                                <TextBlock Text="Firmware key remaps run entirely on the controller hardware, so they work reliably — including inside games. When off, keystrokes are generated virtually (software), which can stop in-game shortcuts from working; turn this on to use the firmware remaps instead. MSI Claw 8/7 AI+ (A2VM) only."
                                                           FontSize="11" Foreground="{StaticResource HintTextBrush}"
                                                           TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <ToggleSwitch x:Name="MsiClawFwKeyboardModeToggle"
                                                          Grid.Column="1"
                                                          VerticalAlignment="Center"
                                                          Style="{StaticResource ModernToggleStyle}"
                                                          IsOn="False"/>
                                        </Grid>
                                    </Border>

                                    <!-- Live firmware button→key readout (reads the controller EEPROM on demand). -->
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Show current firmware keyboard mappings" VerticalAlignment="Center"
                                                   FontSize="12" FontWeight="SemiBold" Foreground="#DDDDDD" TextWrapping="Wrap"/>
                                        <Button Grid.Column="1" Content="Re-read firmware" Style="{StaticResource ModernButtonStyle}"
                                                FontSize="11" Padding="10,4" Click="FwButtonMapRefresh_Click"/>
                                    </Grid>
                                    <TextBlock x:Name="FwButtonMapText" Text="Tap Refresh to read the controller."
                                               FontFamily="Consolas, Courier New" FontSize="11"
                                               Foreground="#BBBBBB" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- GPD TAB -->
                <ScrollViewer x:Name="GPDScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Device Status Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock x:Name="GPDDeviceNameText" Text="GPD Device" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock x:Name="GPDConnectionStatusText"
                                           Text="Detecting..."
                                           FontSize="14"
                                           Foreground="{StaticResource HintTextBrush}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Fan Control Card (Win 5 specific) -->
                        <StackPanel x:Name="GPDFanControlSection" Visibility="Collapsed">
                            <TextBlock Text="FAN CONTROL" Style="{StaticResource SectionHeaderStyle}"/>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <!-- Header: Fan Settings + RPM -->
                                    <TextBlock Text="Fan Settings" Style="{StaticResource CardTitleStyle}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Fan: " Style="{StaticResource CardCaptionStyle}"/>
                                        <TextBlock x:Name="GPDFanRPMText" Text="-- RPM" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>

                                    <!-- Fan Curve Toggle -->
                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Fan Curve" Foreground="#FFFFFF" FontSize="14"/>
                                            <TextBlock Text="Software-controlled fan curve based on CPU temperature"
                                                       FontSize="12" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="GPDFanCurveToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      IsOn="False"
                                                      Toggled="GPDFanCurveToggle_Toggled"
                                                      XYFocusUp="{x:Bind GPDNavItem}"/>
                                    </Grid>

                                    <!-- Manual Fan Controls (visible when curve OFF) -->
                                    <StackPanel x:Name="GPDManualFanContent">
                                        <!-- Fan Mode Toggle -->
                                        <Grid Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Fan Mode" Foreground="#FFFFFF" FontSize="14"/>
                                                <TextBlock x:Name="GPDFanModeText"
                                                           Text="Auto"
                                                           FontSize="12"
                                                           Foreground="{StaticResource HintTextBrush}"/>
                                            </StackPanel>
                                            <ToggleSwitch x:Name="GPDFanModeToggle"
                                                          Grid.Column="1"
                                                          Style="{StaticResource ModernToggleStyle}"
                                                          IsOn="False"
                                                          Toggled="GPDFanModeToggle_Toggled"/>
                                        </Grid>

                                        <!-- Fan Speed Slider (visible only in manual mode) -->
                                        <StackPanel x:Name="GPDFanSpeedSection" Margin="0,16,0,0" Visibility="Collapsed">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Fan Speed" Grid.Column="0" Foreground="#FFFFFF" FontSize="14" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="GPDFanSpeedValueText"
                                                           Grid.Column="1"
                                                           Text="50%"
                                                           FontSize="14"
                                                           Foreground="#00C8FF"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                            <Slider x:Name="GPDFanSpeedSlider"
                                                    Style="{StaticResource ModernSliderStyle}"
                                                    Minimum="30"
                                                    Maximum="100"
                                                    Value="50"
                                                    ValueChanged="GPDFanSpeedSlider_ValueChanged"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Fan Curve Content (visible when curve ON) -->
                                    <StackPanel x:Name="GPDFanCurveContent" Visibility="Collapsed">
                                        <!-- Preset + Expand toggle row -->
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="GPDFanCurvePresetComboBox"
                                                      Grid.Column="0"
                                                      Width="130"
                                                      HorizontalAlignment="Left"
                                                      SelectionChanged="GPDFanCurvePresetComboBox_SelectionChanged">
                                                <ComboBoxItem Content="Silent" Tag="Silent"/>
                                                <ComboBoxItem Content="Balanced" Tag="Balanced"/>
                                                <ComboBoxItem Content="Performance" Tag="Performance"/>
                                                <ComboBoxItem Content="Max Cooling" Tag="MaxCooling"/>
                                                <ComboBoxItem Content="Custom" Tag="Custom" IsSelected="True"/>
                                            </ComboBox>
                                            <ToggleButton x:Name="GPDFanCurveExpandToggle"
                                                          Grid.Column="1"
                                                          IsChecked="False"
                                                          VerticalAlignment="Center"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Padding="8,4"
                                                          Click="GPDFanCurveExpandToggle_Click">
                                                <FontIcon x:Name="GPDFanCurveExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                            </ToggleButton>
                                        </Grid>

                                        <!-- Expandable graph content -->
                                        <StackPanel x:Name="GPDFanCurveGraphContent" Margin="0,12,0,0" Visibility="Collapsed">
                                            <!-- Y-axis label -->
                                            <TextBlock Text="Fan %" FontSize="11" Foreground="#999999" Margin="0,0,0,4"/>

                                            <!-- Graph area -->
                                            <Grid Height="150">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="30"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Y-axis labels -->
                                                <StackPanel Grid.Column="0" VerticalAlignment="Stretch">
                                                    <TextBlock Text="100" FontSize="10" Foreground="#666666" VerticalAlignment="Top"/>
                                                    <TextBlock Text="75" FontSize="10" Foreground="#666666" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                                    <TextBlock Text="50" FontSize="10" Foreground="#666666" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                                    <TextBlock Text="25" FontSize="10" Foreground="#666666" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                                    <TextBlock Text="0" FontSize="10" Foreground="#666666" VerticalAlignment="Bottom"/>
                                                </StackPanel>

                                                <!-- Canvas for drawing the graph -->
                                                <Canvas x:Name="GPDFanCurveCanvas"
                                                        Grid.Column="1"
                                                        Background="#1A1A1A"
                                                        PointerPressed="GPDFanCurveCanvas_PointerPressed"
                                                        PointerMoved="GPDFanCurveCanvas_PointerMoved"
                                                        PointerReleased="GPDFanCurveCanvas_PointerReleased"
                                                        PointerCaptureLost="GPDFanCurveCanvas_PointerReleased"
                                                        SizeChanged="GPDFanCurveCanvas_SizeChanged">

                                                    <!-- Fill under the curve -->
                                                    <Polygon x:Name="GPDFanCurveFill"
                                                             Fill="#3300AAFF"
                                                             Stroke="Transparent"/>

                                                    <!-- The curve line -->
                                                    <Polyline x:Name="GPDFanCurvePolyline"
                                                              Stroke="#00AAFF"
                                                              StrokeThickness="2"
                                                              StrokeLineJoin="Round"/>

                                                    <!-- Temperature indicator line (vertical dashed orange) -->
                                                    <Line x:Name="GPDTempIndicatorLine"
                                                          Y1="0" Y2="150"
                                                          Stroke="#FF8800"
                                                          StrokeThickness="2"
                                                          StrokeDashArray="4,2"
                                                          Visibility="Collapsed"/>

                                                    <!-- Control points created in code-behind -->
                                                </Canvas>
                                            </Grid>

                                            <!-- X-axis labels (30°C to 100°C) -->
                                            <Grid Margin="30,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="30°C" FontSize="10" Foreground="#666666" HorizontalAlignment="Left"/>
                                                <TextBlock Grid.Column="1" Text="46°C" FontSize="10" Foreground="#666666" HorizontalAlignment="Left"/>
                                                <TextBlock Grid.Column="2" Text="62°C" FontSize="10" Foreground="#666666" HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="3" Text="78°C" FontSize="10" Foreground="#666666" HorizontalAlignment="Right"/>
                                                <TextBlock Grid.Column="4" Text="100°C" FontSize="10" Foreground="#666666" HorizontalAlignment="Right"/>
                                            </Grid>

                                            <!-- Current CPU temperature display -->
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Center">
                                                <TextBlock Text="CPU Temp: " FontSize="12" Foreground="#999999"/>
                                                <TextBlock x:Name="GPDCurrentTempLabel" Text="--°C" FontSize="12" Foreground="#FF8800" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Button Remapping Section (Win 5 specific) -->
                        <StackPanel x:Name="GPDButtonRemapSection" Visibility="Collapsed">
                            <TextBlock Text="BUTTON REMAPPING" Style="{StaticResource SectionHeaderStyle}"/>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Button Remapping" Style="{StaticResource CardTitleStyle}"/>
                                            <TextBlock Text="Remap controller buttons to keyboard or mouse"
                                                       Style="{StaticResource CardCaptionStyle}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="GPDButtonRemapExpandToggle"
                                                      Grid.Column="1"
                                                      IsChecked="False"
                                                      VerticalAlignment="Center"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      Padding="8,4"
                                                      Click="GPDButtonRemapExpandToggle_Click">
                                            <FontIcon x:Name="GPDButtonRemapExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                        </ToggleButton>
                                    </Grid>

                                    <StackPanel x:Name="GPDButtonRemapContent" Spacing="8" Margin="0,12,0,0" Visibility="Collapsed">

                                        <!-- Face Buttons -->
                                        <TextBlock Text="Face Buttons" Foreground="#FFFFFF" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="A" Grid.Column="0" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
