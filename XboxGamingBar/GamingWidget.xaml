                        <!-- Program Actions + URL Actions were moved up into the "Customize Tiles and
                             Hotkeys" panel (Quick Settings tab), just above "Show Metrics Row". -->

                        <!-- Debug Card (Collapsible) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header with Expand/Collapse -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Debug" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Troubleshooting and diagnostic tools"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="DebugExpandButton"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="DebugExpandButton_Click">
                                        <FontIcon x:Name="DebugExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <!-- Collapsible Content -->
                                <StackPanel x:Name="DebugContent" Visibility="Collapsed" Margin="0,12,0,0">
                                    <!-- Theme selector moved to the top of the System tab (Appearance card) -->

                                    <!-- Restart Helper / Kill GoTweaks Buttons (side by side) -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="RestartHelperButton"
                                                Grid.Column="0"
                                                Content="Restart Helper"
                                                HorizontalAlignment="Stretch"
                                                Style="{StaticResource StandaloneButtonStyle}"
                                                Click="RestartHelperButton_Click"/>
                                        <Button x:Name="KillGoTweaksButton"
                                                Grid.Column="2"
                                                Content="Kill ClawTweaks"
                                                HorizontalAlignment="Stretch"
                                                Style="{StaticResource StandaloneButtonStyle}"
                                                Click="KillGoTweaksButton_Click"/>
                                    </Grid>

                                    <!-- Export Logs Button -->
                                    <Button x:Name="ExportLogsButton"
                                            Content="Export Logs"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,8,0,0"
                                            Style="{StaticResource StandaloneButtonStyle}"
                                            Click="ExportLogsButton_Click"/>

                                    <!-- Check for Update Button -->
                                    <Button x:Name="CheckForUpdateButton"
                                            Content="Check for Update (Coming Soon)"
                                            IsEnabled="False"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,8,0,0"
                                            Style="{StaticResource StandaloneButtonStyle}"
                                            Click="CheckForUpdateButton_Click"/>

                                    <!-- GoTweaks self-update preferences. Shared with the
                                         Quick-tab update banner: the helper's startup
                                         probe is gated by "Check for updates on start",
                                         and the banner is hidden when "Hide banner" is
                                         on. Persisted per-user in LocalSettings. -->
                                    <CheckBox x:Name="GoTweaksUpdateOnStartCheckbox"
                                              Content="Check for updates on start (Coming Soon)"
                                              IsChecked="False"
                                              IsEnabled="False"
                                              FontSize="12"
                                              Foreground="#AAAAAA"
                                              Margin="0,8,0,0"
                                              Checked="GoTweaksUpdateOnStartCheckbox_Changed"
                                              Unchecked="GoTweaksUpdateOnStartCheckbox_Changed"/>
                                    <CheckBox x:Name="GoTweaksHideBannerCheckbox"
                                              Content="Hide ClawTweaks update banner on Quick tab"
                                              IsChecked="False"
                                              IsEnabled="False"
                                              FontSize="12"
                                              Foreground="#AAAAAA"
                                              Checked="GoTweaksHideBannerCheckbox_Changed"
                                              Unchecked="GoTweaksHideBannerCheckbox_Changed"/>

                                    <!-- Export Default Game Profiles Button -->
                                    <Button x:Name="ExportDGPsButton"
                                            Content="Export DGPs (Coming Soon)"
                                            IsEnabled="False"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,8,0,0"
                                            Style="{StaticResource StandaloneButtonStyle}"
                                            Click="ExportDGPsButton_Click"/>

                                    <!-- Export/Import All Data Buttons (side by side) -->
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Button x:Name="ExportAllDataButton"
                                                Grid.Column="0"
                                                Content="Export All Data (Coming Soon)"
                                                IsEnabled="False"
                                                HorizontalAlignment="Stretch"
                                                Style="{StaticResource StandaloneButtonStyle}"
                                                Click="ExportAllDataButton_Click"/>
                                        <Button x:Name="ImportAllDataButton"
                                                Grid.Column="2"
                                                Content="Import All Data (Coming Soon)"
                                                IsEnabled="False"
                                                HorizontalAlignment="Stretch"
                                                Style="{StaticResource StandaloneButtonStyle}"
                                                Click="ImportAllDataButton_Click"/>
                                    </Grid>

                                    <!-- Prepare for Uninstall Button — hidden for now -->
                                    <Button x:Name="PrepareForUninstallButton"
                                            Content="Prepare for Uninstall"
                                            Visibility="Collapsed"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,8,0,0"
                                            Style="{StaticResource StandaloneButtonStyle}"
                                            Click="PrepareForUninstallButton_Click"/>

                                    <!-- Enable Debug Tools Toggle -->
                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Enable Debug Tools" FontSize="14" Foreground="#FF6B6B"/>
                                            <TextBlock Text="Enables Debug log level + PawnIO diagnostic tools" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="EnableDebugToolsToggle"
                                                      Grid.Column="1"
                                                      OnContent="" OffContent=""
                                                      IsOn="False"
                                                      Toggled="EnableDebugToolsToggle_Toggled"/>
                                    </Grid>

                                    <!-- VIIPER Emulation Backend Toggle (experimental — debug menu only) -->
                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="Use VIIPER emulation (recommended)" FontSize="14" Foreground="#FFC107"/>
                                            </StackPanel>
                                            <TextBlock Text="Replaces the legacy ViGEm controller emulation with VIIPER (USBIP-based). Requires usbip-win2. Toggling restarts controller emulation." FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap"/>
                                            <TextBlock x:Name="UsbipPrereqStatusLine"
                                                       FontSize="11"
                                                       Margin="0,4,0,0"
                                                       Foreground="{StaticResource HintTextBrush}"
                                                       Text="usbip-win2 driver: checking..."/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="ViiperEmulationToggle"
                                                      Grid.Column="1"
                                                      OnContent="" OffContent=""
                                                      IsOn="False"/>
                                    </Grid>

                                    <!-- USBIP prerequisite card, visible only when VIIPER toggle is on and usbip-win2 is not installed -->
                                    <Border x:Name="UsbipInstallCard"
                                            Visibility="Collapsed"
                                            Background="#3A2A10"
                                            BorderBrush="#FFC107"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="12"
                                            Margin="0,8,0,0">
                                        <StackPanel>
                                            <TextBlock Text="⚠ usbip-win2 required" FontSize="13" FontWeight="SemiBold" Foreground="#FFC107"/>
                                            <TextBlock Text="VIIPER emulation needs the usbip-win2 kernel driver. Download + install the signed driver, reboot, then come back here."
                                                       FontSize="11" Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,4,0,8"/>
                                            <Button x:Name="UsbipInstallCardBtn"
                                                    Content="Install usbip-win2"
                                                    Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="10,4"
                                                    HorizontalAlignment="Left"
                                                    Click="OnbUsbipInstall_Click"/>
                                            <HyperlinkButton x:Name="UsbipInstallLink"
                                                             Margin="0,4,0,0"
                                                             Content="Or open usbip-win2 releases"
                                                             NavigateUri="https://github.com/vadimgrn/usbip-win2/releases"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- ═══ EXPERIMENTAL: Controller HID probe + native MSI fan detection ═══
                                         Harness to reverse-engineer the controller config (button remap) the
                                         same way the LED protocol was cracked: send a raw vendor frame,
                                         read the response, diff against MSI Center M changes. -->
                                    <Border Background="#14000000" BorderBrush="#3D5A80" BorderThickness="1"
                                            CornerRadius="6" Padding="12" Margin="0,12,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Controller HID Probe (experimental)"
                                                       FontSize="13" FontWeight="SemiBold" Foreground="#4AB3F4"/>
                                            <TextBlock Text="Send a raw vendor frame (hex bytes) to the physical controller and read the response. Framing: 0F 00 00 3C [opcode] … . Requires controller emulation ON. Read Gamepad Mode = known-good test (0F 00 00 3C 26)."
                                                       FontSize="11" Foreground="{StaticResource HintTextBrush}"
                                                       TextWrapping="Wrap" Margin="0,2,0,8"/>
                                            <TextBox x:Name="ClawHidProbeInput"
                                                     Text="0F 00 00 3C 26"
                                                     FontFamily="Consolas, Courier New"
                                                     Header="Hex frame"
                                                     Margin="0,0,0,6"/>
                                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
                                                <CheckBox x:Name="ClawHidProbeReadCheck" Content="Read response" IsChecked="True"
                                                          Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                                <Button Content="Send frame" Style="{StaticResource ModernButtonStyle}"
                                                        FontSize="11" Padding="10,4" Click="ClawHidProbeSend_Click"/>
                                                <Button Content="Read Gamepad Mode" Style="{StaticResource ModernButtonStyle}"
                                                        FontSize="11" Padding="10,4" Click="ClawHidProbeReadMode_Click"/>
                                            </StackPanel>
                                            <TextBlock x:Name="ClawHidProbeResult" Text=""
                                                       FontFamily="Consolas, Courier New" FontSize="11"
                                                       Foreground="#DDDDDD" TextWrapping="Wrap"/>

                                            <TextBlock Text="Gyro source" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#4AB3F4" Margin="0,12,0,0"/>
                                            <TextBlock Text="Auto follows the device: Windows sensor on the Claw 8 AI+, controller HID on the Claw 8 EX (which has no usable Windows gyrometer). Force the HID path here to test it on a device where the sensor path also works. Applies immediately."
                                                       FontSize="11" Foreground="#C8C8C8"
                                                       TextWrapping="Wrap" Margin="0,2,0,6"/>
                                            <ComboBox x:Name="ClawGyroSourceComboBox"
                                                      Width="220" HorizontalAlignment="Left"
                                                      Style="{StaticResource ModernComboBoxStyle}"
                                                      SelectionChanged="ClawGyroSourceComboBox_SelectionChanged">
                                                <ComboBoxItem Content="Auto (per device)" Tag="0" IsSelected="True"/>
                                                <ComboBoxItem Content="Windows sensor" Tag="1"/>
                                                <ComboBoxItem Content="Controller HID" Tag="2"/>
                                            </ComboBox>

                                            <TextBlock Text="Native MSI fan" FontSize="13" FontWeight="SemiBold"
                                                       Foreground="#4AB3F4" Margin="0,12,0,0"/>
                                            <TextBlock Text="Read the current fan config from the EC (reflects MSI Center M too). Set a mode in MSI Center M, then detect to learn its signature."
                                                       FontSize="11" Foreground="{StaticResource HintTextBrush}"
                                                       TextWrapping="Wrap" Margin="0,2,0,6"/>
                                            <Button Content="Detect MSI fan" Style="{StaticResource ModernButtonStyle}"
                                                    FontSize="11" Padding="10,4" Click="MsiFanDetect_Click"/>
                                            <TextBlock x:Name="MsiFanDetectResult" Text=""
                                                       FontFamily="Consolas, Courier New" FontSize="11"
                                                       Foreground="#DDDDDD" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                        </StackPanel>
                                    </Border>

                                    <!-- PawnIO Debug Tools (visible when Debug Tools enabled) -->
                                    <StackPanel x:Name="PawnIODebugTools" Visibility="Collapsed" Margin="0,12,0,0">
                                        <Border Background="#402020" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="PawnIO SMU Tools" FontSize="14" FontWeight="SemiBold" Foreground="#FF6B6B"/>
                                                <TextBlock Text="Direct SMU commands - changes apply immediately" FontSize="11" Foreground="{StaticResource HintTextBrush}" Margin="0,2,0,8"/>

                                                <!-- CPU Info -->
                                                <TextBlock x:Name="PawnIOCpuInfoText" Text="CPU: Not detected" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,8"/>

                                                <!-- Curve Optimizer All -->
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="Curve Optimizer (All Cores)" FontSize="13" Foreground="#FFFFFF"/>
                                                        <TextBlock Text="Undervolt: negative, Overvolt: positive" FontSize="10" Foreground="{StaticResource HintTextBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="PawnIOCoAllValue" Grid.Column="1" Text="0" FontSize="13" Foreground="#4CAF50" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                        <Button Content="-" Width="32" Height="32" Click="PawnIOCoAllMinus_Click" Margin="0,0,4,0"/>
                                                        <Button Content="+" Width="32" Height="32" Click="PawnIOCoAllPlus_Click"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Curve Optimizer iGPU -->
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="60"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="Curve Optimizer (iGPU)" FontSize="13" Foreground="#FFFFFF"/>
                                                        <TextBlock Text="Undervolt: negative, Overvolt: positive" FontSize="10" Foreground="{StaticResource HintTextBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="PawnIOCoGfxValue" Grid.Column="1" Text="0" FontSize="13" Foreground="#4CAF50" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                        <Button Content="-" Width="32" Height="32" Click="PawnIOCoGfxMinus_Click" Margin="0,0,4,0"/>
                                                        <Button Content="+" Width="32" Height="32" Click="PawnIOCoGfxPlus_Click"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- iGPU Clock -->
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="iGPU Clock (MHz)" FontSize="13" Foreground="#FFFFFF"/>
                                                        <TextBlock Text="Set iGPU frequency" FontSize="10" Foreground="{StaticResource HintTextBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="PawnIOGfxClkValue" Grid.Column="1" Text="800" FontSize="13" Foreground="#4CAF50" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                        <Button Content="-" Width="32" Height="32" Click="PawnIOGfxClkMinus_Click" Margin="0,0,4,0"/>
                                                        <Button Content="+" Width="32" Height="32" Click="PawnIOGfxClkPlus_Click"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Tctl Temperature -->
                                                <Grid Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="Tctl Temp Limit (°C)" FontSize="13" Foreground="#FFFFFF"/>
                                                        <TextBlock Text="CPU temperature limit" FontSize="10" Foreground="{StaticResource HintTextBrush}"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="PawnIOTctlValue" Grid.Column="1" Text="95" FontSize="13" Foreground="#4CAF50" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                        <Button Content="-" Width="32" Height="32" Click="PawnIOTctlMinus_Click" Margin="0,0,4,0"/>
                                                        <Button Content="+" Width="32" Height="32" Click="PawnIOTctlPlus_Click"/>
                                                    </StackPanel>
                                                </Grid>

                                                <!-- Apply Buttons -->
                                                <Grid Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="8"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Button x:Name="PawnIOApplyButton"
                                                            Grid.Column="0"
                                                            Content="Apply All"
                                                            HorizontalAlignment="Stretch"
                                                            Background="#4CAF50"
                                                            Click="PawnIOApplyButton_Click"/>
                                                    <Button x:Name="PawnIOResetButton"
                                                            Grid.Column="2"
                                                            Content="Reset to 0"
                                                            HorizontalAlignment="Stretch"
                                                            Click="PawnIOResetButton_Click"/>
                                                </Grid>

                                                <!-- Status Text -->
                                                <TextBlock x:Name="PawnIODebugStatusText"
                                                           Text=""
                                                           FontSize="11"
                                                           Foreground="#A0A0A0"
                                                           TextWrapping="Wrap"
                                                           Margin="0,8,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- Intel thermal tasks (DIAGNOSTIC ONLY, visible when Debug Tools enabled).
                                         NOT a fix: on Lunar Lake the fan "panic" is an EC firmware latch that no
                                         software lever releases (only a full shutdown does). Stopping the Intel
                                         IPF/DTT tasks does not calm a latched fan and can make it worse. This is
                                         kept purely to inspect / experiment with the Intel thermal stack state.
                                         Note: disabling the TFN1 fan participant is unsupported on some OS builds,
                                         so "Stop" may only stop the services there. -->
                                    <StackPanel x:Name="IntelThermalDebugTools" Visibility="Collapsed" Margin="0,12,0,0">
                                        <Border Background="#402020" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="Intel thermal stack (IPF/DTT) — diagnostic only" FontSize="14" FontWeight="SemiBold" Foreground="#FF6B6B"/>
                                                <TextBlock Text="Does NOT fix the fan panic. The panic is an EC firmware latch that only a full shutdown clears. For investigation only — stopping these tasks can make a stuck fan worse." FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap" Margin="0,2,0,8"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button x:Name="IntelThermalStopButton"
                                                            Content="Stop Intel tasks"
                                                            Style="{StaticResource ModernButtonStyle}"
                                                            FontSize="11" Padding="10,4"
                                                            Click="IntelThermalStopButton_Click"/>
                                                    <Button x:Name="IntelThermalStartButton"
                                                            Content="Start Intel tasks"
                                                            Margin="8,0,0,0"
                                                            Style="{StaticResource ModernButtonStyle}"
                                                            FontSize="11" Padding="10,4"
                                                            Click="IntelThermalStartButton_Click"/>
                                                    <Button x:Name="IntelThermalRefreshButton"
                                                            Content="Refresh"
                                                            Margin="8,0,0,0"
                                                            Style="{StaticResource ModernButtonStyle}"
                                                            FontSize="11" Padding="10,4"
                                                            Click="IntelThermalRefreshButton_Click"/>
                                                </StackPanel>
                                                <TextBlock x:Name="IntelThermalStatusText"
                                                           Margin="0,8,0,0"
                                                           FontSize="11" TextWrapping="Wrap"
                                                           Foreground="#A0A0A0"
                                                           Text="Press Refresh to read the Intel thermal stack status."/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- Fan max test / scaling check (DIAGNOSTIC, visible when Debug Tools enabled).
                                         Forces the EC full-speed override (block 152.7) so we can compare the real
                                         fan RPM against our table max (100 % = EC byte 150). If Full Blast is clearly
                                         louder / higher RPM than Aggressive@100 %, then 150 is NOT the absolute max
                                         and our 0-100 % scaling tops out below the hardware ceiling. -->
                                    <StackPanel x:Name="FanMaxTestDebugTools" Visibility="Collapsed" Margin="0,12,0,0">
                                        <Border Background="#402020" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="Fan max test (Full Blast) — diagnostic only" FontSize="14" FontWeight="SemiBold" Foreground="#FF6B6B"/>
                                                <TextBlock Text="Forces the EC full-speed override to check whether 100% (EC 150) is really the absolute fan max. Turn ON, wait a few seconds, Read RPM; compare with Aggressive@100%. Turn OFF afterwards." FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap" Margin="0,2,0,8"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button x:Name="FanFullBlastOnButton"
                                                            Content="Full Blast ON"
                                                            Style="{StaticResource ModernButtonStyle}"
                                                            FontSize="11" Padding="10,4"
                                                            Click="FanFullBlastOnButton_Click"/>
                                                    <Button x:Name="FanFullBlastOffButton"
                                                            Content="Full Blast OFF"
                                                            Margin="8,0,0,0"
                                                            Style="{StaticResource ModernButtonStyle}"
                                                            FontSize="11" Padding="10,4"
                                                            Click="FanFullBlastOffButton_Click"/>
                                                    <Button x:Name="FanReadRpmButton"
                                                            Content="Read RPM"
                                                            Margin="8,0,0,0"
                                                            Style="{StaticResource ModernButtonStyle}"
                                                            FontSize="11" Padding="10,4"
                                                            Click="FanReadRpmButton_Click"/>
                                                </StackPanel>
                                                <TextBlock x:Name="FanFullBlastStatusText"
                                                           Margin="0,8,0,0"
                                                           FontSize="11" TextWrapping="Wrap"
                                                           Foreground="#A0A0A0"
                                                           Text="Press Read RPM to read the live fan speed."/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- Fan override probe (DIAGNOSTIC, visible when Debug Tools enabled).
                                         Hunts for a PROPORTIONAL fan-duty register: writes a raw byte to an EC
                                         data block (default 152) and reads it back. Sweep the slider and listen
                                         for a level response between firmware-quiet and Full Blast. WARNING:
                                         writing arbitrary EC blocks is experimental — keep to block 152 unless
                                         you know what a block does. -->
                                    <StackPanel x:Name="FanProbeDebugTools" Visibility="Collapsed" Margin="0,12,0,0">
                                        <Border Background="#402020" CornerRadius="6" Padding="12" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="Fan override probe — diagnostic only" FontSize="14" FontWeight="SemiBold" Foreground="#FF6B6B"/>
                                                <TextBlock Text="Writes a raw byte to an EC block (default 152) to find a proportional fan-duty register. Sweep + Write, then listen. Set value back to 0 when done." FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap" Margin="0,2,0,8"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <TextBlock Text="Block" FontSize="12" Foreground="#C0C0C0" VerticalAlignment="Center"/>
                                                    <TextBox x:Name="FanProbeBlockText" Text="152" Width="56" Margin="8,0,0,0"/>
                                                    <TextBlock Text="Value" FontSize="12" Foreground="#C0C0C0" VerticalAlignment="Center" Margin="16,0,0,0"/>
                                                    <TextBlock x:Name="FanProbeValueLabel" Text="0 (0x00)" FontSize="12" Foreground="#4CAF50" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                                </StackPanel>
                                                <Slider x:Name="FanProbeValueSlider" Minimum="0" Maximum="255" Value="0"
                                                        ValueChanged="FanProbeValueSlider_ValueChanged"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <Button Content="Write" Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="10,4" Click="FanProbeWriteButton_Click"/>
                                                    <Button Content="152=0"   Margin="8,0,0,0" Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="8,4" Click="FanProbeP0_Click"/>
                                                    <Button Content="152=50"  Margin="6,0,0,0" Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="8,4" Click="FanProbeP50_Click"/>
                                                    <Button Content="152=100" Margin="6,0,0,0" Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="8,4" Click="FanProbeP100_Click"/>
                                                    <Button Content="152=150" Margin="6,0,0,0" Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="8,4" Click="FanProbeP150_Click"/>
                                                    <Button Content="0x80|40" Margin="6,0,0,0" Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="8,4" Click="FanProbeEn40_Click"/>
                                                    <Button Content="0x80|80" Margin="6,0,0,0" Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="8,4" Click="FanProbeEn80_Click"/>
                                                </StackPanel>
                                                <TextBlock x:Name="FanProbeStatusText"
                                                           Margin="0,8,0,0"
                                                           FontSize="11" TextWrapping="Wrap"
                                                           Foreground="#A0A0A0"
                                                           Text="Write a value, then listen. Read-back confirms what landed in the EC."/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>

                                    <!-- Update Status Text -->
                                    <TextBlock x:Name="UpdateStatusText"
                                               Text=""
                                               FontSize="12"
                                               Foreground="#A0A0A0"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0"
                                               Visibility="Collapsed"/>

                                    <!-- Update Button (shown when update available) -->
                                    <Button x:Name="UpdateButton"
                                            Content="Update"
                                            HorizontalAlignment="Stretch"
                                            Margin="0,8,0,0"
                                            Style="{StaticResource StandaloneButtonStyle}"
                                            Background="#107C10"
                                            Click="UpdateButton_Click"
                                            Visibility="Collapsed"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Navigation Infos Card (controller shortcuts reference) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Navigation Infos" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Controller navigation shortcuts"
                                                   Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="ProTipsExpandButton"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Top"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="ProTipsExpandButton_Click">
                                        <FontIcon x:Name="ProTipsExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>
                                <StackPanel x:Name="ProTipsContent" Visibility="Collapsed" Margin="0,12,0,0">
                                    <!-- Two-column layout to keep vertical footprint small -->
                                    <Grid ColumnSpacing="20">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- LEFT COLUMN: Tab + Section Navigation -->
                                        <StackPanel Grid.Column="0" Spacing="10">
                                            <!-- Tab Navigation -->
                                            <StackPanel>
                                                <TextBlock Text="Tab Navigation" FontSize="12" Foreground="#AAAAAA" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition/><RowDefinition/>
                                                    </Grid.RowDefinitions>
                                                    <Border Grid.Row="0" Grid.Column="0" Background="#2A2A2A" CornerRadius="3" Padding="6,2" Margin="0,0,8,4" HorizontalAlignment="Left">
                                                        <TextBlock Text="LT / RT" Foreground="#FFFFFF" FontSize="11" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Switch tabs left / right" FontSize="11" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                                    <Border Grid.Row="1" Grid.Column="0" Background="#2A2A2A" CornerRadius="3" Padding="6,2" Margin="0,0,8,4" HorizontalAlignment="Left">
                                                        <TextBlock Text="D-Pad ↓" Foreground="#FFFFFF" FontSize="11" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Enter content area from tab bar" FontSize="11" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                                </Grid>
                                            </StackPanel>
                                            <!-- Section Navigation -->
                                            <StackPanel>
                                                <TextBlock Text="Section Navigation" FontSize="12" Foreground="#AAAAAA" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition/><RowDefinition/><RowDefinition/>
                                                    </Grid.RowDefinitions>
                                                    <Border Grid.Row="0" Grid.Column="0" Background="#3A331A" BorderBrush="#998833" BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,0,8,4" HorizontalAlignment="Left">
                                                        <TextBlock Text="Y" Foreground="#F5C518" FontSize="11" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Jump back to tab bar from anywhere" FontSize="11" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                                    <Border Grid.Row="1" Grid.Column="0" Background="#16301A" BorderBrush="#2E7D32" BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,0,8,4" HorizontalAlignment="Left">
                                                        <TextBlock Text="A" Foreground="#6CC04A" FontSize="11" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Confirm / toggle focused control" FontSize="11" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                                    <Border Grid.Row="2" Grid.Column="0" Background="#3A1A1A" BorderBrush="#993333" BorderThickness="1" CornerRadius="3" Padding="6,2" Margin="0,0,8,4" HorizontalAlignment="Left">
                                                        <TextBlock Text="B" Foreground="#E06C5E" FontSize="11" FontWeight="SemiBold"/>
                                                    </Border>
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Cancel / close widget" FontSize="11" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- RIGHT COLUMN: Virtual Mouse -->
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="Virtual Mouse" FontSize="12" Foreground="#AAAAAA" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                                </Grid.RowDefinitions>
                                                <Border Grid.Row="0" Grid.Column="0" Background="#2A2A2A" CornerRadius="3" Padding="6,2" Margin="0,0,8,4" HorizontalAlignment="Left">
                                                    <TextBlock Text="RT" Foreground="#FFFFFF" FontSize="11" FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Left click (configurable)" FontSize="11" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                                <Border Grid.Row="1" Grid.Column="0" Background="#2A2A2A" CornerRadius="3" Padding="6,2" Margin="0,0,8,4" HorizontalAlignment="Left">
                                                    <TextBlock Text="LT" Foreground="#FFFFFF" FontSize="11" FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Right click (configurable)" FontSize="11" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                                <Border Grid.Row="2" Grid.Column="0" Background="#2A2A2A" CornerRadius="3" Padding="6,2" Margin="0,0,8,4" HorizontalAlignment="Left">
                                                    <TextBlock Text="L-Stick" Foreground="#FFFFFF" FontSize="11" FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Move cursor" FontSize="11" Foreground="#CCCCCC" VerticalAlignment="Center" Margin="0,0,0,4"/>
                                                <Border Grid.Row="3" Grid.Column="0" Background="#2A2A2A" CornerRadius="3" Padding="6,2" Margin="0,0,8,0" HorizontalAlignment="Left">
                                                    <TextBlock Text="R-Stick" Foreground="#FFFFFF" FontSize="11" FontWeight="SemiBold"/>
                                                </Border>
                                                <TextBlock Grid.Row="3" Grid.Column="1" Text="Scroll" FontSize="11" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                                            </Grid>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- About Card (Collapsible) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header with Expand/Collapse -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="About" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Version and credits"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="AboutExpandButton"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="AboutExpandButton_Click">
                                        <FontIcon x:Name="AboutExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <!-- Collapsible Content -->
                                <StackPanel x:Name="AboutContent" Visibility="Collapsed" Margin="0,12,0,0">
                                    <!-- Version -->
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Version"
                                                   FontSize="14"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="AboutVersionText"
                                                   Text="0.3.98.0"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>

                                    <!-- Author -->
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Author"
                                                   FontSize="14"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="Riff_Lash (EnterTheVoidCode)"
                                                   FontSize="14"
                                                   Foreground="#00C8FF"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>

                                    <!-- Special Thanks -->
                                    <Grid Margin="0,0,0,12">
                                        <TextBlock Text="Special Thanks"
                                                   FontSize="14"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="LtChipotle (GoTweaks), HandheldCompanion"
                                                   FontSize="14"
                                                   Foreground="#B0B0B0"
                                                   HorizontalAlignment="Right"
                                                   TextWrapping="Wrap"/>
                                    </Grid>

                                    <!-- Check for updates on startup toggle -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Check for updates on startup"
                                                       FontSize="14"
                                                       Foreground="#FFFFFF"/>
                                            <TextBlock Text="Automatically check GitHub for new versions"
                                                       FontSize="11"
                                                       Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="AutoUpdateCheckToggle"
                                                      Grid.Column="1"
                                                      IsOn="True"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      Toggled="AutoUpdateCheckToggle_Toggled"/>
                                    </Grid>

                                    <!-- Ko-fi donation QR code -->
                                    <StackPanel HorizontalAlignment="Center" Margin="0,0,0,10">
                                        <Border Background="#FFFFFF" CornerRadius="6" Padding="8" HorizontalAlignment="Center">
                                            <Image Source="ms-appx:///Assets/kofi-qr.png"
                                                   Width="150" Height="150"
                                                   Stretch="Uniform"/>
                                        </Border>
                                        <TextBlock Text="Scan to support on Ko-fi"
                                                   FontSize="11"
                                                   Foreground="{StaticResource HintTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,6,0,0"/>
                                    </StackPanel>

                                    <!-- Donate Button -->
                                    <Button x:Name="DonateButton"
                                            Click="DonateButton_Click"
                                            HorizontalAlignment="Stretch"
                                            HorizontalContentAlignment="Center"
                                            Padding="12,8"
                                            Background="#13A1B8"
                                            Foreground="#FFFFFF"
                                            FontSize="14"
                                            CornerRadius="4">
                                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                            <TextBlock Text="Support Development - Donate" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- DRIVERS TAB (MSI + Intel driver/firmware updates) -->
                <ScrollViewer x:Name="DriverScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="12,6,12,10">
                        <Border x:Name="DriverUpdatesCard" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="MSI Claw Driver Updates" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Driver &amp; firmware updates (MSI + Intel)"
                                               Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <StackPanel x:Name="DriverUpdatesContent" Visibility="Visible" Spacing="6" Margin="0,8,0,0">
                                    <!-- Machine info -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Model" FontSize="13" Foreground="#AAAAAA"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="DriverUpdatesModel" Text="—" FontSize="13" Foreground="#E0E0E0" TextWrapping="Wrap"/>
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Installed BIOS" FontSize="13" Foreground="#AAAAAA" Margin="0,4,0,0"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DriverUpdatesBios" Text="—" FontSize="13" Foreground="#E0E0E0" Margin="0,4,0,0"/>
                                    </Grid>

                                    <!-- Actions row -->
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Button x:Name="DriverUpdatesCheckButton"
                                                Content="Check for updates"
                                                Style="{StaticResource ModernButtonStyle}"
                                                Click="DriverUpdatesCheckButton_Click"/>
                                        <Button x:Name="DriverUpdatesOpenPageButton"
                                                Content="Open MSI driver page"
                                                Style="{StaticResource ModernButtonStyle}"
                                                Click="DriverUpdatesOpenPageButton_Click"/>
                                        <Button x:Name="DriverUpdatesIntelDsaButton"
                                                Content="Intel DSA"
                                                Style="{StaticResource ModernButtonStyle}"
                                                Click="DriverUpdatesIntelDsaButton_Click"/>
                                    </StackPanel>

                                    <TextBlock x:Name="DriverUpdatesStatusText"
                                               Text="Tap 'Check for updates' to scan installed driver versions."
                                               FontSize="11"
                                               Foreground="{StaticResource HintTextBrush}"
                                               TextWrapping="Wrap"/>


                                    <CheckBox x:Name="DriverUpdatesUpdateOnStartCheckbox"
                                              Content="Check for driver updates on start"
                                              IsChecked="False"
                                              FontSize="12"
                                              Foreground="#AAAAAA"
                                              Checked="DriverUpdatesUpdateOnStartCheckbox_Changed"
                                              Unchecked="DriverUpdatesUpdateOnStartCheckbox_Changed"/>
                                    <CheckBox x:Name="DriverUpdatesModdedWifiCheckbox"
                                              Content="Use modded Wi-Fi driver (theboss619) — at your own risk"
                                              IsChecked="False"
                                              FontSize="12"
                                              Foreground="#AAAAAA"
                                              Checked="DriverUpdatesModdedWifiCheckbox_Changed"
                                              Unchecked="DriverUpdatesModdedWifiCheckbox_Changed"/>

                                    <ItemsControl x:Name="DriverUpdatesList" Visibility="Collapsed"
                                                  XYFocusKeyboardNavigation="Enabled">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#1A1A2E" CornerRadius="4" Padding="8,6" Margin="0,3,0,0">
                                                    <Grid ColumnSpacing="10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="22"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding CategoryIcon}"
                                                                   FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="16"
                                                                   Foreground="#7A9EC8"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="1" XYFocusKeyboardNavigation="Enabled">
                                                            <Grid>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding Name}" FontSize="13" Foreground="#E0E0E0" TextWrapping="Wrap"/>
                                                                <Border Grid.Column="1" Background="{Binding StatusColor}" CornerRadius="10" Padding="8,2" Margin="8,0,0,0" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding StatusLabel}" FontSize="10" Foreground="#FFFFFF"/>
                                                                </Border>
                                                            </Grid>
                                                            <TextBlock FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap" Margin="0,2,0,0">
                                                                <Run Text="{Binding Category}"/><Run Text=" • "/><Run Text="{Binding Severity}"/>
                                                            </TextBlock>
                                                            <TextBlock FontSize="11" Foreground="#AAAAAA" TextWrapping="Wrap" Margin="0,2,0,0">
                                                                <Run Text="Installed:"/><Run Text=" "/><Run Text="{Binding InstalledVersion}"/><Run Text="  →  "/><Run Text="Latest:"/><Run Text=" "/><Run Text="{Binding Version}"/>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding Highlights}"
                                                                       FontSize="10" Foreground="#AA77CC"
                                                                       FontStyle="Italic"
                                                                       TextWrapping="Wrap" Margin="0,2,0,0"
                                                                       Visibility="{Binding HighlightsVisibility}"/>
                                                            <Grid Margin="0,4,0,0">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="Auto"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding ReleaseDate, FallbackValue=''}" FontSize="10" Foreground="#666666" VerticalAlignment="Center"/>
                                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                                                    <Button Content="{Binding MuteButtonLabel}"
                                                                            Tag="{Binding IgnoreKey}"
                                                                            Visibility="{Binding MuteButtonVisibility}"
                                                                            Style="{StaticResource ModernButtonStyle}"
                                                                            FontSize="11"
                                                                            Padding="10,4"
                                                                            Click="DriverMuteButton_Click"/>
                                                                    <Button Content="{Binding InstallButtonLabel}"
                                                                            Tag="{Binding DownloadUrl}"
                                                                            Visibility="{Binding InstallButtonVisibility}"
                                                                            Style="{StaticResource ModernButtonStyle}"
                                                                            FontSize="11"
                                                                            Padding="10,4"
                                                                            Click="DriverInstallButton_Click"/>
                                                                </StackPanel>
                                                            </Grid>

                                                            <!-- Installer files already downloaded for this driver:
                                                                 re-run (downgrade to) or delete to free space. -->
                                                            <muxc:Expander Visibility="{Binding CachedInstallersVisibility}"
                                                                           Margin="0,6,0,0"
                                                                           HorizontalAlignment="Stretch"
                                                                           HorizontalContentAlignment="Stretch"
                                                                           IsExpanded="False">
                                                                <muxc:Expander.Header>
                                                                    <TextBlock Text="{Binding CachedInstallersHeader}" FontSize="11" Foreground="#9098A0"/>
                                                                </muxc:Expander.Header>
                                                                <ItemsControl ItemsSource="{Binding CachedInstallers}"
                                                                              XYFocusKeyboardNavigation="Enabled">
                                                                    <ItemsControl.ItemTemplate>
                                                                        <DataTemplate>
                                                                            <Grid Margin="0,3,0,0" ColumnSpacing="8">
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="*"/>
                                                                                    <ColumnDefinition Width="Auto"/>
                                                                                </Grid.ColumnDefinitions>
                                                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                                                    <TextBlock Text="{Binding FileName}" FontSize="11" Foreground="#D0D0D0" TextWrapping="Wrap"/>
                                                                                    <TextBlock Text="{Binding DetailText}" FontSize="10" Foreground="#808890" TextWrapping="Wrap"/>
                                                                                </StackPanel>
                                                                                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                                                                    <Button Content="{Binding RunButtonLabel}"
                                                                                            Tag="{Binding}"
                                                                                            Style="{StaticResource ModernButtonStyle}"
                                                                                            FontSize="11"
                                                                                            Padding="10,4"
                                                                                            Click="DriverCachedRunButton_Click"/>
                                                                                    <Button Content="Delete"
                                                                                            Tag="{Binding}"
                                                                                            Style="{StaticResource ModernButtonStyle}"
                                                                                            FontSize="11"
                                                                                            Padding="10,4"
                                                                                            Click="DriverCachedDeleteButton_Click"/>
                                                                                </StackPanel>
                                                                            </Grid>
                                                                        </DataTemplate>
                                                                    </ItemsControl.ItemTemplate>
                                                                </ItemsControl>
                                                            </muxc:Expander>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- DISPLAY TAB (Intel IGCL) — saved in the Performance & Display profile -->
                <ScrollViewer x:Name="DisplayScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16" Spacing="12">

                        <TextBlock Text="Display (Intel)" Style="{StaticResource CardTitleStyle}"/>

                        <!-- Profile status badge: green = per-game active, orange = editing global -->
                        <Border x:Name="DisplayProfileModeBadge"
                                Background="#37260C" BorderBrush="#A06E28" BorderThickness="1"
                                CornerRadius="4" Padding="8,3" Margin="0,2,0,2"
                                HorizontalAlignment="Left">
                            <TextBlock x:Name="DisplayProfileModeText"
                                       Text="Editing Global Profile"
                                       FontSize="11" Foreground="#FFAA46"/>
                        </Border>

                        <!-- Reference image gallery (logic ported from TnC). The IGCL color transform
                             is applied desktop-wide, so this preview shows the effect live. Taller
                             preview; cycle by tapping the image, the on-screen arrows, or — with a
                             controller — by focusing an arrow and pressing A. Dots show the count. -->
                        <Grid Margin="0,4,0,4">
                            <Border CornerRadius="8" Background="#20000000">
                                <Image x:Name="DisplayReferenceImage"
                                       HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                       MinHeight="133" MaxHeight="203" Stretch="UniformToFill"
                                       Tapped="DisplayReferenceImage_Tapped"/>
                            </Border>
                            <Button x:Name="DisplayRefPrevButton" Click="DisplayRefPrevButton_Click"
                                    HorizontalAlignment="Left" VerticalAlignment="Center" Margin="6,0,0,0"
                                    Width="34" Height="34" Padding="0" CornerRadius="17"
                                    Background="#90000000" BorderThickness="0"
                                    ToolTipService.ToolTip="Previous image">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE76B;" FontSize="14" Foreground="#FFFFFF"/>
                            </Button>
                            <Button x:Name="DisplayRefNextButton" Click="DisplayRefNextButton_Click"
                                    HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,6,0"
                                    Width="34" Height="34" Padding="0" CornerRadius="17"
                                    Background="#90000000" BorderThickness="0"
                                    ToolTipService.ToolTip="Next image">
                                <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE76C;" FontSize="14" Foreground="#FFFFFF"/>
                            </Button>
                            <StackPanel x:Name="DisplayRefDots" Orientation="Horizontal" Spacing="5"
                                        HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,8"/>
                        </Grid>

                        <!-- Color Remaster sliders -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="10">
                                <!-- Saturation -->
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Saturation" Style="{StaticResource CardCaptionStyle}" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="DisplaySaturationValueText" Grid.Column="1" Text="50" FontSize="13" Foreground="{StaticResource SystemAccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </Grid>
                                <Slider x:Name="DisplaySaturationSlider" Minimum="0" Maximum="100" Value="50" StepFrequency="1"
                                        ValueChanged="DisplaySlider_ValueChanged"
                                        XYFocusLeft="{x:Bind DisplayNavItem}" XYFocusUp="{x:Bind DisplayRefNextButton}" XYFocusDown="{x:Bind DisplayHueSlider}"/>

                                <!-- Hue -->
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Hue" Style="{StaticResource CardCaptionStyle}" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="DisplayHueValueText" Grid.Column="1" Text="0" FontSize="13" Foreground="{StaticResource SystemAccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </Grid>
                                <Slider x:Name="DisplayHueSlider" Minimum="-180" Maximum="180" Value="0" StepFrequency="1"
                                        ValueChanged="DisplaySlider_ValueChanged"
                                        XYFocusLeft="{x:Bind DisplayNavItem}" XYFocusUp="{x:Bind DisplaySaturationSlider}" XYFocusDown="{x:Bind DisplayContrastSlider}"/>

                                <!-- Contrast -->
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Contrast" Style="{StaticResource CardCaptionStyle}" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="DisplayContrastValueText" Grid.Column="1" Text="50" FontSize="13" Foreground="{StaticResource SystemAccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </Grid>
                                <Slider x:Name="DisplayContrastSlider" Minimum="0" Maximum="100" Value="50" StepFrequency="1"
                                        ValueChanged="DisplaySlider_ValueChanged"
                                        XYFocusLeft="{x:Bind DisplayNavItem}" XYFocusUp="{x:Bind DisplayHueSlider}" XYFocusDown="{x:Bind DisplayBrightnessSlider}"/>

                                <!-- Brightness -->
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Brightness" Style="{StaticResource CardCaptionStyle}" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="DisplayBrightnessValueText" Grid.Column="1" Text="50" FontSize="13" Foreground="{StaticResource SystemAccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </Grid>
                                <Slider x:Name="DisplayBrightnessSlider" Minimum="0" Maximum="100" Value="50" StepFrequency="1"
                                        ValueChanged="DisplaySlider_ValueChanged"
                                        XYFocusLeft="{x:Bind DisplayNavItem}" XYFocusUp="{x:Bind DisplayContrastSlider}" XYFocusDown="{x:Bind DisplayGammaSlider}"/>

                                <!-- Gamma (×100 → 0.30..2.80) -->
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Gamma" Style="{StaticResource CardCaptionStyle}" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="DisplayGammaValueText" Grid.Column="1" Text="1.00" FontSize="13" Foreground="{StaticResource SystemAccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </Grid>
                                <Slider x:Name="DisplayGammaSlider" Minimum="30" Maximum="280" Value="100" StepFrequency="1"
                                        ValueChanged="DisplaySlider_ValueChanged"
                                        XYFocusLeft="{x:Bind DisplayNavItem}" XYFocusUp="{x:Bind DisplayBrightnessSlider}" XYFocusDown="{x:Bind DisplaySharpnessSlider}"/>

                                <!-- Adaptive Sharpness -->
                                <Grid>
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock Text="Adaptive Sharpness" Style="{StaticResource CardCaptionStyle}" Margin="0" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="DisplaySharpnessValueText" Grid.Column="1" Text="Off" FontSize="13" Foreground="{StaticResource SystemAccentBrush}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                </Grid>
                                <Slider x:Name="DisplaySharpnessSlider" Minimum="0" Maximum="100" Value="0" StepFrequency="1"
                                        ValueChanged="DisplaySlider_ValueChanged"
                                        XYFocusLeft="{x:Bind DisplayNavItem}" XYFocusUp="{x:Bind DisplayGammaSlider}" XYFocusDown="{x:Bind DisplayResetButton}"/>

                                <Button x:Name="DisplayResetButton" Content="Reset to neutral" Margin="0,4,0,0"
                                        HorizontalAlignment="Stretch" Click="DisplayResetButton_Click"
                                        XYFocusLeft="{x:Bind DisplayNavItem}" XYFocusUp="{x:Bind DisplaySharpnessSlider}"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Note: these affect the whole screen (desktop-wide), like Intel Graphics Software. They reset to your global profile when no game is running."
                                   Style="{StaticResource CardCaptionStyle}" TextWrapping="Wrap" Margin="0,4,0,0"/>

                        <!-- GAMING (Intel IGCL) — Low Latency + Frame Sync. Per-game (helper-authoritative,
                             pushed to these combos on open). Safe no-op when the driver lacks the feature. -->
                        <TextBlock Text="GAMING (Intel)" Style="{StaticResource SectionHeaderStyle}" Margin="0,8,0,0"/>

                        <!-- Low Latency Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Low Latency" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Reduces input lag (Intel Anti-Lag)" Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ComboBox x:Name="IntelLowLatencyComboBox" Grid.Column="1" Width="150"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          XYFocusLeft="{x:Bind DisplayNavItem}"
                                          XYFocusUp="{x:Bind DisplayResetButton}"
                                          XYFocusDown="{x:Bind IntelFrameSyncComboBox}">
                                    <ComboBoxItem Content="Off"        Tag="0"/>
                                    <ComboBoxItem Content="On"         Tag="1"/>
                                    <ComboBoxItem Content="On + Boost" Tag="2"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Frame Sync Card (Adaptive Sync / V-Sync flip mode) -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Frame Sync" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Adaptive sync / V-Sync behaviour" Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ComboBox x:Name="IntelFrameSyncComboBox" Grid.Column="1" Width="150"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          XYFocusLeft="{x:Bind DisplayNavItem}"
                                          XYFocusUp="{x:Bind IntelLowLatencyComboBox}">
                                    <ComboBoxItem Content="App Default" Tag="0"/>
                                    <ComboBoxItem Content="V-Sync Off"  Tag="1"/>
                                    <ComboBoxItem Content="V-Sync On"   Tag="2"/>
                                    <ComboBoxItem Content="Smooth Sync" Tag="3"/>
                                    <ComboBoxItem Content="Speed Sync"  Tag="4"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- DISPLAY — Resolution and Refresh Rate (moved from System tab) -->
                        <TextBlock Text="DISPLAY" Style="{StaticResource SectionHeaderStyle}" Margin="0,8,0,0"/>

                        <!-- Resolution Card -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Resolution"
                                           Style="{StaticResource CardTitleStyle}"
                                           VerticalAlignment="Center"
                                           Grid.Column="0"/>
                                <ComboBox x:Name="ResolutionComboBox"
                                          PlaceholderText="1920x1080"
                                          Width="150"
                                          Grid.Column="1"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          XYFocusUp="{x:Bind DisplayNavItem}">
                                    <x:String>1920x1080</x:String>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Refresh Rate Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Refresh Rate"
                                           Style="{StaticResource CardTitleStyle}"
                                           VerticalAlignment="Center"
                                           Grid.Column="0"/>
                                <ComboBox x:Name="RefreshRatesComboBox"
                                          PlaceholderText="60 Hz"
                                          Width="120"
                                          Grid.Column="1"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          XYFocusUp="{x:Bind DisplayNavItem}">
                                    <x:String>60 Hz</x:String>
                                </ComboBox>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- FAN TAB (MSI Claw) — the Fan Control card is reparented here at runtime -->
                <ScrollViewer x:Name="FanScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16" Spacing="12">
                        <TextBlock Text="Fan" Style="{StaticResource CardTitleStyle}"/>

                        <!-- Hardcoded global badge: per-game fan profiles are not supported yet -->
                        <Border Background="#37260C" BorderBrush="#A06E28" BorderThickness="1"
                                CornerRadius="4" Padding="8,3" Margin="0,2,0,0" HorizontalAlignment="Left">
                            <TextBlock Text="Editing Global Profile" FontSize="11" Foreground="#FFAA46"/>
                        </Border>
                        <TextBlock Text="Per-game fan profiles — coming soon. The fan curve is currently global (applies on every game)."
                                   Style="{StaticResource CardCaptionStyle}" TextWrapping="Wrap"/>

                        <!-- The MSI Claw Fan Control card lives here permanently (no runtime reparenting). -->
                        <StackPanel x:Name="FanTabContent">
                            <!-- MSI Claw (Lunar Lake) Fan Control Card — shown only on MSI Claw -->
                            <Border x:Name="MsiFanCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Fan Control" Style="{StaticResource CardTitleStyle}"/>
                                            <TextBlock Text="Custom fan curve"
                                                       Style="{StaticResource CardCaptionStyle}"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="MsiFanEnableToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      IsOn="False"
                                                      VerticalAlignment="Center"
                                                      Toggled="MsiFanEnableToggle_Toggled"
                                                      KeyDown="MsiFanEnableToggle_KeyDown"/>
                                    </Grid>

                                    <StackPanel x:Name="MsiFanContent" Margin="0,10,0,0" Visibility="Collapsed">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="Preset" FontSize="13" Foreground="#E0E0E0" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="MsiFanPresetComboBox"
                                                      Grid.Column="1"
                                                      HorizontalAlignment="Right"
                                                      Width="160"
                                                      SelectionChanged="MsiFanPresetComboBox_SelectionChanged"
                                                      KeyDown="MsiFanPresetComboBox_KeyDown">
                                                <ComboBoxItem Content="MSI Default" Tag="0" IsSelected="True"/>
                                                <ComboBoxItem Content="Quiet Idle" Tag="1"/>
                                                <ComboBoxItem Content="Cooling · Early Ramp" Tag="2"/>
                                                <ComboBoxItem Content="Custom" Tag="3"/>
                                                <ComboBoxItem Content="EC Sport default (debug)" Tag="4"/>
                                            </ComboBox>
                                        </Grid>

                                        <!-- One dark panel holds the live readout, the bar graph and Apply, so the
                                             readout/Apply read as part of the graph instead of floating loose. -->
                                        <Border Background="#1A1A1A" CornerRadius="6" Padding="10,8,10,10" Margin="0,10,0,0">
                                          <StackPanel>

                                        <StackPanel Orientation="Horizontal" Margin="2,0,0,6">
                                            <!-- Spacing via Margin, not trailing spaces in Text: XAML trims/collapses
                                                 attribute whitespace, so the values would otherwise touch the colons. -->
                                            <TextBlock Text="CPU package temperature:" FontSize="13" Foreground="#B0B0B0"/>
                                            <TextBlock x:Name="MsiFanTempLabel" Text="--&#xB0;C" Margin="5,0,0,0" FontSize="13" Foreground="#FF8800" FontWeight="SemiBold"/>
                                            <TextBlock Text="·" Margin="10,0,10,0" FontSize="13" Foreground="#B0B0B0"/>
                                            <TextBlock Text="Fan:" FontSize="13" Foreground="#B0B0B0"/>
                                            <TextBlock x:Name="MsiFanRpmLabel" Text="0 RPM" Margin="5,0,0,0" FontSize="13" Foreground="#00AAFF" FontWeight="SemiBold"/>
                                        </StackPanel>

                                        <!-- MSI-style bars: fan % per fixed breakpoint; the temperature is the label under each bar -->
                                        <Grid Height="230">
                                            <!-- Focusable wrapper so the graph is reachable by controller
                                                 (Canvas itself is a Panel and cannot be a tab stop). -->
                                            <ContentControl x:Name="MsiFanCurveFocus"
                                                            IsTabStop="True"
                                                            UseSystemFocusVisuals="True"
                                                            HorizontalContentAlignment="Stretch"
                                                            VerticalContentAlignment="Stretch"
                                                            GotFocus="MsiFanCurveCanvas_GotFocus"
                                                            LostFocus="MsiFanCurveCanvas_LostFocus"
                                                            KeyDown="MsiFanCurveCanvas_KeyDown">
                                                <Canvas x:Name="MsiFanCurveCanvas"
                                                        Background="Transparent"
                                                        PointerPressed="MsiFanCurveCanvas_PointerPressed"
                                                        PointerMoved="MsiFanCurveCanvas_PointerMoved"
                                                        PointerReleased="MsiFanCurveCanvas_PointerReleased"
                                                        PointerCaptureLost="MsiFanCurveCanvas_PointerReleased"
                                                        SizeChanged="MsiFanCurveCanvas_SizeChanged">
                                                    <!-- "Beyond MSI" zone: above MSI's 75 % cap (only when extended range is on) -->
                                                    <Rectangle x:Name="MsiFanBeyondBand" Fill="#1EF0603C" IsHitTestVisible="False"/>
                                                    <!-- Retained (collapsed) from the old line-graph layout so code refs stay valid -->
                                                    <Polygon x:Name="MsiFanCurveFill" Visibility="Collapsed"/>
                                                    <Polyline x:Name="MsiFanCurvePolyline" Visibility="Collapsed"/>
                                                    <!-- MSI max (75 %) reference line + label -->
                                                    <Line x:Name="MsiFanMsiMaxLine" Stroke="#88F0603C" StrokeThickness="1" StrokeDashArray="3,3" IsHitTestVisible="False"/>
                                                    <TextBlock x:Name="MsiFanMsiMaxLabel" Text="MSI max 75%" FontSize="12" Foreground="#F0A090" IsHitTestVisible="False"/>
                                                    <Line x:Name="MsiFanTempIndicatorLine"
                                                          Stroke="#FF8800" StrokeThickness="2" StrokeDashArray="4,2"
                                                          Visibility="Collapsed"/>
                                                </Canvas>
                                            </ContentControl>
                                        </Grid>

                                        <!-- Apply pending curve/temp edits to the EC. Lit + focusable only when
                                             there are unsaved manual edits (protects the fan/EC from a write on
                                             every drag); disabled + skipped by the D-Pad focus chain otherwise.
                                             It only appears on a change, so it pulses while pending to catch the eye. -->
                                        <Button x:Name="MsiFanApplyButton"
                                                Content="Apply fan curve"
                                                HorizontalAlignment="Left"
                                                Margin="0,10,0,0"
                                                IsEnabled="False"
                                                IsTabStop="False"
                                                Opacity="0.45"
                                                Background="#1F6FEB"
                                                Foreground="White"
                                                Style="{StaticResource StandaloneButtonStyle}"
                                                Click="MsiFanApplyButton_Click"
                                                KeyDown="MsiFanApplyButton_KeyDown">
                                            <Button.Resources>
                                                <Storyboard x:Name="MsiFanApplyBlink" RepeatBehavior="Forever" AutoReverse="True">
                                                    <DoubleAnimation Storyboard.TargetName="MsiFanApplyButton"
                                                                     Storyboard.TargetProperty="Opacity"
                                                                     From="1.0" To="0.5" Duration="0:0:0.7"/>
                                                </Storyboard>
                                            </Button.Resources>
                                        </Button>

                                          </StackPanel>
                                        </Border>

                                        <!-- Verify the values actually written to the EC against the graph -->
                                        <StackPanel Margin="0,10,0,0">
                                            <Button x:Name="MsiFanCheckButton"
                                                    Content="Check applied values"
                                                    HorizontalAlignment="Left"
                                                    Style="{StaticResource StandaloneButtonStyle}"
                                                    Click="MsiFanCheckButton_Click"
                                                    KeyDown="MsiFanCheckButton_KeyDown"/>
                                            <TextBlock x:Name="MsiFanCheckStatus"
                                                       Margin="0,6,0,0"
                                                       FontSize="11" TextWrapping="Wrap"
                                                       Foreground="#A0A0A0"
                                                       Text=""/>
                                        </StackPanel>

                                        <!-- Extended range: unlock fan % above MSI's 75 % cap. Sits below the
                                             graph/verify block: it is a rarely-touched escape hatch, not part of
                                             the everyday edit-then-apply flow above. -->
                                        <Grid Margin="0,14,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Extended range (&gt;75%)" FontSize="13" Foreground="#E0E0E0"/>
                                                <TextBlock Text="Allow fan % beyond what MSI does" FontSize="11" Foreground="#999999"/>
                                            </StackPanel>
                                            <ToggleSwitch x:Name="MsiFanExtendedRangeToggle"
                                                          Grid.Column="1"
                                                          Style="{StaticResource ModernToggleStyle}"
                                                          IsOn="False"
                                                          VerticalAlignment="Center"
                                                          Toggled="MsiFanExtendedRangeToggle_Toggled"/>
                                        </Grid>
                                        <TextBlock Margin="0,8,0,0"
                                                   FontSize="11" Foreground="#A0A0A0" TextWrapping="Wrap"
                                                   Text="Custom curve: drag a bar up/down for its fan %. With a controller: D-Pad left/right to pick a bar, A to grab, D-Pad up/down to adjust, A/B to release. The temperatures under the bars are the firmware's own breakpoints and are shown for reference — like MSI Center M, only the fan % is adjustable. The curve is written to the EC (both fans). Turn this off to return to MSI's firmware control."/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <!-- TINY CENTER M TAB (MSI Claw hardware controller config, Center-M-conform).
                     Four collapsible sections, all collapsed by default: LED, charge limit,
                     stick/trigger deadzones and the hardware gyro. The LED + charge-limit cards
                     moved here verbatim from the System tab (same controls, same handlers) so
                     everything that talks to the controller hardware lives in one place. -->
                <ScrollViewer x:Name="TinyCenterMScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">
                        <TextBlock Text="Tiny Center M" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,2"/>
                        <TextBlock Text="Hardware controller settings, written straight to the controller and kept in sync with MSI Center M."
                                   FontSize="13" Foreground="#C8C8C8" TextWrapping="Wrap" Margin="0,0,0,10"/>
                        <TextBlock x:Name="TcmStatusText" FontSize="13" Foreground="#FFC107" TextWrapping="Wrap"
                                   Visibility="Collapsed" Margin="0,0,0,10"/>

                        <!-- ═══ 1. LED lighting ═══════════════════════════════════════════ -->
                        <!-- Controller LED Color (MSI Claw) — placed directly below Charge Limit.
                             Visibility is enabled by code on MSI Claw. -->
                        <Border x:Name="MsiLedColorCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Controller LED Color" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Set the controller LED color."
                                                   Style="{StaticResource CardCaptionStyle}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="MsiLedExpandButton"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  IsEnabled="True"
                                                  VerticalAlignment="Top"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="MsiLedExpandButton_Click">
                                        <FontIcon x:Name="MsiLedExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>
                                <StackPanel x:Name="MsiLedContent" Visibility="Collapsed" Margin="0,12,0,0"
                                            XYFocusKeyboardNavigation="Enabled">

                                    <!-- ── Sync all zones ─────────────────────────────────────────────── -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Sync right stick, left stick &amp; buttons" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Off lets you give the right stick, left stick and buttons their own individual colors and effects."
                                                       FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="MsiLedSyncToggle" Grid.Column="1"
                                                      OnContent="" OffContent="" IsOn="True"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      Toggled="MsiLedSyncToggle_Toggled"/>
                                    </Grid>

                                    <!-- ── Zone selector (only when NOT synced) ───────────────────────── -->
                                    <StackPanel x:Name="MsiLedZoneRow" Margin="0,0,0,12" Visibility="Collapsed">
                                        <TextBlock Text="Zone" FontSize="12" Foreground="#DDDDDD" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="MsiLedZoneCombo" Width="280" HorizontalAlignment="Left"
                                                  SelectionChanged="MsiLedZoneCombo_SelectionChanged">
                                            <ComboBoxItem>
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <Image Source="ms-appx:///Assets/ButtonIcons/xbox_stick_r.png" Width="20" Height="20"/>
                                                    <TextBlock Text="Right stick" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </ComboBoxItem>
                                            <ComboBoxItem>
                                                <StackPanel Orientation="Horizontal" Spacing="10">
                                                    <Image Source="ms-appx:///Assets/ButtonIcons/xbox_stick_l.png" Width="20" Height="20"/>
                                                    <TextBlock Text="Left stick" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </ComboBoxItem>
                                            <ComboBoxItem>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <Image Source="ms-appx:///Assets/ButtonIcons/xbox_button_color_a.png" Width="20" Height="20"/>
                                                    <Image Source="ms-appx:///Assets/ButtonIcons/xbox_button_color_b.png" Width="20" Height="20"/>
                                                    <Image Source="ms-appx:///Assets/ButtonIcons/xbox_button_color_x.png" Width="20" Height="20"/>
                                                    <Image Source="ms-appx:///Assets/ButtonIcons/xbox_button_color_y.png" Width="20" Height="20"/>
                                                    <TextBlock Text="Buttons" VerticalAlignment="Center" Margin="4,0,0,0"/>
                                                </StackPanel>
                                            </ComboBoxItem>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- ── Mode selector (per zone) ───────────────────────────────────── -->
                                    <TextBlock Text="Mode" FontSize="12" Foreground="#DDDDDD" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="MsiLedModeCombo" Width="280" HorizontalAlignment="Left"
                                              SelectionChanged="MsiLedModeCombo_SelectionChanged">
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <FontIcon Glyph="&#xE790;" FontSize="16"/><TextBlock Text="Static" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <FontIcon Glyph="&#xE706;" FontSize="16"/><TextBlock Text="Breathing" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <FontIcon Glyph="&#xE895;" FontSize="16"/><TextBlock Text="Color Cycle" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <FontIcon Glyph="&#xE72C;" FontSize="16"/><TextBlock Text="Wave" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <FontIcon Glyph="&#xE83F;" FontSize="16"/><TextBlock Text="Battery" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                    </ComboBox>

                                    <!-- ── Color (Static / Breathing-solid): swatch opens the colour wheel ── -->
                                    <StackPanel x:Name="MsiLedColorRow" Margin="0,14,0,0">
                                        <TextBlock Text="Color" FontSize="12" Foreground="#DDDDDD" Margin="0,0,0,4"/>
                                        <Button x:Name="MsiLedColorSwatchButton" Padding="2" BorderThickness="1"
                                                BorderBrush="#55FFFFFF" Background="#22FFFFFF" HorizontalAlignment="Left">
                                            <Border x:Name="MsiLedColorSwatch" Width="56" Height="28" CornerRadius="3" Background="#FFFFFF"/>
                                            <Button.Flyout>
                                                <Flyout>
                                                    <muxc:ColorPicker x:Name="MsiLedColorPicker"
                                                                      ColorSpectrumShape="Ring"
                                                                      IsAlphaEnabled="False" IsAlphaSliderVisible="False"
                                                                      IsColorSliderVisible="False"
                                                                      IsHexInputVisible="False" IsColorChannelTextInputVisible="False"
                                                                      IsMoreButtonVisible="False"
                                                                      Loaded="MsiLedPicker_Loaded"
                                                                      ColorChanged="MsiLedColorPicker_ColorChanged"/>
                                                </Flyout>
                                            </Button.Flyout>
                                        </Button>
                                    </StackPanel>

                                    <!-- ── Rainbow toggle (Breathing + Wave) ──────────────────────────── -->
                                    <Grid x:Name="MsiLedRainbowRow" Margin="0,14,0,0" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Rainbow" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock x:Name="MsiLedRainbowCaption" Text="On = rainbow. Off = your colour(s)."
                                                       FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="MsiLedRainbowToggle" Grid.Column="1"
                                                      OnContent="" OffContent="" IsOn="False"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      Toggled="MsiLedRainbowToggle_Toggled"/>
                                    </Grid>

                                    <!-- ── Wave custom colours: 4 swatches (Wave, Rainbow off) ────────── -->
                                    <StackPanel x:Name="MsiLedWaveSwatchRow" Orientation="Horizontal" Spacing="10" Margin="0,10,0,0" Visibility="Collapsed">
                                        <Button x:Name="MsiLedWaveSwatchButton0" Padding="2" BorderThickness="1" BorderBrush="#55FFFFFF" Background="#22FFFFFF">
                                            <Border x:Name="MsiLedWaveSwatch0" Width="40" Height="28" CornerRadius="3" Background="#FF0000"/>
                                            <Button.Flyout>
                                                <Flyout>
                                                    <muxc:ColorPicker x:Name="MsiLedWavePicker0" Tag="0" ColorSpectrumShape="Ring"
                                                                      IsAlphaEnabled="False" IsAlphaSliderVisible="False" IsColorSliderVisible="False"
                                                                      IsHexInputVisible="False" IsColorChannelTextInputVisible="False"
                                                                      IsMoreButtonVisible="False" Loaded="MsiLedPicker_Loaded" ColorChanged="MsiLedWavePicker_ColorChanged"/>
                                                </Flyout>
                                            </Button.Flyout>
                                        </Button>
                                        <Button x:Name="MsiLedWaveSwatchButton1" Padding="2" BorderThickness="1" BorderBrush="#55FFFFFF" Background="#22FFFFFF">
                                            <Border x:Name="MsiLedWaveSwatch1" Width="40" Height="28" CornerRadius="3" Background="#FFFF00"/>
                                            <Button.Flyout>
                                                <Flyout>
                                                    <muxc:ColorPicker x:Name="MsiLedWavePicker1" Tag="1" ColorSpectrumShape="Ring"
                                                                      IsAlphaEnabled="False" IsAlphaSliderVisible="False" IsColorSliderVisible="False"
                                                                      IsHexInputVisible="False" IsColorChannelTextInputVisible="False"
                                                                      IsMoreButtonVisible="False" Loaded="MsiLedPicker_Loaded" ColorChanged="MsiLedWavePicker_ColorChanged"/>
                                                </Flyout>
                                            </Button.Flyout>
                                        </Button>
                                        <Button x:Name="MsiLedWaveSwatchButton2" Padding="2" BorderThickness="1" BorderBrush="#55FFFFFF" Background="#22FFFFFF">
                                            <Border x:Name="MsiLedWaveSwatch2" Width="40" Height="28" CornerRadius="3" Background="#00FF00"/>
                                            <Button.Flyout>
                                                <Flyout>
                                                    <muxc:ColorPicker x:Name="MsiLedWavePicker2" Tag="2" ColorSpectrumShape="Ring"
                                                                      IsAlphaEnabled="False" IsAlphaSliderVisible="False" IsColorSliderVisible="False"
                                                                      IsHexInputVisible="False" IsColorChannelTextInputVisible="False"
                                                                      IsMoreButtonVisible="False" Loaded="MsiLedPicker_Loaded" ColorChanged="MsiLedWavePicker_ColorChanged"/>
                                                </Flyout>
                                            </Button.Flyout>
                                        </Button>
                                        <Button x:Name="MsiLedWaveSwatchButton3" Padding="2" BorderThickness="1" BorderBrush="#55FFFFFF" Background="#22FFFFFF">
                                            <Border x:Name="MsiLedWaveSwatch3" Width="40" Height="28" CornerRadius="3" Background="#0000FF"/>
                                            <Button.Flyout>
                                                <Flyout>
                                                    <muxc:ColorPicker x:Name="MsiLedWavePicker3" Tag="3" ColorSpectrumShape="Ring"
                                                                      IsAlphaEnabled="False" IsAlphaSliderVisible="False" IsColorSliderVisible="False"
                                                                      IsHexInputVisible="False" IsColorChannelTextInputVisible="False"
                                                                      IsMoreButtonVisible="False" Loaded="MsiLedPicker_Loaded" ColorChanged="MsiLedWavePicker_ColorChanged"/>
                                                </Flyout>
                                            </Button.Flyout>
                                        </Button>
                                    </StackPanel>

                                    <!-- ── Speed (Breathing / Color Cycle / Wave) ─────────────────────── -->
                                    <StackPanel x:Name="MsiLedSpeedRow" Margin="0,14,0,0" Visibility="Collapsed">
                                        <TextBlock Text="Speed" FontSize="12" Foreground="#DDDDDD" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="MsiLedSpeedCombo" Width="280" HorizontalAlignment="Left"
                                                  SelectionChanged="MsiLedSpeedCombo_SelectionChanged">
                                            <ComboBoxItem Content="Slow"/>
                                            <ComboBoxItem Content="Medium"/>
                                            <ComboBoxItem Content="Fast"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- ── Direction (Wave) ───────────────────────────────────────────── -->
                                    <StackPanel x:Name="MsiLedDirectionRow" Margin="0,14,0,0" Visibility="Collapsed">
                                        <TextBlock Text="Direction" FontSize="12" Foreground="#DDDDDD" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="MsiLedDirectionCombo" Width="280" HorizontalAlignment="Left"
                                                  SelectionChanged="MsiLedDirectionCombo_SelectionChanged">
                                            <ComboBoxItem Content="Clockwise"/>
                                            <ComboBoxItem Content="Counter-clockwise"/>
                                        </ComboBox>
                                    </StackPanel>

                                    <!-- ── Color Cycle note (shown only in Color Cycle mode) ──────────── -->
                                    <TextBlock x:Name="MsiLedCycleNote" Visibility="Collapsed" Margin="0,14,0,0"
                                               Text="Color Cycle sweeps smoothly through a colour spectrum. Custom cycle colours are coming in a follow-up."
                                               FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap"/>

                                    <!-- ── Brightness — GLOBAL (applies to ALL zones); visually separated ── -->
                                    <Border Height="1" Background="#22FFFFFF" Margin="0,18,0,0"/>
                                    <TextBlock x:Name="MsiLedBrightnessLabel" Text="Brightness"
                                               FontSize="12" Foreground="#DDDDDD" Margin="0,12,0,0"/>
                                    <TextBlock Text="Applies to all zones" FontSize="11"
                                               Foreground="{StaticResource HintTextBrush}" Margin="0,0,0,2"/>
                                    <Slider x:Name="MsiLedBrightnessSlider" Minimum="0" Maximum="100"
                                            Width="280" HorizontalAlignment="Left"
                                            XYFocusUp="{x:Bind MsiLedSpeedCombo}"
                                            ValueChanged="MsiLedBrightnessSlider_ValueChanged"/>

                                    <!-- ── Battery note (shown only in Battery mode) ──────────────────── -->
                                    <TextBlock x:Name="MsiLedBatteryNote" Visibility="Collapsed" Margin="0,10,0,0"
                                               Text="Battery: the LED hue follows the charge level (≥90% blue → &lt;20% purple), updated when it crosses a 10% band. The slider above sets its brightness."
                                               FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap"/>

                                    <!-- Legacy compat control — kept Collapsed so its existing code-behind
                                         handler keeps compiling (the old battery toggle is superseded by the
                                         Battery mode above). -->
                                    <ToggleSwitch x:Name="LedColorBySocToggle" Visibility="Collapsed"
                                                  OnContent="" OffContent="" IsOn="False" Toggled="LedColorBySocToggle_Toggled"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ═══ 2. Charge limit ══════════════════════════════════════════ -->
                        <!-- Charge Limit Card (MSI Claw A1M / A2VM) -->
                        <Border x:Name="MsiChargeLimitCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <!-- Header: title + expand toggle. The enable toggle lives inside the
                                     collapsible body (there is a separate Quick Settings tile that shows
                                     the charge limit), so the header stays clean when collapsed. -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Charge Limit" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Limit battery charging to extend long-term lifespan"
                                                   Style="{StaticResource CardCaptionStyle}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="ChargeLimitExpandButton" Grid.Column="1" IsChecked="False"
                                                  VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Padding="8,4"
                                                  Click="ChargeLimitExpandButton_Click" UseSystemFocusVisuals="True">
                                        <FontIcon x:Name="ChargeLimitExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <!-- Collapsible content -->
                                <StackPanel x:Name="MsiChargeLimitContent" Visibility="Collapsed" Margin="0,12,0,0">
                                <!-- Enable toggle (moved out of the header) -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Enable charge limit" FontSize="13" Foreground="#FFFFFF"/>
                                        <TextBlock Text="Stop charging once the battery reaches the level below."
                                                   FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="MsiChargeLimitToggle"
                                                  Grid.Column="1"
                                                  OnContent="" OffContent=""
                                                  IsOn="False"
                                                  Toggled="MsiChargeLimitToggle_Toggled"/>
                                </Grid>
                                <!-- Percentage selection — shown when toggle is on -->
                                <StackPanel x:Name="MsiChargeLimitPercentPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <Grid Margin="0,0,0,2">
                                        <TextBlock Text="Charge to at most" FontSize="12" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="MsiChargeLimitValue" Text="80%"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   FontSize="14" Foreground="#4CAF50" FontWeight="SemiBold"/>
                                    </Grid>
                                    <Slider x:Name="MsiChargeLimitSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="20" Maximum="100"
                                            StepFrequency="5" TickFrequency="10"
                                            TickPlacement="Outside" SnapsTo="StepValues"
                                            Value="80"
                                            XYFocusUp="{x:Bind MsiChargeLimitToggle}"
                                            XYFocusDown="{x:Bind MsiChargeLimitVerifyButton}"
                                            ValueChanged="MsiChargeLimitSlider_ValueChanged"/>

                                    <!-- Read-back / verification row (reads the actual EC value) -->
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="MsiChargeLimitStatusText" Grid.Column="0"
                                                   Text="" FontSize="11" Foreground="{StaticResource HintTextBrush}"
                                                   TextWrapping="Wrap" VerticalAlignment="Center"/>
                                        <Button x:Name="MsiChargeLimitVerifyButton" Grid.Column="1"
                                                Content="Verify" FontSize="12" Padding="12,4"
                                                Click="MsiChargeLimitVerifyButton_Click"/>
                                    </Grid>

                                    <TextBlock Text="Note: the limit is enforced by the controller (EC) itself, so it keeps working while the Claw is asleep or shut down but plugged in. The EC value can be cleared by an EC reset, BIOS update or a full battery drain — use Verify to re-check the live value after sleep / hibernation."
                                               FontSize="11" Foreground="#FF8C00"
                                               TextWrapping="Wrap" Margin="0,8,0,0"/>
                                </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ═══ 3. Stick & trigger deadzones / limits ════════════════════ -->
                        <Border x:Name="TcmSticksCard" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Stick &amp; Trigger Settings" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Deadzones and limits for both sticks and triggers, written straight to the controller."
                                                   Style="{StaticResource CardCaptionStyle}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="TcmSticksExpandButton" Grid.Column="1" IsChecked="False"
                                                  VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Padding="8,4"
                                                  Click="TcmSticksExpandButton_Click" UseSystemFocusVisuals="True">
                                        <FontIcon x:Name="TcmSticksExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <StackPanel x:Name="TcmSticksContent" Visibility="Collapsed" Margin="0,12,0,0"
                                            XYFocusKeyboardNavigation="Enabled">
                                    <!-- Slider drags only STAGE a change; this button is what actually writes
                                         firmware + profile.rec and bounces Center M. Hence it sits on top. -->
                                    <Button x:Name="TcmApplyButton" Click="TcmApply_Click" IsEnabled="False"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Padding="12,10" Margin="0,0,0,8"
                                            XYFocusUp="{x:Bind TcmSticksExpandButton}"
                                            XYFocusDown="{x:Bind TcmResetButton}">
                                        <StackPanel Orientation="Horizontal">
                                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE73E;" FontSize="14" Margin="0,0,8,0"/>
                                            <TextBlock x:Name="TcmApplyText" Text="No unsaved changes"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- One reset for sticks AND triggers. Stages the MSI factory values like any
                                         other edit, so it still goes through Apply above. -->
                                    <Button x:Name="TcmResetButton" Content="Reset sticks &amp; triggers to default"
                                            Click="TcmResetAll_Click"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Padding="12,6"
                                            XYFocusUp="{x:Bind TcmApplyButton}"
                                            XYFocusDown="{x:Bind TcmLSDZSlider}"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,16,0,8">
                                        <Image Source="ms-appx:///Assets/ButtonIcons/xbox_stick_l.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                        <TextBlock Text="Left stick" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Margin="28,0,0,0">
                                        <Grid><TextBlock Text="Inner deadzone"/><TextBlock x:Name="TcmLSDZValue" Text="—" HorizontalAlignment="Right"/></Grid>
                                        <Slider x:Name="TcmLSDZSlider" Tag="LSDZ" Minimum="0" Maximum="50" StepFrequency="1" SmallChange="1" ValueChanged="TcmSlider_ValueChanged"
                                                XYFocusUp="{x:Bind TcmResetButton}" XYFocusDown="{x:Bind TcmLSEDZSlider}"/>
                                        <Grid Margin="0,8,0,0"><TextBlock Text="Outer threshold"/><TextBlock x:Name="TcmLSEDZValue" Text="—" HorizontalAlignment="Right"/></Grid>
                                        <Slider x:Name="TcmLSEDZSlider" Tag="LSEDZ" Minimum="75" Maximum="100" StepFrequency="1" SmallChange="1" ValueChanged="TcmSlider_ValueChanged"
                                                XYFocusUp="{x:Bind TcmLSDZSlider}" XYFocusDown="{x:Bind TcmRSDZSlider}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,16,0,8">
                                        <Image Source="ms-appx:///Assets/ButtonIcons/xbox_stick_r.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                        <TextBlock Text="Right stick" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Margin="28,0,0,0">
                                        <Grid><TextBlock Text="Inner deadzone"/><TextBlock x:Name="TcmRSDZValue" Text="—" HorizontalAlignment="Right"/></Grid>
                                        <Slider x:Name="TcmRSDZSlider" Tag="RSDZ" Minimum="0" Maximum="50" StepFrequency="1" SmallChange="1" ValueChanged="TcmSlider_ValueChanged"
                                                XYFocusUp="{x:Bind TcmLSEDZSlider}" XYFocusDown="{x:Bind TcmRSEDZSlider}"/>
                                        <Grid Margin="0,8,0,0"><TextBlock Text="Outer threshold"/><TextBlock x:Name="TcmRSEDZValue" Text="—" HorizontalAlignment="Right"/></Grid>
                                        <Slider x:Name="TcmRSEDZSlider" Tag="RSEDZ" Minimum="75" Maximum="100" StepFrequency="1" SmallChange="1" ValueChanged="TcmSlider_ValueChanged"
                                                XYFocusUp="{x:Bind TcmRSDZSlider}" XYFocusDown="{x:Bind TcmLTDZSlider}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,16,0,8">
                                        <Image Source="ms-appx:///Assets/ButtonIcons/xbox_lt.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                        <TextBlock Text="Left trigger" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Margin="28,0,0,0">
                                        <Grid><TextBlock Text="Deadzone"/><TextBlock x:Name="TcmLTDZValue" Text="—" HorizontalAlignment="Right"/></Grid>
                                        <Slider x:Name="TcmLTDZSlider" Tag="LTDZ" Minimum="0" Maximum="50" StepFrequency="1" SmallChange="1" ValueChanged="TcmSlider_ValueChanged"
                                                XYFocusUp="{x:Bind TcmRSEDZSlider}" XYFocusDown="{x:Bind TcmLTEDZSlider}"/>
                                        <Grid Margin="0,8,0,0"><TextBlock Text="Limit"/><TextBlock x:Name="TcmLTEDZValue" Text="—" HorizontalAlignment="Right"/></Grid>
                                        <Slider x:Name="TcmLTEDZSlider" Tag="LTEDZ" Minimum="50" Maximum="100" StepFrequency="1" SmallChange="1" ValueChanged="TcmSlider_ValueChanged"
                                                XYFocusUp="{x:Bind TcmLTDZSlider}" XYFocusDown="{x:Bind TcmRTDZSlider}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,16,0,8">
                                        <Image Source="ms-appx:///Assets/ButtonIcons/xbox_rt.png" Width="20" Height="20" Margin="0,0,8,0"/>
                                        <TextBlock Text="Right trigger" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <StackPanel Margin="28,0,0,0">
                                        <Grid><TextBlock Text="Deadzone"/><TextBlock x:Name="TcmRTDZValue" Text="—" HorizontalAlignment="Right"/></Grid>
                                        <Slider x:Name="TcmRTDZSlider" Tag="RTDZ" Minimum="0" Maximum="50" StepFrequency="1" SmallChange="1" ValueChanged="TcmSlider_ValueChanged"
                                                XYFocusUp="{x:Bind TcmLTEDZSlider}" XYFocusDown="{x:Bind TcmRTEDZSlider}"/>
                                        <Grid Margin="0,8,0,0"><TextBlock Text="Limit"/><TextBlock x:Name="TcmRTEDZValue" Text="—" HorizontalAlignment="Right"/></Grid>
                                        <Slider x:Name="TcmRTEDZSlider" Tag="RTEDZ" Minimum="50" Maximum="100" StepFrequency="1" SmallChange="1" ValueChanged="TcmSlider_ValueChanged"
                                                XYFocusUp="{x:Bind TcmRTDZSlider}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- ═══ 4. Hardware gyro (detect + disable only) ═════════════════ -->
                        <!-- The firmware gyro is MSI Center M's own motion feature, living in EEPROM
                             0x0029 bit0 (RE-verified on A2VM). It runs inside the controller and keeps
                             running independently of ClawTweaks' virtual gyro, which is why the two can
                             fight. This section only READS that bit and offers a one-way off switch —
                             there is deliberately no enable path, turning it back on stays Center M's job. -->
                        <Border x:Name="TcmGyroCard" Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Hardware Gyro" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Detect MSI's firmware gyro and turn it off."
                                                   Style="{StaticResource CardCaptionStyle}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="TcmGyroExpandButton" Grid.Column="1" IsChecked="False"
                                                  VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Padding="8,4"
                                                  Click="TcmGyroExpandButton_Click" UseSystemFocusVisuals="True">
                                        <FontIcon x:Name="TcmGyroExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <StackPanel x:Name="TcmGyroContent" Visibility="Collapsed" Margin="0,12,0,0"
                                            XYFocusKeyboardNavigation="Enabled">
                                    <Grid>
                                        <TextBlock Text="Firmware gyro" FontSize="13" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TcmGyroStateText" Text="—"
                                                   HorizontalAlignment="Right" VerticalAlignment="Center"
                                                   FontSize="14" FontWeight="SemiBold" Foreground="#C8C8C8"/>
                                    </Grid>
                                    <TextBlock Text="Set in MSI Center M and stored in the controller itself, so it stays active even with Center M closed. If it is on while ClawTweaks' own gyro runs, both drive the stick at once."
                                               FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                    <Button x:Name="TcmGyroDisableButton" Content="Turn firmware gyro off"
                                            Click="TcmGyroDisable_Click" IsEnabled="False"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Padding="12,6" Margin="0,10,0,0"
                                            XYFocusUp="{x:Bind TcmGyroExpandButton}"/>
                                    <TextBlock Text="Writes straight to the controller. Turning it back on is done in MSI Center M."
                                               FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap" Margin="0,6,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>

                <!-- SCALING TAB -->
                <ScrollViewer x:Name="ScalingScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Status Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Lossless Scaling Status" Style="{StaticResource CardTitleStyle}" Grid.Column="0" VerticalAlignment="Center"/>
                                    <Button x:Name="ShowLosslessScalingWindowButton"
                                            Grid.Column="1"
                                            Content="Show Window"
                                            Margin="0,0,8,0"
                                            Visibility="Collapsed"
                                            Click="ShowLosslessScalingWindowButton_Click"
                                            XYFocusUp="{x:Bind ScalingNavItem}"/>
                                    <Button x:Name="LaunchLosslessScalingButton"
                                            Grid.Column="2"
                                            Visibility="Collapsed"
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Click="LaunchLosslessScalingButton_Click"
                                            XYFocusUp="{x:Bind ScalingNavItem}">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE768;" FontSize="14" VerticalAlignment="Center"/>
                                            <TextBlock Text="Launch" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </Grid>
                                <TextBlock x:Name="LosslessScalingStatusText"
                                           Text="Not Installed"
                                           FontSize="14"
                                           Foreground="#A0A0A0"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Current Profile Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Current Profile" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock x:Name="LosslessScalingCurrentProfileText"
                                                   Text="Default"
                                                   FontSize="14"
                                                   Foreground="#00C8FF"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button x:Name="LosslessScalingCreateProfileButton"
                                            Grid.Column="1"
                                            Content="Create Profile"
                                            VerticalAlignment="Center"
                                            IsEnabled="False"
                                            FontSize="16"
                                            FontWeight="SemiBold"
                                            Click="LosslessScalingCreateProfileButton_Click"
                                            XYFocusUp="{x:Bind ScalingNavItem}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Scale Toggle Button -->
                        <ToggleButton x:Name="LosslessScalingEnabledToggle"
                                      HorizontalAlignment="Stretch"
                                      IsEnabled="False"
                                      FontSize="16"
                                      FontWeight="SemiBold"
                                      Margin="0,10,0,0"
                                      Style="{StaticResource StandaloneToggleButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                                <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                    <PathIcon Data="M5 5.27368C5 3.56682 6.82609 2.48151 8.32538 3.2973L20.687 10.0235C22.2531 10.8756 22.2531 13.124 20.687 13.9762L8.32538 20.7024C6.82609 21.5181 5 20.4328 5 18.726V5.27368Z"/>
                                </Viewbox>
                                <TextBlock Text="Lossless Scaling" VerticalAlignment="Center" FontSize="16" FontWeight="SemiBold"/>
                            </StackPanel>
                        </ToggleButton>

                        <!-- Apply and Restart Button -->
                        <Button x:Name="LosslessScalingSaveSettingsButton"
                                Content="Apply and Restart"
                                HorizontalAlignment="Stretch"
                                Margin="0,8,0,0"
                                IsEnabled="False"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Style="{StaticResource StandaloneButtonStyle}"
                                Click="LosslessScalingSaveSettingsButton_Click"/>

                        <!-- Reset Profile Button -->
                        <Button x:Name="LosslessScalingResetProfileButton"
                                Content="Reset to Defaults"
                                HorizontalAlignment="Stretch"
                                Margin="0,8,0,0"
                                IsEnabled="False"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Style="{StaticResource StandaloneButtonStyle}"
                                Click="LosslessScalingResetProfileButton_Click"/>

                        <!-- AutoScale Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="AutoScale" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Automatically detect and scale games"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LosslessScalingAutoScaleToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                                <StackPanel Visibility="{Binding ElementName=LosslessScalingAutoScaleToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid Margin="0,8,0,0">
                                        <TextBlock Text="AutoScale Delay (s)"
                                                   FontSize="14"
                                                   Foreground="#A0A0A0"/>
                                        <TextBlock x:Name="LosslessScalingAutoScaleDelayValueText"
                                                   Text="{Binding ElementName=LosslessScalingAutoScaleDelaySlider, Path=Value}"
                                                   FontSize="14"
                                                   Foreground="#00C8FF"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="LosslessScalingAutoScaleDelaySlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="10"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Scaling Type Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Scaling Algorithm" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                                <ComboBox x:Name="LosslessScalingScalingTypeComboBox"
                                          PlaceholderText="Select Type"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectionChanged="LosslessScalingScalingTypeComboBox_SelectionChanged">
                                    <x:String>Off</x:String>
                                    <x:String>LS1</x:String>
                                    <x:String>FSR</x:String>
                                    <x:String>NIS</x:String>
                                    <x:String>SGSR</x:String>
                                    <x:String>BCAS</x:String>
                                    <x:String>Anime4K</x:String>
                                    <x:String>xBR</x:String>
                                    <x:String>Sharp Bilinear</x:String>
                                    <x:String>Integer</x:String>
                                    <x:String>Nearest Neighbor</x:String>
                                </ComboBox>

                                <!-- Sharpness Slider (for FSR, NIS, SGSR, BCAS) -->
                                <StackPanel x:Name="LosslessScalingSharpnessPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <Grid>
                                        <TextBlock Text="Sharpness" FontSize="12" Foreground="#A0A0A0"/>
                                        <TextBlock x:Name="LosslessScalingSharpnessValueText"
                                                   Text="{Binding ElementName=LosslessScalingSharpnessSlider, Path=Value}"
                                                   FontSize="12"
                                                   Foreground="#00C8FF"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="LosslessScalingSharpnessSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="100"
                                            TickFrequency="10"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            IsEnabled="False"/>
                                </StackPanel>

                                <!-- FSR Optimize Toggle (FSR only) -->
                                <Grid x:Name="LosslessScalingFSROptimizePanel" Visibility="Collapsed" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Optimize" FontSize="12" Foreground="#A0A0A0" VerticalAlignment="Center"/>
                                    <ToggleSwitch x:Name="LosslessScalingFSROptimizeToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>

                                <!-- LS1 Type (LS1 only) — BALANCED vs PERFORMANCE -->
                                <StackPanel x:Name="LosslessScalingLS1TypePanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <TextBlock Text="LS1 Type" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="LosslessScalingLS1TypeComboBox"
                                              PlaceholderText="Select Type"
                                              Width="Auto"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="False"
                                              Style="{StaticResource ModernComboBoxStyle}">
                                        <x:String>BALANCED</x:String>
                                        <x:String>PERFORMANCE</x:String>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Resize Before Scale (any non-Off scaling type) -->
                                <Grid x:Name="LosslessScalingResizeBeforePanel" Visibility="Collapsed" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Resize Before Scale" FontSize="12" Foreground="#A0A0A0"/>
                                        <TextBlock Text="Snap window to integer ratio before upscale"
                                                   FontSize="11" Foreground="#707070"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LosslessScalingResizeBeforeToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>

                                <!-- Anime4K Settings -->
                                <StackPanel x:Name="LosslessScalingAnime4KPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <TextBlock Text="Size" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="LosslessScalingAnime4KSizeComboBox"
                                              PlaceholderText="Select Size"
                                              Width="Auto"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="False"
                                              Style="{StaticResource ModernComboBoxStyle}">
                                        <x:String>Small</x:String>
                                        <x:String>Medium</x:String>
                                        <x:String>Large</x:String>
                                        <x:String>Very Large</x:String>
                                        <x:String>Ultra Large</x:String>
                                    </ComboBox>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="VRS" FontSize="12" Foreground="#A0A0A0" VerticalAlignment="Center"/>
                                        <ToggleSwitch x:Name="LosslessScalingAnime4KVRSToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      IsEnabled="False"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Scale Mode Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Scale Mode" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                                <ComboBox x:Name="LosslessScalingScaleModeComboBox"
                                          PlaceholderText="Select Mode"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectionChanged="LosslessScalingScaleModeComboBox_SelectionChanged">
                                    <x:String>Auto</x:String>
                                    <x:String>Custom</x:String>
                                </ComboBox>

                                <!-- Auto Mode Settings -->
                                <StackPanel x:Name="LosslessScalingAutoModePanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <TextBlock Text="Aspect" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="LosslessScalingAspectRatioComboBox"
                                              PlaceholderText="Select Aspect"
                                              Width="Auto"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="False"
                                              Style="{StaticResource ModernComboBoxStyle}">
                                        <x:String>Aspect Ratio</x:String>
                                        <x:String>Fullscreen</x:String>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Custom Mode Settings -->
                                <StackPanel x:Name="LosslessScalingCustomModePanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <Grid>
                                        <TextBlock Text="Scale Factor" FontSize="12" Foreground="#A0A0A0"/>
                                        <TextBlock x:Name="LosslessScalingScaleFactorValueText"
                                                   Text="{Binding ElementName=LosslessScalingScaleFactorSlider, Path=Value}"
                                                   FontSize="12"
                                                   Foreground="#00C8FF"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="LosslessScalingScaleFactorSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="1" Maximum="5"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Frame Generation Type Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Frame Generation" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                                <ComboBox x:Name="LosslessScalingFrameGenTypeComboBox"
                                          PlaceholderText="Select Type"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}">
                                    <x:String>Off</x:String>
                                    <x:String>LSFG1</x:String>
                                    <x:String>LSFG2</x:String>
                                    <x:String>LSFG3</x:String>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- LSFG3 Settings Card -->
                        <Border x:Name="LSFG3SettingsCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="LSFG3 Settings" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>

                                <!-- LSFG3 Mode -->
                                <TextBlock Text="Mode" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                <ComboBox x:Name="LosslessScalingLSFG3ModeComboBox"
                                          PlaceholderText="Select Mode"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          Margin="0,0,0,12"
                                          SelectionChanged="LosslessScalingLSFG3ModeComboBox_SelectionChanged">
                                    <x:String>FIXED</x:String>
                                    <x:String>ADAPTIVE</x:String>
                                </ComboBox>

                                <!-- LSFG3 Multiplier (hidden when Adaptive) -->
                                <StackPanel x:Name="LosslessScalingLSFG3MultiplierPanel">
                                    <TextBlock Text="Multiplier" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="LosslessScalingLSFG3MultiplierComboBox"
                                              PlaceholderText="Select Multiplier"
                                              Width="Auto"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="False"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              Margin="0,0,0,12">
                                        <x:String>2</x:String>
                                        <x:String>3</x:String>
                                        <x:String>4</x:String>
                                    </ComboBox>
                                </StackPanel>

                                <!-- LSFG3 Target FPS -->
                                <Grid>
                                    <TextBlock Text="Target FPS" FontSize="12" Foreground="#A0A0A0"/>
                                    <TextBlock x:Name="LosslessScalingLSFG3TargetValueText"
                                               Text="{Binding ElementName=LosslessScalingLSFG3TargetSlider, Path=Value}"
                                               FontSize="12"
                                               Foreground="#00C8FF"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="LosslessScalingLSFG3TargetSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="30" Maximum="240"
                                        TickFrequency="10"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"
                                        Margin="0,0,0,12"/>

                                <!-- Flow Scale -->
                                <Grid>
                                    <TextBlock Text="Flow Scale" FontSize="12" Foreground="#A0A0A0"/>
                                    <TextBlock x:Name="LosslessScalingFlowScaleValueText"
                                               Text="{Binding ElementName=LosslessScalingFlowScaleSlider, Path=Value}"
                                               FontSize="12"
                                               Foreground="#00C8FF"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="LosslessScalingFlowScaleSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="25" Maximum="100"
                                        TickFrequency="5"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"
                                        Margin="0,0,0,12"/>

                                <!-- Size Toggle (Performance/Balanced) -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Performance Mode" FontSize="14" Foreground="#FFFFFF"/>
                                        <TextBlock Text="Lighter model for less input lag"
                                                   FontSize="11"
                                                   Foreground="#A0A0A0"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LosslessScalingSizeToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- LSFG2 Settings Card -->
                        <Border x:Name="LSFG2SettingsCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="LSFG2 Settings" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>

                                <!-- LSFG2 Mode -->
                                <TextBlock Text="Mode" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                <ComboBox x:Name="LosslessScalingLSFG2ModeComboBox"
                                          PlaceholderText="Select Mode"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}">
                                    <x:String>X2</x:String>
                                    <x:String>X3</x:String>
                                    <x:String>X4</x:String>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- Sync & Display Card (added 2026-05-01) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Sync &amp; Display" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>

                                <!-- Sync Mode -->
                                <TextBlock Text="Sync Mode" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                <ComboBox x:Name="LosslessScalingSyncModeComboBox"
                                          PlaceholderText="Select Mode"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          Margin="0,0,0,12">
                                    <x:String>OFF</x:String>
                                    <x:String>DEFAULT</x:String>
                                    <x:String>VSYNC1</x:String>
                                    <x:String>VSYNC2</x:String>
                                    <x:String>VSYNC3</x:String>
                                    <x:String>VSYNC4</x:String>
                                </ComboBox>

                                <!-- Max Frame Latency -->
                                <Grid>
                                    <TextBlock Text="Max Frame Latency" FontSize="12" Foreground="#A0A0A0"/>
                                    <TextBlock x:Name="LosslessScalingMaxFrameLatencyValueText"
                                               Text="{Binding ElementName=LosslessScalingMaxFrameLatencySlider, Path=Value}"
                                               FontSize="12"
                                               Foreground="#00C8FF"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="LosslessScalingMaxFrameLatencySlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="4"
                                        TickFrequency="1"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"
                                        Margin="0,0,0,12"/>

                                <!-- HDR Support -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="HDR Support" FontSize="14" Foreground="#FFFFFF"/>
                                        <TextBlock Text="Preserve HDR through scaling/FG"
                                                   FontSize="11" Foreground="#A0A0A0"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LosslessScalingHdrSupportToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>

                                <!-- G-Sync Support -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="G-Sync / VRR Support" FontSize="14" Foreground="#FFFFFF"/>
                                        <TextBlock Text="Improves pacing on VRR displays"
                                                   FontSize="11" Foreground="#A0A0A0"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LosslessScalingGsyncSupportToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Capture & Overlay Card (added 2026-05-01) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Capture &amp; Overlay" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>

                                <!-- Capture API -->
                                <TextBlock Text="Capture API" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                <ComboBox x:Name="LosslessScalingCaptureApiComboBox"
                                          PlaceholderText="Select API"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          Margin="0,0,0,12">
                                    <x:String>DXGI</x:String>
                                    <x:String>WGC</x:String>
                                    <x:String>GDI</x:String>
                                </ComboBox>
                                <TextBlock Text="WGC = best compat, DXGI = lower latency, GDI = legacy"
                                           FontSize="11" Foreground="#707070" Margin="0,0,0,8"/>

                                <!-- Draw FPS overlay -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Draw FPS Overlay" FontSize="14" Foreground="#FFFFFF"/>
                                        <TextBlock Text="LS draws fps counter on top-left of scaled output"
                                                   FontSize="11" Foreground="#A0A0A0"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LosslessScalingDrawFpsToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Conflict Warning Card -->
                        <Border Style="{StaticResource CardStyle}" x:Name="LSConflictWarningBorder" Visibility="Collapsed" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Conflict Detected"
                                           Style="{StaticResource CardTitleStyle}"
                                           Foreground="#FFA500"/>
                                <TextBlock x:Name="LSConflictWarningText"
                                           Text="AMD Fluid Motion Frames has been automatically disabled because it conflicts with Lossless Scaling Frame Generation."
                                           FontSize="12"
                                           Foreground="#FFA500"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- LEGION TAB -->
                <ScrollViewer x:Name="LegionScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Virtual Controller master toggle — top of the Controller tab. Slim standalone
                             card (no expander): turns the virtual controller + mouse runtime on/off. Hidden
                             in-game and while unsupported (same gate as the other controller cards). -->
                        <Border x:Name="VirtualControllerMasterCard" Style="{StaticResource CardStyle}"
                                BorderBrush="{StaticResource ThemeAccentBrush}" Visibility="Collapsed">
                            <StackPanel>
                                <!-- MSI Center M conflict warning -->
                                <Border x:Name="MsiCenterControllerWarning" Background="#2A1800" BorderBrush="#FFA500"
                                        BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,6,0,0" Visibility="Collapsed">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE7BA;" FontSize="13" Foreground="#FFA500" VerticalAlignment="Top" Margin="0,1,0,0"/>
                                        <TextBlock Text="MSI Center M is active — controller emulation and gyro unavailable. Disable it via the MSI Center tile in the Quick Tab."
                                                   FontSize="11" Foreground="#FFA500" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                                <!-- Steam Xbox Extended Feature Support driver warning -->
                                <Border x:Name="SteamXboxDriverWarning" Background="#220000" BorderBrush="#FF5050"
                                        BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,6,0,0" Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Grid.Column="0" Glyph="&#xE7BA;" FontSize="13" Foreground="#FF5050" VerticalAlignment="Top" Margin="0,1,8,0"/>
                                        <TextBlock Grid.Column="1" FontSize="11" Foreground="#FF5050" TextWrapping="Wrap"
                                                   Text="Steam's &quot;Xbox Extended Feature Support&quot; driver is active. It intercepts HID reports and prevents virtual controller emulation. Disable it in Steam → Settings → Controller → uncheck &quot;Xbox Extended Feature Support&quot;."/>
                                    </Grid>
                                </Border>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Main Controller Mode" FontSize="14" Foreground="#FFFFFF"/>
                                        <TextBlock x:Name="ControllerEmulationStatusText"
                                                   Text="Main mode for all games. Hardware = native XInput + firmware remaps. Virtual = emulated pad, gyro, Mouse Mode &amp; macros. Per game: enable the Controller Profile to set the opposite mode as an exception."
                                                   FontSize="11" Foreground="#C8C8C8" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <!-- User-facing standard-mode picker. Drives the DefaultControllerMode
                                         setting; the helper derives ControllerEmulationEnabled and mirrors
                                         it back into the (now hidden) master toggle that the gating logic
                                         still reads. Each item carries a round status dot matching the
                                         Controller Status card colours: blue = Hardware, green = Virtual. -->
                                    <ComboBox x:Name="DefaultControllerModeComboBox"
                                              Grid.Column="1" MinWidth="170"
                                              VerticalAlignment="Center"
                                              IsEnabled="False">
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Ellipse Width="12" Height="12" Fill="#2E9BFF" VerticalAlignment="Center"/>
                                                <TextBlock Text="Hardware Controller" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal" Spacing="10">
                                                <Ellipse Width="12" Height="12" Fill="#00C853" VerticalAlignment="Center"/>
                                                <TextBlock Text="Virtual Controller" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                    </ComboBox>
                                    <!-- Hidden mirror of the standard mode as a bool ("virtual pad should
                                         run"). Kept so the existing IsVirtualControllerActive gating and
                                         focus wiring stay unchanged; the helper drives its value. -->
                                    <ToggleSwitch x:Name="ControllerEmulationEnabledToggle"
                                                  Grid.Column="1" IsOn="False"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"
                                                  Visibility="Collapsed"
                                                  Toggled="ControllerEmulationEnabledToggle_Toggled"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Per-Game Controller Profile Card — same layout as the Performance tab's
                             "Per Game performance & display profile" card (ActiveProfileCard): a
                             large far-left game icon, title, then badge + detected-game text row. -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Far-left: game icon, sized to the card. Collapsed (zero width)
                                         when no game runs, so the text gets the full width. -->
                                    <Image x:Name="LegionControllerProfileGameIcon"
                                           Grid.Column="0"
                                           Width="48" Height="48"
                                           Margin="0,0,12,0"
                                           Stretch="UniformToFill"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"/>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                        <TextBlock Text="Per-Game Controller Profile" Style="{StaticResource CardTitleStyle}"/>
                                        <!-- Badge + detected game on one row: badge left, game status to its right. -->
                                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0" VerticalAlignment="Center">
                                            <Border x:Name="ControllerProfileModeBadge"
                                                    Background="#37260C"
                                                    BorderBrush="#A06E28"
                                                    BorderThickness="1"
                                                    CornerRadius="4"
                                                    Padding="8,3"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Left">
                                                <TextBlock x:Name="ControllerProfileModeText"
                                                           Text="Editing Global Profile"
                                                           FontSize="11"
                                                           Foreground="#FFAA46"/>
                                            </Border>
                                            <TextBlock x:Name="LegionControllerProfileGameText"
                                                       Text="No app/game detected"
                                                       Style="{StaticResource CardCaptionStyle}"
                                                       Margin="10,0,0,0"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <ToggleSwitch x:Name="LegionControllerProfileToggle"
                                                  Grid.Column="2"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsOn="False"
                                                  IsEnabled="False"
                                                  VerticalAlignment="Top"
                                                  Toggled="LegionControllerProfileToggle_Toggled"/>
                                </Grid>
                                <TextBlock x:Name="PerGameProfileHelpText"
                                           Text="Start a game to enable a per-game controller profile."
                                           Style="{StaticResource CardCaptionStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0"
                                           Visibility="Collapsed"/>

                                <!-- Shown while a per-game profile exists (toggle locked on): the profile's
                                     existence IS the on/off state, so the only way to turn it off is to delete it. -->
                                <TextBlock x:Name="LegionControllerProfileLockHint"
                                           Text="This game has its own controller profile, so it stays active automatically. To switch back to the global profile, delete it under Saved Profiles."
                                           Style="{StaticResource CardCaptionStyle}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0"
                                           Visibility="Collapsed"/>

                                <!-- Per-game capture scope: user picks which categories the per-game
                                     profile should override. Unchecked categories stay global even
                                     when the master Per-Game Controller Profile toggle is on. -->
                                <!-- Per-game capture checkboxes: hidden on MSI Claw.
                                     NintendoLayout + ButtonMappings are forced to true in code (ProfileCustomization.cs).
                                     Named controls kept for code-behind compat. -->
                                <StackPanel Visibility="Collapsed">
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="Customize per-game capture"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   VerticalAlignment="Center"/>
                                        <ToggleButton x:Name="LegionControllerProfileScopeExpandToggle"
                                                      Grid.Column="1"
                                                      IsChecked="False"
                                                      VerticalAlignment="Center"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      Padding="8,4"
                                                      Click="LegionControllerProfileScopeExpandToggle_Click">
                                            <FontIcon x:Name="LegionControllerProfileScopeExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                        </ToggleButton>
                                    </Grid>
                                    <StackPanel x:Name="LegionControllerProfileScopeContent" Margin="0,8,0,0">
                                        <CheckBox x:Name="ProfileSaveNintendoLayoutCheckBox"
                                                  Content="Nintendo Layout" IsChecked="True"
                                                  Checked="ProfileSettingsCheckBox_Changed"
                                                  Unchecked="ProfileSettingsCheckBox_Changed"/>
                                        <CheckBox x:Name="ProfileSaveVibrationCheckBox"
                                                  Content="Vibration" IsChecked="False"
                                                  Checked="ProfileSettingsCheckBox_Changed"
                                                  Unchecked="ProfileSettingsCheckBox_Changed"/>
                                        <CheckBox x:Name="ProfileSaveLightingCheckBox"
                                                  Content="Lighting" IsChecked="False"
                                                  Checked="ProfileSettingsCheckBox_Changed"
                                                  Unchecked="ProfileSettingsCheckBox_Changed"/>
                                        <CheckBox x:Name="ProfileSaveButtonMappingsCheckBox"
                                                  Content="Button Mappings" IsChecked="True"
                                                  Checked="ProfileSettingsCheckBox_Changed"
                                                  Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        
                        <!-- Front Buttons Card (was "Virtual Controller & Mouse"). Keeps the same x:Names
                             (ControllerEmulationCard / *ExpandButton / *Content / *ExpandIcon) so the expand,
                             gating and code-behind wiring are unchanged. -->
                        <Border x:Name="ControllerEmulationCard" Style="{StaticResource CardStyle}"
                                BorderBrush="{StaticResource ThemeAccentBrush}" Visibility="Collapsed">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xEECA;" FontSize="16"
                                                      Foreground="{StaticResource ThemeAccentBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Front Buttons" Style="{StaticResource CardTitleStyle}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <!-- Preview line: names what the two front buttons do, so the collapsed
                                             card still says what is configured in here. -->
                                        <TextBlock Text="Choose what pressing the MSI button does, and which widget the Quick Settings button jumps to."
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="ControllerEmulationExpandButton"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="ControllerEmulationExpandButton_Click"
                                                  XYFocusUp="{x:Bind LegionNavItem}">
                                        <FontIcon x:Name="ControllerEmulationExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <StackPanel x:Name="ControllerEmulationContent" Visibility="Collapsed" Margin="0,12,0,0">

                                <!-- ── Left MSI Button (Front) — single + double-click grouped in one card ── -->
                                <Border Background="#14FFFFFF" CornerRadius="8" Padding="12,10,12,12"
                                        BorderThickness="1" BorderBrush="#22FFFFFF" Margin="0,0,0,12">
                                  <StackPanel x:Name="LeftMsiButtonCard">
                                    <TextBlock Text="MSI Button" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#CCCCCC" Margin="0,0,0,10"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Single&#10;click" VerticalAlignment="Center"
                                                   Foreground="#AAAAAA" FontSize="12"/>
                                        <ComboBox x:Name="LegionButtonDesktopTypeComboBox" Grid.Column="1" Margin="0,0,8,0"
                                                  Style="{StaticResource ModernComboBoxStyle}" SelectedIndex="1">
                                            <x:String>Keyboard</x:String>
                                            <x:String>Action</x:String>
                                        </ComboBox>
                                        <ComboBox x:Name="LegionButtonDesktopComboBox" Grid.Column="2"
                                                  Visibility="Collapsed"
                                                  Style="{StaticResource ModernComboBoxStyle}" SelectedIndex="0">
                                            <x:String>Disabled</x:String>
                                        </ComboBox>
                                        <ComboBox x:Name="LegionButtonDesktopMouseComboBox" Grid.Column="2"
                                                  Visibility="Collapsed"
                                                  Style="{StaticResource ModernComboBoxStyle}" SelectedIndex="0">
                                            <x:String>Left Click</x:String>
                                        </ComboBox>
                                        <ComboBox x:Name="LegionButtonDesktopActionComboBox" Grid.Column="2"
                                                  Visibility="Collapsed"
                                                  HorizontalAlignment="Stretch"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  PlaceholderText="Select action..."/>
                                    </Grid>
                                    <StackPanel x:Name="LegionButtonDesktopKeyboardPanel" Visibility="Visible" Margin="70,8,0,0" Orientation="Horizontal">
                                        <StackPanel x:Name="LegionButtonDesktopKeyTags" Orientation="Horizontal"/>
                                        <Button x:Name="LegionButtonDesktopKeyPickerButton" Width="100" Content="+ Key  &#x25BE;" Style="{StaticResource KeyPickerButtonStyle}"/>
                                    </StackPanel>

                                    <!-- divider between single- and double-click inside the card -->
                                    <Border Height="1" Background="#1AFFFFFF" Margin="0,12,0,2"/>

                                    <!-- Optional double-click action for the Left MSI button -->
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Double-click action" Foreground="#AAAAAA" FontSize="12" VerticalAlignment="Center"/>
                                        <ToggleSwitch x:Name="LeftMsiDoubleClickToggle" Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      Toggled="LeftMsiDoubleClickToggle_Toggled"/>
                                    </Grid>
                                    <StackPanel x:Name="LeftMsiDoubleClickPanel" Visibility="Collapsed" Margin="0,8,0,0">
                                        <TextBlock Text="Runs a second action on a quick double-press."
                                                   Foreground="#808080" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                        <!-- Mode selector (Keyboard / Action) — mirrors the single-click row -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Double&#10;click" VerticalAlignment="Center"
                                                       Foreground="#AAAAAA" FontSize="12"/>
                                            <ComboBox x:Name="LeftMsiDoubleTypeComboBox" Grid.Column="1" Margin="0,0,8,0"
                                                      Style="{StaticResource ModernComboBoxStyle}" SelectedIndex="1"
                                                      SelectionChanged="LeftMsiDoubleType_SelectionChanged">
                                                <x:String>Keyboard</x:String>
                                                <x:String>Action</x:String>
                                            </ComboBox>
                                            <ComboBox x:Name="LeftMsiDoubleActionComboBox" Grid.Column="2" HorizontalAlignment="Stretch"
                                                      Style="{StaticResource ModernComboBoxStyle}"
                                                      PlaceholderText="Select double-click action..."
                                                      SelectionChanged="LeftMsiDoubleAction_SelectionChanged"/>
                                        </Grid>
                                        <StackPanel x:Name="LeftMsiDoubleKeyboardPanel" Visibility="Collapsed" Margin="70,8,0,0" Orientation="Horizontal">
                                            <StackPanel x:Name="LeftMsiDoubleKeyTags" Orientation="Horizontal"/>
                                            <Button x:Name="LeftMsiDoubleKeyPickerButton" Tag="LeftMsiDouble" Width="100" Content="+ Key  &#x25BE;" Click="ExtraKeyPicker_Click" Style="{StaticResource KeyPickerButtonStyle}"/>
                                        </StackPanel>
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Detection window" Foreground="#AAAAAA" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="LeftMsiDoubleDelayValue" Grid.Column="1" Text="220 ms"
                                                       Foreground="{StaticResource SystemAccentBrush}" FontSize="12" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Slider x:Name="LeftMsiDoubleDelaySlider" Minimum="150" Maximum="600" StepFrequency="10" Value="220"
                                                ValueChanged="LeftMsiDoubleDelay_ValueChanged"/>
                                        <Border Background="#20000000" CornerRadius="6" Padding="8,6" Margin="0,4,0,0">
                                            <TextBlock x:Name="LeftMsiDoubleDetectText" Text="Press the Left MSI button to test…"
                                                       Foreground="#808080" FontSize="12"/>
                                        </Border>
                                    </StackPanel>
                                  </StackPanel>
                                </Border>

                                <!-- ── Right MSI Button (Front) — Game Bar; auto-jump to ClawTweaks ── -->
                                <Border Background="#14FFFFFF" CornerRadius="8" Padding="12,10,12,12"
                                        BorderThickness="1" BorderBrush="#22FFFFFF" Margin="0,0,0,12">
                                  <StackPanel x:Name="RightMsiButtonCard">
                                    <TextBlock Text="Quick Settings Button" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#CCCCCC" Margin="0,0,0,6"/>
                                    <TextBlock Text="When the virtual controller is active, ClawTweaks jumps to a specific widget."
                                               Foreground="#C8C8C8" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Define widget position to autojump to ClawTweaks"
                                                   Foreground="#C8C8C8" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                        <TextBlock x:Name="ClawTweaksWidgetPositionValue" Grid.Column="1" Text="1"
                                                   Foreground="{StaticResource SystemAccentBrush}" FontSize="12" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="ClawTweaksWidgetPositionSlider" Minimum="1" Maximum="10" StepFrequency="1" Value="1"
                                            ValueChanged="ClawTweaksWidgetPosition_ValueChanged"/>
                                  </StackPanel>
                                </Border>


                                <!-- Hidden Page controls for code-behind compatibility -->
                                <StackPanel Visibility="Collapsed">
                                    <ComboBox x:Name="LegionButtonPageTypeComboBox" SelectedIndex="0">
                                        <x:String>Gamepad</x:String><x:String>Keyboard</x:String><x:String>Mouse</x:String>
                                    </ComboBox>
                                    <ComboBox x:Name="LegionButtonPageComboBox" SelectedIndex="0"><x:String>Disabled</x:String></ComboBox>
                                    <ComboBox x:Name="LegionButtonPageMouseComboBox" SelectedIndex="0"><x:String>Left Click</x:String></ComboBox>
                                    <StackPanel x:Name="LegionButtonPageKeyboardPanel">
                                        <StackPanel x:Name="LegionButtonPageKeyTags" Orientation="Horizontal"/>
                                        <ComboBox x:Name="LegionButtonPageKeyComboBox" Width="100"
                                                  Style="{StaticResource ModernComboBoxStyle}" SelectedIndex="0">
                                            <x:String>+ Key</x:String>
                                        </ComboBox>
                                    </StackPanel>
                                </StackPanel>


                                <!-- Improved Controller Emulation — hidden on MSI Claw (not applicable) -->
                                <Grid Margin="0,12,0,0" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Improved Controller Emulation" FontSize="14" Foreground="#FFFFFF"/>
                                        <TextBlock Text="Use Legion HID gamepad reads instead of stock XInput reads (Legion Go / Go 2)"
                                                   FontSize="11"
                                                   Foreground="{StaticResource HintTextBrush}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="ControllerEmulationImprovedInputToggle"
                                                  Grid.Column="1"
                                                  IsOn="False"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"
                                                  XYFocusUp="{x:Bind DefaultControllerModeComboBox}"
                                                  XYFocusDown="{x:Bind ControllerEmulationHideStockControllerToggle}"/>
                                </Grid>

                                <!-- Hide Stock Controller — always true on MSI Claw (UI hidden) -->
                                <Grid Margin="0,12,0,0" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Hide Stock Controller" FontSize="14" Foreground="#FFFFFF"/>
                                        <TextBlock Text="Hide physical input when virtual controller modes are active"
                                                   FontSize="11"
                                                   Foreground="{StaticResource HintTextBrush}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="ControllerEmulationHideStockControllerToggle"
                                                  Grid.Column="1"
                                                  IsOn="True"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"
                                                  XYFocusUp="{x:Bind ControllerEmulationImprovedInputToggle}"
                                                  XYFocusDown="{x:Bind ControllerEmulationHideTargetComboBox}"/>
                                </Grid>

                                <!-- Hide Target — hidden on MSI Claw (not applicable) -->
                                <Grid Margin="0,12,0,0" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Hide Target" FontSize="14" Foreground="#FFFFFF"/>
                                        <TextBlock Text="Select which physical gamepad family to cloak"
                                                   FontSize="11"
                                                   Foreground="{StaticResource HintTextBrush}"/>
                                    </StackPanel>
                                    <ComboBox x:Name="ControllerEmulationHideTargetComboBox"
                                              Grid.Column="1"
                                              Width="220"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              XYFocusUp="{x:Bind ControllerEmulationHideStockControllerToggle}"
                                              XYFocusDown="{x:Bind GyroActivationExpandToggle}"
                                              IsEnabled="False">
                                        <ComboBoxItem Content="Auto (Native handheld only)" Tag="0" IsSelected="True"/>
                                        <ComboBoxItem Content="Native handheld controller" Tag="1"/>
                                        <ComboBoxItem Content="Xbox 360 bridge (VID 045E:028E)" Tag="2"/>
                                        <ComboBoxItem Content="Native + Xbox 360 bridge" Tag="3"/>
                                    </ComboBox>
                                </Grid>

                                <!-- Gyro Activation Group — controlled via the Gyro card below, hidden here -->
                                <Grid Margin="0,16,0,0" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Gyro Activation" FontSize="14" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                        <TextBlock Text="Source, simulation mode, and activation settings" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="GyroActivationExpandToggle"
                                                  Grid.Column="1" IsChecked="False"
                                                  VerticalAlignment="Center" Background="Transparent" BorderThickness="0"
                                                  Padding="8,4" Click="GyroActivationExpandToggle_Click">
                                        <FontIcon x:Name="GyroActivationExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>
                                <StackPanel x:Name="GyroActivationContent" Spacing="10" Margin="0,8,0,0" Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Gyroscope Source" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Select which gyroscope to use" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ControllerEmulationGyroSourceComboBox"
                                                  Grid.Column="1" Width="180"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  SelectionChanged="ControllerEmulationGyroSourceComboBox_SelectionChanged"
                                                  IsEnabled="False">
                                            <ComboBoxItem Content="Internal Handheld" Tag="0" IsSelected="True"/>
                                            <ComboBoxItem Content="Controller (Right)" Tag="1"/>
                                            <ComboBoxItem Content="Controller (Left)" Tag="2"/>
                                            <ComboBoxItem Content="Controller (Mixed)" Tag="3"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid x:Name="CalibrateGyroGrid" Visibility="Collapsed">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Calibrate Gyro" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Hold controllers still during calibration" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <Button x:Name="CalibrateGyroButton" Grid.Column="1"
                                                Content="Calibrate" Style="{StaticResource ModernButtonStyle}"
                                                Click="CalibrateGyroButton_Click" IsEnabled="False"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Gyro Simulation" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Choose how gyro motion is emulated" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ControllerEmulationModeComboBox"
                                                  Grid.Column="1" Width="180"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  IsEnabled="False"
                                                  SelectionChanged="ControllerEmulationModeComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Mouse" Tag="0" IsSelected="True"/>
                                            <ComboBoxItem Content="Xbox (Stick)" Tag="1"/>
                                            <ComboBoxItem Content="PS4 (Motion)" Tag="2"/>
                                            <ComboBoxItem Content="PS4 (Stick)" Tag="3"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Gyro Activation" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Always on, hold, or toggle by button" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ControllerEmulationGyroActivationModeComboBox"
                                                  Grid.Column="1" Width="180"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  IsEnabled="False"
                                                  SelectionChanged="ControllerEmulationGyroActivationModeComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Always On" Tag="0" IsSelected="True"/>
                                            <ComboBoxItem Content="Hold" Tag="1"/>
                                            <ComboBoxItem Content="Toggle" Tag="2"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Activation Button" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Button used for hold or toggle activation" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ControllerEmulationGyroActivationButtonComboBox"
                                                  Grid.Column="1" Width="180"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  IsEnabled="False">
                                            <ComboBoxItem Content="None" Tag="0"/>
                                            <ComboBoxItem Content="Right Trigger" Tag="1" IsSelected="True"/>
                                            <ComboBoxItem Content="Left Trigger" Tag="2"/>
                                            <ComboBoxItem Content="Right Bumper" Tag="3"/>
                                            <ComboBoxItem Content="Left Bumper" Tag="4"/>
                                            <ComboBoxItem Content="A" Tag="5"/>
                                            <ComboBoxItem Content="B" Tag="6"/>
                                            <ComboBoxItem Content="X" Tag="7"/>
                                            <ComboBoxItem Content="Y" Tag="8"/>
                                            <ComboBoxItem Content="Right Stick Click" Tag="9"/>
                                            <ComboBoxItem Content="Left Stick Click" Tag="10"/>
                                            <ComboBoxItem Content="D-Pad Up" Tag="11"/>
                                            <ComboBoxItem Content="D-Pad Down" Tag="12"/>
                                            <ComboBoxItem Content="D-Pad Left" Tag="13"/>
                                            <ComboBoxItem Content="D-Pad Right" Tag="14"/>
                                            <ComboBoxItem Content="Start" Tag="15"/>
                                            <ComboBoxItem Content="Back" Tag="16"/>
                                            <!-- Legion-only auxiliary buttons (FR-1, issue #79). Reads from the cached LegionHid sample's AuxButtons; on non-Legion handhelds these never trigger. -->
                                            <ComboBoxItem Content="M3 (back R lower)" Tag="17"/>
                                            <ComboBoxItem Content="M1 (side grip L)" Tag="18"/>
                                            <ComboBoxItem Content="M2 (side grip R)" Tag="19"/>
                                            <ComboBoxItem Content="Y1 (back L upper)" Tag="20"/>
                                            <ComboBoxItem Content="Y2 (back L lower)" Tag="21"/>
                                            <ComboBoxItem Content="Y3 (back R upper)" Tag="22"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid x:Name="ControllerEmulationDs4OrientationRow">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="DS4 Orientation" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Parallel or Orthogonal handheld posture" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ControllerEmulationDs4OrientationComboBox"
                                                  Grid.Column="1" Width="180"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  IsEnabled="False">
                                            <ComboBoxItem Content="Parallel" Tag="0" IsSelected="True"/>
                                            <ComboBoxItem Content="Orthogonal" Tag="1"/>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>

                                <!-- Features Group — hidden on MSI Claw (not applicable) -->
                                <StackPanel Visibility="Collapsed">
                                <Grid Margin="0,16,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Features" FontSize="14" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                        <TextBlock Text="Touchpad, LED, rumble, and button layout" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="FeaturesExpandToggle"
                                                  Grid.Column="1" IsChecked="False"
                                                  VerticalAlignment="Center" Background="Transparent" BorderThickness="0"
                                                  Padding="8,4" Click="FeaturesExpandToggle_Click">
                                        <FontIcon x:Name="FeaturesExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>
                                <StackPanel x:Name="FeaturesContent" Spacing="10" Margin="0,8,0,0" Visibility="Collapsed">
                                    <Grid x:Name="ControllerEmulationPs4TouchpadRow">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Touchpad Emulation" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Forward right touchpad input to virtual DS4 touchpad" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="ControllerEmulationPs4TouchpadToggle"
                                                      Grid.Column="1" IsOn="True"
                                                      Style="{StaticResource ModernToggleStyle}" IsEnabled="False"/>
                                    </Grid>

                                    <Grid x:Name="ControllerEmulationLedForwardingRow">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="LED Forwarding" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Forward game LED requests to physical controller" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="ControllerEmulationLedForwardingToggle"
                                                      Grid.Column="1" IsOn="False"
                                                      Style="{StaticResource ModernToggleStyle}" IsEnabled="False"/>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Rumble Profile" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Tune vibration response for virtual gamepad rumble" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ControllerEmulationRumbleProfileComboBox"
                                                  Grid.Column="1" Width="180"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  IsEnabled="False">
                                            <ComboBoxItem Content="Balanced" Tag="0" IsSelected="True"/>
                                            <ComboBoxItem Content="Sharp" Tag="1"/>
                                            <ComboBoxItem Content="Soft" Tag="2"/>
                                            <ComboBoxItem Content="Impact" Tag="3"/>
                                            <ComboBoxItem Content="Boosted" Tag="4"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Virtual ABXY Layout" FontSize="13" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="ControllerEmulationVirtualAbxyLayoutComboBox"
                                                  Grid.Column="1" Width="180"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  IsEnabled="False">
                                            <ComboBoxItem Content="Xbox" Tag="0" IsSelected="True"/>
                                            <ComboBoxItem Content="Nintendo" Tag="1"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Only Joystick Data" FontSize="13" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                        <ToggleSwitch x:Name="ControllerEmulationStickOnlyJoystickToggle"
                                                      Grid.Column="1" IsOn="False"
                                                      Style="{StaticResource ModernToggleStyle}" IsEnabled="False"/>
                                    </Grid>
                                </StackPanel>
                                </StackPanel>
                                <!-- End Features Group wrapper -->

                                <!-- Joystick Output Group -->
                                <Grid x:Name="JoystickOutputGroupHeader" Margin="0,16,0,0" Visibility="Collapsed">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Joystick Output" FontSize="14" Foreground="#FFFFFF" FontWeight="SemiBold"/>
                                        <TextBlock Text="Gyro-to-stick pipeline settings" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="JoystickOutputExpandToggle"
                                                  Grid.Column="1" IsChecked="False"
                                                  VerticalAlignment="Center" Background="Transparent" BorderThickness="0"
                                                  Padding="8,4" Click="JoystickOutputExpandToggle_Click">
                                        <FontIcon x:Name="JoystickOutputExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>
                                <StackPanel x:Name="JoystickOutputContent" Spacing="10" Margin="0,8,0,0" Visibility="Collapsed">
                                    <!-- Send to Joystick -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Send to Joystick" FontSize="13" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="ControllerEmulationStickSelectComboBox"
                                                  Grid.Column="1" Width="180"
                                                  Style="{StaticResource ModernComboBoxStyle}" IsEnabled="False">
                                            <ComboBoxItem Content="Left" Tag="0"/>
                                            <ComboBoxItem Content="Right" Tag="1" IsSelected="True"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- 3DOF to 2D Conversion -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="3DOF to 2D Conversion" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Map gyro axes to stick output" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="StickConversionComboBox"
                                                  Grid.Column="1" Width="180"
                                                  Style="{StaticResource ModernComboBoxStyle}" IsEnabled="False">
                                            <ComboBoxItem Content="Yaw" Tag="0"/>
                                            <ComboBoxItem Content="Roll" Tag="1"/>
                                            <ComboBoxItem Content="Yaw + Roll" Tag="2" IsSelected="True"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Orientation -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Gyro Orientation" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Handheld posture for stick output" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <ComboBox x:Name="StickOrientationV2ComboBox"
                                                  Grid.Column="1" Width="180"
                                                  Style="{StaticResource ModernComboBoxStyle}" IsEnabled="False">
                                            <ComboBoxItem Content="Parallel" Tag="0" IsSelected="True"/>
                                            <ComboBoxItem Content="Orthogonal" Tag="1"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Invert X -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Invert X Output" FontSize="13" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                        <ToggleSwitch x:Name="ControllerEmulationStickInvertXToggle"
                                                      Grid.Column="1" IsOn="False"
                                                      Style="{StaticResource ModernToggleStyle}" IsEnabled="False"/>
                                    </Grid>

                                    <!-- Invert Y -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Invert Y Output" FontSize="13" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                        <ToggleSwitch x:Name="ControllerEmulationStickInvertYToggle"
                                                      Grid.Column="1" IsOn="False"
                                                      Style="{StaticResource ModernToggleStyle}" IsEnabled="False"/>
                                    </Grid>

                                    <!-- Sensitivity -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Sensitivity" FontSize="13" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="StickSensitivityV2ValueText" Grid.Column="1" Text="1.00x"
                                                   FontSize="13" Foreground="#4CAF50" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="StickSensitivityV2Slider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="1" Maximum="400" TickFrequency="1" SnapsTo="Ticks" Value="100"
                                            IsEnabled="False" ValueChanged="StickSensitivityV2Slider_ValueChanged"/>

                                    <!-- Min Gyro Input Speed -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Min Gyro Input Speed" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Ignore motion below this speed" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="StickMinGyroSpeedValueText" Grid.Column="1" Text="0°/s"
                                                   FontSize="13" Foreground="#4CAF50" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="StickMinGyroSpeedSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="100" TickFrequency="1" SnapsTo="Ticks" Value="0"
                                            IsEnabled="False" ValueChanged="StickMinGyroSpeedSlider_ValueChanged"/>

                                    <!-- Max Gyro Input Speed -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Max Gyro Input Speed" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Speed for full stick deflection" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="StickMaxGyroSpeedValueText" Grid.Column="1" Text="220°/s"
                                                   FontSize="13" Foreground="#4CAF50" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="StickMaxGyroSpeedSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="50" Maximum="720" TickFrequency="1" SnapsTo="Ticks" Value="220"
                                            IsEnabled="False" ValueChanged="StickMaxGyroSpeedSlider_ValueChanged"/>

                                    <!-- Min Joystick Output (anti-deadzone) -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Min Joystick Output" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Anti-deadzone: minimum output when moving" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="StickMinOutputValueText" Grid.Column="1" Text="0%"
                                                   FontSize="13" Foreground="#4CAF50" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="StickMinOutputSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="100" TickFrequency="1" SnapsTo="Ticks" Value="0"
                                            IsEnabled="False" ValueChanged="StickMinOutputSlider_ValueChanged"/>

                                    <!-- Max Joystick Output -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Max Joystick Output" FontSize="13" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="StickMaxOutputValueText" Grid.Column="1" Text="100%"
                                                   FontSize="13" Foreground="#4CAF50" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="StickMaxOutputSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="1" Maximum="100" TickFrequency="1" SnapsTo="Ticks" Value="100"
                                            IsEnabled="False" ValueChanged="StickMaxOutputSlider_ValueChanged"/>

                                    <!-- Power Curve -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Power Curve" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="0.1 = aggressive, 1.0 = linear, 4.0 = relaxed" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="StickPowerCurveValueText" Grid.Column="1" Text="1.0"
                                                   FontSize="13" Foreground="#4CAF50" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="StickPowerCurveSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="10" Maximum="400" TickFrequency="1" SnapsTo="Ticks" Value="100"
                                            IsEnabled="False" ValueChanged="StickPowerCurveSlider_ValueChanged"/>

                                    <!-- Gyro Speed Deadzone -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Gyro Speed Deadzone" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Smooth recovery above threshold" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="StickDeadzoneValueText" Grid.Column="1" Text="2°/s"
                                                   FontSize="13" Foreground="#4CAF50" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="StickDeadzoneSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="50" TickFrequency="1" SnapsTo="Ticks" Value="2"
                                            IsEnabled="False" ValueChanged="StickDeadzoneSlider_ValueChanged"/>

                                    <!-- Precision Speed -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Precision Speed" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Reduces sensitivity below this speed" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="StickPrecisionSpeedValueText" Grid.Column="1" Text="Off"
                                                   FontSize="13" Foreground="#4CAF50" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="StickPrecisionSpeedSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="100" TickFrequency="1" SnapsTo="Ticks" Value="0"
                                            IsEnabled="False" ValueChanged="StickPrecisionSpeedSlider_ValueChanged"/>

                                    <!-- Output Mix -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Output Mix" FontSize="13" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Balance between vertical and horizontal output" FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="StickOutputMixValueText" Grid.Column="1" Text="Balanced"
                                                   FontSize="13" Foreground="#4CAF50" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="StickOutputMixSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="-100" Maximum="100" TickFrequency="1" SnapsTo="Ticks" Value="0"
                                            IsEnabled="False" ValueChanged="StickOutputMixSlider_ValueChanged"/>

                                    <!-- Reset to recommended defaults (issue #79: vvalente30 asked for a
                                         reset button after experimenting and getting lost in the settings).
                                         Drives the same controls the VIIPER reset button does — they share
                                         LocalSettings keys, so one handler is enough. -->
                                    <Button x:Name="StickGyroLegacyResetButton" Content="Reset gyro settings to recommended defaults"
                                            HorizontalAlignment="Stretch" Margin="0,8,0,0"
                                            Click="StickGyroLegacyResetButton_Click"
                                            Background="#2A2A2A" BorderBrush="#444444" BorderThickness="1" Foreground="#CCCCCC"/>
                                </StackPanel>

                            </StackPanel>

                            <!-- VIIPER emulation content — replaces ControllerEmulationContent when
                                 the VIIPER backend toggle (under Debug panel) is on. Only one of the
                                 two bodies is visible at a time; they are not run concurrently. -->
                            <StackPanel x:Name="ViiperEmulationContent" Visibility="Collapsed" Margin="0,12,0,0">
                                <Border Background="#1E2A3E" BorderBrush="#3D5A80" BorderThickness="1" CornerRadius="6" Padding="12">
                                    <StackPanel>
                                        <!-- VIIPER Device Configuration title + the "Virtual device" / Steam
                                             sub-device pickers were RELOCATED to the Controller Status card
                                             (ViiperDeviceConfigPanel). The forwarder-only controls below stay
                                             here but ViiperEmulationContent is never shown on the Claw — they
                                             are inert (GoTweaks/Legion path) and kept only so their existing
                                             property wiring keeps compiling. -->
                                        <TextBlock Text="Input source" FontSize="12" Foreground="#CCCCCC" Margin="0,12,0,4"/>
                                        <ComboBox x:Name="ViiperInputSourceComboBox" HorizontalAlignment="Stretch">
                                            <ComboBoxItem Content="XInput (any controller)" Tag="XInput"/>
                                            <ComboBoxItem Content="Legion Go HID (native)" Tag="LegionHid"/>
                                        </ComboBox>

                                        <TextBlock Text="Gyro source" FontSize="12" Foreground="#CCCCCC" Margin="0,12,0,4"/>
                                        <ComboBox x:Name="ViiperGyroSourceComboBox" HorizontalAlignment="Stretch">
                                            <ComboBoxItem Content="None" Tag="None"/>
                                            <ComboBoxItem Content="Left controller" Tag="Left"/>
                                            <ComboBoxItem Content="Right controller" Tag="Right"/>
                                            <ComboBoxItem Content="Mixed (L+R averaged)" Tag="Mixed"/>
                                            <ComboBoxItem Content="Handheld (device IMU)" Tag="Handheld"/>
                                        </ComboBox>

                                        <!-- IMU Axis Mapping — per-axis source selector (with optional flip).
                                             Applies to both gyro and accel so the output vectors stay coherent. -->
                                        <TextBlock Text="IMU axis mapping" FontSize="12" Foreground="#CCCCCC" Margin="0,12,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="X→" FontSize="11" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <ComboBox x:Name="ViiperGyroAxisMapXComboBox" Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,0,6,0" FontSize="12">
                                                <ComboBoxItem Content="X"  Tag="X"/>
                                                <ComboBoxItem Content="Y"  Tag="Y"/>
                                                <ComboBoxItem Content="Z"  Tag="Z"/>
                                                <ComboBoxItem Content="-X" Tag="-X"/>
                                                <ComboBoxItem Content="-Y" Tag="-Y"/>
                                                <ComboBoxItem Content="-Z" Tag="-Z"/>
                                            </ComboBox>
                                            <TextBlock Grid.Column="2" Text="Y→" FontSize="11" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <ComboBox x:Name="ViiperGyroAxisMapYComboBox" Grid.Column="3" HorizontalAlignment="Stretch" Margin="0,0,6,0" FontSize="12">
                                                <ComboBoxItem Content="X"  Tag="X"/>
                                                <ComboBoxItem Content="Y"  Tag="Y"/>
                                                <ComboBoxItem Content="Z"  Tag="Z"/>
                                                <ComboBoxItem Content="-X" Tag="-X"/>
                                                <ComboBoxItem Content="-Y" Tag="-Y"/>
                                                <ComboBoxItem Content="-Z" Tag="-Z"/>
                                            </ComboBox>
                                            <TextBlock Grid.Column="4" Text="Z→" FontSize="11" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                            <ComboBox x:Name="ViiperGyroAxisMapZComboBox" Grid.Column="5" HorizontalAlignment="Stretch" FontSize="12">
                                                <ComboBoxItem Content="X"  Tag="X"/>
                                                <ComboBoxItem Content="Y"  Tag="Y"/>
                                                <ComboBoxItem Content="Z"  Tag="Z"/>
                                                <ComboBoxItem Content="-X" Tag="-X"/>
                                                <ComboBoxItem Content="-Y" Tag="-Y"/>
                                                <ComboBoxItem Content="-Z" Tag="-Z"/>
                                            </ComboBox>
                                        </Grid>

                                        <!-- Gyro → Right Stick (synthesized).
                                             Visible only when targetType has no native motion field
                                             (xbox360, xboxelite2, switchpro family, etc.) — see
                                             ViiperStickGyroProcessor.IsApplicableForTarget. The four
                                             controls below mirror the legacy ControllerEmulation
                                             stick-gyro controls so the same widget property pushes
                                             values to the helper; no separate property surface. -->
                                        <StackPanel x:Name="ViiperStickGyroSection" Visibility="Collapsed" Margin="0,12,0,0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <!-- Header text is dynamic: reflects "Gyro → Left Stick" or "Gyro → Right
                                                     Stick" based on the Send-to-joystick setting so the title doesn't lie
                                                     when stickSelect is flipped. Driven from C# whenever the routing changes. -->
                                                <TextBlock x:Name="ViiperStickGyroSectionHeader"
                                                           Grid.Column="0"
                                                           Text="Gyro → Right Stick"
                                                           FontSize="13" FontWeight="SemiBold" Foreground="#4AB3F4"
                                                           VerticalAlignment="Center"/>
                                                <!-- Configuration summary badge: at-a-glance "ON: Hold RT" / "ON: Always" /
                                                     "OFF" so first-time users can verify activation without expanding any
                                                     groups. Pure widget-side computation; no helper round-trip. -->
                                                <Border x:Name="ViiperStickGyroStatusBadge"
                                                        Grid.Column="1"
                                                        Background="#1F2A3D"
                                                        BorderBrush="#3D5A80"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="6,2"
                                                        VerticalAlignment="Center">
                                                    <TextBlock x:Name="ViiperStickGyroStatusBadgeText"
                                                               Text="OFF"
                                                               FontSize="10"
                                                               Foreground="#AAAAAA"/>
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="Synthesizes a stick contribution from gyro motion for emulated targets without a native motion field (Xbox 360, Xbox Elite 2, Switch Pro)."
                                                       FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap" Margin="0,2,0,8"/>

                                            <!-- Master enable.
                                                 Off = raw stick passthrough (legacy behavior pre-2152). On = synthesize gyro
                                                 contribution into the chosen stick. Default true. -->
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="Enable gyro → stick" FontSize="13" Foreground="#FFFFFF"/>
                                                    <TextBlock Text="Off = raw stick passthrough; processor short-circuits."
                                                               FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <ToggleSwitch x:Name="ViiperStickGyroEnabledToggle"
                                                              Grid.Column="1"
                                                              Style="{StaticResource ModernToggleStyle}"/>
                                            </Grid>

                                            <TextBlock Text="Activation mode" FontSize="12" Foreground="#CCCCCC" Margin="0,0,0,4"/>
                                            <ComboBox x:Name="ViiperStickGyroActivationModeComboBox" HorizontalAlignment="Stretch"
                                                      SelectionChanged="ViiperStickGyroActivationModeComboBox_SelectionChanged">
                                                <ComboBoxItem Content="Always On" Tag="0" IsSelected="True"/>
                                                <ComboBoxItem Content="Hold" Tag="1"/>
                                                <ComboBoxItem Content="Toggle" Tag="2"/>
                                            </ComboBox>

                                            <TextBlock Text="Activation button" FontSize="12" Foreground="#CCCCCC" Margin="0,8,0,4"/>
                                            <ComboBox x:Name="ViiperStickGyroActivationButtonComboBox" HorizontalAlignment="Stretch"
                                                      SelectionChanged="ViiperStickGyroActivationButtonComboBox_SelectionChanged">
                                                <ComboBoxItem Content="None" Tag="0"/>
                                                <ComboBoxItem Content="Right Trigger" Tag="1" IsSelected="True"/>
                                                <ComboBoxItem Content="Left Trigger" Tag="2"/>
                                                <ComboBoxItem Content="Right Bumper" Tag="3"/>
                                                <ComboBoxItem Content="Left Bumper" Tag="4"/>
                                                <ComboBoxItem Content="A" Tag="5"/>
                                                <ComboBoxItem Content="B" Tag="6"/>
                                                <ComboBoxItem Content="X" Tag="7"/>
                                                <ComboBoxItem Content="Y" Tag="8"/>
                                                <ComboBoxItem Content="Right Stick Click" Tag="9"/>
                                                <ComboBoxItem Content="Left Stick Click" Tag="10"/>
                                                <ComboBoxItem Content="D-Pad Up" Tag="11"/>
                                                <ComboBoxItem Content="D-Pad Down" Tag="12"/>
                                                <ComboBoxItem Content="D-Pad Left" Tag="13"/>
                                                <ComboBoxItem Content="D-Pad Right" Tag="14"/>
                                                <ComboBoxItem Content="Start" Tag="15"/>
                                                <ComboBoxItem Content="Back" Tag="16"/>
                                                <ComboBoxItem Content="M3 (back R lower)" Tag="17"/>
                                                <ComboBoxItem Content="M1 (side grip L)" Tag="18"/>
                                                <ComboBoxItem Content="M2 (side grip R)" Tag="19"/>
                                                <ComboBoxItem Content="Y1 (back L upper)" Tag="20"/>
                                                <ComboBoxItem Content="Y2 (back L lower)" Tag="21"/>
                                                <ComboBoxItem Content="Y3 (back R upper)" Tag="22"/>
                                            </ComboBox>

                                            <Grid Margin="0,8,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Sensitivity" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Foreground="#CCCCCC"/>
                                                <TextBlock x:Name="ViiperStickGyroSensitivityValueText" Grid.Column="1" Text="1.00x" FontSize="12" Foreground="{StaticResource HintTextBrush}"/>
                                            </Grid>
                                            <Slider x:Name="ViiperStickGyroSensitivitySlider"
                                                    Minimum="1" Maximum="400" StepFrequency="1" SmallChange="5" LargeChange="25"
                                                    ValueChanged="ViiperStickGyroSensitivitySlider_ValueChanged"/>

                                            <Grid Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Deadzone" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Foreground="#CCCCCC"/>
                                                <TextBlock x:Name="ViiperStickGyroDeadzoneValueText" Grid.Column="1" Text="2°/s" FontSize="12" Foreground="{StaticResource HintTextBrush}"/>
                                            </Grid>
                                            <Slider x:Name="ViiperStickGyroDeadzoneSlider"
                                                    Minimum="0" Maximum="50" StepFrequency="1" SmallChange="1" LargeChange="5"
                                                    ValueChanged="ViiperStickGyroDeadzoneSlider_ValueChanged"/>

                                            <!-- Advanced expander.
                                                 Each control mirrors a legacy ControllerEmulation* control via
                                                 GamingWidget.ViiperStickGyro.cs, so the same widget property
                                                 pushes values to the helper. Defaults match vvalente30's
                                                 recommended SteamOS-aligned settings (issue #79). -->
                                            <Grid Margin="0,12,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Advanced gyro → stick options" FontSize="12" Foreground="#AAAAAA"
                                                           VerticalAlignment="Center"/>
                                                <ToggleButton x:Name="ViiperStickGyroAdvancedToggle"
                                                              Grid.Column="1" IsChecked="False"
                                                              VerticalAlignment="Center" Background="Transparent" BorderThickness="0"
                                                              Padding="8,4" Click="ViiperStickGyroAdvancedToggle_Click">
                                                    <FontIcon x:Name="ViiperStickGyroAdvancedIcon" Glyph="&#xE70D;" FontSize="12"/>
                                                </ToggleButton>
                                            </Grid>
                                            <StackPanel x:Name="ViiperStickGyroAdvancedContent" Spacing="8" Margin="0,8,0,0" Visibility="Collapsed">

                                                <!-- Send to joystick -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="Send to joystick" FontSize="12" Foreground="#CCCCCC"/>
                                                        <TextBlock Text="Which emulated stick receives the gyro contribution." FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <ComboBox x:Name="ViiperStickGyroSelectComboBox"
                                                              Grid.Column="1" Width="160"
                                                              SelectionChanged="ViiperStickGyroSelectComboBox_SelectionChanged">
                                                        <ComboBoxItem Content="Left" Tag="0"/>
                                                        <ComboBoxItem Content="Right" Tag="1" IsSelected="True"/>
                                                    </ComboBox>
                                                </Grid>

                                                <!-- 3DOF to 2D conversion -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="3DOF to 2D conversion" FontSize="12" Foreground="#CCCCCC"/>
                                                        <TextBlock Text="Which gyro axes drive the stick. Yaw = look L/R, Roll = tilt L/R, Yaw+Roll = both." FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <ComboBox x:Name="ViiperStickGyroConversionComboBox"
                                                              Grid.Column="1" Width="160"
                                                              SelectionChanged="ViiperStickGyroConversionComboBox_SelectionChanged">
                                                        <ComboBoxItem Content="Yaw" Tag="0"/>
                                                        <ComboBoxItem Content="Roll" Tag="1"/>
                                                        <ComboBoxItem Content="Yaw + Roll" Tag="2" IsSelected="True"/>
                                                    </ComboBox>
                                                </Grid>

                                                <!-- Gyro orientation -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="Gyro orientation" FontSize="12" Foreground="#CCCCCC"/>
                                                        <TextBlock Text="Handheld posture. Switch to Orthogonal if your IMU axes feel rotated 90°." FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <ComboBox x:Name="ViiperStickGyroOrientationComboBox"
                                                              Grid.Column="1" Width="160"
                                                              SelectionChanged="ViiperStickGyroOrientationComboBox_SelectionChanged">
                                                        <ComboBoxItem Content="Parallel" Tag="0" IsSelected="True"/>
                                                        <ComboBoxItem Content="Orthogonal" Tag="1"/>
                                                    </ComboBox>
                                                </Grid>

                                                <!-- Invert toggles -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Invert X output" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Foreground="#CCCCCC"/>
                                                    <ToggleSwitch x:Name="ViiperStickGyroInvertXToggle"
                                                                  Grid.Column="1"
                                                                  Style="{StaticResource ModernToggleStyle}"
                                                                  Toggled="ViiperStickGyroInvertXToggle_Toggled"/>
                                                </Grid>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="Invert Y output" Grid.Column="0" VerticalAlignment="Center" FontSize="12" Foreground="#CCCCCC"/>
                                                    <ToggleSwitch x:Name="ViiperStickGyroInvertYToggle"
                                                                  Grid.Column="1"
                                                                  Style="{StaticResource ModernToggleStyle}"
                                                                  Toggled="ViiperStickGyroInvertYToggle_Toggled"/>
                                                </Grid>

                                                <!-- Min gyro input speed -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="Min gyro input speed" FontSize="12" Foreground="#CCCCCC"/>
                                                        <TextBlock Text="Ignore motion below this speed (filters drift / micro-shake)." FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="ViiperStickGyroMinGyroSpeedValueText" Grid.Column="1" VerticalAlignment="Center" Text="0°/s" FontSize="12" Foreground="{StaticResource HintTextBrush}"/>
                                                </Grid>
                                                <Slider x:Name="ViiperStickGyroMinGyroSpeedSlider"
                                                        Minimum="0" Maximum="100" StepFrequency="1" SmallChange="1" LargeChange="5"
                                                        ValueChanged="ViiperStickGyroMinGyroSpeedSlider_ValueChanged"/>

                                                <!-- Max gyro input speed -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="Max gyro input speed" FontSize="12" Foreground="#CCCCCC"/>
                                                        <TextBlock Text="Speed at which the stick reaches full deflection." FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="ViiperStickGyroMaxGyroSpeedValueText" Grid.Column="1" VerticalAlignment="Center" Text="220°/s" FontSize="12" Foreground="{StaticResource HintTextBrush}"/>
                                                </Grid>
                                                <Slider x:Name="ViiperStickGyroMaxGyroSpeedSlider"
                                                        Minimum="50" Maximum="720" StepFrequency="1" SmallChange="5" LargeChange="50"
                                                        ValueChanged="ViiperStickGyroMaxGyroSpeedSlider_ValueChanged"/>

                                                <!-- Min joystick output -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="Min joystick output" FontSize="12" Foreground="#CCCCCC"/>
                                                        <TextBlock Text="Anti-deadzone: minimum stick magnitude when any motion is detected." FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="ViiperStickGyroMinOutputValueText" Grid.Column="1" VerticalAlignment="Center" Text="0%" FontSize="12" Foreground="{StaticResource HintTextBrush}"/>
                                                </Grid>
                                                <Slider x:Name="ViiperStickGyroMinOutputSlider"
                                                        Minimum="0" Maximum="100" StepFrequency="1" SmallChange="1" LargeChange="5"
                                                        ValueChanged="ViiperStickGyroMinOutputSlider_ValueChanged"/>

                                                <!-- Max joystick output -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="Max joystick output" FontSize="12" Foreground="#CCCCCC"/>
                                                        <TextBlock Text="Cap the synthesized stick magnitude. Lower for slower, calmer aim." FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="ViiperStickGyroMaxOutputValueText" Grid.Column="1" VerticalAlignment="Center" Text="100%" FontSize="12" Foreground="{StaticResource HintTextBrush}"/>
                                                </Grid>
                                                <Slider x:Name="ViiperStickGyroMaxOutputSlider"
                                                        Minimum="1" Maximum="100" StepFrequency="1" SmallChange="1" LargeChange="5"
                                                        ValueChanged="ViiperStickGyroMaxOutputSlider_ValueChanged"/>

                                                <!-- Power curve -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="Power curve" FontSize="12" Foreground="#CCCCCC"/>
                                                        <TextBlock Text="0.1 = aggressive (small motion → big stick), 1.0 = linear, 4.0 = relaxed." FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="ViiperStickGyroPowerCurveValueText" Grid.Column="1" VerticalAlignment="Center" Text="1.0" FontSize="12" Foreground="{StaticResource HintTextBrush}"/>
                                                </Grid>
                                                <Slider x:Name="ViiperStickGyroPowerCurveSlider"
                                                        Minimum="10" Maximum="400" StepFrequency="1" SmallChange="5" LargeChange="25"
                                                        ValueChanged="ViiperStickGyroPowerCurveSlider_ValueChanged"/>

                                                <!-- Precision speed -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="Precision speed" FontSize="12" Foreground="#CCCCCC"/>
                                                        <TextBlock Text="Slow-tilt damping. 0 = off." FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="ViiperStickGyroPrecisionSpeedValueText" Grid.Column="1" VerticalAlignment="Center" Text="Off" FontSize="12" Foreground="{StaticResource HintTextBrush}"/>
                                                </Grid>
                                                <Slider x:Name="ViiperStickGyroPrecisionSpeedSlider"
                                                        Minimum="0" Maximum="100" StepFrequency="1" SmallChange="1" LargeChange="5"
                                                        ValueChanged="ViiperStickGyroPrecisionSpeedSlider_ValueChanged"/>

                                                <!-- Output mix -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                        <TextBlock Text="Output mix" FontSize="12" Foreground="#CCCCCC"/>
                                                        <TextBlock Text="Negative bias = vertical, positive = horizontal, 0 = balanced." FontSize="10" Foreground="#666666" TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                    <TextBlock x:Name="ViiperStickGyroOutputMixValueText" Grid.Column="1" VerticalAlignment="Center" Text="Balanced" FontSize="12" Foreground="{StaticResource HintTextBrush}"/>
                                                </Grid>
                                                <Slider x:Name="ViiperStickGyroOutputMixSlider"
                                                        Minimum="-100" Maximum="100" StepFrequency="1" SmallChange="5" LargeChange="25"
                                                        ValueChanged="ViiperStickGyroOutputMixSlider_ValueChanged"/>

                                                <!-- Reset to vvalente30's recommended SteamOS-aligned defaults. Each
                                                     value mirrors over to the legacy CE control via the existing
                                                     property pipe path; no separate save logic. -->
                                                <Button x:Name="ViiperStickGyroResetButton"
                                                        Content="Reset to recommended defaults"
                                                        Margin="0,12,0,0"
                                                        HorizontalAlignment="Stretch"
                                                        Style="{StaticResource ModernButtonStyle}"
                                                        Click="ViiperStickGyroResetButton_Click"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <TextBlock Text="Guide/Mode button" FontSize="12" Foreground="#CCCCCC" Margin="0,12,0,4"/>
                                        <ComboBox x:Name="ViiperGuideButtonModeComboBox" HorizontalAlignment="Stretch">
                                            <ComboBoxItem Content="Native (emulated device Guide/PS)" Tag="Native"/>
                                            <ComboBoxItem Content="Open Xbox Game Bar (Win+G)" Tag="GameBar"/>
                                        </ComboBox>
                                        <TextBlock x:Name="ViiperLegionLDisabledHint"
                                                   Text="Legion L is disabled in Special Remapping — set it to &quot;Guide&quot; to route the Xbox button through the emulated device."
                                                   FontSize="11"
                                                   Foreground="#FFB060"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,0"
                                                   Visibility="Collapsed"/>

                                        <!-- Swap rumble motors -->
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Swap rumble motors"
                                                       Grid.Column="0"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"
                                                       Foreground="#CCCCCC"/>
                                            <ToggleSwitch x:Name="ViiperSwapRumbleMotorsToggle"
                                                          Grid.Column="1"
                                                          Style="{StaticResource ModernToggleStyle}"
                                                          IsOn="False"/>
                                        </Grid>

                                        <!-- Mirror emulated lightbar (DS4 / DualSense Edge) onto Legion stick lights -->
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Mirror emulated lightbar to stick lights"
                                                           FontSize="13"
                                                           Foreground="#CCCCCC"/>
                                                <TextBlock Text="DualShock 4 / DualSense Edge only — when on, game-driven LED color overrides the picker color you chose for the Legion Go sticks. Off keeps your saved stick color."
                                                           FontSize="11"
                                                           Foreground="{StaticResource HintTextBrush}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <ToggleSwitch x:Name="ViiperMirrorLightbarToStickToggle"
                                                          Grid.Column="1"
                                                          VerticalAlignment="Center"
                                                          Style="{StaticResource ModernToggleStyle}"
                                                          IsOn="False"/>
                                        </Grid>

                                        <!-- Rumble intensity -->
                                        <StackPanel Margin="0,8,0,0">
                                            <Grid>
                                                <TextBlock Text="Rumble intensity" FontSize="13" Foreground="#CCCCCC"/>
                                                <TextBlock x:Name="ViiperRumbleIntensityValue"
                                                           Text="100%"
                                                           Style="{StaticResource CardValueStyle}"/>
                                            </Grid>
                                            <Slider x:Name="ViiperRumbleIntensitySlider"
                                                    Style="{StaticResource ModernSliderStyle}"
                                                    Minimum="0" Maximum="200"
                                                    Value="100"
                                                    StepFrequency="5"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                        </Border>


                        <!-- Mouse Settings Card (collapsible; the Mouse Mode emulation options moved out of the
                             former "Virtual Controller & Mouse" card). Hidden in-game + gated when the virtual
                             controller is inactive, like the other controller cards. -->
                        <Border x:Name="MouseSettingsCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon FontFamily="Segoe Fluent Icons" Glyph="&#xE962;" FontSize="16"
                                                      Foreground="{StaticResource ThemeAccentBrush}" VerticalAlignment="Center"/>
                                            <TextBlock Text="Mouse Settings" Style="{StaticResource CardTitleStyle}" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="Mouse Mode sensitivity, buttons and sticks" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="MouseSettingsExpandToggle" Grid.Column="1" IsChecked="False"
                                                  VerticalAlignment="Center" Background="Transparent" BorderThickness="0"
                                                  Padding="8,4" Click="MouseSettingsExpandToggle_Click">
                                        <FontIcon x:Name="MouseSettingsExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>
                                <StackPanel x:Name="MouseSettingsContent" Visibility="Collapsed" Margin="0,12,0,0">
                                <!-- Mouse Emulation Settings -->
                                <StackPanel x:Name="ControllerEmulationMouseSettingsPanel" Margin="0,16,0,0" Visibility="Visible">
                                <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="Mouse Emulation" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Fine-tune mouse behavior"
                                               Style="{StaticResource CardCaptionStyle}"
                                               Margin="0,0,0,6"/>

                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Sensitivity" FontSize="13" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ControllerEmulationMouseSensitivityValue"
                                                   Grid.Column="1"
                                                   Text="100"
                                                   FontSize="13"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="ControllerEmulationMouseSensitivitySlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="1" Maximum="400"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            Value="100"
                                            IsEnabled="False"
                                            XYFocusUp="{x:Bind MouseSettingsExpandToggle}"
                                            ValueChanged="ControllerEmulationMouseSensitivitySlider_ValueChanged"/>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Threshold" FontSize="13" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                        <TextBlock x:Name="ControllerEmulationMouseThresholdValue"
                                                   Grid.Column="1"
                                                   Text="2"
                                                   FontSize="13"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="ControllerEmulationMouseThresholdSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="20"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            Value="2"
                                            IsEnabled="False"
                                            ValueChanged="ControllerEmulationMouseThresholdSlider_ValueChanged"/>

                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Acceleration" FontSize="13" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                            <TextBlock Text="0 = off (linear). Held deflection ramps up speed over time."
                                                       FontSize="11"
                                                       Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <TextBlock x:Name="ControllerEmulationMouseAccelerationValue"
                                                   Grid.Column="1"
                                                   Text="0"
                                                   FontSize="13"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="ControllerEmulationMouseAccelerationSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="100"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            Value="0"
                                            IsEnabled="False"
                                            ValueChanged="ControllerEmulationMouseAccelerationSlider_ValueChanged"/>

                                    <!-- Mouse Mode Button Mapping -->
                                    <TextBlock Text="Button Mapping" FontSize="13" Foreground="#FFFFFF" Margin="0,14,0,4"/>

                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="180"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Left Click" FontSize="13" Foreground="#FFFFFF"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ControllerEmulationMouseLeftClickButtonComboBox"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  IsEnabled="False">
                                            <ComboBoxItem Content="None"  Tag="0"/>
                                            <ComboBoxItem Content="A"     Tag="1"/>
                                            <ComboBoxItem Content="B"     Tag="2"/>
                                            <ComboBoxItem Content="X"     Tag="3"/>
                                            <ComboBoxItem Content="Y"     Tag="4"/>
                                            <ComboBoxItem Content="LB"    Tag="5"/>
                                            <ComboBoxItem Content="RB"    Tag="6"/>
                                            <ComboBoxItem Content="LS"    Tag="7"/>
                                            <ComboBoxItem Content="RS"    Tag="8"/>
                                            <ComboBoxItem Content="LT"    Tag="9"/>
                                            <ComboBoxItem Content="RT"    Tag="10" IsSelected="True"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="180"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Right Click" FontSize="13" Foreground="#FFFFFF"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ControllerEmulationMouseRightClickButtonComboBox"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  IsEnabled="False">
                                            <ComboBoxItem Content="None"  Tag="0"/>
                                            <ComboBoxItem Content="A"     Tag="1"/>
                                            <ComboBoxItem Content="B"     Tag="2"/>
                                            <ComboBoxItem Content="X"     Tag="3"/>
                                            <ComboBoxItem Content="Y"     Tag="4"/>
                                            <ComboBoxItem Content="LB"    Tag="5"/>
                                            <ComboBoxItem Content="RB"    Tag="6"/>
                                            <ComboBoxItem Content="LS"    Tag="7"/>
                                            <ComboBoxItem Content="RS"    Tag="8"/>
                                            <ComboBoxItem Content="LT"    Tag="9" IsSelected="True"/>
                                            <ComboBoxItem Content="RT"    Tag="10"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="180"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Cursor" FontSize="13" Foreground="#FFFFFF"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ControllerEmulationMouseCursorStickComboBox"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  IsEnabled="False">
                                            <ComboBoxItem Content="Right Stick" Tag="0"/>
                                            <ComboBoxItem Content="Left Stick"  Tag="1" IsSelected="True"/>
                                        </ComboBox>
                                    </Grid>

                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="180"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Scroll" FontSize="13" Foreground="#FFFFFF"/>
                                        </StackPanel>
                                        <ComboBox x:Name="ControllerEmulationMouseScrollStickComboBox"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  IsEnabled="False">
                                            <ComboBoxItem Content="Left Stick"  Tag="0"/>
                                            <ComboBoxItem Content="Right Stick" Tag="1" IsSelected="True"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Extra assignable actions: browser/window-management shortcuts + cursor
                                         nudge, on top of the fixed Left/Right Click above. Each of the 4 slots
                                         picks a trigger button and an action; None/None = unused. -->
                                    <TextBlock Text="Extra Actions" FontSize="13" Foreground="#FFFFFF" Margin="0,14,0,4"/>
                                    <TextBlock Text="Assign a button to a browser/window shortcut or cursor nudge"
                                               FontSize="11"
                                               Foreground="{StaticResource HintTextBrush}"
                                               Margin="0,0,0,4"/>

                                    <Grid Margin="0,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox x:Name="ControllerEmulationMouseAction1ButtonComboBox" Grid.Column="0"
                                                  ItemTemplate="{StaticResource GamepadActionItemTemplate}"
                                                  Style="{StaticResource ModernComboBoxStyle}" IsEnabled="False" SelectedIndex="0"
                                                  SelectionChanged="ControllerEmulationMouseActionSlot_SelectionChanged">
                                            <x:String>None</x:String>
                                            <x:String>A</x:String><x:String>B</x:String><x:String>X</x:String><x:String>Y</x:String>
                                            <x:String>LB</x:String><x:String>RB</x:String><x:String>LS</x:String><x:String>RS</x:String>
                                            <x:String>LT</x:String><x:String>RT</x:String>
                                        </ComboBox>
                                        <ComboBox x:Name="ControllerEmulationMouseAction1TypeComboBox" Grid.Column="1" Margin="6,0,0,0"
                                                  Style="{StaticResource ModernComboBoxStyle}" IsEnabled="False"
                                                  SelectionChanged="ControllerEmulationMouseActionSlot_SelectionChanged">
                                            <ComboBoxItem Content="None" Tag="0" IsSelected="True"/>
                                            <ComboBoxItem Content="Escape" Tag="1"/>
                                            <ComboBoxItem Content="Tab" Tag="2"/>
                                            <ComboBoxItem Content="Shift+Tab" Tag="3"/>
                                            <ComboBoxItem Content="Alt+Left (Back)" Tag="4"/>
                                            <ComboBoxItem Content="Alt+Right (Forward)" Tag="5"/>
