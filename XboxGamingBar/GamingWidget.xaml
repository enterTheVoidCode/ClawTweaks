                                        </Grid>

                                        <!-- Back Paddles -->
                                        <TextBlock Text="Back Paddles" Foreground="#FFFFFF" FontSize="13" FontWeight="SemiBold" Margin="0,8,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="L4" Grid.Column="0" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
                                            <ComboBox x:Name="GPDL4PaddleComboBox"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernComboBoxStyle}"
                                                      SelectionChanged="GPDL4PaddleComboBox_SelectionChanged">
                                                <x:String>Disabled</x:String>
                                                <x:String>F1</x:String><x:String>F2</x:String><x:String>F3</x:String><x:String>F4</x:String><x:String>F5</x:String><x:String>F6</x:String><x:String>F7</x:String><x:String>F8</x:String><x:String>F9</x:String><x:String>F10</x:String><x:String>F11</x:String><x:String>F12</x:String>
                                                <x:String>F13</x:String><x:String>F14</x:String><x:String>F15</x:String><x:String>F16</x:String><x:String>F17</x:String>
                                                <x:String>Enter</x:String><x:String>Escape</x:String><x:String>Space</x:String><x:String>Tab</x:String><x:String>Backspace</x:String>
                                                <x:String>Up</x:String><x:String>Down</x:String><x:String>Left</x:String><x:String>Right</x:String>
                                                <x:String>Home</x:String><x:String>End</x:String><x:String>PageUp</x:String><x:String>PageDown</x:String><x:String>Insert</x:String><x:String>Delete</x:String>
                                                <x:String>Left Ctrl</x:String><x:String>Left Shift</x:String><x:String>Left Alt</x:String><x:String>Left Win</x:String>
                                                <x:String>Right Ctrl</x:String><x:String>Right Shift</x:String><x:String>Right Alt</x:String>
                                                <x:String>Mouse Left</x:String><x:String>Mouse Right</x:String><x:String>Mouse Middle</x:String>
                                                <x:String>Mouse Wheel Up</x:String><x:String>Mouse Wheel Down</x:String>
                                            </ComboBox>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="R4" Grid.Column="0" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
                                            <ComboBox x:Name="GPDR4PaddleComboBox"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernComboBoxStyle}"
                                                      SelectionChanged="GPDR4PaddleComboBox_SelectionChanged">
                                                <x:String>Disabled</x:String>
                                                <x:String>F1</x:String><x:String>F2</x:String><x:String>F3</x:String><x:String>F4</x:String><x:String>F5</x:String><x:String>F6</x:String><x:String>F7</x:String><x:String>F8</x:String><x:String>F9</x:String><x:String>F10</x:String><x:String>F11</x:String><x:String>F12</x:String>
                                                <x:String>F13</x:String><x:String>F14</x:String><x:String>F15</x:String><x:String>F16</x:String><x:String>F17</x:String>
                                                <x:String>Enter</x:String><x:String>Escape</x:String><x:String>Space</x:String><x:String>Tab</x:String><x:String>Backspace</x:String>
                                                <x:String>Up</x:String><x:String>Down</x:String><x:String>Left</x:String><x:String>Right</x:String>
                                                <x:String>Home</x:String><x:String>End</x:String><x:String>PageUp</x:String><x:String>PageDown</x:String><x:String>Insert</x:String><x:String>Delete</x:String>
                                                <x:String>Left Ctrl</x:String><x:String>Left Shift</x:String><x:String>Left Alt</x:String><x:String>Left Win</x:String>
                                                <x:String>Right Ctrl</x:String><x:String>Right Shift</x:String><x:String>Right Alt</x:String>
                                                <x:String>Mouse Left</x:String><x:String>Mouse Right</x:String><x:String>Mouse Middle</x:String>
                                                <x:String>Mouse Wheel Up</x:String><x:String>Mouse Wheel Down</x:String>
                                            </ComboBox>
                                        </Grid>

                                        <!-- Apply/Restore Buttons -->
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="8"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Button x:Name="GPDApplyMappingsButton"
                                                    Grid.Column="0"
                                                    Content="Apply Mappings"
                                                    HorizontalAlignment="Stretch"
                                                    Style="{StaticResource StandaloneButtonStyle}"
                                                    Click="GPDApplyMappingsButton_Click"/>

                                            <Button x:Name="GPDRestoreDefaultsButton"
                                                    Grid.Column="2"
                                                    Content="Restore Defaults"
                                                    HorizontalAlignment="Stretch"
                                                    Style="{StaticResource StandaloneButtonStyle}"
                                                    Click="GPDRestoreDefaultsButton_Click"/>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- Dim overlay: shown whenever the connection banner is visible to focus
                     the user on the banner and block accidental tile interaction. -->
                <Border x:Name="BannerDimOverlay"
                        Background="#99000000"
                        VerticalAlignment="Stretch"
                        HorizontalAlignment="Stretch"
                        IsHitTestVisible="True"
                        Visibility="Collapsed"/>

                <!-- Connection Status Banner - placed last for z-order (renders on top) -->
                <!-- Visible by default with Loading... so user sees immediate feedback before code runs -->
                <Border x:Name="ConnectionStatusBanner"
                        Background="#3366CC"
                        Padding="14,10"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Stretch"
                        Visibility="Visible"
                        CornerRadius="10"
                        Margin="8,8,8,0">
                    <Border.Shadow>
                        <ThemeShadow/>
                    </Border.Shadow>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                Spacing="10">
                        <FontIcon x:Name="ConnectionStatusIcon"
                                  FontFamily="Segoe MDL2 Assets"
                                  Glyph="&#xE895;"
                                  FontSize="16"
                                  Foreground="White"
                                  VerticalAlignment="Center"/>
                        <TextBlock x:Name="ConnectionStatusText"
                                   Text="Loading..."
                                   Foreground="White"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap"
                                   MaxWidth="320"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Update Available Banner - appears below connection banner when update is found -->
                <Border x:Name="UpdateAvailableBanner"
                        Background="#2D7D2D"
                        Padding="8,6"
                        VerticalAlignment="Top"
                        Visibility="Collapsed"
                        CornerRadius="0"
                        Margin="0,24,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="UpdateAvailableText"
                                   Text="Update Available: v0.0.0"
                                   Foreground="White"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Grid.Column="0"
                                   Margin="8,0,0,0"/>
                        <Button x:Name="UpdateBannerButton"
                                Content="Update"
                                Grid.Column="1"
                                Padding="12,2"
                                FontSize="11"
                                Background="#3D9D3D"
                                Foreground="White"
                                Margin="8,0,0,0"
                                Click="UpdateBannerButton_Click"/>
                        <Button x:Name="DismissUpdateBannerButton"
                                Content="&#xE711;"
                                FontFamily="Segoe MDL2 Assets"
                                Grid.Column="2"
                                Padding="6,2"
                                FontSize="10"
                                Background="Transparent"
                                Foreground="#AAFFAA"
                                Margin="4,0,4,0"
                                Click="DismissUpdateBannerButton_Click"/>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════════════════════
                     Trigger Tab
                     ══════════════════════════════════════════════════════ -->
                <ScrollViewer x:Name="TriggerScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16" Spacing="0">

                        <!-- ── Hotkeys ─────────────────────────────────── -->
                        <TextBlock Text="HOTKEYS"
                                   Style="{StaticResource SectionHeaderStyle}"
                                   Margin="0,0,0,8"/>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Hotkeys" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="Assign controller button combinations that trigger keyboard shortcuts or Actions defined below."
                                           Style="{StaticResource CardCaptionStyle}"
                                           TextWrapping="Wrap"/>

                                <!-- Placeholder — list will be populated in a future update -->
                                <Border Background="#111111" BorderBrush="#2A2A2A" BorderThickness="1"
                                        CornerRadius="6" Padding="12,10" Margin="0,4,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE946;" FontSize="14" Foreground="#555555" VerticalAlignment="Center"/>
                                        <TextBlock Text="No hotkeys configured yet."
                                                   FontSize="12" Foreground="#555555" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ── Actions ─────────────────────────────────── -->
                        <TextBlock Text="ACTIONS"
                                   Style="{StaticResource SectionHeaderStyle}"
                                   Margin="0,20,0,8"/>

                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel Spacing="8">
                                <TextBlock Text="Actions" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="Define reusable actions — e.g. launch Steam Big Picture, open Playnite, show Alt+Tab overview — that can be assigned to Hotkeys above."
                                           Style="{StaticResource CardCaptionStyle}"
                                           TextWrapping="Wrap"/>

                                <!-- Placeholder — action list will be populated in a future update -->
                                <Border Background="#111111" BorderBrush="#2A2A2A" BorderThickness="1"
                                        CornerRadius="6" Padding="12,10" Margin="0,4,0,0">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE946;" FontSize="14" Foreground="#555555" VerticalAlignment="Center"/>
                                        <TextBlock Text="No actions defined yet."
                                                   FontSize="12" Foreground="#555555" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- Stub elements for removed UI features — Visibility=Collapsed, preserve x:Name for C# compilation -->
                <StackPanel Visibility="Collapsed" IsHitTestVisible="False">
                    <!-- AutoTDP stubs -->
                    <ToggleSwitch x:Name="AutoTDPToggle"/>
                    <Slider x:Name="AutoTDPTargetFPSSlider"/>
                    <TextBlock x:Name="AutoTDPTargetFPSValue"/>
                    <Slider x:Name="AutoTDPMinSlider"/>
                    <TextBlock x:Name="AutoTDPMinValue"/>
                    <Slider x:Name="AutoTDPMaxSlider"/>
                    <TextBlock x:Name="AutoTDPMaxValue"/>
                    <TextBlock x:Name="AutoTDPCurrentFPSValue"/>
                    <CheckBox x:Name="AutoTDPPauseWhenUnfocusedCheckBox"/>
                    <CheckBox x:Name="AutoTDPSyncFPSLimitCheckBox"/>
                    <ComboBox x:Name="AutoTDPControllerModeComboBox"/>
                    <StackPanel x:Name="AutoTDPMLInfoPanel">
                        <TextBlock x:Name="AutoTDPMLStatusText"/>
                        <Button x:Name="AutoTDPResetMLButton"/>
                        <TextBlock x:Name="AutoTDPLearnedSummaryText"/>
                        <StackPanel x:Name="AutoTDPLearnedHeatmapPanel"/>
                    </StackPanel>
                    <!-- StickyTDP stubs -->
                    <ToggleSwitch x:Name="StickyTDPToggle"/>
                    <Slider x:Name="StickyTDPIntervalSlider"/>
                    <TextBlock x:Name="StickyTDPIntervalValue"/>
                    <!-- CPU EPP / CPU State stubs -->
                    <Slider x:Name="CPUEPPSlider"/>
                    <TextBlock x:Name="CPUEPPValueText"/>
                    <ComboBox x:Name="MinCPUStateComboBox"/>
                    <ComboBox x:Name="MaxCPUStateComboBox"/>
                    <!-- Advanced Card stubs -->
                    <ToggleButton x:Name="AdvancedExpandButton"/>
                    <FontIcon x:Name="AdvancedExpandIcon"/>
                    <TextBlock x:Name="AdvancedSummary"/>
                    <StackPanel x:Name="AdvancedContent">
                        <ComboBox x:Name="ACPowerPlanComboBox"/>
                        <ComboBox x:Name="DCPowerPlanComboBox"/>
                        <ToggleSwitch x:Name="PowerPlanAutoSwitchToggle"/>
                        <StackPanel x:Name="CoreParkingSection">
                            <TextBlock x:Name="CoreParkingDescription"/>
                            <ComboBox x:Name="CoreParkingComboBox"/>
                        </StackPanel>
                        <StackPanel x:Name="CoreAffinitySection">
                            <ComboBox x:Name="PCoreCountComboBox"/>
                            <ComboBox x:Name="ECoreCountComboBox"/>
                        </StackPanel>
                        <ToggleSwitch x:Name="ForceParkModeToggle"/>
                    </StackPanel>
                    <!-- Removed device-info card stubs (replaced by ControllerStateCard) -->
                    <TextBlock x:Name="LegionDeviceNameText"/>
                    <TextBlock x:Name="LegionControllerStatusText"/>
                    <TextBlock x:Name="LegionControllerPidVidText"/>
                    <StackPanel x:Name="LegionControllerInfoSection">
                        <TextBlock x:Name="LegionControllerFirmwareText"/>
                        <TextBlock x:Name="LegionControllerLightText"/>
                        <Border x:Name="LegionControllerLightSwatch"/>
                        <TextBlock x:Name="LegionControllerVibrationText"/>
                        <TextBlock x:Name="LegionControllerTouchpadText"/>
                    </StackPanel>
                    <!-- Controller Battery stubs -->
                    <StackPanel x:Name="ControllerBatterySection">
                        <TextBlock x:Name="LeftControllerBatteryText"/>
                        <FontIcon x:Name="LeftControllerChargingIcon"/>
                        <TextBlock x:Name="LeftControllerConnectionText"/>
                        <TextBlock x:Name="RightControllerBatteryText"/>
                        <FontIcon x:Name="RightControllerChargingIcon"/>
                        <TextBlock x:Name="RightControllerConnectionText"/>
                    </StackPanel>
                    <!-- Battery Charge Limit stub -->
                    <ToggleSwitch x:Name="LegionChargeLimitToggle"/>
                    <!-- Display Tab (HDR + Adaptive Brightness + AMD) stubs -->
                    <ToggleSwitch x:Name="HDRToggle"/>
                    <StackPanel x:Name="SdrWhiteLevelSyncPanel"/>
                    <ComboBox x:Name="SdrWhiteLevelSyncModeComboBox"/>
                    <ToggleSwitch x:Name="AdaptiveBrightnessToggle"/>
                    <ToggleSwitch x:Name="AMDRadeonSuperResolutionToggle"/>
                    <Slider x:Name="AMDRadeonSuperResolutionSharpnessSlider"/>
                    <ToggleSwitch x:Name="AMDFluidMotionFrameToggle"/>
                    <ComboBox x:Name="AMDFluidMotionFrameAlgorithmComboBox"/>
                    <ComboBox x:Name="AMDFluidMotionFrameSearchModeComboBox"/>
                    <ComboBox x:Name="AMDFluidMotionFramePerformanceModeComboBox"/>
                    <ComboBox x:Name="AMDFluidMotionFrameFastMotionResponseComboBox"/>
                    <ToggleSwitch x:Name="AMDRadeonAntiLagToggle"/>
                    <ToggleSwitch x:Name="AMDRadeonBoostToggle"/>
                    <Slider x:Name="AMDRadeonBoostResolutionSlider"/>
                    <ToggleSwitch x:Name="AMDRadeonChillToggle"/>
                    <Slider x:Name="AMDRadeonChillMinFPSSlider"/>
                    <Slider x:Name="AMDRadeonChillMaxFPSSlider"/>
                    <ToggleSwitch x:Name="AMDImageSharpeningToggle"/>
                    <Slider x:Name="AMDImageSharpeningSlider"/>
                    <!-- TDP Settings (Control Method + PawnIO) stubs -->
                    <TextBlock x:Name="TdpMethodDescription"/>
                    <ComboBox x:Name="TdpMethodComboBox"/>
                    <ComboBoxItem x:Name="TdpMethodWmiItem"/>
                    <ComboBoxItem x:Name="TdpMethodPawnIOItem"/>
                    <ComboBoxItem x:Name="TdpMethodWinRing0Item"/>
                    <TextBlock x:Name="PawnIOStatusText"/>
                    <Button x:Name="InstallPawnIOButton"/>
                    <!-- Force Default Game Profiles stub -->
                    <ToggleSwitch x:Name="ForceDefaultGameProfileToggle"/>
                    <!-- Auto Hibernate stubs -->
                    <Border x:Name="AutoHibernateCard"/>
                    <ToggleSwitch x:Name="AutoHibernateToggle"/>
                    <ComboBox x:Name="AutoHibernateModeComboBox"/>
                    <TextBlock x:Name="AutoHibernateTimeoutValue"/>
                    <Slider x:Name="AutoHibernateTimeoutSlider"/>
                    <!-- Labs section (Controller tab) stubs -->
                    <Button x:Name="ToggleDAServiceButton"/>
                    <TextBlock x:Name="DAServiceStatusText"/>
                    <!-- Display tab (AMDScrollViewer) removed — stub for C# references -->
                    <ScrollViewer x:Name="AMDScrollViewer"/>
                </StackPanel>

            </Grid>
            </Grid> <!-- End Content Area Grid.Row="1" -->
        </Grid> <!-- End MainNavContainer -->
    </Grid>
</Page>
