                                        <TextBlock Grid.Row="11" Grid.Column="0" x:Name="GameProfileHDRLabel" Text="HDR" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="11" Grid.Column="1" x:Name="GameProfileHDRText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="12" Grid.Column="0" x:Name="GameProfileResolutionLabel" Text="Resolution" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="12" Grid.Column="1" x:Name="GameProfileResolutionText" Text="Native" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="13" Grid.Column="0" x:Name="GameProfileStickyTDPLabel" Text="Sticky TDP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="13" Grid.Column="1" x:Name="GameProfileStickyTDPText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="14" Grid.Column="0" x:Name="GameProfileCpuAdvLabel" Text="CPU" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="14" Grid.Column="1" x:Name="GameProfileCpuAdvText" Text="" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="15" Grid.Column="0" x:Name="GameProfileDisplayLabel" Text="Display" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="15" Grid.Column="1" x:Name="GameProfileDisplayText" Text="" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                                    </Grid>
                                    <!-- Multi-column rendering of the Now Playing profile (replaces the single-column grid above) -->
                                    <StackPanel x:Name="GameProfilePairs" Margin="0,8,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Saved Profiles (collapsible, own expandable region; collapsed by default) -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,16,0,0">
                            <StackPanel>
                                <!-- Header: title + expand toggle -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Saved Profiles" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Your saved per-game performance &amp; display profiles"
                                                   Style="{StaticResource CardCaptionStyle}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="PerfSavedProfilesExpandButton" Grid.Column="1" IsChecked="False"
                                                  VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Padding="8,4"
                                                  KeyDown="PerfSavedProfilesExpandButton_KeyDown"
                                                  Click="PerfSavedProfilesExpandButton_Click" UseSystemFocusVisuals="True">
                                        <FontIcon x:Name="PerfSavedProfilesExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <!-- Collapsible content: sort dropdown + the dynamically built profile cards -->
                                <StackPanel x:Name="PerfSavedProfilesContent" Visibility="Collapsed" Margin="0,12,0,0">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Sort by" FontSize="12" Foreground="#AAAAAA" VerticalAlignment="Center"/>
                                        <!--
                                            Sort dropdown for the saved-profiles list. Selection is
                                            persisted to LocalSettings["ProfileSortMode"] so it
                                            survives across widget re-opens. Tags are read by the
                                            C# code-behind in UpdateAllGameProfilesDisplay to drive ordering.
                                        -->
                                        <ComboBox x:Name="ProfileSortComboBox"
                                                  Grid.Column="1"
                                                  Width="150"
                                                  SelectionChanged="ProfileSortComboBox_SelectionChanged"
                                                  Style="{StaticResource ModernComboBoxStyle}">
                                            <ComboBoxItem Tag="name" Content="Name (A→Z)" IsSelected="True"/>
                                            <ComboBoxItem Tag="modified" Content="Last Modified"/>
                                            <ComboBoxItem Tag="tdp" Content="TDP (high → low)"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Container for dynamically created game profile cards -->
                                    <StackPanel x:Name="AllGameProfilesContainer"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Power Source Profile Card.
                             AC/DC split is removed for the GLOBAL profile, so this card is only shown
                             while a per-game profile is active (per-game profiles keep their AC/DC
                             split). Visibility is driven in code by UpdatePowerSourceProfileScopeText. -->
                        <Border x:Name="PowerSourceProfileCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Extra per Power Source Profiles" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Separate profiles for AC (plugged in) and DC (battery). Per-game only."
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="PowerSourceProfileToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}" Width="47"
                                                  XYFocusUp="{x:Bind ProfilesNavItem}"
                                                  XYFocusDown="{x:Bind ProfileSettingsExpandToggle}"/>
                                </Grid>
                                <TextBlock x:Name="PowerSourceProfileScopeText"
                                           Margin="0,8,0,0"
                                           FontSize="11"
                                           Foreground="#AAAAAA"
                                           TextWrapping="Wrap"
                                           Text="Scope: Global profiles. AC/DC split: Off. Enable Per-Game Profile to set this per game."/>
                            </StackPanel>
                        </Border>

                        <!-- Game Detection Card — [HIDDEN: Game-Bar-only redesign] detection is hardcoded
                             to Xbox Game Bar (+ RTSS); these toggles are ignored. Kept (Collapsed) so the
                             ProfileMatchByExe/ProfileGamesOnly property bindings stay intact. -->
                        <Border Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Game Detection"
                                                   Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Games with profiles always detect regardless of settings"
                                                   Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="ProfileDetectionExpandToggle"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="ProfileDetectionExpandToggle_Click">
                                        <FontIcon x:Name="ProfileDetectionExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <StackPanel x:Name="ProfileDetectionContent" Visibility="Collapsed" Margin="0,12,0,0" Spacing="12">

                                    <!-- Match Exe Toggle -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Prefer executable"
                                                       FontSize="12"
                                                       Foreground="#FFFFFF"/>
                                            <TextBlock Text="Use .exe name, fall back to window title if unavailable"
                                                       FontSize="11"
                                                       Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="ProfileMatchByExeToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"/>
                                    </Grid>

                                    <!-- Games Only Toggle -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Games only"
                                                       FontSize="12"
                                                       Foreground="#FFFFFF"/>
                                            <TextBlock Text="Detect apps with FPS (RTSS) or added to Xbox Game Bar"
                                                       FontSize="11"
                                                       Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="ProfileGamesOnlyToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      IsOn="True"/>
                                    </Grid>

                                    <!-- COMMENTED OUT: Current Apps, Custom Games, and Blacklist sections
                                         These features caused user confusion and are disabled for now.

                                    <StackPanel>
                                        <TextBlock Text="Current apps"
                                                   FontSize="11"
                                                   Foreground="{StaticResource HintTextBrush}"
                                                   Margin="0,0,0,4"/>
                                        <StackPanel x:Name="ForegroundAppsContainer" Spacing="4">
                                            <TextBlock x:Name="ForegroundAppsEmptyText"
                                                       Text="No apps detected"
                                                       FontSize="11"
                                                       Foreground="#666666"
                                                       FontStyle="Italic"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="Custom games"
                                                   FontSize="12"
                                                   Foreground="#FFFFFF"/>
                                        <TextBlock Text="Apps always treated as games"
                                                   FontSize="11"
                                                   Foreground="{StaticResource HintTextBrush}"/>
                                        <TextBlock x:Name="CustomGamesEmptyText"
                                                   Text="No custom games added"
                                                   FontSize="11"
                                                   Foreground="#666666"
                                                   FontStyle="Italic"
                                                   Margin="0,8,0,0"/>
                                        <ItemsControl x:Name="CustomGamesList" Margin="0,4,0,0">
                                            ...
                                        </ItemsControl>
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="Blacklist"
                                                   FontSize="12"
                                                   Foreground="#FFFFFF"/>
                                        <TextBlock Text="Apps never treated as games"
                                                   FontSize="11"
                                                   Foreground="{StaticResource HintTextBrush}"/>
                                        <TextBlock x:Name="BlacklistEmptyText"
                                                   Text="No apps blacklisted"
                                                   FontSize="11"
                                                   Foreground="#666666"
                                                   FontStyle="Italic"
                                                   Margin="0,8,0,0"/>
                                        <ItemsControl x:Name="BlacklistList" Margin="0,4,0,0">
                                            ...
                                        </ItemsControl>
                                    </StackPanel>

                                    END COMMENTED OUT -->

                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Profile Settings Card (Collapsible) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header with Expand/Collapse -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Profile Settings" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Choose which settings are saved in profiles"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="ProfileSettingsExpandToggle"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  KeyDown="ProfileSettingsExpandToggle_KeyDown"
                                                  Click="ProfileSettingsExpandToggle_Click">
                                        <FontIcon x:Name="ProfileSettingsExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <!-- Collapsible Content -->
                                <StackPanel x:Name="ProfileSettingsContent" Visibility="Collapsed" Margin="0,12,0,0">
                                    <CheckBox x:Name="ProfileSaveTDPCheckBox"
                                              Content="TDP Power Limit"
                                              IsChecked="True"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveCPUBoostCheckBox"
                                              Content="CPU Boost"
                                              IsChecked="True"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <!-- CPU EPP — hidden on MSI Claw -->
                                    <CheckBox x:Name="ProfileSaveCPUEPPCheckBox"
                                              Content="CPU EPP"
                                              IsChecked="True"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Visibility="Collapsed"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <!-- CPU State — hidden on MSI Claw -->
                                    <CheckBox x:Name="ProfileSaveCPUStateCheckBox"
                                              Content="CPU State"
                                              IsChecked="True"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Visibility="Collapsed"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <!-- AMD Features — hidden on MSI Claw -->
                                    <CheckBox x:Name="ProfileSaveAMDFeaturesCheckBox"
                                              Content="AMD Features (FMF, Anti-Lag, Boost, Chill)"
                                              IsChecked="False"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Visibility="Collapsed"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveFPSLimitCheckBox"
                                              Content="FPS Limit"
                                              IsChecked="True"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <!-- AutoTDP — hidden on MSI Claw -->
                                    <CheckBox x:Name="ProfileSaveAutoTDPCheckBox"
                                              Content="AutoTDP (Enabled + Target FPS)"
                                              IsChecked="True"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Visibility="Collapsed"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveOSPowerModeCheckBox"
                                              Content="OS Power Mode"
                                              IsChecked="True"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <!-- HDR — hidden on MSI Claw -->
                                    <CheckBox x:Name="ProfileSaveHDRCheckBox"
                                              Content="HDR"
                                              IsChecked="False"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Visibility="Collapsed"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveResolutionCheckBox"
                                              Content="Resolution"
                                              IsChecked="False"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveRefreshRateCheckBox"
                                              Content="Refresh Rate"
                                              IsChecked="False"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <!-- Sticky TDP — hidden on MSI Claw -->
                                    <CheckBox x:Name="ProfileSaveStickyTDPCheckBox"
                                              Content="Sticky TDP"
                                              IsChecked="False"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Visibility="Collapsed"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveOverlayLevelCheckBox"
                                              Content="Overlay Level"
                                              IsChecked="False"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <!-- CPU Affinity — hidden on MSI Claw -->
                                    <CheckBox x:Name="ProfileSaveCPUAffinityCheckBox"
                                              Content="CPU Affinity"
                                              IsChecked="False"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Visibility="Collapsed"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- GAME TAB -->
                <ScrollViewer x:Name="GameScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Profiles content moved into the Performance tab. This tab is hidden (see TabSettings) and kept as an empty template for a future tab. -->

                        <!-- Hidden legacy elements from the removed "Current Game" card. Retained (Collapsed)
                             so the existing code-behind that updates them still compiles; the live
                             "current game" display is now the ActiveProfileCard at the top of the Performance tab. -->
                        <Image     x:Name="CurrentGameIcon"          Visibility="Collapsed" IsHitTestVisible="False"/>
                        <TextBlock x:Name="RunningGameText"          Visibility="Collapsed" Text="No game detected"/>
                        <TextBlock x:Name="CurrentGameProfileStatus" Visibility="Collapsed"/>

                    </StackPanel>
                </ScrollViewer>

                <!-- ONBOARDING / SETUP TAB -->
                <ScrollViewer x:Name="OnboardingScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16"
                                XYFocusKeyboardNavigation="Enabled">
                        <!-- App version & updates — collapsible, at the very top. Lists the latest and
                             previous release so the user can jump forward or roll back. -->
                        <muxc:Expander x:Name="AppUpdateExpander" Margin="0,0,0,10"
                                       HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                                       CornerRadius="8"
                                       IsExpanded="False" Expanding="AppUpdateExpander_Expanding">
                            <!-- Accent frame around the whole expander (header + content), collapsed and expanded. -->
                            <muxc:Expander.Resources>
                                <StaticResource x:Key="ExpanderHeaderBorderBrush" ResourceKey="ThemeAccentBrush"/>
                                <StaticResource x:Key="ExpanderContentBorderBrush" ResourceKey="ThemeAccentBrush"/>
                                <Thickness x:Key="ExpanderHeaderBorderThickness">1</Thickness>
                                <Thickness x:Key="ExpanderContentDownBorderThickness">1</Thickness>
                            </muxc:Expander.Resources>
                            <muxc:Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <FontIcon Glyph="&#xE895;" FontSize="14" Foreground="#5B8DEF" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="App version &amp; updates" FontSize="13" FontWeight="SemiBold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                </StackPanel>
                            </muxc:Expander.Header>
                            <StackPanel>
                                <!-- Version line + small refresh icon (clearly distinct from the Download &amp; install action) -->
                                <Grid Margin="0,0,0,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="AppUpdateCurrentVersionText" Grid.Column="0" Text="Installed version: …"
                                               FontSize="11" Foreground="#AAAAAA" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    <Button x:Name="AppUpdateRefreshBtn" Grid.Column="1" Click="AppUpdateRefresh_Click"
                                            Background="Transparent" BorderThickness="0" Padding="6" Width="34" Height="34"
                                            VerticalAlignment="Top" ToolTipService.ToolTip="Reload releases">
                                        <FontIcon Glyph="&#xE72C;" FontSize="16" Foreground="#5B8DEF"/>
                                    </Button>
                                </Grid>
                                <TextBlock Text="Only versions newer than yours are shown (no downgrades). Experimental test builds are flagged. The signed helper downloads and runs the installer — a PowerShell window shows the progress."
                                           FontSize="10" Foreground="#777777" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                <!-- Release cards (each with a Download &amp; install button) — directly below the header
                                     so the install action sits near the top. Built in code-behind (GamingWidget.AppUpdate.cs). -->
                                <StackPanel x:Name="AppReleasesContainer"/>

                                <!-- Spinner + status: directly under the cards so progress is visible right where you tapped install -->
                                <Border x:Name="AppUpdateProgressPanel" Visibility="Collapsed"
                                        Background="#1A1A2E" CornerRadius="8" Padding="12,10" Margin="0,8,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ProgressRing x:Name="AppUpdateSpinner" Grid.Column="0" IsActive="False" Width="22" Height="22"
                                                      Foreground="#5B8DEF" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                        <TextBlock x:Name="AppUpdateStatusText" Grid.Column="1" Text="" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#E6E6E6" TextWrapping="Wrap" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </muxc:Expander>

                        <muxc:Expander x:Name="SetupExpander"
                                       Margin="0,0,0,10"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Stretch"
                                       CornerRadius="8"
                                       IsExpanded="False">
                            <muxc:Expander.Resources>
                                <StaticResource x:Key="ExpanderHeaderBorderBrush" ResourceKey="ThemeAccentBrush"/>
                                <StaticResource x:Key="ExpanderContentBorderBrush" ResourceKey="ThemeAccentBrush"/>
                                <Thickness x:Key="ExpanderHeaderBorderThickness">1</Thickness>
                                <Thickness x:Key="ExpanderContentDownBorderThickness">1</Thickness>
                            </muxc:Expander.Resources>
                            <muxc:Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8D7;" FontSize="14" Foreground="#5B8DEF" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Setup &amp; Onboarding" FontSize="13" FontWeight="SemiBold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                </StackPanel>
                            </muxc:Expander.Header>
                            <StackPanel>
                        <TextBlock Text="ClawTweaks needs a few small tools. One click checks what's present and installs anything missing."
                                   FontSize="11" Foreground="#AAAAAA" TextWrapping="Wrap" Margin="0,0,0,8"/>

                        <!-- Step 1: Required tools — one button runs the proven check/installer for all four -->
                        <Border Background="#1A1A2E" CornerRadius="6" Padding="12" Margin="0,4,0,0">
                            <StackPanel>
                                <TextBlock Text="1. Install required tools" FontSize="13" FontWeight="SemiBold" Foreground="#FFFFFF"/>

                                <!-- Backend-switch notice (replaces the old usbip blurb): shown as a headline and
                                     blinking accent so the move off the discontinued ViGEm backend is unmissable. -->
                                <TextBlock x:Name="OnbBackendBlink" Loaded="OnbBackendBlink_Loaded"
                                           Text="We're switching from the discontinued ViGEm to VIIPER (USBIP)"
                                           FontSize="13" FontWeight="SemiBold" Foreground="#5B8DEF"
                                           TextWrapping="Wrap" Margin="0,4,0,10"/>

                                <!-- usbip-win2 FIRST: VIIPER backend driver. Not on winget → own download button
                                     (downloaded signed Inno-Setup installer, runs silently). -->
                                <Grid Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock x:Name="OnbUsbipStatus" Text="usbip-win2: Checking..." FontSize="11" Foreground="{StaticResource HintTextBrush}" VerticalAlignment="Center"/>
                                    <Button x:Name="OnbUsbipInstallBtn" Grid.Column="1" Content="Install usbip-win2"
                                            Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="10,4"
                                            Click="OnbUsbipInstall_Click"/>
                                </Grid>
                                <TextBlock Text="USB/IP kernel driver powering the default VIIPER controller emulation (button remapping, gyro-as-stick, Mouse Mode). Downloads + installs the official signed driver silently — needs internet once, reboot afterwards."
                                           FontSize="10" Foreground="#777777" TextWrapping="Wrap" Margin="0,1,0,4"/>
                                <TextBlock Text="Note: the usbip-win2 installer may open in the background — that's expected. Let it finish; it closes itself."
                                           FontSize="10" Foreground="#AAAAAA" TextWrapping="Wrap" Margin="0,0,0,8"/>

                                <!-- Frame around everything the "Check &amp; install tools" button covers — i.e. all
                                     required tools EXCEPT usbip-win2 (which has its own download button above). -->
                                <Border Background="#15151F" BorderBrush="#33333F" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,4,0,0">
                                    <StackPanel>
                                        <TextBlock Text="„Check &amp; install tools“ installs everything in this box in one go (everything except usbip-win2)."
                                                   FontSize="10" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap" Margin="0,0,0,4"/>

                                        <!-- Read-only per-tool status (refreshed after the run) + what each tool does -->
                                        <TextBlock x:Name="OnbHidHideStatus" Text="HidHide: Checking..."  FontSize="11" Foreground="{StaticResource HintTextBrush}" Margin="0,4,0,0"/>
                                        <TextBlock Text="Hides the Claw's built-in controller while emulation runs, so games see only the virtual pad — prevents double input."
                                                   FontSize="10" Foreground="#777777" TextWrapping="Wrap" Margin="0,1,0,0"/>

                                        <TextBlock x:Name="OnbRtssStatus"    Text="RTSS: Checking..."     FontSize="11" Foreground="{StaticResource HintTextBrush}" Margin="0,8,0,0"/>
                                        <TextBlock Text="RivaTuner Statistics Server. Draws the on-screen overlay (FPS, TDP, temps) and enforces the FPS limiter."
                                                   FontSize="10" Foreground="#777777" TextWrapping="Wrap" Margin="0,1,0,0"/>

                                        <TextBlock x:Name="OnbPawnIOStatus"  Text="PawnIO: Checking..."   FontSize="11" Foreground="{StaticResource HintTextBrush}" Margin="0,8,0,0"/>
                                        <TextBlock Text="Kernel sensor driver. Exposes CPU/GPU power and temperature to the overlay — without it the power readout stays at 0 W."
                                                   FontSize="10" Foreground="#777777" TextWrapping="Wrap" Margin="0,1,0,0"/>

                                        <!-- One-click group install. Backend-aware:
                                             PawnIO/HidHide/RTSS always, plus usbip when VIIPER / ViGEm when Legacy. -->
                                        <Button x:Name="OnbRunSetupBtn" Content="Check &amp; install tools"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                Style="{StaticResource ModernButtonStyle}" FontSize="13" Padding="10,8" Margin="0,12,0,0"
                                                Click="OnbRunSetup_Click"/>
                                        <!-- Live progress: spinner + text while the setup runs in the background -->
                                        <StackPanel x:Name="OnbSetupProgressPanel" Orientation="Horizontal" Margin="0,6,0,0" Visibility="Collapsed">
                                            <ProgressRing x:Name="OnbSetupSpinner" IsActive="False" Width="16" Height="16"
                                                          Foreground="#5B8DEF" VerticalAlignment="Top" Margin="0,1,8,0"/>
                                            <TextBlock x:Name="OnbSetupProgress" Text="" FontSize="11" Foreground="#AAAAAA"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="HidHide, RTSS and PawnIO are official, signed third-party tools installed via winget; usbip-win2 is the signed vendor driver, downloaded on demand. Individual install / download buttons live under System → Debug → Driver dependencies."
                                           FontSize="10" Foreground="#777777" TextWrapping="Wrap" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Step 2: MSI Center M -->
                        <Border Background="#1A1A2E" CornerRadius="6" Padding="12" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="2. Disable MSI Center M" FontSize="13" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock x:Name="OnbMsiCenterStatus" Text="Checking MSI Center M..." FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Button x:Name="OnbMsiCenterBtn" Grid.Column="1" Content="Disable" IsEnabled="False" Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="10,4" Click="OnbMsiCenterDisable_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Step 3: Controller emulation -->
                        <Border Background="#1A1A2E" CornerRadius="6" Padding="12" Margin="0,8,0,16">
                            <StackPanel>
                                <TextBlock Text="3. Enable controller emulation" FontSize="13" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                                    <TextBlock x:Name="OnbEmulationStatus" Text="Controller emulation: off" FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <Button x:Name="OnbEmulationBtn" Grid.Column="1" Content="Enable" IsEnabled="False" Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="10,4" Click="OnbEmulationEnable_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Optional (below step 3): Left MSI single-click setup — links to the Controls tab
                             (the combo group there is too coupled to safely duplicate). -->
                        <Border Background="#1A1A2E" CornerRadius="6" Padding="12" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Set up Left MSI (Claw) button" FontSize="13" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                                <TextBlock Text="Assign a single-click action to the Left MSI (front) button — e.g. open the Steam menu. Opens the full setup in the Controls tab."
                                           FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap" Margin="0,4,0,8"/>
                                <Button x:Name="OnbSetupLeftMsiBtn" Content="Set up Left MSI button →"
                                        Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="10,4"
                                        Click="OnbSetupLeftMsi_Click" HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <!-- Optional (below step 3): Auto-Jump position — mirror of the Controls-tab slider
                             (same handler ClawTweaksWidgetPosition_ValueChanged, kept in sync both ways). -->
                        <Border Background="#1A1A2E" CornerRadius="6" Padding="12" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Auto Jump to Clawtweaks on Gamebar Open" FontSize="13" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                                <TextBlock Text="The Right MSI button opens Game Bar (its press action is unchanged). When controller emulation is active, ClawTweaks then auto-jumps to its widget slot on open. Set this to ClawTweaks' actual position (usually #3 — Microsoft occupies the first two)."
                                           FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap" Margin="0,4,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="ClawTweaks widget position" Foreground="#AAAAAA" FontSize="12" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="OnbClawTweaksWidgetPositionValue" Grid.Column="1" Text="1"
                                               Foreground="{StaticResource SystemAccentBrush}" FontSize="12" VerticalAlignment="Center"/>
                                </Grid>
                                <Slider x:Name="OnbClawTweaksWidgetPositionSlider" Minimum="1" Maximum="10" StepFrequency="1" Value="1"
                                        ValueChanged="ClawTweaksWidgetPosition_ValueChanged"/>
                            </StackPanel>
                        </Border>

                        <!-- Legacy (ViGEm) — the old emulation backend, only relevant if you switch off VIIPER.
                             Not needed by default and does NOT gate onboarding while VIIPER is active. -->
                        <Border Background="#15151F" BorderBrush="#33333F" BorderThickness="1" CornerRadius="6" Padding="12" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Legacy (ViGEm)" FontSize="13" FontWeight="SemiBold" Foreground="#AAAAAA"/>
                                <TextBlock Text="ViGEmBus is the old controller-emulation driver. The default backend is now VIIPER (usbip-win2), so ViGEm is optional — only install it if you switch the backend to Legacy under System → Debug. It does not affect onboarding completion while VIIPER is active."
                                           FontSize="10" Foreground="#777777" TextWrapping="Wrap" Margin="0,2,0,6"/>
                                <TextBlock x:Name="OnbViGEmStatus" Text="ViGEmBus: Checking..." FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                            </StackPanel>
                        </Border>
                            </StackPanel>
                        </muxc:Expander>

                        <!-- Offboarding — install or remove individual tools, collapsed by default -->
                        <muxc:Expander x:Name="OffboardingExpander"
                                       Margin="0,0,0,10"
                                       HorizontalAlignment="Stretch"
                                       HorizontalContentAlignment="Stretch"
                                       CornerRadius="8"
                                       IsExpanded="False">
                            <muxc:Expander.Resources>
                                <StaticResource x:Key="ExpanderHeaderBorderBrush" ResourceKey="ThemeAccentBrush"/>
                                <StaticResource x:Key="ExpanderContentBorderBrush" ResourceKey="ThemeAccentBrush"/>
                                <Thickness x:Key="ExpanderHeaderBorderThickness">1</Thickness>
                                <Thickness x:Key="ExpanderContentDownBorderThickness">1</Thickness>
                            </muxc:Expander.Resources>
                            <muxc:Expander.Header>
                                <StackPanel Orientation="Horizontal">
                                    <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE74D;" FontSize="14" Foreground="#CC6644" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Offboarding" FontSize="13" FontWeight="SemiBold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                                </StackPanel>
                            </muxc:Expander.Header>
                            <StackPanel>
                                <TextBlock Text="Remove individual tools. Each row shows the current status and lets you uninstall independently."
                                           FontSize="11" Foreground="#AAAAAA" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <Border Background="#1A1A2E" CornerRadius="6" Padding="12">
                                    <StackPanel>
                                        <!-- usbip-win2 -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="DebugUsbipStatusText" Text="usbip-win2: Checking..."
                                                       FontSize="11" Foreground="{StaticResource HintTextBrush}" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" Margin="12,0,0,0">
                                                <Button x:Name="DebugUsbipInstallButton" Content="Install usbip-win2"
                                                        Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="10,4"
                                                        Click="DebugUsbipInstall_Click" Visibility="Collapsed"/>
                                                <Button x:Name="DebugUsbipUninstallButton" Content="Uninstall" IsEnabled="False"
                                                        Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="10,4"
                                                        Click="DebugUsbipUninstall_Click"/>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="USB/IP kernel driver for VIIPER controller emulation."
                                                   FontSize="10" Foreground="#777777" TextWrapping="Wrap" Margin="0,2,0,8"/>

                                        <!-- ViGEmBus -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="ControllerEmulationViGEmBusStatusText" Text="ViGEmBus: Checking..."
                                                       FontSize="11" Foreground="{StaticResource HintTextBrush}" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" Margin="12,0,0,0">
                                                <Button x:Name="ControllerEmulationViGEmBusInstallButton" Content="Install ViGEmBus"
                                                        Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="10,4"
                                                        Click="ViGEmBusInstallButton_Click" Visibility="Collapsed"/>
                                                <Button x:Name="ControllerEmulationViGEmBusUninstallButton" Content="Uninstall" IsEnabled="False"
                                                        Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="10,4"
                                                        Click="ViGEmBusUninstallButton_Click"/>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="Legacy controller emulation driver. Only needed when the VIIPER backend is off."
                                                   FontSize="10" Foreground="#777777" TextWrapping="Wrap" Margin="0,2,0,8"/>

                                        <!-- HidHide -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="ControllerEmulationHidHideStatusText" Text="HidHide: Checking..."
                                                       FontSize="11" Foreground="{StaticResource HintTextBrush}" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" Margin="12,0,0,0">
                                                <Button x:Name="ControllerEmulationHidHideInstallButton" Content="Install HidHide"
                                                        Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="10,4"
                                                        Click="HidHideInstallButton_Click" Visibility="Collapsed"/>
                                                <Button x:Name="ControllerEmulationHidHideUninstallButton" Content="Uninstall" IsEnabled="False"
                                                        Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="10,4"
                                                        Click="HidHideUninstallButton_Click"/>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="Hides the Claw's built-in controller while emulation runs — prevents double input."
                                                   FontSize="10" Foreground="#777777" TextWrapping="Wrap" Margin="0,2,0,8"/>

                                        <!-- RTSS -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="DebugRtssStatusText" Text="RTSS: Checking..."
                                                       FontSize="11" Foreground="{StaticResource HintTextBrush}" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" Margin="12,0,0,0">
                                                <Button x:Name="DebugRtssInstallButton" Content="Install RTSS"
                                                        Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="10,4"
                                                        Click="DebugRtssInstall_Click" Visibility="Collapsed"/>
                                                <Button x:Name="DebugRtssUninstallButton" Content="Uninstall" IsEnabled="False"
                                                        Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="10,4"
                                                        Click="DebugRtssUninstall_Click"/>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="RivaTuner Statistics Server — FPS limiter and on-screen overlay."
                                                   FontSize="10" Foreground="#777777" TextWrapping="Wrap" Margin="0,2,0,8"/>

                                        <!-- PawnIO -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock x:Name="DebugPawnIOStatusText" Text="PawnIO: Checking..."
                                                       FontSize="11" Foreground="{StaticResource HintTextBrush}" VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" Margin="12,0,0,0">
                                                <Button x:Name="DebugPawnIOInstallButton" Content="Install PawnIO"
                                                        Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="10,4"
                                                        Click="DebugPawnIOInstall_Click" Visibility="Collapsed"/>
                                                <Button x:Name="DebugPawnIOUninstallButton" Content="Uninstall" IsEnabled="False"
                                                        Style="{StaticResource ModernButtonStyle}" FontSize="11" Padding="10,4"
                                                        Click="DebugPawnIOUninstall_Click"/>
                                            </StackPanel>
                                        </Grid>
                                        <TextBlock Text="Kernel sensor driver — exposes CPU/GPU power and temperature to the overlay."
                                                   FontSize="10" Foreground="#777777" TextWrapping="Wrap" Margin="0,2,0,4"/>

                                    </StackPanel>
                                </Border>

                                <!-- Factory Reset -->
                        <Border Background="#2A1A1A"
                                BorderBrush="#662222"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Factory Reset" FontSize="14" Foreground="#CC4444" FontWeight="SemiBold"/>
                                    <TextBlock Text="Deletes all profiles, controller settings, custom tiles, TDP presets and Quick Settings. Charge limit is disabled and reset to 100 %. The app restarts with factory defaults."
                                               FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                </StackPanel>
                                <Button x:Name="FactoryResetButton"
                                        Grid.Column="1"
                                        Content="Reset all"
                                        Padding="12,6"
                                        Background="#3A1A1A"
                                        Foreground="#CC4444"
                                        BorderBrush="#662222"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        VerticalAlignment="Center"
                                        Click="FactoryResetButton_Click"/>
                            </Grid>
                        </Border>

                        <!-- Uninstall ClawTweaks -->
                        <Border Background="#1A1A1A"
                                BorderBrush="#444444"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="12"
                                Margin="0,0,0,8">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Uninstall ClawTweaks" FontSize="14" Foreground="#AAAAAA" FontWeight="SemiBold"/>
                                    <TextBlock Text="Opens Windows Settings → Apps so you can remove ClawTweaks. Run Factory Reset first to clean up all profiles and settings."
                                               FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap" Margin="0,3,0,0"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="Uninstall"
                                        Padding="12,6"
                                        VerticalAlignment="Center"
                                        Style="{StaticResource ModernButtonStyle}"
                                        Click="UninstallClawTweaks_Click"/>
                            </Grid>
                        </Border>
                            </StackPanel>
                        </muxc:Expander>

                        <!-- Tab Settings is owned by the System tab; hidden here to avoid a duplicate.
                             Kept in the tree (Collapsed) because the *Onboarding controls are referenced in code. -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0" Visibility="Collapsed">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Tab Settings" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Reorder tabs, hide the ones you don't need, optionally pick a default tab."
                                                   Style="{StaticResource CardCaptionStyle}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="TabSettingsExpandButtonOnboarding" Grid.Column="1" IsChecked="False"
                                                  VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Padding="8,4"
                                                  Click="TabSettingsExpandButton_Click" KeyDown="TabSettingsExpandButton_KeyDown"
                                                  UseSystemFocusVisuals="True">
                                        <FontIcon x:Name="TabSettingsExpandIconOnboarding" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <StackPanel x:Name="TabSettingsContentOnboarding" Visibility="Collapsed" Margin="0,12,0,0"
                                            XYFocusKeyboardNavigation="Enabled">
                                    <TextBlock Text="System and Setup can't be hidden."
                                               FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    <ItemsControl x:Name="TabSettingsItemsControlOnboarding">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0" Content="{Binding DisplayName}"
                                                              IsChecked="{Binding IsVisible, Mode=TwoWay}"
                                                              Visibility="{Binding CheckBoxVisibility}"
                                                              Foreground="#FFFFFF" Tag="{Binding Tag}"
                                                              UseSystemFocusVisuals="True" FocusVisualPrimaryBrush="White"
                                                              Checked="TabSettingVisible_Changed" Unchecked="TabSettingVisible_Changed"/>
                                                    <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                                               Visibility="{Binding LabelVisibility}"
                                                               Foreground="#FFFFFF" VerticalAlignment="Center" Margin="32,0,0,0"/>
                                                    <Button Grid.Column="1" Content="&#xE70E;" FontFamily="Segoe MDL2 Assets"
                                                            FontSize="10" Width="28" Height="24" Padding="0" Margin="4,0,0,0"
                                                            Background="Transparent" Tag="{Binding Tag}"
                                                            IsEnabled="{Binding CanMoveUp}" Click="TabSettingMoveUp_Click"/>
                                                    <Button Grid.Column="2" Content="&#xE70D;" FontFamily="Segoe MDL2 Assets"
                                                            FontSize="10" Width="28" Height="24" Padding="0" Margin="4,0,0,0"
                                                            Background="Transparent" Tag="{Binding Tag}"
                                                            IsEnabled="{Binding CanMoveDown}" Click="TabSettingMoveDown_Click"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid Margin="0,14,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0">
                                            <TextBlock Text="Open a specific tab on Game Bar open"
                                                       FontSize="14" Foreground="#E0E0E0" FontWeight="SemiBold" TextWrapping="Wrap"/>
                                            <TextBlock Text="Off = reopen at the last tab (default)." FontSize="11" Foreground="{StaticResource HintTextBrush}"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="DefaultTabToggleOnboarding" Grid.Column="1" VerticalAlignment="Center"
                                                      MinWidth="0" HorizontalAlignment="Right" Toggled="DefaultTabToggle_Toggled"/>
                                    </Grid>
                                    <ComboBox x:Name="DefaultTabComboOnboarding" HorizontalAlignment="Stretch" Margin="0,8,0,0"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              SelectionChanged="DefaultTabCombo_SelectionChanged"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Controller Guide button → stop Windows Game Bar from grabbing it -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Controller Guide button" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="Stops the virtual controller's Xbox/Guide button from opening the Windows Game Bar (turns off Windows' controller-to-Game-Bar shortcuts in the registry). Note: the Xbox button can currently still open the Xbox app, but it does not open Steam Big Picture or the Steam overlay — so this is geared toward Xbox-app users rather than Steam."
                                           FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap" Margin="0,2,0,8"/>
                                <Button x:Name="OnbGuideGameBarBtn" Content="Disable Game Bar on Guide button"
                                        Click="OnbDisableGuideGameBar_Click" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="OnbGuideGameBarStatus" FontSize="11" Foreground="{StaticResource HintTextBrush}"
                                           TextWrapping="Wrap" Margin="0,6,0,0" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- SYSTEM TAB -->
                <ScrollViewer x:Name="SystemScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">
                        <!-- Tab Settings: collapsible (default collapsed) — reorder tabs, hide non-mandatory ones, optional default tab -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
                            <StackPanel>
                                <!-- Header: title + expand toggle -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Tab Settings" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Reorder tabs, hide the ones you don't need, optionally pick a default tab."
                                                   Style="{StaticResource CardCaptionStyle}" TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="TabSettingsExpandButtonSystem" Grid.Column="1" IsChecked="False"
                                                  VerticalAlignment="Center" Background="Transparent" BorderThickness="0" Padding="8,4"
                                                  Click="TabSettingsExpandButton_Click" KeyDown="TabSettingsExpandButton_KeyDown"
                                                  UseSystemFocusVisuals="True">
                                        <FontIcon x:Name="TabSettingsExpandIconSystem" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <!-- Collapsible content -->
                                <StackPanel x:Name="TabSettingsContentSystem" Visibility="Collapsed" Margin="0,12,0,0"
                                            XYFocusKeyboardNavigation="Enabled">
                                    <TextBlock Text="System and Setup can't be hidden."
                                               FontSize="11" Foreground="{StaticResource HintTextBrush}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    <ItemsControl x:Name="TabSettingsItemsControlSystem">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,2">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0" Content="{Binding DisplayName}"
                                                              IsChecked="{Binding IsVisible, Mode=TwoWay}"
                                                              Visibility="{Binding CheckBoxVisibility}"
                                                              Foreground="#FFFFFF" Tag="{Binding Tag}"
                                                              UseSystemFocusVisuals="True" FocusVisualPrimaryBrush="White"
                                                              Checked="TabSettingVisible_Changed" Unchecked="TabSettingVisible_Changed"/>
                                                    <TextBlock Grid.Column="0" Text="{Binding DisplayName}"
                                                               Visibility="{Binding LabelVisibility}"
                                                               Foreground="#FFFFFF" VerticalAlignment="Center" Margin="32,0,0,0"/>
                                                    <Button Grid.Column="1" Content="&#xE70E;" FontFamily="Segoe MDL2 Assets"
