                        <Border x:Name="GameProfileCard" Style="{StaticResource CardStyle}" Visibility="Collapsed" Margin="0,8,0,0">
                            <StackPanel>
                                <!-- Game Profile with Power Source -->
                                <StackPanel x:Name="GameProfileWithPowerSource" Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    Spacing="8"
                                                    VerticalAlignment="Center">
                                            <Border Background="#005C2E"
                                                    CornerRadius="10"
                                                    Padding="6,1,6,1"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="Now Playing"
                                                           FontSize="9"
                                                           FontWeight="SemiBold"
                                                           Foreground="#A8FFC9"/>
                                            </Border>
                                            <TextBlock x:Name="GameProfileTitleWithPower"
                                                       Text="Game"
                                                       Style="{StaticResource CardTitleStyle}"
                                                       Foreground="#FFA500"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button x:Name="DeleteActiveProfileButtonWithPower"
                                                Grid.Column="1"
                                                Content="🗑️"
                                                FontSize="12"
                                                Width="28"
                                                Height="28"
                                                Padding="0"
                                                Background="#64FF0000"
                                                Foreground="White"
                                                BorderBrush="Transparent"
                                                BorderThickness="2"
                                                VerticalAlignment="Center"
                                                Click="DeleteActiveProfileButton_Click"/>
                                    </Grid>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Header -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="" FontSize="11" Foreground="#AAAAAA"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="AC" FontSize="11" Foreground="#FFD700" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="DC" FontSize="11" Foreground="#FF6B6B" HorizontalAlignment="Center"/>

                                        <!-- TDP Mode Row (Legion only) -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" x:Name="GameACDCProfileTDPModeLabel" Text="Mode" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="GameACProfileTDPModeText" Text="Balanced" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" x:Name="GameDCProfileTDPModeText" Text="Balanced" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>

                                        <!-- TDP Row -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" x:Name="GameACDCProfileTDPLabel" Text="TDP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="GameACProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" x:Name="GameDCProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>

                                        <!-- CPU Boost Row -->
                                        <TextBlock Grid.Row="3" Grid.Column="0" x:Name="GameACDCProfileCPUBoostLabel" Text="Boost" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="GameACProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="3" Grid.Column="2" x:Name="GameDCProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>

                                        <!-- CPU EPP Row -->
                                        <TextBlock Grid.Row="4" Grid.Column="0" x:Name="GameACDCProfileCPUEPPLabel" Text="EPP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="GameACProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="4" Grid.Column="2" x:Name="GameDCProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>

                                        <!-- CPU Clock Row -->
                                        <TextBlock Grid.Row="5" Grid.Column="0" x:Name="GameACDCProfileCPUStateLabel" Text="CPU St" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="GameACProfileCPUStateText" Text="5-100%" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="5" Grid.Column="2" x:Name="GameDCProfileCPUStateText" Text="5-100%" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>

                                        <!-- FPS Limit Row -->
                                        <TextBlock Grid.Row="6" Grid.Column="0" x:Name="GameACDCProfileFPSLimitLabel" Text="FPS Lim" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="6" Grid.Column="1" x:Name="GameACProfileFPSLimitText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="6" Grid.Column="2" x:Name="GameDCProfileFPSLimitText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>

                                        <!-- AutoTDP Row -->
                                        <TextBlock Grid.Row="7" Grid.Column="0" x:Name="GameACDCProfileAutoTDPLabel" Text="AutoTDP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="7" Grid.Column="1" x:Name="GameACProfileAutoTDPText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="7" Grid.Column="2" x:Name="GameDCProfileAutoTDPText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>

                                        <!-- Power Mode Row -->
                                        <TextBlock Grid.Row="8" Grid.Column="0" x:Name="GameACDCProfilePowerModeLabel" Text="Power" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="8" Grid.Column="1" x:Name="GameACProfilePowerModeText" Text="Balanced" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="8" Grid.Column="2" x:Name="GameDCProfilePowerModeText" Text="Balanced" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>

                                        <!-- AMD Features Row -->
                                        <TextBlock Grid.Row="9" Grid.Column="0" x:Name="GameACDCProfileAMDLabel" Text="AMD" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="9" Grid.Column="1" x:Name="GameACProfileAMDText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="9" Grid.Column="2" x:Name="GameDCProfileAMDText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>

                                        <!-- HDR Row -->
                                        <TextBlock Grid.Row="10" Grid.Column="0" x:Name="GameACDCProfileHDRLabel" Text="HDR" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="10" Grid.Column="1" x:Name="GameACProfileHDRText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="10" Grid.Column="2" x:Name="GameDCProfileHDRText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>

                                        <!-- Resolution Row -->
                                        <TextBlock Grid.Row="11" Grid.Column="0" x:Name="GameACDCProfileResolutionLabel" Text="Res" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="11" Grid.Column="1" x:Name="GameACProfileResolutionText" Text="Native" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="11" Grid.Column="2" x:Name="GameDCProfileResolutionText" Text="Native" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>

                                        <!-- Sticky TDP Row -->
                                        <TextBlock Grid.Row="12" Grid.Column="0" x:Name="GameACDCProfileStickyTDPLabel" Text="Sticky" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="12" Grid.Column="1" x:Name="GameACProfileStickyTDPText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="12" Grid.Column="2" x:Name="GameDCProfileStickyTDPText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>

                                    </Grid>
                                </StackPanel>

                                <!-- Game Profile without Power Source -->
                                <StackPanel x:Name="GameProfileWithoutPowerSource" Visibility="Collapsed">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0"
                                                    Orientation="Horizontal"
                                                    Spacing="8"
                                                    VerticalAlignment="Center">
                                            <Border Background="#005C2E"
                                                    CornerRadius="10"
                                                    Padding="6,1,6,1"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="Now Playing"
                                                           FontSize="9"
                                                           FontWeight="SemiBold"
                                                           Foreground="#A8FFC9"/>
                                            </Border>
                                            <TextBlock x:Name="GameProfileTitleNoPower"
                                                       Text="Game"
                                                       Style="{StaticResource CardTitleStyle}"
                                                       Foreground="#FFA500"
                                                       FontSize="14"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>
                                        <Button x:Name="DeleteActiveProfileButtonNoPower"
                                                Grid.Column="1"
                                                Content="🗑️"
                                                FontSize="12"
                                                Width="28"
                                                Height="28"
                                                Padding="0"
                                                Background="#64FF0000"
                                                Foreground="White"
                                                BorderBrush="Transparent"
                                                BorderThickness="2"
                                                VerticalAlignment="Center"
                                                Click="DeleteActiveProfileButton_Click"/>
                                    </Grid>
                                    <Grid Margin="0,8,0,0" Visibility="Collapsed">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" x:Name="GameProfileTDPModeLabel" Text="TDP Mode" FontSize="11" Foreground="#AAAAAA" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="GameProfileTDPModeText" Text="Balanced" FontSize="11" Foreground="#FFFFFF" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" x:Name="GameProfileTDPLabel" Text="TDP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="GameProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" x:Name="GameProfileTDPBoostLabel" Text="TDP Overboost" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="GameProfileTDPBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" x:Name="GameProfilePL2Label" Text="  PL2" FontSize="11" Foreground="#888888" Margin="0,2,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="GameProfilePL2Text" Text="37W" FontSize="11" Foreground="#888888" Margin="0,2,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" x:Name="GameProfileCPUBoostLabel" Text="CPU Boost" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="GameProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" x:Name="GameProfileCPUEPPLabel" Text="CPU EPP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="GameProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="6" Grid.Column="0" x:Name="GameProfileCPUStateLabel" Text="CPU State" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="6" Grid.Column="1" x:Name="GameProfileCPUStateText" Text="5-100%" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="7" Grid.Column="0" x:Name="GameProfileFPSLimitLabel" Text="FPS Limit" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="7" Grid.Column="1" x:Name="GameProfileFPSLimitText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="8" Grid.Column="0" x:Name="GameProfileAutoTDPLabel" Text="AutoTDP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="8" Grid.Column="1" x:Name="GameProfileAutoTDPText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="9" Grid.Column="0" x:Name="GameProfilePowerModeLabel" Text="Power Mode" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="9" Grid.Column="1" x:Name="GameProfilePowerModeText" Text="Balanced" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="10" Grid.Column="0" x:Name="GameProfileAMDLabel" Text="AMD" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="10" Grid.Column="1" x:Name="GameProfileAMDText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="11" Grid.Column="0" x:Name="GameProfileHDRLabel" Text="HDR" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="11" Grid.Column="1" x:Name="GameProfileHDRText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="12" Grid.Column="0" x:Name="GameProfileResolutionLabel" Text="Resolution" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="12" Grid.Column="1" x:Name="GameProfileResolutionText" Text="Native" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="13" Grid.Column="0" x:Name="GameProfileStickyTDPLabel" Text="Sticky TDP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="13" Grid.Column="1" x:Name="GameProfileStickyTDPText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="14" Grid.Column="0" x:Name="GameProfileCpuAdvLabel" Text="CPU" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="14" Grid.Column="1" x:Name="GameProfileCpuAdvText" Text="" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="15" Grid.Column="0" x:Name="GameProfileDisplayLabel" Text="Display" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="15" Grid.Column="1" x:Name="GameProfileDisplayText" Text="" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" TextWrapping="Wrap" Visibility="Collapsed"/>
                                    </Grid>
                                    <!-- Multi-column rendering of the Now Playing profile (replaces the single-column grid above) -->
                                    <StackPanel x:Name="GameProfilePairs" Margin="0,8,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Saved Profiles Section -->
                        <Grid Margin="0,24,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Saved Profiles"
                                       FontSize="16"
                                       Foreground="#00C8FF"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                            <!--
                                Sort dropdown for the saved-profiles list. Selection is
                                persisted to LocalSettings["ProfileSortMode"] so it
                                survives across widget re-opens. Tags are read by the
                                C# code-behind in UpdateAllGameProfilesDisplay to drive
                                ordering.
                            -->
                            <ComboBox x:Name="ProfileSortComboBox"
                                      Grid.Column="1"
                                      Width="150"
                                      SelectionChanged="ProfileSortComboBox_SelectionChanged"
                                      Style="{StaticResource ModernComboBoxStyle}">
                                <ComboBoxItem Tag="name" Content="Name (A→Z)" IsSelected="True"/>
                                <ComboBoxItem Tag="modified" Content="Last Modified"/>
                                <ComboBoxItem Tag="tdp" Content="TDP (high → low)"/>
                            </ComboBox>
                        </Grid>

                        <!-- Container for dynamically created game profile cards -->
                        <StackPanel x:Name="AllGameProfilesContainer"/>

                        <!-- Power Source Profile Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Extra per Power Source Profiles" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Separate profiles for AC (plugged in) and DC (battery)"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="PowerSourceProfileToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}" Width="47"
                                                  XYFocusUp="{x:Bind ProfilesNavItem}"
                                                  XYFocusDown="{x:Bind ProfileSettingsExpandToggle}"/>
                                </Grid>
                                <TextBlock x:Name="PowerSourceProfileScopeText"
                                           Margin="0,8,0,0"
                                           FontSize="11"
                                           Foreground="#AAAAAA"
                                           TextWrapping="Wrap"
                                           Text="Scope: Global profiles. AC/DC split: Off. Enable Per-Game Profile to set this per game."/>
                            </StackPanel>
                        </Border>

                        <!-- Game Detection Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Game Detection"
                                                   Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Games with profiles always detect regardless of settings"
                                                   Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="ProfileDetectionExpandToggle"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="ProfileDetectionExpandToggle_Click">
                                        <FontIcon x:Name="ProfileDetectionExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <StackPanel x:Name="ProfileDetectionContent" Visibility="Collapsed" Margin="0,12,0,0" Spacing="12">

                                    <!-- Match Exe Toggle -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Prefer executable"
                                                       FontSize="12"
                                                       Foreground="#FFFFFF"/>
                                            <TextBlock Text="Use .exe name, fall back to window title if unavailable"
                                                       FontSize="11"
                                                       Foreground="#888888"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="ProfileMatchByExeToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"/>
                                    </Grid>

                                    <!-- Games Only Toggle -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Games only"
                                                       FontSize="12"
                                                       Foreground="#FFFFFF"/>
                                            <TextBlock Text="Detect apps with FPS (RTSS) or added to Xbox Game Bar"
                                                       FontSize="11"
                                                       Foreground="#888888"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="ProfileGamesOnlyToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      IsOn="True"/>
                                    </Grid>

                                    <!-- COMMENTED OUT: Current Apps, Custom Games, and Blacklist sections
                                         These features caused user confusion and are disabled for now.

                                    <StackPanel>
                                        <TextBlock Text="Current apps"
                                                   FontSize="11"
                                                   Foreground="#888888"
                                                   Margin="0,0,0,4"/>
                                        <StackPanel x:Name="ForegroundAppsContainer" Spacing="4">
                                            <TextBlock x:Name="ForegroundAppsEmptyText"
                                                       Text="No apps detected"
                                                       FontSize="11"
                                                       Foreground="#666666"
                                                       FontStyle="Italic"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="Custom games"
                                                   FontSize="12"
                                                   Foreground="#FFFFFF"/>
                                        <TextBlock Text="Apps always treated as games"
                                                   FontSize="11"
                                                   Foreground="#888888"/>
                                        <TextBlock x:Name="CustomGamesEmptyText"
                                                   Text="No custom games added"
                                                   FontSize="11"
                                                   Foreground="#666666"
                                                   FontStyle="Italic"
                                                   Margin="0,8,0,0"/>
                                        <ItemsControl x:Name="CustomGamesList" Margin="0,4,0,0">
                                            ...
                                        </ItemsControl>
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="Blacklist"
                                                   FontSize="12"
                                                   Foreground="#FFFFFF"/>
