                        <!-- MSI Claw Fan Control card now lives permanently in the Fan tab (FanTabContent). -->

                        <!-- Fan Curve Graph Card (Coming Soon) -->
                        <Border x:Name="LegionFanCurveCard" Style="{StaticResource CardStyle}">
                            <StackPanel IsHitTestVisible="False" Opacity="0.5">
                                <!-- Coming Soon notice -->
                                <Border Background="#1A3A1A" CornerRadius="4" Padding="8,4" Margin="0,0,0,8" HorizontalAlignment="Left">
