<Page
    x:Class="XboxGamingBar.GamingWidget"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:XboxGamingBar"
    xmlns:converter="using:XboxGamingBar.Converter"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="670" d:DesignWidth="600"
    FontFamily="Bahnschrift SemiLight">

    <Page.Resources>
        <!-- Existing Converters -->
        <converter:WattStringConverter x:Key="WattStringConverter"/>
        <converter:MegahertzStringConverter x:Key="MegahertzStringConverter"/>
        <converter:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converter:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <converter:SharpnessPercentStringConverter x:Key="SharpnessPercentStringConverter"/>
        <converter:RadeonBoostResolutionStringConverter x:Key="RadeonBoostResolutionStringConverter"/>

        <!-- Xbox glyph next to each gamepad-action name in the button-remap dropdowns. -->
        <local:GamepadButtonIconConverter x:Key="GamepadButtonIconConverter"/>
        <local:GamepadButtonIconVisibilityConverter x:Key="GamepadButtonIconVisibilityConverter"/>
        <DataTemplate x:Key="GamepadActionItemTemplate">
            <StackPanel Orientation="Horizontal">
                <Image Width="20" Height="20" Margin="0,0,8,0" VerticalAlignment="Center"
                       Source="{Binding Converter={StaticResource GamepadButtonIconConverter}}"
                       Visibility="{Binding Converter={StaticResource GamepadButtonIconVisibilityConverter}}"/>
                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>

        <!-- Fluent glyph next to each Back-Button mode name (Gamepad/Keyboard/Mouse/Macro). -->
        <local:ButtonModeIconConverter x:Key="ButtonModeIconConverter"/>
        <DataTemplate x:Key="ButtonModeItemTemplate">
            <StackPanel Orientation="Horizontal">
                <FontIcon FontFamily="Segoe Fluent Icons" FontSize="14" Width="18" Margin="0,0,8,0" VerticalAlignment="Center"
                          Glyph="{Binding Converter={StaticResource ButtonModeIconConverter}}"/>
                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>

        <!-- Fluent glyph(s) next to each Macro repeat-mode name (Once/Repeat while held/Hold/
             Hold+Repeat). The combined "Hold + Repeat" mode shows both its icons together. -->
        <local:MacroModeIconConverter x:Key="MacroModeIconConverter"/>
        <local:MacroModeSecondaryIconConverter x:Key="MacroModeSecondaryIconConverter"/>
        <local:MacroModeSecondaryIconVisibilityConverter x:Key="MacroModeSecondaryIconVisibilityConverter"/>
        <DataTemplate x:Key="MacroModeItemTemplate">
            <StackPanel Orientation="Horizontal">
                <FontIcon FontFamily="Segoe Fluent Icons" FontSize="14" Width="18" Margin="0,0,4,0" VerticalAlignment="Center"
                          Glyph="{Binding Converter={StaticResource MacroModeIconConverter}}"/>
                <FontIcon FontFamily="Segoe Fluent Icons" FontSize="14" Width="18" Margin="0,0,8,0" VerticalAlignment="Center"
                          Glyph="{Binding Converter={StaticResource MacroModeSecondaryIconConverter}}"
                          Visibility="{Binding Converter={StaticResource MacroModeSecondaryIconVisibilityConverter}}"/>
                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
            </StackPanel>
        </DataTemplate>

        <!-- ════════════════════════════════════════════════════════════════════
             THEME ACCENT BRUSHES — driven entirely by the in-app theme (NOT the
             Windows system accent). Their colours are mutated at runtime in
             ApplyTheme(); because controls reference these same brush INSTANCES via
             {StaticResource}/{ThemeResource}, mutating .Color updates them live.
             ════════════════════════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="ThemeAccentBrush"  Color="#00C8FF"/>
        <SolidColorBrush x:Key="SystemAccentBrush" Color="#00C8FF"/>

        <!-- Slider: thicker track + themed gradient value fill. These override the
             WinUI Slider lightweight-styling resources for every Slider on the page. -->
        <x:Double x:Key="SliderTrackThemeHeight">7</x:Double>
        <x:Double x:Key="SliderHorizontalThumbWidth">22</x:Double>
        <x:Double x:Key="SliderHorizontalThumbHeight">22</x:Double>
        <LinearGradientBrush x:Key="SliderTrackValueFill" StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop Color="#00C8FF" Offset="0"/>
            <GradientStop Color="#66E6FF" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="SliderTrackValueFillPointerOver" StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop Color="#00C8FF" Offset="0"/>
            <GradientStop Color="#66E6FF" Offset="1"/>
        </LinearGradientBrush>
        <LinearGradientBrush x:Key="SliderTrackValueFillPressed" StartPoint="0,0.5" EndPoint="1,0.5">
            <GradientStop Color="#00C8FF" Offset="0"/>
            <GradientStop Color="#66E6FF" Offset="1"/>
        </LinearGradientBrush>
        <SolidColorBrush x:Key="SliderThumbBackground"            Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SliderThumbBackgroundPointerOver" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="SliderThumbBackgroundPressed"     Color="#E6F8FF"/>

        <!-- ToggleSwitch: ON state uses the theme accent instead of the system accent. -->
        <SolidColorBrush x:Key="ToggleSwitchFillOn"              Color="#00C8FF"/>
        <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver"   Color="#33D6FF"/>
        <SolidColorBrush x:Key="ToggleSwitchFillOnPressed"       Color="#00B0E0"/>
        <SolidColorBrush x:Key="ToggleSwitchStrokeOn"            Color="#00C8FF"/>
        <SolidColorBrush x:Key="ToggleSwitchStrokeOnPointerOver" Color="#33D6FF"/>
        <SolidColorBrush x:Key="ToggleSwitchStrokeOnPressed"     Color="#00B0E0"/>

        <!-- Tooth Theme Colors -->
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#25282C"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#30343A"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#50555C"/>
        <SolidColorBrush x:Key="ButtonBackground" Color="#3E434B"/>
        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#484E58"/>
        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3A3F47"/>
        <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="#2C3035"/>
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#6B7584"/>
        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#6B7584"/>
        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#555D69"/>
        <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="#3A3F46"/>
        <CornerRadius x:Key="ControlCornerRadius">8,8,8,8</CornerRadius>
        <Thickness x:Key="ButtonPadding">15,10,15,11</Thickness>

        <!-- Card Style - Tooth Theme -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
        </Style>

        <!-- Card Focus Border Brush -->
        <SolidColorBrush x:Key="CardFocusBorderBrush" Color="White"/>

        <!-- Navigation RadioButton Style - Optimized for Handheld XY Navigation -->
        <!-- Uses RadioButtons group which treats tabs as single navigable unit -->
        <Style x:Key="NavRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="8,7,8,7"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="UseSystemFocusVisuals" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid x:Name="RootGrid" Background="{TemplateBinding Background}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#FFFFFF"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#888888"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#555555"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#FFFFFF"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionBackground" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <!-- subtle "lift": the icon scales up a touch for a 3D/raised feel -->
                                            <DoubleAnimation Storyboard.TargetName="ContentScale" Storyboard.TargetProperty="ScaleX" To="1.05" Duration="0:0:0.12"/>
                                            <DoubleAnimation Storyboard.TargetName="ContentScale" Storyboard.TargetProperty="ScaleY" To="1.05" Duration="0:0:0.12"/>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unchecked"/>
                                    <VisualState x:Name="Indeterminate"/>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="FocusStates">
                                    <VisualState x:Name="Focused">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="FocusBorder" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unfocused"/>
                                    <VisualState x:Name="PointerFocused"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <!-- Active-tab "register" pill: raised rounded surface (subtle 3D
                                 gradient, lighter top → darker bottom) with an accent outline.
                                 Fully contained within the button bounds (small inset margin, no
                                 negative margins) so it stays centered on the icon and is never
                                 clipped by the nav bar. -->
                            <Border x:Name="SelectionBackground"
                                    Margin="2"
                                    CornerRadius="8"
                                    BorderThickness="1.2"
                                    BorderBrush="{StaticResource SystemAccentBrush}"
                                    Visibility="Collapsed">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="#454049" Offset="0"/>
                                        <GradientStop Color="#211F26" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                            <ContentPresenter x:Name="ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Foreground="{TemplateBinding Foreground}"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalContentAlignment="Center"
                                              VerticalContentAlignment="Center"
                                              RenderTransformOrigin="0.5,0.5"
                                              AutomationProperties.AccessibilityView="Raw">
                                <ContentPresenter.RenderTransform>
                                    <ScaleTransform x:Name="ContentScale" ScaleX="1" ScaleY="1"/>
                                </ContentPresenter.RenderTransform>
                            </ContentPresenter>
                            <!-- Focus ring (D-pad navigation) — stays on top so it's always visible -->
                            <Border x:Name="FocusBorder"
                                    BorderBrush="White"
                                    BorderThickness="2"
                                    CornerRadius="9"
                                    Margin="-2"
                                    Visibility="Collapsed"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card Title Style - Tooth Theme -->
        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Card Title Style - Compact Mode -->
        <Style x:Key="CardTitleStyleCompact" TargetType="TextBlock" BasedOn="{StaticResource CardTitleStyle}">
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <!-- Card Caption Style - Tooth Theme -->
        <Style x:Key="CardCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <!-- Card Caption Style - Compact Mode -->
        <Style x:Key="CardCaptionStyleCompact" TargetType="TextBlock" BasedOn="{StaticResource CardCaptionStyle}">
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <!-- Secondary "hint" text colour (the small sub-labels under a control, e.g. "Change the
             widget appearance"). Single knob for all of them: previously hard-coded #888888 inline
             everywhere, which read too dark across themes. Brightened here so it can be tuned (and
             theme-overridden) in one place. -->
        <SolidColorBrush x:Key="HintTextBrush" Color="#B4B4B4"/>

        <!-- Card Value Style -->
        <Style x:Key="CardValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource SystemAccentBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Card Value Style - Compact Mode -->
        <Style x:Key="CardValueStyleCompact" TargetType="TextBlock" BasedOn="{StaticResource CardValueStyle}">
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <!-- Modern Toggle Style - Uses system style, focus highlight on parent card -->
        <Style x:Key="ModernToggleStyle" TargetType="ToggleSwitch" BasedOn="{StaticResource DefaultToggleSwitchStyle}">
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="MaxWidth" Value="40"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="OffContent" Value=""/>
            <Setter Property="OnContent" Value=""/>
            <Setter Property="UseSystemFocusVisuals" Value="True"/>
            <Setter Property="FocusVisualPrimaryBrush" Value="White"/>
            <Setter Property="FocusVisualSecondaryBrush" Value="Transparent"/>
            <Setter Property="FocusVisualPrimaryThickness" Value="2"/>
            <Setter Property="FocusVisualMargin" Value="-3,-3,-3,-3"/>
        </Style>

        <!-- Modern Slider Style - Fluent with System Accent Color, focus on parent card -->
        <Style x:Key="ModernSliderStyle" TargetType="Slider" BasedOn="{StaticResource DefaultSliderStyle}">
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ManipulationMode" Value="None"/>
            <Setter Property="IsFocusEngagementEnabled" Value="True"/>
        </Style>

        <!-- Modern ComboBox Style - System style with minor customizations -->
        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource DefaultComboBoxStyle}">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <!-- Override ComboBox border colors to prevent highlight on focus/hover -->
        <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="#50555C"/>
        <SolidColorBrush x:Key="ComboBoxBorderBrushPressed" Color="#50555C"/>
        <SolidColorBrush x:Key="ComboBoxBorderBrushFocused" Color="#50555C"/>
        <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#30343A"/>
        <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="#30343A"/>
        <SolidColorBrush x:Key="ComboBoxBackgroundFocused" Color="#30343A"/>

        <!-- Modern Button Style - System style -->
        <Style x:Key="ModernButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        </Style>

        <!-- Key-picker launcher button: looks like the old "+ Key" dropdown, opens the grouped picker -->
        <Style x:Key="KeyPickerButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="BorderBrush" Value="#50555C"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Standalone Button Style - System style -->
        <Style x:Key="StandaloneButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <!-- Standalone ToggleButton Style - System style -->
        <Style x:Key="StandaloneToggleButtonStyle" TargetType="ToggleButton" BasedOn="{StaticResource DefaultToggleButtonStyle}">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <!-- Checkbox with system style -->
        <Style x:Key="FocusableCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource DefaultCheckBoxStyle}">
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- Default Button Style Override - uses system style -->
        <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        </Style>

        <!-- Default ToggleButton Style Override - uses system style -->
        <Style TargetType="ToggleButton" BasedOn="{StaticResource DefaultToggleButtonStyle}">
        </Style>

        <!-- Default CheckBox Style Override - uses system style -->
        <Style TargetType="CheckBox" BasedOn="{StaticResource DefaultCheckBoxStyle}">
        </Style>

        <!-- Section Header Style - Tooth Theme -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource SystemAccentBrush}"/>
            <Setter Property="Margin" Value="0,20,0,0"/>
        </Style>

        <!-- Quick Settings Tile Colors - Dark mode with sharp contrast -->
        <SolidColorBrush x:Key="TileOffBackground" Color="#1A1C1E"/>
        <SolidColorBrush x:Key="TileOnBackground" Color="#1A2E1F"/>
        <SolidColorBrush x:Key="TileActiveBackground" Color="#1A2530"/>
        <SolidColorBrush x:Key="TileTriggerBackground" Color="#252030"/>
        <SolidColorBrush x:Key="TileBorderBrush" Color="Transparent"/>
        <SolidColorBrush x:Key="TileFocusBorderBrush" Color="White"/>
        <!-- Inactive state: even darker -->
        <SolidColorBrush x:Key="TileInactiveBackground" Color="#0D0E0F"/>
        <SolidColorBrush x:Key="TileInactiveForeground" Color="#606060"/>

        <!-- Quick Settings Tile Style - Xbox Game Bar Widget UI Guidelines -->
        <!-- Rest: normal background, Focus: rest + white stroke, Press: 10% darker, Focus+Press: press + stroke, Inactive: 50% darker -->
        <Style x:Key="QuickSettingsTileStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource TileOffBackground}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,16"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="MinHeight" Value="90"/>
            <Setter Property="UseSystemFocusVisuals" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Shimmer" Storyboard.TargetProperty="Opacity">
                                                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                                                <LinearDoubleKeyFrame KeyTime="0:0:0.03" Value="0.5"/>
                                                <LinearDoubleKeyFrame KeyTime="0:0:0.28" Value="0.5"/>
                                                <LinearDoubleKeyFrame KeyTime="0:0:0.4" Value="0"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimation Storyboard.TargetName="ShimGS1" Storyboard.TargetProperty="Offset" From="0.00" To="0.70" Duration="0:0:0.4" EnableDependentAnimation="True">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ShimGS2" Storyboard.TargetProperty="Offset" From="0.10" To="0.80" Duration="0:0:0.4" EnableDependentAnimation="True">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ShimGS3" Storyboard.TargetProperty="Offset" From="0.20" To="0.90" Duration="0:0:0.4" EnableDependentAnimation="True">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ShimGS4" Storyboard.TargetProperty="Offset" From="0.30" To="1.00" Duration="0:0:0.4" EnableDependentAnimation="True">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PressedOverlay" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="InactiveOverlay" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource TileInactiveForeground}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="FocusStates">
                                    <VisualState x:Name="Focused">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="FocusBorder" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <!-- Controller focus triggers the same full-tile sheen sweep as hover,
                                                 so moving across tiles with the D-pad/stick plays the shimmer. -->
                                            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="Shimmer" Storyboard.TargetProperty="Opacity">
                                                <LinearDoubleKeyFrame KeyTime="0:0:0" Value="0"/>
                                                <LinearDoubleKeyFrame KeyTime="0:0:0.03" Value="0.5"/>
                                                <LinearDoubleKeyFrame KeyTime="0:0:0.28" Value="0.5"/>
                                                <LinearDoubleKeyFrame KeyTime="0:0:0.4" Value="0"/>
                                            </DoubleAnimationUsingKeyFrames>
                                            <DoubleAnimation Storyboard.TargetName="ShimGS1" Storyboard.TargetProperty="Offset" From="0.00" To="0.70" Duration="0:0:0.4" EnableDependentAnimation="True">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ShimGS2" Storyboard.TargetProperty="Offset" From="0.10" To="0.80" Duration="0:0:0.4" EnableDependentAnimation="True">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ShimGS3" Storyboard.TargetProperty="Offset" From="0.20" To="0.90" Duration="0:0:0.4" EnableDependentAnimation="True">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="ShimGS4" Storyboard.TargetProperty="Offset" From="0.30" To="1.00" Duration="0:0:0.4" EnableDependentAnimation="True">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseInOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unfocused"/>
                                    <VisualState x:Name="PointerFocused"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <!-- Background with light-grey border. Hosts the hover shimmer as its
                                 child so the diagonal light band is clipped to the rounded corners. -->
                            <Border x:Name="BackgroundBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#80B8C0CE"
                                    BorderThickness="1"
                                    CornerRadius="12">
                                <Grid>
                                    <!-- Permanent glass sheen: soft top-left highlight, always on at
                                         low opacity. Gives every (glass-theme) tile a glassy look. -->
                                    <Rectangle x:Name="GlassSheen" Opacity="0.34" IsHitTestVisible="False">
                                        <Rectangle.Fill>
                                            <!-- Strong in the top-left corner, fading to nothing by the
                                                 centre of the tile. -->
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop Color="#FFFFFFFF" Offset="0.0"/>
                                                <GradientStop Color="#80FFFFFF" Offset="0.22"/>
                                                <GradientStop Color="#00FFFFFF" Offset="0.50"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>

                                    <!-- Animated sheen: a constant-width bright band that sweeps the
                                         WHOLE tile on focus/hover. Offsets stay within [0,1] (UWP clamps
                                         GradientStop.Offset). The offset animations MUST set
                                         EnableDependentAnimation=True or UWP silently skips them (Offset
                                         is not a composition property) — that was why it never travelled. -->
                                    <Rectangle x:Name="Shimmer" Opacity="0" IsHitTestVisible="False">
                                        <Rectangle.Fill>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                <GradientStop x:Name="ShimGS1" Color="#00FFFFFF" Offset="0.00"/>
                                                <GradientStop x:Name="ShimGS2" Color="#C8FFFFFF" Offset="0.10"/>
                                                <GradientStop x:Name="ShimGS3" Color="#C8FFFFFF" Offset="0.20"/>
                                                <GradientStop x:Name="ShimGS4" Color="#00FFFFFF" Offset="0.30"/>
                                            </LinearGradientBrush>
                                        </Rectangle.Fill>
                                    </Rectangle>
                                </Grid>
                            </Border>

                            <!-- Pressed overlay (10% darker) -->
                            <Border x:Name="PressedOverlay"
                                    Background="#1A000000"
                                    CornerRadius="12"
                                    Visibility="Collapsed"/>

                            <!-- Inactive overlay (50% darker) -->
                            <Border x:Name="InactiveOverlay"
                                    Background="#80000000"
                                    CornerRadius="12"
                                    Visibility="Collapsed"/>

                            <!-- Focus stroke border -->
                            <Border x:Name="FocusBorder"
                                    BorderBrush="White"
                                    BorderThickness="2"
                                    CornerRadius="12"
                                    Visibility="Collapsed"/>

                            <!-- Content -->
                            <ContentPresenter x:Name="ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Quick Settings Edit Mode Checkbox Style -->
        <Style x:Key="TileVisibilityCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource DefaultCheckBoxStyle}">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

