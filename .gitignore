# Build outputs
[Bb]in/
[Oo]bj/
Build/

# NuGet packages
packages/

# MSIX app packages and bundles (can appear under any project subfolder)
AppPackages/
BundleArtifacts/

# Code signing certificate (sensitive — do not commit)
*.pfx

# Build logs
*.log
*.binlog

# Visual Studio
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates

# ReSharper
_ReSharper*/
*.ReSharper

# Rider
.idea/

# Private build/packaging tooling — kept local, not published
Build-Package.ps1

# Internal test-build counter (per machine, advanced by Build-Package.ps1 -Mode Test)
XboxGamingBarPackage/internal_build.txt

# Local-only reverse-engineering notes (kept off GitHub, purged from history)
/reverse_engineered/

# Local-only diagnostics tooling and button-icon assets (kept off GitHub)
/Diagnostics/
/XboxGamingBar/Assets/ButtonIcons/

# Claude's assistant memory — local working notes, never published.
# The real files live here; C:\Users\<user>\.claude\projects\<slug>\memory is a
# directory junction pointing at this folder, so both paths are the same data.
/memory/
