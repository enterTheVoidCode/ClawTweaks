<Page
    x:Class="XboxGamingBar.GamingWidget"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:XboxGamingBar"
    xmlns:converter="using:XboxGamingBar.Converter"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="670" d:DesignWidth="600">

    <Page.Resources>
        <!-- Existing Converters -->
        <converter:WattStringConverter x:Key="WattStringConverter"/>
        <converter:MegahertzStringConverter x:Key="MegahertzStringConverter"/>
        <converter:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converter:SharpnessPercentStringConverter x:Key="SharpnessPercentStringConverter"/>
        <converter:RadeonBoostResolutionStringConverter x:Key="RadeonBoostResolutionStringConverter"/>

        <!-- Tooth Theme Colors -->
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#25282C"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#30343A"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#50555C"/>
        <SolidColorBrush x:Key="ButtonBackground" Color="#3E434B"/>
        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#484E58"/>
        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3A3F47"/>
        <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="#2C3035"/>
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#6B7584"/>
        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#6B7584"/>
        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#555D69"/>
        <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="#3A3F46"/>
        <CornerRadius x:Key="ControlCornerRadius">8,8,8,8</CornerRadius>
        <Thickness x:Key="ButtonPadding">15,10,15,11</Thickness>

        <!-- Card Style - Tooth Theme -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
        </Style>

        <!-- Card Focus Border Brush -->
        <SolidColorBrush x:Key="CardFocusBorderBrush" Color="White"/>

        <!-- Navigation Item Style with Focus - Optimized for Handheld -->
        <Style x:Key="NavItemStyle" TargetType="muxc:NavigationViewItem">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FocusVisualPrimaryBrush" Value="White"/>
            <Setter Property="FocusVisualSecondaryBrush" Value="Transparent"/>
            <Setter Property="FocusVisualPrimaryThickness" Value="2"/>
            <Setter Property="FocusVisualMargin" Value="-2"/>
        </Style>

        <!-- Card Title Style - Tooth Theme -->
        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Card Title Style - Compact Mode -->
        <Style x:Key="CardTitleStyleCompact" TargetType="TextBlock" BasedOn="{StaticResource CardTitleStyle}">
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <!-- Card Caption Style - Tooth Theme -->
        <Style x:Key="CardCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <!-- Card Caption Style - Compact Mode -->
        <Style x:Key="CardCaptionStyleCompact" TargetType="TextBlock" BasedOn="{StaticResource CardCaptionStyle}">
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <!-- Card Value Style -->
        <Style x:Key="CardValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#00C8FF"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Card Value Style - Compact Mode -->
        <Style x:Key="CardValueStyleCompact" TargetType="TextBlock" BasedOn="{StaticResource CardValueStyle}">
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <!-- Modern Toggle Style - Uses system style, focus highlight on parent card -->
        <Style x:Key="ModernToggleStyle" TargetType="ToggleSwitch" BasedOn="{StaticResource DefaultToggleSwitchStyle}">
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="MaxWidth" Value="40"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="OffContent" Value=""/>
            <Setter Property="OnContent" Value=""/>
            <Setter Property="UseSystemFocusVisuals" Value="True"/>
            <Setter Property="FocusVisualPrimaryBrush" Value="White"/>
            <Setter Property="FocusVisualSecondaryBrush" Value="Transparent"/>
            <Setter Property="FocusVisualPrimaryThickness" Value="2"/>
            <Setter Property="FocusVisualMargin" Value="-3,-3,-3,-3"/>
        </Style>

        <!-- Modern Slider Style - Fluent with System Accent Color, focus on parent card -->
        <Style x:Key="ModernSliderStyle" TargetType="Slider" BasedOn="{StaticResource DefaultSliderStyle}">
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ManipulationMode" Value="None"/>
        </Style>

        <!-- Modern ComboBox Style - System style with minor customizations -->
        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource DefaultComboBoxStyle}">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <!-- Override ComboBox border colors to prevent highlight on focus/hover -->
        <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="#50555C"/>
        <SolidColorBrush x:Key="ComboBoxBorderBrushPressed" Color="#50555C"/>
        <SolidColorBrush x:Key="ComboBoxBorderBrushFocused" Color="#50555C"/>
        <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#30343A"/>
        <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="#30343A"/>
        <SolidColorBrush x:Key="ComboBoxBackgroundFocused" Color="#30343A"/>

        <!-- Modern Button Style - System style -->
        <Style x:Key="ModernButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        </Style>

        <!-- Standalone Button Style - System style -->
        <Style x:Key="StandaloneButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <!-- Standalone ToggleButton Style - System style -->
        <Style x:Key="StandaloneToggleButtonStyle" TargetType="ToggleButton" BasedOn="{StaticResource DefaultToggleButtonStyle}">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <!-- Checkbox with system style -->
        <Style x:Key="FocusableCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource DefaultCheckBoxStyle}">
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- Default Button Style Override - uses system style -->
        <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        </Style>

        <!-- Default ToggleButton Style Override - uses system style -->
        <Style TargetType="ToggleButton" BasedOn="{StaticResource DefaultToggleButtonStyle}">
        </Style>

        <!-- Default CheckBox Style Override - uses system style -->
        <Style TargetType="CheckBox" BasedOn="{StaticResource DefaultCheckBoxStyle}">
        </Style>

        <!-- Section Header Style - Tooth Theme -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#00C8FF"/>
            <Setter Property="Margin" Value="0,20,0,0"/>
        </Style>

        <!-- Quick Settings Tile Colors - Dark mode with sharp contrast -->
        <SolidColorBrush x:Key="TileOffBackground" Color="#1A1C1E"/>
        <SolidColorBrush x:Key="TileOnBackground" Color="#1A2E1F"/>
        <SolidColorBrush x:Key="TileActiveBackground" Color="#1A2530"/>
        <SolidColorBrush x:Key="TileTriggerBackground" Color="#252030"/>
        <SolidColorBrush x:Key="TileBorderBrush" Color="Transparent"/>
        <SolidColorBrush x:Key="TileFocusBorderBrush" Color="White"/>
        <!-- Inactive state: even darker -->
        <SolidColorBrush x:Key="TileInactiveBackground" Color="#0D0E0F"/>
        <SolidColorBrush x:Key="TileInactiveForeground" Color="#606060"/>

        <!-- Quick Settings Tile Style - Xbox Game Bar Widget UI Guidelines -->
        <!-- Rest: normal background, Focus: rest + white stroke, Press: 10% darker, Focus+Press: press + stroke, Inactive: 50% darker -->
        <Style x:Key="QuickSettingsTileStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource TileOffBackground}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,16"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="MinHeight" Value="90"/>
            <Setter Property="UseSystemFocusVisuals" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver"/>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PressedOverlay" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="InactiveOverlay" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource TileInactiveForeground}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="FocusStates">
                                    <VisualState x:Name="Focused">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="FocusBorder" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unfocused"/>
                                    <VisualState x:Name="PointerFocused"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <!-- Background with light border -->
                            <Border x:Name="BackgroundBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#50555C"
                                    BorderThickness="1"
                                    CornerRadius="12"/>

                            <!-- Pressed overlay (10% darker) -->
                            <Border x:Name="PressedOverlay"
                                    Background="#1A000000"
                                    CornerRadius="12"
                                    Visibility="Collapsed"/>

                            <!-- Inactive overlay (50% darker) -->
                            <Border x:Name="InactiveOverlay"
                                    Background="#80000000"
                                    CornerRadius="12"
                                    Visibility="Collapsed"/>

                            <!-- Focus stroke border -->
                            <Border x:Name="FocusBorder"
                                    BorderBrush="White"
                                    BorderThickness="2"
                                    CornerRadius="12"
                                    Visibility="Collapsed"/>

                            <!-- Content -->
                            <ContentPresenter x:Name="ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Quick Settings Edit Mode Checkbox Style -->
        <Style x:Key="TileVisibilityCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource DefaultCheckBoxStyle}">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

    </Page.Resources>

    <Grid>
        <ProgressRing x:Name="LoadingProgressRing"
                      IsActive="True"
                      Visibility="Collapsed"
                      Width="60"
                      Height="60"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>

        <muxc:NavigationView x:Name="MainNavigationView"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        IsPaneToggleButtonVisible="False"
                        PaneDisplayMode="Top"
                        OpenPaneLength="140"
                        CompactModeThresholdWidth="0"
                        ExpandedModeThresholdWidth="0"
                        Background="Transparent"
                        SelectionChanged="MainNavigationView_SelectionChanged">

            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem x:Name="QuickNavItem" Content="Quick" Tag="Quick" Style="{StaticResource NavItemStyle}"/>
                <muxc:NavigationViewItem x:Name="PerformanceNavItem" Content="Performance" Tag="Performance" Style="{StaticResource NavItemStyle}"/>
                <muxc:NavigationViewItem x:Name="ProfilesNavItem" Content="Profiles" Tag="Game" Style="{StaticResource NavItemStyle}"/>
                <muxc:NavigationViewItem x:Name="GraphicsNavItem" Content="Graphics" Tag="AMD" Style="{StaticResource NavItemStyle}"/>
                <muxc:NavigationViewItem x:Name="ScalingNavItem" Content="Scaling" Tag="Scaling" Style="{StaticResource NavItemStyle}"/>
                <muxc:NavigationViewItem x:Name="LegionNavItem" Content="Legion" Tag="Legion" Style="{StaticResource NavItemStyle}" Visibility="Collapsed"/>
                <muxc:NavigationViewItem x:Name="SystemNavItem" Content="System" Tag="System" Style="{StaticResource NavItemStyle}"/>
            </muxc:NavigationView.MenuItems>

            <!-- QUICK SETTINGS TAB -->
            <Grid>
                <!-- Connection Status Banner -->
                <Border x:Name="ConnectionStatusBanner"
                        Background="#CC3333"
                        Padding="8,4"
                        VerticalAlignment="Top"
                        Visibility="Collapsed"
                        CornerRadius="0"
                        Margin="0,0,0,0">
                    <TextBlock x:Name="ConnectionStatusText"
                               Text="Not connected to helper"
                               Foreground="White"
                               FontSize="12"
                               HorizontalAlignment="Center"/>
                </Border>
                <ScrollViewer x:Name="QuickSettingsScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Visible"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Dynamic Tiles Container - tiles generated in code-behind -->
                        <StackPanel x:Name="QuickSettingsTilesContainer"/>

                        <!-- Customize Button -->
                        <Button x:Name="QuickSettingsCustomizeButton"
                                Content="Customize"
                                HorizontalAlignment="Stretch"
                                Margin="0,16,0,0"
                                Style="{StaticResource StandaloneButtonStyle}"
                                Click="QuickSettingsCustomize_Click"/>

                        <!-- Customization Panel (hidden by default) -->
                        <Border x:Name="QuickSettingsCustomizePanel"
                                Style="{StaticResource CardStyle}"
                                Visibility="Collapsed"
                                Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Customize Tiles" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="Tap tile to select, tap another to swap. Tap same tile to toggle visibility."
                                           Style="{StaticResource CardCaptionStyle}"
                                           Margin="0,0,0,8"
                                           TextWrapping="Wrap"/>

                                <!-- Column Count Toggle -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Columns:"
                                               VerticalAlignment="Center"
                                               Foreground="#AAAAAA"
                                               FontSize="13"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button x:Name="Column3Button"
                                                Content="3"
                                                MinWidth="40"
                                                Margin="0,0,4,0"
                                                Click="ColumnCount3_Click"/>
                                        <Button x:Name="Column4Button"
                                                Content="4"
                                                MinWidth="40"
                                                Click="ColumnCount4_Click"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Sortable Tile Grid - generated in code-behind -->
                                <StackPanel x:Name="TileSortableGrid"/>

                                <!-- Selected tile indicator -->
                                <Border x:Name="SelectedTileIndicator"
                                        Visibility="Collapsed"
                                        Background="#1A2530"
                                        CornerRadius="4"
                                        Padding="8"
                                        Margin="0,8,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedTileText"
                                                   Foreground="#00C8FF"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                        <Button x:Name="DeleteSelectedTileButton"
                                                Grid.Column="1"
                                                Visibility="Collapsed"
                                                Background="#662020"
                                                Foreground="White"
                                                Margin="8,0,0,0"
                                                Padding="12,6"
                                                Click="DeleteSelectedTile_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <FontIcon Glyph="&#xE74D;" FontSize="14" Margin="0,0,6,0"/>
                                                <TextBlock Text="Delete"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Add Custom Shortcut Section -->
                                <TextBlock Text="Add Custom Shortcut"
                                           Style="{StaticResource CardTitleStyle}"
                                           Margin="0,16,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="CustomShortcutNameBox"
                                             PlaceholderText="Name"
                                             Grid.Column="0"/>
                                    <TextBox x:Name="CustomShortcutKeyBox"
                                             PlaceholderText="Shortcut (e.g. Alt+S)"
                                             Grid.Column="2"/>
                                </Grid>
                                <Button x:Name="AddCustomShortcutButton"
                                        Content="Add Shortcut Tile"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,8,0,0"
                                        Style="{StaticResource StandaloneButtonStyle}"
                                        Click="AddCustomShortcut_Click"/>

                                <!-- Done Button -->
                                <Button Content="Done"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,16,0,0"
                                        Style="{StaticResource StandaloneButtonStyle}"
                                        Click="QuickSettingsCustomizeDone_Click"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- PERFORMANCE TAB -->
                <ScrollViewer x:Name="PerformanceScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Active Profile Indicator -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="Using profile:"
                                               FontSize="12"
                                               Foreground="#AAAAAA"
                                               VerticalAlignment="Top" Margin="4,1,-5,0"/>
                                    <TextBlock x:Name="ActiveProfileText"
                                               Text="Global Settings"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#00C8FF"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Top" Margin="0,26,0,0"/>
                                </Grid>

                                <!-- Per-Game Profile Toggle -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Use per-game profile"
                                                   FontSize="12"
                                                   Foreground="#FFFFFF"/>
                                        <TextBlock x:Name="DetectedGameText"
                                                   Text="No game detected"
                                                   FontSize="11"
                                                   Foreground="#888888"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="200"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="PerGameProfileToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Performance Overlay Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Performance Overlay"
                                               Style="{StaticResource CardTitleStyle}"
                                               VerticalAlignment="Center"
                                               Grid.Column="0"/>
                                    <ComboBox x:Name="PerformanceOverlayComboBox"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              Width="120"
                                              Grid.Column="1"
                                              SelectionChanged="PerformanceOverlayComboBox_SelectionChanged"
                                              XYFocusDown="{x:Bind TDPSlider}"
                                              XYFocusLeft="{x:Bind PerformanceNavItem}">
                                        <ComboBoxItem Content="Off" Tag="0" IsSelected="True"/>
                                        <ComboBoxItem Content="Basic" Tag="1"/>
                                        <ComboBoxItem Content="Detailed" Tag="2"/>
                                        <ComboBoxItem Content="Full" Tag="3"/>
                                    </ComboBox>
                                </Grid>

                                <!-- Hidden slider for property system compatibility -->
                                <Slider x:Name="PerformanceOverlaySlider"
                                        Visibility="Collapsed"
                                        Minimum="0" Maximum="3"
                                        Value="0"
                                        ValueChanged="PerformanceOverlaySlider_ValueChanged"/>
                            </StackPanel>
                        </Border>

                        <!-- TDP Mode Card (Legion devices only) -->
                        <Border x:Name="TDPModeCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="TDP Mode" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Controls power and thermal profile"
                                               Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ComboBox x:Name="TDPModeComboBox"
                                          Width="140"
                                          Grid.Column="1"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectedIndex="1"
                                          SelectionChanged="TDPModeComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Quiet" Tag="1"/>
                                    <ComboBoxItem Content="Balanced" Tag="2"/>
                                    <ComboBoxItem Content="Performance" Tag="3"/>
                                    <ComboBoxItem Content="Custom" Tag="255"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- TDP Power Limit Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="TDP Power Limit" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock x:Name="TDPValueText"
                                               Text="{Binding ElementName=TDPSlider, Path=Value, Converter={StaticResource WattStringConverter}}"
                                               Style="{StaticResource CardValueStyle}"/>
                                </Grid>
                                <Slider x:Name="TDPSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="4" Maximum="35"
                                        TickFrequency="1"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False" Value="-5"/>
                                <Grid Margin="0,4,0,0">
                                    <TextBlock x:Name="CurrentTDPText"
                                               Text="Limits:"
                                               FontSize="12"
                                               Foreground="#A0A0A0"/>
                                    <TextBlock x:Name="CurrentTDPValueText"
                                               Text="-- W"
                                               FontSize="12"
                                               Foreground="#A0A0A0"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <!-- Sticky TDP Active Indicator -->
                                <TextBlock Text="Sticky TDP: Active"
                                           FontSize="13"
                                           Foreground="#4CAF50"
                                           FontWeight="SemiBold"
                                           Margin="0,1,0,0"
                                           Visibility="{Binding ElementName=StickyTDPToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- TDP Boost Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="TDP Boost" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Apply boost values to SPPT and FPPT for burst performance"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="TDPBoostToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  Toggled="TDPBoostToggle_Toggled"/>
                                </Grid>
                                <!-- TDP Boost Active Indicator -->
                                <TextBlock Text="TDP Boost: Active"
                                           FontSize="13"
                                           Foreground="#4CAF50"
                                           FontWeight="SemiBold"
                                           Margin="0,4,0,0"
                                           Visibility="{Binding ElementName=TDPBoostToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- AutoTDP Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="AutoTDP" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Automatically adjust TDP to maintain target FPS"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AutoTDPToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  Toggled="AutoTDPToggle_Toggled"/>
                                </Grid>
                                <StackPanel Visibility="{Binding ElementName=AutoTDPToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid Margin="0,12,0,0">
                                        <TextBlock Text="Target FPS"
                                                   FontSize="14"
                                                   Foreground="#A0A0A0"/>
                                        <TextBlock x:Name="AutoTDPTargetFPSValue"
                                                   Text="60 FPS"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="AutoTDPTargetFPSSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="30" Maximum="144"
                                            StepFrequency="1"
                                            Value="60"
                                            ValueChanged="AutoTDPTargetFPSSlider_ValueChanged"/>
                                    <Grid Margin="0,8,0,0">
                                        <TextBlock Text="Current FPS"
                                                   FontSize="14"
                                                   Foreground="#A0A0A0"/>
                                        <TextBlock x:Name="AutoTDPCurrentFPSValue"
                                                   Text="-- FPS"
                                                   FontSize="14"
                                                   Foreground="#FFCC00"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <!-- Min TDP Range -->
                                    <Grid Margin="0,12,0,0">
                                        <TextBlock Text="Min TDP"
                                                   FontSize="14"
                                                   Foreground="#A0A0A0"/>
                                        <TextBlock x:Name="AutoTDPMinValue"
                                                   Text="8W"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="AutoTDPMinSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="4" Maximum="85"
                                            StepFrequency="1"
                                            Value="8"
                                            ValueChanged="AutoTDPMinSlider_ValueChanged"/>
                                    <!-- Max TDP Range -->
                                    <Grid Margin="0,8,0,0">
                                        <TextBlock Text="Max TDP"
                                                   FontSize="14"
                                                   Foreground="#A0A0A0"/>
                                        <TextBlock x:Name="AutoTDPMaxValue"
                                                   Text="30W"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="AutoTDPMaxSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="4" Maximum="85"
                                            StepFrequency="1"
                                            Value="30"
                                            ValueChanged="AutoTDPMaxSlider_ValueChanged"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Sticky TDP Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Sticky TDP" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Automatically restore TDP limits if changed by other apps"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="StickyTDPToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  Toggled="StickyTDPToggle_Toggled"/>
                                </Grid>
                                <StackPanel Visibility="{Binding ElementName=StickyTDPToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid Margin="0,2,0,0">
                                        <TextBlock Text="How often to reapply TDP settings"
                                                   FontSize="14"
                                                   Foreground="#A0A0A0"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock x:Name="StickyTDPIntervalValue"
                                                   Text="5s"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="StickyTDPIntervalSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="3" Maximum="15"
                                            TickFrequency="2"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            Header="Check Interval"
                                            Value="5"
                                            ValueChanged="StickyTDPIntervalSlider_ValueChanged"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- OS Power Mode Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="OS Power Mode" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Windows power slider setting"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <TextBlock x:Name="OSPowerModeValue"
                                               Grid.Column="1"
                                               Text="Balanced"
                                               FontSize="14"
                                               Foreground="#4CAF50"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="0,0,0,0"/>
                                </Grid>
                                <ComboBox x:Name="OSPowerModeComboBox"
                                          Margin="0,12,0,0"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectedIndex="1"
                                          SelectionChanged="OSPowerModeComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Best Power Efficiency"/>
                                    <ComboBoxItem Content="Balanced"/>
                                    <ComboBoxItem Content="Best Performance"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- CPU Boost Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="CPU Boost" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Higher boost clocks" Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="CPUBoostToggle"
                                              Style="{StaticResource ModernToggleStyle}"
                                              Grid.Column="1"
                                              IsEnabled="False"/>
                            </Grid>
                        </Border>

                        <!-- CPU EPP Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="CPU EPP" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock x:Name="CPUEPPValueText"
                                               Text="{Binding ElementName=CPUEPPSlider, Path=Value}"
                                               Style="{StaticResource CardValueStyle}"/>
                                </Grid>
                                <Slider x:Name="CPUEPPSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="100"
                                        TickFrequency="10"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"/>
                                <Grid Margin="0,4,0,0">
                                    <TextBlock Text="0 = Prioritize CPU"
                                               FontSize="12"
                                               Foreground="#A0A0A0"/>
                                    <TextBlock Text="100 = Prioritize GPU"
                                               FontSize="12"
                                               Foreground="#A0A0A0"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- CPU State Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="CPU State" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="Processor performance limits" Style="{StaticResource CardCaptionStyle}"/>
                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                        <TextBlock Text="Min %" FontSize="12" Foreground="#888888" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="MinCPUStateComboBox"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  SelectionChanged="MinCPUStateComboBox_SelectionChanged"
                                                  IsEnabled="False"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                        <TextBlock Text="Max %" FontSize="12" Foreground="#888888" Margin="0,0,0,4"/>
                                        <ComboBox x:Name="MaxCPUStateComboBox"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  SelectionChanged="MaxCPUStateComboBox_SelectionChanged"
                                                  IsEnabled="False"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- FPS Limit Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="FPS Limit" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock x:Name="FPSLimitCaption"
                                                   Text=""
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   Visibility="Collapsed"/>
                                    </StackPanel>
                                    <TextBlock x:Name="FPSLimitValue"
                                               Grid.Column="1"
                                               Text=""
                                               FontSize="14"
                                               Foreground="#4CAF50"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"
                                               Visibility="{Binding ElementName=FPSLimitToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <ToggleSwitch x:Name="FPSLimitToggle"
                                                  Grid.Column="2"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False" Width="52"/>
                                </Grid>
                                <Slider x:Name="FPSLimitSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="15" Maximum="144"
                                        StepFrequency="1"
                                        TickFrequency="15"
                                        TickPlacement="Outside"
                                        SnapsTo="StepValues"
                                        Visibility="{Binding ElementName=FPSLimitToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- GAME TAB -->
                <ScrollViewer x:Name="GameScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Power Source Profile Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Power Source Profile" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Separate profiles for AC (plugged in) and DC (battery)"
                                               Style="{StaticResource CardCaptionStyle}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="PowerSourceProfileToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}" Width="47"
                                              XYFocusUp="{x:Bind ProfilesNavItem}"
                                              XYFocusDown="{x:Bind ProfileSettingsExpandButton}"/>
                            </Grid>
                        </Border>

                        <!-- Profile Settings Card (Collapsible) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header with Expand/Collapse -->
                                <Button x:Name="ProfileSettingsExpandButton"
                                        Click="ProfileSettingsExpandButton_Click"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        UseSystemFocusVisuals="True"
                                        FocusVisualPrimaryBrush="White"
                                        XYFocusUp="{x:Bind PowerSourceProfileToggle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Profile Settings" Style="{StaticResource CardTitleStyle}"/>
                                            <TextBlock Text="Choose which settings are saved in profiles"
                                                       Style="{StaticResource CardCaptionStyle}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <TextBlock x:Name="ProfileSettingsExpandIcon"
                                                   Text="&#xE70D;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14"
                                                   Foreground="#A0A0A0"
                                                   Grid.Column="1"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>

                                <!-- Collapsible Content -->
                                <StackPanel x:Name="ProfileSettingsContent" Visibility="Collapsed" Margin="0,12,0,0">
                                    <CheckBox x:Name="ProfileSaveTDPCheckBox"
                                              Content="TDP Power Limit"
                                              IsChecked="True"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveCPUBoostCheckBox"
                                              Content="CPU Boost"
                                              IsChecked="True"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveCPUEPPCheckBox"
                                              Content="CPU EPP"
                                              IsChecked="True"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveCPUStateCheckBox"
                                              Content="CPU State"
                                              IsChecked="True"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveAMDFeaturesCheckBox"
                                              Content="AMD Features (FMF, Anti-Lag, Boost, Chill)"
                                              IsChecked="False"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveFPSLimitCheckBox"
                                              Content="FPS Limit"
                                              IsChecked="True"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveAutoTDPCheckBox"
                                              Content="AutoTDP (Enabled + Target FPS)"
                                              IsChecked="True"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveOSPowerModeCheckBox"
                                              Content="OS Power Mode"
                                              IsChecked="True"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveHDRResolutionCheckBox"
                                              Content="HDR + Resolution"
                                              IsChecked="False"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveStickyTDPCheckBox"
                                              Content="Sticky TDP"
                                              IsChecked="False"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Current Game Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Current Game" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock x:Name="RunningGameText"
                                           Text="No game detected"
                                           FontSize="16"
                                           Foreground="White"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Global Profile Section -->
                        <TextBlock Text="Global Profile"
                                   FontSize="16"
                                   Foreground="#00C8FF"
                                   FontWeight="SemiBold"
                                   Margin="0,16,0,8"/>

                        <!-- Global Profile Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Global"
                                           Style="{StaticResource CardTitleStyle}"
                                           Foreground="#00FF88"
                                           FontSize="14"/>

                                <!-- Simple Mode (Power Source Toggle OFF) -->
                                <Grid x:Name="GlobalProfileSimple" Margin="0,8,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" x:Name="GlobalProfileTDPModeLabel" Text="TDP Mode" FontSize="11" Foreground="#AAAAAA" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="GlobalProfileTDPModeText" Text="Balanced" FontSize="11" Foreground="#FFFFFF" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" x:Name="GlobalProfileTDPLabel" Text="TDP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="GlobalProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" x:Name="GlobalProfileCPUBoostLabel" Text="CPU Boost" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="GlobalProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" x:Name="GlobalProfileCPUEPPLabel" Text="CPU EPP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="GlobalProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="4" Grid.Column="0" x:Name="GlobalProfileCPUStateLabel" Text="CPU State" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="GlobalProfileCPUStateText" Text="5-100%" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="5" Grid.Column="0" x:Name="GlobalProfileFPSLimitLabel" Text="FPS Limit" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="GlobalProfileFPSLimitText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="6" Grid.Column="0" x:Name="GlobalProfileAutoTDPLabel" Text="AutoTDP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="6" Grid.Column="1" x:Name="GlobalProfileAutoTDPText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="7" Grid.Column="0" x:Name="GlobalProfilePowerModeLabel" Text="Power Mode" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="7" Grid.Column="1" x:Name="GlobalProfilePowerModeText" Text="Balanced" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                    <TextBlock Grid.Row="8" Grid.Column="0" x:Name="GlobalProfileAMDLabel" Text="AMD" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="8" Grid.Column="1" x:Name="GlobalProfileAMDText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>
                                </Grid>

                                <!-- AC/DC Mode (Power Source Toggle ON) -->
                                <Grid x:Name="GlobalProfileACDC" Margin="0,8,0,0" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Header -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="" FontSize="11" Foreground="#AAAAAA"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="AC" FontSize="11" Foreground="#FFD700" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="DC" FontSize="11" Foreground="#FF6B6B" HorizontalAlignment="Center"/>

                                    <!-- TDP Mode Row (Legion only) -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" x:Name="ACDCProfileTDPModeLabel" Text="Mode" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ACProfileTDPModeText" Text="Balanced" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" x:Name="DCProfileTDPModeText" Text="Balanced" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>

                                    <!-- TDP Row -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" x:Name="ACDCProfileTDPLabel" Text="TDP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ACProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" x:Name="DCProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>

                                    <!-- CPU Boost Row -->
                                    <TextBlock Grid.Row="3" Grid.Column="0" x:Name="ACDCProfileCPUBoostLabel" Text="Boost" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ACProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="3" Grid.Column="2" x:Name="DCProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>

                                    <!-- CPU EPP Row -->
                                    <TextBlock Grid.Row="4" Grid.Column="0" x:Name="ACDCProfileCPUEPPLabel" Text="EPP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="ACProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="4" Grid.Column="2" x:Name="DCProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>

                                    <!-- CPU Clock Row -->
                                    <TextBlock Grid.Row="5" Grid.Column="0" x:Name="ACDCProfileCPUStateLabel" Text="CPU St" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="ACProfileCPUStateText" Text="5-100%" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                    <TextBlock Grid.Row="5" Grid.Column="2" x:Name="DCProfileCPUStateText" Text="5-100%" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>

                                    <!-- FPS Limit Row -->
