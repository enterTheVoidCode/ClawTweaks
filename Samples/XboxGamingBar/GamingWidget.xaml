<Page
    x:Class="XboxGamingBar.GamingWidget"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:XboxGamingBar"
    xmlns:converter="using:XboxGamingBar.Converter"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="670" d:DesignWidth="600">

    <Page.Resources>
        <!-- Existing Converters -->
        <converter:WattStringConverter x:Key="WattStringConverter"/>
        <converter:MegahertzStringConverter x:Key="MegahertzStringConverter"/>
        <converter:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converter:SharpnessPercentStringConverter x:Key="SharpnessPercentStringConverter"/>
        <converter:RadeonBoostResolutionStringConverter x:Key="RadeonBoostResolutionStringConverter"/>

        <!-- Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- Navigation Item Style with Focus - Optimized for Handheld -->
        <Style x:Key="NavItemStyle" TargetType="muxc:NavigationViewItem">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FocusVisualPrimaryBrush" Value="#00C8FF"/>
            <Setter Property="FocusVisualPrimaryThickness" Value="2"/>
        </Style>

        <!-- Card Title Style -->
        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Card Title Style - Compact Mode -->
        <Style x:Key="CardTitleStyleCompact" TargetType="TextBlock" BasedOn="{StaticResource CardTitleStyle}">
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <!-- Card Caption Style -->
        <Style x:Key="CardCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="Margin" Value="0,1,0,0"/>
        </Style>

        <!-- Card Caption Style - Compact Mode -->
        <Style x:Key="CardCaptionStyleCompact" TargetType="TextBlock" BasedOn="{StaticResource CardCaptionStyle}">
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <!-- Card Value Style -->
        <Style x:Key="CardValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#00C8FF"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Card Value Style - Compact Mode -->
        <Style x:Key="CardValueStyleCompact" TargetType="TextBlock" BasedOn="{StaticResource CardValueStyle}">
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <!-- Modern Toggle Style - Simplified for proper mouse/touch support -->
        <Style x:Key="ModernToggleStyle" TargetType="ToggleSwitch">
            <Setter Property="MinWidth" Value="44"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="OffContent" Value=""/>
            <Setter Property="OnContent" Value=""/>
            <Setter Property="FocusVisualPrimaryBrush" Value="#00C8FF"/>
            <Setter Property="FocusVisualPrimaryThickness" Value="2"/>
        </Style>

        <!-- Modern Slider Style - WinUI 3 Style -->
        <Style x:Key="ModernSliderStyle" TargetType="Slider">
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#00C8FF"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FocusVisualPrimaryBrush" Value="#00C8FF"/>
            <Setter Property="FocusVisualPrimaryThickness" Value="2"/>
            <Setter Property="FocusVisualMargin" Value="-3"/>
            <Setter Property="UseSystemFocusVisuals" Value="True"/>
            <Setter Property="ManipulationMode" Value="None"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.Resources>
                                <Style x:Key="SliderThumbStyle" TargetType="Thumb">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="{TemplateBinding Background}"
                                                        Width="20"
                                                        Height="20"
                                                        Stroke="#00C8FF"
                                                        StrokeThickness="2"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Grid.Resources>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid x:Name="SliderContainer" Grid.Row="1" Height="32" VerticalAlignment="Center">
                                <Grid x:Name="HorizontalTemplate">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <!-- Track Background -->
                                    <Rectangle x:Name="HorizontalTrackRect"
                                              Grid.ColumnSpan="3"
                                              Fill="#3A3A3A"
                                              Height="4"
                                              RadiusX="2"
                                              RadiusY="2"
                                              VerticalAlignment="Center"/>
                                    <!-- Filled Track -->
                                    <Rectangle x:Name="HorizontalDecreaseRect"
                                              Grid.Column="0"
                                              Fill="#00C8FF"
                                              Height="4"
                                              RadiusX="2"
                                              RadiusY="2"
                                              VerticalAlignment="Center"/>
                                    <!-- Thumb -->
                                    <Thumb x:Name="HorizontalThumb"
                                          Grid.Column="1"
                                          Style="{StaticResource SliderThumbStyle}"
                                          DataContext="{TemplateBinding Value}"
                                          Height="20"
                                          Width="20"
                                          AutomationProperties.AccessibilityView="Raw"/>
                                </Grid>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern ComboBox Style -->
        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="FocusVisualPrimaryBrush" Value="#00C8FF"/>
            <Setter Property="FocusVisualPrimaryThickness" Value="2"/>
        </Style>

    </Page.Resources>

    <Grid Background="Black">
        <ProgressRing x:Name="LoadingProgressRing"
                      IsActive="True"
                      Visibility="Collapsed"
                      Width="60"
                      Height="60"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>

        <muxc:NavigationView x:Name="MainNavigationView"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        IsPaneToggleButtonVisible="False"
                        PaneDisplayMode="Top"
                        OpenPaneLength="140"
                        CompactModeThresholdWidth="0"
                        ExpandedModeThresholdWidth="0"
                        Background="Transparent"
                        SelectionChanged="MainNavigationView_SelectionChanged">

            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="Performance" Tag="Performance" Style="{StaticResource NavItemStyle}"/>
                <muxc:NavigationViewItem Content="Profiles" Tag="Game" Style="{StaticResource NavItemStyle}"/>
                <muxc:NavigationViewItem Content="Graphics" Tag="AMD" Style="{StaticResource NavItemStyle}"/>
                <muxc:NavigationViewItem Content="System" Tag="System" Style="{StaticResource NavItemStyle}"/>
            </muxc:NavigationView.MenuItems>

            <!-- PERFORMANCE TAB -->
            <Grid>
                <ScrollViewer x:Name="PerformanceScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <StackPanel Padding="16,0,16,16">

                        <!-- Active Profile Indicator -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="Using profile:"
                                               FontSize="12"
                                               Foreground="#AAAAAA"
                                               VerticalAlignment="Top" Margin="4,1,-5,0"/>
                                    <TextBlock x:Name="ActiveProfileText"
                                               Text="Global Settings"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#00C8FF"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Top" Margin="0,26,0,0"/>
                                </Grid>

                                <!-- Per-Game Profile Toggle -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Use per-game profile"
                                                   FontSize="12"
                                                   Foreground="#FFFFFF"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="PerGameProfileToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Performance Overlay Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Performance Overlay" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>

                                <!-- Horizontal StackPanel for RadioButtons -->
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="2">
                                    <RadioButton x:Name="OverlayOff" Content="Off" GroupName="PerformanceOverlay" Tag="0" IsChecked="True" Checked="PerformanceOverlayRadio_Checked" Width="60"/>
                                    <RadioButton x:Name="OverlayBasic" Content="Basic" GroupName="PerformanceOverlay" Tag="1" Checked="PerformanceOverlayRadio_Checked"/>
                                    <RadioButton x:Name="OverlayDetailed" Content="Detailed" GroupName="PerformanceOverlay" Tag="2" Checked="PerformanceOverlayRadio_Checked"/>
                                    <RadioButton x:Name="OverlayFull" Content="Full" GroupName="PerformanceOverlay" Tag="3" Checked="PerformanceOverlayRadio_Checked"/>
                                </StackPanel>

                                <!-- Hidden slider for property system compatibility -->
                                <Slider x:Name="PerformanceOverlaySlider"
                                        Visibility="Collapsed"
                                        Minimum="0" Maximum="3"
                                        Value="0"
                                        ValueChanged="PerformanceOverlaySlider_ValueChanged"/>
                            </StackPanel>
                        </Border>

                        <!-- TDP Power Limit Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="TDP Power Limit" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock x:Name="TDPValueText"
                                               Text="{Binding ElementName=TDPSlider, Path=Value, Converter={StaticResource WattStringConverter}}"
                                               Style="{StaticResource CardValueStyle}"/>
                                </Grid>
                                <Slider x:Name="TDPSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="4" Maximum="35"
                                        TickFrequency="1"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"/>
                                <Grid Margin="0,4,0,0">
                                    <TextBlock x:Name="CurrentTDPText"
                                               Text="Limits:"
                                               FontSize="12"
                                               Foreground="#A0A0A0"/>
                                    <TextBlock x:Name="CurrentTDPValueText"
                                               Text="-- W"
                                               FontSize="12"
                                               Foreground="#A0A0A0"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <!-- Sticky TDP Active Indicator -->
                                <TextBlock Text="Sticky TDP: Active"
                                           FontSize="13"
                                           Foreground="#4CAF50"
                                           FontWeight="SemiBold"
                                           Margin="0,1,0,0"
                                           Visibility="{Binding ElementName=StickyTDPToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- CPU Boost Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="CPU Boost" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Higher boost clocks" Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="CPUBoostToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsEnabled="False"/>
                            </Grid>
                        </Border>

                        <!-- CPU EPP Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="CPU EPP" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock x:Name="CPUEPPValueText"
                                               Text="{Binding ElementName=CPUEPPSlider, Path=Value}"
                                               Style="{StaticResource CardValueStyle}"/>
                                </Grid>
                                <Slider x:Name="CPUEPPSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="100"
                                        TickFrequency="10"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"/>
                                <Grid Margin="0,4,0,0">
                                    <TextBlock Text="0 = Prioritize CPU"
                                               FontSize="12"
                                               Foreground="#A0A0A0"/>
                                    <TextBlock Text="100 = Prioritize GPU"
                                               FontSize="12"
                                               Foreground="#A0A0A0"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Limit CPU Clock Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Limit CPU Clock" Style="{StaticResource CardTitleStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LimitCPUClockToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                                <Slider x:Name="CPUClockMaxSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="1400" Maximum="5500"
                                        TickFrequency="100"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        Header="Max Frequency (MHz)"
                                        IsEnabled="False"
                                        Visibility="{Binding ElementName=LimitCPUClockToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- GAME TAB -->
                <ScrollViewer x:Name="GameScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <StackPanel Padding="16,0,16,16">

                        <!-- Power Source Profile Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Power Source Profile" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Separate profiles for AC (plugged in) and DC (battery)"
                                               Style="{StaticResource CardCaptionStyle}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="PowerSourceProfileToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"/>
                            </Grid>
                        </Border>

                        <!-- Current Game Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Current Game" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock x:Name="RunningGameText"
                                           Text="No game detected"
                                           FontSize="16"
                                           Foreground="White"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Global Profile Section -->
                        <TextBlock Text="Global Profile"
                                   FontSize="16"
                                   Foreground="#00C8FF"
                                   FontWeight="SemiBold"
                                   Margin="0,16,0,8"/>

                        <!-- Global Profile Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Global"
                                           Style="{StaticResource CardTitleStyle}"
                                           Foreground="#00FF88"
                                           FontSize="14"/>

                                <!-- Simple Mode (Power Source Toggle OFF) -->
                                <Grid x:Name="GlobalProfileSimple" Margin="0,8,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="TDP" FontSize="11" Foreground="#AAAAAA"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="GlobalProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="CPU Boost" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="GlobalProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="CPU EPP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="GlobalProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0"/>
                                </Grid>

                                <!-- AC/DC Mode (Power Source Toggle ON) -->
                                <Grid x:Name="GlobalProfileACDC" Margin="0,8,0,0" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Header -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="" FontSize="11" Foreground="#AAAAAA"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="AC" FontSize="11" Foreground="#FFD700" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="DC" FontSize="11" Foreground="#FF6B6B" HorizontalAlignment="Center"/>

                                    <!-- TDP Row -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="TDP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ACProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" x:Name="DCProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>

                                    <!-- CPU Boost Row -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Boost" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ACProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" x:Name="DCProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>

                                    <!-- CPU EPP Row -->
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="EPP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ACProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="2" x:Name="DCProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Game Profile Card (shown when game is detected) -->
                        <Border x:Name="GameProfileCard" Style="{StaticResource CardStyle}" Visibility="Collapsed" Margin="0,8,0,0">
                            <StackPanel>
                                <!-- Game Profile with Power Source -->
                                <StackPanel x:Name="GameProfileWithPowerSource" Visibility="Collapsed">
                                    <TextBlock x:Name="GameProfileTitleWithPower"
                                               Text="Game"
                                               Style="{StaticResource CardTitleStyle}"
                                               Foreground="#FFA500"
                                               FontSize="14"/>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Header -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="" FontSize="11" Foreground="#AAAAAA"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="AC" FontSize="11" Foreground="#FFD700" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="DC" FontSize="11" Foreground="#FF6B6B" HorizontalAlignment="Center"/>

                                        <!-- TDP Row -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="TDP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="GameACProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" x:Name="GameDCProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>

                                        <!-- CPU Boost Row -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Boost" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="GameACProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" x:Name="GameDCProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>

                                        <!-- CPU EPP Row -->
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="EPP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="GameACProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Row="3" Grid.Column="2" x:Name="GameDCProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Game Profile without Power Source -->
                                <StackPanel x:Name="GameProfileWithoutPowerSource" Visibility="Collapsed">
                                    <TextBlock x:Name="GameProfileTitleNoPower"
                                               Text="Game"
                                               Style="{StaticResource CardTitleStyle}"
                                               Foreground="#FFA500"
                                               FontSize="14"/>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="TDP" FontSize="11" Foreground="#AAAAAA"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="GameProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="CPU Boost" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="GameProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="CPU EPP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="GameProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Saved Profiles Section -->
                        <TextBlock Text="Saved Profiles"
                                   FontSize="16"
                                   Foreground="#00C8FF"
                                   FontWeight="SemiBold"
                                   Margin="0,24,0,8"/>

                        <!-- Container for dynamically created game profile cards -->
                        <StackPanel x:Name="AllGameProfilesContainer"/>

                    </StackPanel>
                </ScrollViewer>

                <!-- GRAPHICS TAB -->
                <ScrollViewer x:Name="AMDScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <StackPanel Padding="16,0,16,16">

                        <!-- Refresh Rate Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Refresh Rate" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,12"/>
                                <ComboBox x:Name="RefreshRatesComboBox"
                                          PlaceholderText="60 Hz"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}">
                                    <x:String>60 Hz</x:String>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- AMD Section Header -->
                        <TextBlock Text="AMD"
                                   FontSize="16"
                                   Foreground="#00C8FF"
                                   FontWeight="SemiBold"
                                   Margin="0,16,0,8"/>

                        <!-- Radeon Super Resolution Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Radeon Super Resolution" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Upscales lower resolutions" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AMDRadeonSuperResolutionToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                                <Slider x:Name="AMDRadeonSuperResolutionSharpnessSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="100"
                                        TickFrequency="10"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        Header="Sharpness"
                                        IsEnabled="False"
                                        Visibility="{Binding ElementName=AMDRadeonSuperResolutionToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- Fluid Motion Frames Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Fluid Motion Frames" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Frame generation" Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="AMDFluidMotionFrameToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsEnabled="False"/>
                            </Grid>
                        </Border>

                        <!-- Anti-Lag Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Radeon Anti-Lag" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Reduces input latency" Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="AMDRadeonAntiLagToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsEnabled="False"/>
                            </Grid>
                        </Border>

                        <!-- Radeon Boost Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Radeon Boost" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Dynamic resolution scaling" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AMDRadeonBoostToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                                <Slider x:Name="AMDRadeonBoostResolutionSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="1"
                                        TickFrequency="1"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"
                                        Visibility="{Binding ElementName=AMDRadeonBoostToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- Radeon Chill Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Radeon Chill" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Power saving when idle" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AMDRadeonChillToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                                <StackPanel Visibility="{Binding ElementName=AMDRadeonChillToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Slider x:Name="AMDRadeonChillMinFPSSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="30" Maximum="300"
                                            TickFrequency="10"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            Header="Min FPS"
                                            IsEnabled="False"/>
                                    <Slider x:Name="AMDRadeonChillMaxFPSSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="30" Maximum="300"
                                            TickFrequency="10"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            Header="Max FPS"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- SYSTEM TAB -->
                <ScrollViewer x:Name="SystemScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                    <StackPanel Padding="16,0,16,16">

                        <!-- Profile Settings Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Profile Settings" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                                <TextBlock Text="Choose which settings are saved in profiles"
                                           FontSize="12"
                                           Foreground="#A0A0A0"
                                           Margin="0,0,0,12"
                                           TextWrapping="Wrap"/>

                                <CheckBox x:Name="ProfileSaveTDPCheckBox"
                                          Content="TDP Power Limit"
                                          IsChecked="True"
                                          Foreground="#FFFFFF"
                                          Margin="0,4,0,0"/>
                                <CheckBox x:Name="ProfileSaveCPUBoostCheckBox"
                                          Content="CPU Boost"
                                          IsChecked="True"
                                          Foreground="#FFFFFF"
                                          Margin="0,4,0,0"/>
                                <CheckBox x:Name="ProfileSaveCPUEPPCheckBox"
                                          Content="CPU EPP"
                                          IsChecked="True"
                                          Foreground="#FFFFFF"
                                          Margin="0,4,0,0"/>
                                <CheckBox x:Name="ProfileSaveLimitCPUClockCheckBox"
                                          Content="Limit CPU Clock"
                                          IsChecked="True"
                                          Foreground="#FFFFFF"
                                          Margin="0,4,0,0"/>
                                <CheckBox x:Name="ProfileSaveAMDFeaturesCheckBox"
                                          Content="AMD Features (FMF, Anti-Lag, Boost, Chill)"
                                          IsChecked="False"
                                          Foreground="#FFFFFF"
                                          Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Sticky TDP Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Sticky TDP" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Automatically restore TDP limits if changed by other apps"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="StickyTDPToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  Toggled="StickyTDPToggle_Toggled"/>
                                </Grid>
                                <StackPanel Visibility="{Binding ElementName=StickyTDPToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid Margin="0,2,0,0">
                                        <TextBlock Text="How often to reapply TDP settings"
                                                   FontSize="14"
                                                   Foreground="#A0A0A0"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock x:Name="StickyTDPIntervalValue"
                                                   Text="5s"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="StickyTDPIntervalSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="3" Maximum="15"
                                            TickFrequency="2"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            Header="Check Interval"
                                            Value="5"
                                            ValueChanged="StickyTDPIntervalSlider_ValueChanged"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- About Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="About" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="Version: 0.3.31"
                                           FontSize="14"
                                           Foreground="#A0A0A0"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

            </Grid>

        </muxc:NavigationView>
    </Grid>
</Page>
