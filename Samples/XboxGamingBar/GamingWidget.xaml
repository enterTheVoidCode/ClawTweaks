                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectedIndex="1"
                                          SelectionChanged="LegionPerformanceModeComboBox_SelectionChanged"
                                          XYFocusDown="{x:Bind LegionCustomTDPSlowSlider}">
                                    <ComboBoxItem Content="Quiet" Tag="1"/>
                                    <ComboBoxItem Content="Balanced" Tag="2"/>
                                    <ComboBoxItem Content="Performance" Tag="3"/>
                                    <ComboBoxItem Content="Custom" Tag="255"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Custom TDP Cards (visible when Custom mode selected) -->
                        <StackPanel x:Name="LegionCustomTDPCard" Visibility="Collapsed">
                            <!-- Slow TDP (SPL) Card -->
                            <Border x:Name="LegionCustomTDPSlowCard" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="Slow TDP (SPL)"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="LegionCustomTDPSlowValue"
                                                   Text="15W"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="LegionCustomTDPSlowSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="5" Maximum="45"
                                            Value="15"
                                            Margin="0,4,0,0"
                                            ValueChanged="LegionCustomTDPSlider_ValueChanged"
                                            XYFocusUp="{x:Bind LegionPerformanceModeComboBox}"
                                            XYFocusDown="{x:Bind LegionCustomTDPFastSlider}"/>
                                </StackPanel>
                            </Border>

                            <!-- Fast TDP (SPPL) Card -->
                            <Border x:Name="LegionCustomTDPFastCard" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="Fast TDP (SPPL)"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="LegionCustomTDPFastValue"
                                                   Text="25W"
                                                   FontSize="14"
                                                   Foreground="#FFA500"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="LegionCustomTDPFastSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="5" Maximum="55"
                                            Value="25"
                                            Margin="0,4,0,0"
                                            ValueChanged="LegionCustomTDPSlider_ValueChanged"
                                            XYFocusUp="{x:Bind LegionCustomTDPSlowSlider}"
                                            XYFocusDown="{x:Bind LegionCustomTDPPeakSlider}"/>
                                </StackPanel>
                            </Border>

                            <!-- Peak TDP (FPPT) Card -->
                            <Border x:Name="LegionCustomTDPPeakCard" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="Peak TDP (FPPT)"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="LegionCustomTDPPeakValue"
                                                   Text="35W"
                                                   FontSize="14"
                                                   Foreground="#FF6B6B"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="LegionCustomTDPPeakSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="5" Maximum="65"
                                            Value="35"
                                            Margin="0,4,0,0"
                                            ValueChanged="LegionCustomTDPSlider_ValueChanged"
                                            XYFocusUp="{x:Bind LegionCustomTDPFastSlider}"
                                            XYFocusDown="{x:Bind LegionFanFullSpeedToggle}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Fan Full Speed Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Fan Full Speed" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Override fan curve for maximum cooling"
                                               Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="LegionFanFullSpeedToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsOn="False"/>
                            </Grid>
                        </Border>

                        <!-- Fan Curve Graph Card -->
                        <Border x:Name="LegionFanCurveCard" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header with expand toggle -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Fan Curve" Style="{StaticResource CardTitleStyle}"/>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Fan: " Style="{StaticResource CardCaptionStyle}"/>
                                            <TextBlock x:Name="FanRPMLabel" Text="-- RPM" Style="{StaticResource CardCaptionStyle}"/>
                                        </StackPanel>
                                        <TextBlock Text="Only applies when using Custom TDP mode"
                                                   FontSize="10" Foreground="#888888" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <ComboBox x:Name="FanCurvePresetComboBox"
                                              Grid.Column="1"
                                              Width="110"
                                              VerticalAlignment="Center"
                                              Margin="0,0,8,0"
                                              SelectionChanged="FanCurvePresetComboBox_SelectionChanged">
                                        <ComboBoxItem Content="Silent" Tag="Silent"/>
                                        <ComboBoxItem Content="Balanced" Tag="Balanced"/>
                                        <ComboBoxItem Content="Performance" Tag="Performance"/>
                                        <ComboBoxItem Content="Max Cooling" Tag="MaxCooling"/>
                                        <ComboBoxItem Content="Custom" Tag="Custom" IsSelected="True"/>
                                    </ComboBox>
                                    <ToggleButton x:Name="FanCurveExpandToggle"
                                                  Grid.Column="2"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="FanCurveExpandToggle_Click">
                                        <FontIcon x:Name="FanCurveExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <!-- Expandable graph content -->
                                <StackPanel x:Name="FanCurveContent" Margin="0,12,0,0" Visibility="Collapsed">
                                    <!-- Y-axis label -->
                                    <TextBlock Text="Fan %" FontSize="11" Foreground="#999999" Margin="0,0,0,4"/>

                                    <!-- Graph area -->
                                    <Grid Height="150">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="30"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Y-axis labels (percentage scale) -->
                                        <StackPanel Grid.Column="0" VerticalAlignment="Stretch">
                                            <TextBlock Text="100" FontSize="10" Foreground="#666666" VerticalAlignment="Top"/>
                                            <TextBlock Text="75" FontSize="10" Foreground="#666666" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                            <TextBlock Text="50" FontSize="10" Foreground="#666666" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                            <TextBlock Text="25" FontSize="10" Foreground="#666666" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                            <TextBlock Text="0" FontSize="10" Foreground="#666666" VerticalAlignment="Bottom"/>
                                        </StackPanel>

                                        <!-- Canvas for drawing the graph -->
                                        <Canvas x:Name="FanCurveCanvas"
                                                Grid.Column="1"
                                                Background="#1A1A1A"
                                                PointerPressed="FanCurveCanvas_PointerPressed"
                                                PointerMoved="FanCurveCanvas_PointerMoved"
                                                PointerReleased="FanCurveCanvas_PointerReleased"
                                                PointerCaptureLost="FanCurveCanvas_PointerReleased"
                                                SizeChanged="FanCurveCanvas_SizeChanged">
                                            <!-- Grid lines drawn in code-behind -->

                                            <!-- Fill under the curve -->
                                            <Polygon x:Name="FanCurveFill"
                                                     Fill="#3300AAFF"
                                                     Stroke="Transparent"/>

                                            <!-- EC Override Floor Line (dashed orange reference line) -->
                                            <Polyline x:Name="ECFloorPolyline"
                                                      Stroke="#FF6600"
                                                      StrokeThickness="1.5"
                                                      StrokeDashArray="4,2"
                                                      Opacity="0.7"/>

                                            <!-- The curve line -->
                                            <Polyline x:Name="FanCurvePolyline"
                                                      Stroke="#00AAFF"
                                                      StrokeThickness="2"
                                                      StrokeLineJoin="Round"/>

                                            <!-- Temperature indicator line (vertical dashed line) - on top of curve -->
                                            <Line x:Name="TempIndicatorLine"
                                                  Y1="0" Y2="150"
                                                  Stroke="#FF8800"
                                                  StrokeThickness="2"
                                                  StrokeDashArray="4,2"
                                                  Visibility="Collapsed"/>

                                            <!-- RPM indicator line (horizontal dashed line) - on top of curve -->
                                            <Line x:Name="RPMIndicatorLine"
                                                  X1="0" X2="300"
                                                  Stroke="#00FF88"
                                                  StrokeThickness="2"
                                                  StrokeDashArray="4,2"
                                                  Visibility="Collapsed"/>

                                            <!-- Control points are created in code-behind -->
                                        </Canvas>
                                    </Grid>

                                    <!-- X-axis labels -->
                                    <Grid Margin="30,4,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="10°C" FontSize="10" Foreground="#666666" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="1" Text="30°C" FontSize="10" Foreground="#666666" HorizontalAlignment="Left"/>
                                        <TextBlock Grid.Column="2" Text="50°C" FontSize="10" Foreground="#666666" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="70°C" FontSize="10" Foreground="#666666" HorizontalAlignment="Right"/>
                                        <TextBlock Grid.Column="4" Text="100°C" FontSize="10" Foreground="#666666" HorizontalAlignment="Right"/>
                                    </Grid>

                                    <!-- Current temperature display (0x01 sensor - what EC uses for fan curve) -->
                                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Center">
                                        <TextBlock Text="Fan Sensor Temp: " FontSize="12" Foreground="#999999"/>
                                        <TextBlock x:Name="CurrentTempLabel" Text="--°C" FontSize="12" Foreground="#FF8800" FontWeight="SemiBold"/>
                                    </StackPanel>

                                    <!-- EC Floor legend -->
                                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0" HorizontalAlignment="Center">
                                        <Line X1="0" Y1="0" X2="20" Y2="0" Stroke="#FF8800" StrokeThickness="2" StrokeDashArray="4,2" VerticalAlignment="Center"/>
                                        <TextBlock Text=" EC Protection Floor" FontSize="10" Foreground="#888888" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Battery Section Header -->
                        <TextBlock Text="BATTERY" Style="{StaticResource SectionHeaderStyle}"/>

                        <!-- Battery Charge Limit Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Charge Limit (80%)" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Limit battery charge to extend lifespan"
                                               Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="LegionChargeLimitToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsOn="False"/>
                            </Grid>
                        </Border>

                        <!-- LABS Section Header -->
                        <TextBlock Text="LABS" Style="{StaticResource SectionHeaderStyle}"/>

                        <!-- Labs Description -->
                        <TextBlock Text="Experimental features - use at your own risk"
                                   Style="{StaticResource CardCaptionStyle}"
                                   Margin="0,4,0,8"/>

                        <!-- Disable Legion Space Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Disable Legion Space Service" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Removes Legion L/R handling. May override TDP, remaps, fan curve. You can still open Legion Space for updates."
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <Button x:Name="ToggleDAServiceButton"
                                            Grid.Column="1"
                                            Content="Disable"
                                            Style="{StaticResource ModernButtonStyle}"
                                            Click="ToggleDAServiceButton_Click"/>
                                </Grid>
                                <TextBlock x:Name="DAServiceStatusText"
                                           Text="Checking..."
                                           FontSize="14"
                                           Foreground="#A0A0A0"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- GPD TAB -->
                <ScrollViewer x:Name="GPDScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Device Status Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock x:Name="GPDDeviceNameText" Text="GPD Device" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock x:Name="GPDConnectionStatusText"
                                           Text="Detecting..."
                                           FontSize="14"
                                           Foreground="#888888"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Fan Control Card (Win 5 specific) -->
                        <StackPanel x:Name="GPDFanControlSection" Visibility="Collapsed">
                            <TextBlock Text="FAN CONTROL" Style="{StaticResource SectionHeaderStyle}"/>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <!-- Header: Fan Settings + RPM -->
                                    <TextBlock Text="Fan Settings" Style="{StaticResource CardTitleStyle}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Fan: " Style="{StaticResource CardCaptionStyle}"/>
                                        <TextBlock x:Name="GPDFanRPMText" Text="-- RPM" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>

                                    <!-- Fan Curve Toggle -->
                                    <Grid Margin="0,16,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Fan Curve" Foreground="#FFFFFF" FontSize="14"/>
                                            <TextBlock Text="Software-controlled fan curve based on CPU temperature"
                                                       FontSize="12" Foreground="#888888"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="GPDFanCurveToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      IsOn="False"
                                                      Toggled="GPDFanCurveToggle_Toggled"
                                                      XYFocusUp="{x:Bind GPDNavItem}"/>
                                    </Grid>

                                    <!-- Manual Fan Controls (visible when curve OFF) -->
                                    <StackPanel x:Name="GPDManualFanContent">
                                        <!-- Fan Mode Toggle -->
                                        <Grid Margin="0,16,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0">
                                                <TextBlock Text="Fan Mode" Foreground="#FFFFFF" FontSize="14"/>
                                                <TextBlock x:Name="GPDFanModeText"
                                                           Text="Auto"
                                                           FontSize="12"
                                                           Foreground="#888888"/>
                                            </StackPanel>
                                            <ToggleSwitch x:Name="GPDFanModeToggle"
                                                          Grid.Column="1"
                                                          Style="{StaticResource ModernToggleStyle}"
                                                          IsOn="False"
                                                          Toggled="GPDFanModeToggle_Toggled"/>
                                        </Grid>

                                        <!-- Fan Speed Slider (visible only in manual mode) -->
                                        <StackPanel x:Name="GPDFanSpeedSection" Margin="0,16,0,0" Visibility="Collapsed">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Fan Speed" Grid.Column="0" Foreground="#FFFFFF" FontSize="14" VerticalAlignment="Center"/>
                                                <TextBlock x:Name="GPDFanSpeedValueText"
                                                           Grid.Column="1"
                                                           Text="50%"
                                                           FontSize="14"
                                                           Foreground="#00C8FF"
                                                           VerticalAlignment="Center"/>
                                            </Grid>
                                            <Slider x:Name="GPDFanSpeedSlider"
                                                    Style="{StaticResource ModernSliderStyle}"
                                                    Minimum="30"
                                                    Maximum="100"
                                                    Value="50"
                                                    ValueChanged="GPDFanSpeedSlider_ValueChanged"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Fan Curve Content (visible when curve ON) -->
                                    <StackPanel x:Name="GPDFanCurveContent" Visibility="Collapsed">
                                        <!-- Preset + Expand toggle row -->
                                        <Grid Margin="0,12,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="GPDFanCurvePresetComboBox"
                                                      Grid.Column="0"
                                                      Width="130"
                                                      HorizontalAlignment="Left"
                                                      SelectionChanged="GPDFanCurvePresetComboBox_SelectionChanged">
                                                <ComboBoxItem Content="Silent" Tag="Silent"/>
                                                <ComboBoxItem Content="Balanced" Tag="Balanced"/>
                                                <ComboBoxItem Content="Performance" Tag="Performance"/>
                                                <ComboBoxItem Content="Max Cooling" Tag="MaxCooling"/>
                                                <ComboBoxItem Content="Custom" Tag="Custom" IsSelected="True"/>
                                            </ComboBox>
                                            <ToggleButton x:Name="GPDFanCurveExpandToggle"
                                                          Grid.Column="1"
                                                          IsChecked="False"
                                                          VerticalAlignment="Center"
                                                          Background="Transparent"
                                                          BorderThickness="0"
                                                          Padding="8,4"
                                                          Click="GPDFanCurveExpandToggle_Click">
                                                <FontIcon x:Name="GPDFanCurveExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                            </ToggleButton>
                                        </Grid>

                                        <!-- Expandable graph content -->
                                        <StackPanel x:Name="GPDFanCurveGraphContent" Margin="0,12,0,0" Visibility="Collapsed">
                                            <!-- Y-axis label -->
                                            <TextBlock Text="Fan %" FontSize="11" Foreground="#999999" Margin="0,0,0,4"/>

                                            <!-- Graph area -->
                                            <Grid Height="150">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="30"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Y-axis labels -->
                                                <StackPanel Grid.Column="0" VerticalAlignment="Stretch">
                                                    <TextBlock Text="100" FontSize="10" Foreground="#666666" VerticalAlignment="Top"/>
                                                    <TextBlock Text="75" FontSize="10" Foreground="#666666" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                                    <TextBlock Text="50" FontSize="10" Foreground="#666666" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                                    <TextBlock Text="25" FontSize="10" Foreground="#666666" VerticalAlignment="Top" Margin="0,25,0,0"/>
                                                    <TextBlock Text="0" FontSize="10" Foreground="#666666" VerticalAlignment="Bottom"/>
                                                </StackPanel>

                                                <!-- Canvas for drawing the graph -->
                                                <Canvas x:Name="GPDFanCurveCanvas"
                                                        Grid.Column="1"
                                                        Background="#1A1A1A"
                                                        PointerPressed="GPDFanCurveCanvas_PointerPressed"
                                                        PointerMoved="GPDFanCurveCanvas_PointerMoved"
                                                        PointerReleased="GPDFanCurveCanvas_PointerReleased"
                                                        PointerCaptureLost="GPDFanCurveCanvas_PointerReleased"
                                                        SizeChanged="GPDFanCurveCanvas_SizeChanged">

                                                    <!-- Fill under the curve -->
                                                    <Polygon x:Name="GPDFanCurveFill"
                                                             Fill="#3300AAFF"
                                                             Stroke="Transparent"/>

                                                    <!-- The curve line -->
                                                    <Polyline x:Name="GPDFanCurvePolyline"
                                                              Stroke="#00AAFF"
                                                              StrokeThickness="2"
                                                              StrokeLineJoin="Round"/>

                                                    <!-- Temperature indicator line (vertical dashed orange) -->
                                                    <Line x:Name="GPDTempIndicatorLine"
                                                          Y1="0" Y2="150"
                                                          Stroke="#FF8800"
                                                          StrokeThickness="2"
                                                          StrokeDashArray="4,2"
                                                          Visibility="Collapsed"/>

                                                    <!-- Control points created in code-behind -->
                                                </Canvas>
                                            </Grid>

                                            <!-- X-axis labels (30°C to 100°C) -->
                                            <Grid Margin="30,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="30°C" FontSize="10" Foreground="#666666" HorizontalAlignment="Left"/>
                                                <TextBlock Grid.Column="1" Text="46°C" FontSize="10" Foreground="#666666" HorizontalAlignment="Left"/>
                                                <TextBlock Grid.Column="2" Text="62°C" FontSize="10" Foreground="#666666" HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="3" Text="78°C" FontSize="10" Foreground="#666666" HorizontalAlignment="Right"/>
                                                <TextBlock Grid.Column="4" Text="100°C" FontSize="10" Foreground="#666666" HorizontalAlignment="Right"/>
                                            </Grid>

                                            <!-- Current CPU temperature display -->
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0" HorizontalAlignment="Center">
                                                <TextBlock Text="CPU Temp: " FontSize="12" Foreground="#999999"/>
                                                <TextBlock x:Name="GPDCurrentTempLabel" Text="--°C" FontSize="12" Foreground="#FF8800" FontWeight="SemiBold"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Button Remapping Section (Win 5 specific) -->
                        <StackPanel x:Name="GPDButtonRemapSection" Visibility="Collapsed">
                            <TextBlock Text="BUTTON REMAPPING" Style="{StaticResource SectionHeaderStyle}"/>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Button Remapping" Style="{StaticResource CardTitleStyle}"/>
                                            <TextBlock Text="Remap controller buttons to keyboard or mouse"
                                                       Style="{StaticResource CardCaptionStyle}"/>
                                        </StackPanel>
                                        <ToggleButton x:Name="GPDButtonRemapExpandToggle"
                                                      Grid.Column="1"
                                                      IsChecked="False"
                                                      VerticalAlignment="Center"
                                                      Background="Transparent"
                                                      BorderThickness="0"
                                                      Padding="8,4"
                                                      Click="GPDButtonRemapExpandToggle_Click">
                                            <FontIcon x:Name="GPDButtonRemapExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                        </ToggleButton>
                                    </Grid>

                                    <StackPanel x:Name="GPDButtonRemapContent" Spacing="8" Margin="0,12,0,0" Visibility="Collapsed">

                                        <!-- Face Buttons -->
                                        <TextBlock Text="Face Buttons" Foreground="#FFFFFF" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="A" Grid.Column="0" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
                                            <ComboBox x:Name="GPDButtonAComboBox" Grid.Column="1" Style="{StaticResource ModernComboBoxStyle}" SelectionChanged="GPDButtonComboBox_SelectionChanged" Tag="A">
                                                <x:String>Disabled</x:String>
                                                <x:String>F1</x:String><x:String>F2</x:String><x:String>F3</x:String><x:String>F4</x:String><x:String>F5</x:String><x:String>F6</x:String><x:String>F7</x:String><x:String>F8</x:String><x:String>F9</x:String><x:String>F10</x:String><x:String>F11</x:String><x:String>F12</x:String>
                                                <x:String>F13</x:String><x:String>F14</x:String><x:String>F15</x:String><x:String>F16</x:String><x:String>F17</x:String>
                                                <x:String>Enter</x:String><x:String>Escape</x:String><x:String>Space</x:String><x:String>Tab</x:String><x:String>Backspace</x:String>
                                                <x:String>Up</x:String><x:String>Down</x:String><x:String>Left</x:String><x:String>Right</x:String>
                                                <x:String>Home</x:String><x:String>End</x:String><x:String>PageUp</x:String><x:String>PageDown</x:String><x:String>Insert</x:String><x:String>Delete</x:String>
                                                <x:String>Left Ctrl</x:String><x:String>Left Shift</x:String><x:String>Left Alt</x:String><x:String>Left Win</x:String>
                                                <x:String>Right Ctrl</x:String><x:String>Right Shift</x:String><x:String>Right Alt</x:String>
                                                <x:String>Mouse Left</x:String><x:String>Mouse Right</x:String><x:String>Mouse Middle</x:String>
                                                <x:String>Mouse Wheel Up</x:String><x:String>Mouse Wheel Down</x:String>
                                            </ComboBox>
                                        </Grid>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
