<Page
    x:Class="XboxGamingBar.GamingWidget"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:XboxGamingBar"
    xmlns:converter="using:XboxGamingBar.Converter"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="670" d:DesignWidth="600">

    <Page.Resources>
        <!-- Existing Converters -->
        <converter:WattStringConverter x:Key="WattStringConverter"/>
        <converter:MegahertzStringConverter x:Key="MegahertzStringConverter"/>
        <converter:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converter:SharpnessPercentStringConverter x:Key="SharpnessPercentStringConverter"/>
        <converter:RadeonBoostResolutionStringConverter x:Key="RadeonBoostResolutionStringConverter"/>

        <!-- Tooth Theme Colors -->
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#25282C"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#30343A"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#50555C"/>
        <SolidColorBrush x:Key="ButtonBackground" Color="#3E434B"/>
        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#484E58"/>
        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3A3F47"/>
        <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="#2C3035"/>
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#6B7584"/>
        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#6B7584"/>
        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#555D69"/>
        <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="#3A3F46"/>
        <CornerRadius x:Key="ControlCornerRadius">8,8,8,8</CornerRadius>
        <Thickness x:Key="ButtonPadding">15,10,15,11</Thickness>

        <!-- Card Style - Tooth Theme -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
        </Style>

        <!-- Card Focus Border Brush -->
        <SolidColorBrush x:Key="CardFocusBorderBrush" Color="White"/>

        <!-- Navigation Item Style with Focus - Optimized for Handheld -->
        <Style x:Key="NavItemStyle" TargetType="muxc:NavigationViewItem">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FocusVisualPrimaryBrush" Value="White"/>
            <Setter Property="FocusVisualSecondaryBrush" Value="Transparent"/>
            <Setter Property="FocusVisualPrimaryThickness" Value="2"/>
            <Setter Property="FocusVisualMargin" Value="-2"/>
        </Style>

        <!-- Card Title Style - Tooth Theme -->
        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Card Title Style - Compact Mode -->
        <Style x:Key="CardTitleStyleCompact" TargetType="TextBlock" BasedOn="{StaticResource CardTitleStyle}">
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <!-- Card Caption Style - Tooth Theme -->
        <Style x:Key="CardCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <!-- Card Caption Style - Compact Mode -->
        <Style x:Key="CardCaptionStyleCompact" TargetType="TextBlock" BasedOn="{StaticResource CardCaptionStyle}">
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <!-- Card Value Style -->
        <Style x:Key="CardValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#00C8FF"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Card Value Style - Compact Mode -->
        <Style x:Key="CardValueStyleCompact" TargetType="TextBlock" BasedOn="{StaticResource CardValueStyle}">
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <!-- Modern Toggle Style - Uses system style, focus highlight on parent card -->
        <Style x:Key="ModernToggleStyle" TargetType="ToggleSwitch">
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="OffContent" Value=""/>
            <Setter Property="OnContent" Value=""/>
            <Setter Property="UseSystemFocusVisuals" Value="False"/>
        </Style>

        <!-- Modern Slider Style - Fluent with System Accent Color, focus on parent card -->
        <Style x:Key="ModernSliderStyle" TargetType="Slider">
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="UseSystemFocusVisuals" Value="False"/>
            <Setter Property="ManipulationMode" Value="None"/>
        </Style>

        <!-- Modern ComboBox Style - Tooth Theme (no focus visual, uses card focus) -->
        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="UseSystemFocusVisuals" Value="False"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
        </Style>

        <!-- Override ComboBox border colors to prevent highlight on focus/hover -->
        <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="#50555C"/>
        <SolidColorBrush x:Key="ComboBoxBorderBrushPressed" Color="#50555C"/>
        <SolidColorBrush x:Key="ComboBoxBorderBrushFocused" Color="#50555C"/>
        <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#30343A"/>
        <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="#30343A"/>
        <SolidColorBrush x:Key="ComboBoxBackgroundFocused" Color="#30343A"/>

        <!-- Modern Button Style - Tooth Theme (uses card focus) -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15,10,15,11"/>
            <Setter Property="UseSystemFocusVisuals" Value="False"/>
        </Style>

        <!-- Standalone Button Style - Shows white focus border (for buttons not in cards) -->
        <Style x:Key="StandaloneButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15,10,15,11"/>
            <Setter Property="FocusVisualPrimaryBrush" Value="White"/>
            <Setter Property="FocusVisualSecondaryBrush" Value="Transparent"/>
            <Setter Property="FocusVisualPrimaryThickness" Value="2"/>
            <Setter Property="FocusVisualMargin" Value="-3"/>
            <Setter Property="UseSystemFocusVisuals" Value="True"/>
        </Style>

        <!-- Standalone ToggleButton Style - Shows white focus border (for toggles not in cards) -->
        <Style x:Key="StandaloneToggleButtonStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="{StaticResource ButtonBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15,10,15,11"/>
            <Setter Property="FocusVisualPrimaryBrush" Value="White"/>
            <Setter Property="FocusVisualSecondaryBrush" Value="Transparent"/>
            <Setter Property="FocusVisualPrimaryThickness" Value="2"/>
            <Setter Property="FocusVisualMargin" Value="-3"/>
            <Setter Property="UseSystemFocusVisuals" Value="True"/>
        </Style>

        <!-- Checkbox with individual rounded focus (for checkboxes in settings cards) -->
        <Style x:Key="FocusableCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="UseSystemFocusVisuals" Value="False"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="FocusStates">
                                    <VisualState x:Name="Focused">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="FocusBorder" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unfocused"/>
                                    <VisualState x:Name="PointerFocused"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <!-- Rounded focus border -->
                            <Border x:Name="FocusBorder"
                                    BorderBrush="White"
                                    BorderThickness="2"
                                    CornerRadius="6"
                                    Margin="-6,-4,-6,-4"
                                    Visibility="Collapsed"/>

                            <!-- Default CheckBox content -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border x:Name="CheckboxBorder"
                                        Width="20" Height="20"
                                        Background="Transparent"
                                        BorderBrush="#6B7280"
                                        BorderThickness="2"
                                        CornerRadius="4"
                                        VerticalAlignment="Center">
                                    <FontIcon x:Name="CheckGlyph"
                                              Glyph="&#xE73E;"
                                              FontSize="14"
                                              Foreground="White"
                                              Visibility="{Binding IsChecked, RelativeSource={RelativeSource TemplatedParent}, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </Border>
                                <ContentPresenter x:Name="ContentPresenter"
                                                  Grid.Column="1"
                                                  Margin="8,0,0,0"
                                                  VerticalAlignment="Center"
                                                  Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"/>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Default Button Style Override (uses card focus) -->
        <Style TargetType="Button">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="UseSystemFocusVisuals" Value="False"/>
        </Style>

        <!-- Default ToggleButton Style Override (uses card focus) -->
        <Style TargetType="ToggleButton">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="UseSystemFocusVisuals" Value="False"/>
        </Style>

        <!-- Default CheckBox Style Override (uses card focus) -->
        <Style TargetType="CheckBox">
            <Setter Property="UseSystemFocusVisuals" Value="False"/>
        </Style>

        <!-- Section Header Style - Tooth Theme -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#00C8FF"/>
            <Setter Property="Margin" Value="0,20,0,0"/>
        </Style>

        <!-- Quick Settings Tile Colors - Dark mode with sharp contrast -->
        <SolidColorBrush x:Key="TileOffBackground" Color="#1A1C1E"/>
        <SolidColorBrush x:Key="TileOnBackground" Color="#1A2E1F"/>
        <SolidColorBrush x:Key="TileActiveBackground" Color="#1A2530"/>
        <SolidColorBrush x:Key="TileTriggerBackground" Color="#252030"/>
        <SolidColorBrush x:Key="TileBorderBrush" Color="Transparent"/>
        <SolidColorBrush x:Key="TileFocusBorderBrush" Color="White"/>
        <!-- Inactive state: even darker -->
        <SolidColorBrush x:Key="TileInactiveBackground" Color="#0D0E0F"/>
        <SolidColorBrush x:Key="TileInactiveForeground" Color="#606060"/>

        <!-- Quick Settings Tile Style - Xbox Game Bar Widget UI Guidelines -->
        <!-- Rest: normal background, Focus: rest + white stroke, Press: 10% darker, Focus+Press: press + stroke, Inactive: 50% darker -->
        <Style x:Key="QuickSettingsTileStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource TileOffBackground}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,16"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="MinHeight" Value="90"/>
            <Setter Property="UseSystemFocusVisuals" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver"/>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PressedOverlay" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="InactiveOverlay" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource TileInactiveForeground}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="FocusStates">
                                    <VisualState x:Name="Focused">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="FocusBorder" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unfocused"/>
                                    <VisualState x:Name="PointerFocused"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <!-- Background with light border -->
                            <Border x:Name="BackgroundBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#50555C"
                                    BorderThickness="1"
                                    CornerRadius="12"/>

                            <!-- Pressed overlay (10% darker) -->
                            <Border x:Name="PressedOverlay"
                                    Background="#1A000000"
                                    CornerRadius="12"
                                    Visibility="Collapsed"/>

                            <!-- Inactive overlay (50% darker) -->
                            <Border x:Name="InactiveOverlay"
                                    Background="#80000000"
                                    CornerRadius="12"
                                    Visibility="Collapsed"/>

                            <!-- Focus stroke border -->
                            <Border x:Name="FocusBorder"
                                    BorderBrush="White"
                                    BorderThickness="2"
                                    CornerRadius="12"
                                    Visibility="Collapsed"/>

                            <!-- Content -->
                            <ContentPresenter x:Name="ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Quick Settings Edit Mode Checkbox Style -->
        <Style x:Key="TileVisibilityCheckBoxStyle" TargetType="CheckBox">
            <Setter Property="UseSystemFocusVisuals" Value="True"/>
            <Setter Property="FocusVisualPrimaryBrush" Value="White"/>
            <Setter Property="FocusVisualSecondaryBrush" Value="Transparent"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

    </Page.Resources>

    <Grid>
        <ProgressRing x:Name="LoadingProgressRing"
                      IsActive="True"
                      Visibility="Collapsed"
                      Width="60"
                      Height="60"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>

        <muxc:NavigationView x:Name="MainNavigationView"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        IsPaneToggleButtonVisible="False"
                        PaneDisplayMode="Top"
                        OpenPaneLength="140"
                        CompactModeThresholdWidth="0"
                        ExpandedModeThresholdWidth="0"
                        Background="Transparent"
                        SelectionChanged="MainNavigationView_SelectionChanged">

            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem x:Name="QuickNavItem" Content="Quick" Tag="Quick" Style="{StaticResource NavItemStyle}"/>
                <muxc:NavigationViewItem x:Name="PerformanceNavItem" Content="Performance" Tag="Performance" Style="{StaticResource NavItemStyle}"
                                            XYFocusDown="{x:Bind PerformanceOverlayComboBox}"/>
                <muxc:NavigationViewItem x:Name="ProfilesNavItem" Content="Profiles" Tag="Game" Style="{StaticResource NavItemStyle}"/>
                <muxc:NavigationViewItem x:Name="GraphicsNavItem" Content="Graphics" Tag="AMD" Style="{StaticResource NavItemStyle}"/>
                <muxc:NavigationViewItem x:Name="ScalingNavItem" Content="Scaling" Tag="Scaling" Style="{StaticResource NavItemStyle}"/>
                <muxc:NavigationViewItem x:Name="LegionNavItem" Content="Legion" Tag="Legion" Style="{StaticResource NavItemStyle}" Visibility="Collapsed"/>
                <muxc:NavigationViewItem x:Name="SystemNavItem" Content="System" Tag="System" Style="{StaticResource NavItemStyle}"
                                            XYFocusDown="{x:Bind ProfileSaveTDPCheckBox}"/>
            </muxc:NavigationView.MenuItems>

            <!-- QUICK SETTINGS TAB -->
            <Grid>
                <ScrollViewer x:Name="QuickSettingsScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Visible"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Dynamic Tiles Container - tiles generated in code-behind -->
                        <StackPanel x:Name="QuickSettingsTilesContainer"/>

                        <!-- Customize Button -->
                        <Button x:Name="QuickSettingsCustomizeButton"
                                Content="Customize"
                                HorizontalAlignment="Stretch"
                                Margin="0,16,0,0"
                                Style="{StaticResource StandaloneButtonStyle}"
                                Click="QuickSettingsCustomize_Click"/>

                        <!-- Customization Panel (hidden by default) -->
                        <Border x:Name="QuickSettingsCustomizePanel"
                                Style="{StaticResource CardStyle}"
                                Visibility="Collapsed"
                                Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Customize Tiles" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="Show/hide tiles"
                                           Style="{StaticResource CardCaptionStyle}"
                                           Margin="0,0,0,12"/>

                                <!-- Tile Visibility Checkboxes - generated in code-behind -->
                                <StackPanel x:Name="TileVisibilityPanel"/>

                                <!-- Add Custom Shortcut Section -->
                                <TextBlock Text="Add Custom Shortcut"
                                           Style="{StaticResource CardTitleStyle}"
                                           Margin="0,16,0,8"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="8"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="CustomShortcutNameBox"
                                             PlaceholderText="Name"
                                             Grid.Column="0"/>
                                    <TextBox x:Name="CustomShortcutKeyBox"
                                             PlaceholderText="Shortcut (e.g. Alt+S)"
                                             Grid.Column="2"/>
                                </Grid>
                                <Button x:Name="AddCustomShortcutButton"
                                        Content="Add Shortcut Tile"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,8,0,0"
                                        Style="{StaticResource StandaloneButtonStyle}"
                                        Click="AddCustomShortcut_Click"/>

                                <!-- Done Button -->
                                <Button Content="Done"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,16,0,0"
                                        Style="{StaticResource StandaloneButtonStyle}"
                                        Click="QuickSettingsCustomizeDone_Click"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- PERFORMANCE TAB -->
                <ScrollViewer x:Name="PerformanceScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Active Profile Indicator -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="Using profile:"
                                               FontSize="12"
                                               Foreground="#AAAAAA"
                                               VerticalAlignment="Top" Margin="4,1,-5,0"/>
                                    <TextBlock x:Name="ActiveProfileText"
                                               Text="Global Settings"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#00C8FF"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Top" Margin="0,26,0,0"/>
                                </Grid>

                                <!-- Per-Game Profile Toggle -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Use per-game profile"
                                                   FontSize="12"
                                                   Foreground="#FFFFFF"/>
                                        <TextBlock x:Name="DetectedGameText"
                                                   Text="No game detected"
                                                   FontSize="11"
                                                   Foreground="#888888"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="200"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="PerGameProfileToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False" HorizontalAlignment="Right" Width="50"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Performance Overlay Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Performance Overlay"
                                               Style="{StaticResource CardTitleStyle}"
                                               VerticalAlignment="Center"
                                               Grid.Column="0"/>
                                    <ComboBox x:Name="PerformanceOverlayComboBox"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              Width="120"
                                              Grid.Column="1"
                                              SelectionChanged="PerformanceOverlayComboBox_SelectionChanged"
                                              XYFocusUp="{x:Bind PerformanceNavItem}"
                                              XYFocusDown="{x:Bind TDPSlider}"
                                              XYFocusLeft="{x:Bind PerformanceNavItem}">
                                        <ComboBoxItem Content="Off" Tag="0" IsSelected="True"/>
                                        <ComboBoxItem Content="Basic" Tag="1"/>
                                        <ComboBoxItem Content="Detailed" Tag="2"/>
                                        <ComboBoxItem Content="Full" Tag="3"/>
                                    </ComboBox>
                                </Grid>

                                <!-- Hidden slider for property system compatibility -->
                                <Slider x:Name="PerformanceOverlaySlider"
                                        Visibility="Collapsed"
                                        Minimum="0" Maximum="3"
                                        Value="0"
                                        ValueChanged="PerformanceOverlaySlider_ValueChanged"/>
                            </StackPanel>
                        </Border>

                        <!-- TDP Power Limit Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="TDP Power Limit" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock x:Name="TDPValueText"
                                               Text="{Binding ElementName=TDPSlider, Path=Value, Converter={StaticResource WattStringConverter}}"
                                               Style="{StaticResource CardValueStyle}"/>
                                </Grid>
                                <Slider x:Name="TDPSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="4" Maximum="35"
                                        TickFrequency="1"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False" Value="-5"/>
                                <Grid Margin="0,4,0,0">
                                    <TextBlock x:Name="CurrentTDPText"
                                               Text="Limits:"
                                               FontSize="12"
                                               Foreground="#A0A0A0"/>
                                    <TextBlock x:Name="CurrentTDPValueText"
                                               Text="-- W"
                                               FontSize="12"
                                               Foreground="#A0A0A0"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <!-- Sticky TDP Active Indicator -->
                                <TextBlock Text="Sticky TDP: Active"
                                           FontSize="13"
                                           Foreground="#4CAF50"
                                           FontWeight="SemiBold"
                                           Margin="0,1,0,0"
                                           Visibility="{Binding ElementName=StickyTDPToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- CPU Boost Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="CPU Boost" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Higher boost clocks" Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="CPUBoostToggle"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsEnabled="False" HorizontalAlignment="Stretch" Grid.Column="1" HorizontalContentAlignment="Right" UseLayoutRounding="True" Width="50"/>
                            </Grid>
                        </Border>

                        <!-- CPU EPP Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="CPU EPP" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock x:Name="CPUEPPValueText"
                                               Text="{Binding ElementName=CPUEPPSlider, Path=Value}"
                                               Style="{StaticResource CardValueStyle}"/>
                                </Grid>
                                <Slider x:Name="CPUEPPSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="100"
                                        TickFrequency="10"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"/>
                                <Grid Margin="0,4,0,0">
                                    <TextBlock Text="0 = Prioritize CPU"
                                               FontSize="12"
                                               Foreground="#A0A0A0"/>
                                    <TextBlock Text="100 = Prioritize GPU"
                                               FontSize="12"
                                               Foreground="#A0A0A0"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Limit CPU Clock Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Limit CPU Clock" Style="{StaticResource CardTitleStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LimitCPUClockToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False" Width="52"/>
                                </Grid>
                                <Slider x:Name="CPUClockMaxSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="1400" Maximum="5500"
                                        TickFrequency="100"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        Header="Max Frequency (MHz)"
                                        IsEnabled="False"
                                        Visibility="{Binding ElementName=LimitCPUClockToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- FPS Limit Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="FPS Limit" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock x:Name="FPSLimitCaption"
                                                   Text=""
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   Visibility="Collapsed"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="FPSLimitToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False" Width="52"/>
                                </Grid>
                                <Slider x:Name="FPSLimitSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="15" Maximum="144"
                                        StepFrequency="1"
                                        TickFrequency="15"
                                        TickPlacement="Outside"
                                        SnapsTo="StepValues"
                                        Visibility="{Binding ElementName=FPSLimitToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- GAME TAB -->
                <ScrollViewer x:Name="GameScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Power Source Profile Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Power Source Profile" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Separate profiles for AC (plugged in) and DC (battery)"
                                               Style="{StaticResource CardCaptionStyle}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="PowerSourceProfileToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}" Width="47"
                                              XYFocusUp="{x:Bind ProfilesNavItem}"/>
                            </Grid>
                        </Border>

                        <!-- Current Game Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Current Game" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock x:Name="RunningGameText"
                                           Text="No game detected"
                                           FontSize="16"
                                           Foreground="White"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Global Profile Section -->
                        <TextBlock Text="Global Profile"
                                   FontSize="16"
                                   Foreground="#00C8FF"
                                   FontWeight="SemiBold"
                                   Margin="0,16,0,8"/>

                        <!-- Global Profile Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Global"
                                           Style="{StaticResource CardTitleStyle}"
                                           Foreground="#00FF88"
                                           FontSize="14"/>

                                <!-- Simple Mode (Power Source Toggle OFF) -->
                                <Grid x:Name="GlobalProfileSimple" Margin="0,8,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="TDP" FontSize="11" Foreground="#AAAAAA"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="GlobalProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="CPU Boost" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="GlobalProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="CPU EPP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="GlobalProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0"/>
                                </Grid>

                                <!-- AC/DC Mode (Power Source Toggle ON) -->
                                <Grid x:Name="GlobalProfileACDC" Margin="0,8,0,0" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Header -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="" FontSize="11" Foreground="#AAAAAA"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="AC" FontSize="11" Foreground="#FFD700" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="DC" FontSize="11" Foreground="#FF6B6B" HorizontalAlignment="Center"/>

                                    <!-- TDP Row -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="TDP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ACProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" x:Name="DCProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>

                                    <!-- CPU Boost Row -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Boost" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ACProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" x:Name="DCProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>

                                    <!-- CPU EPP Row -->
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="EPP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ACProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="2" x:Name="DCProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Game Profile Card (shown when game is detected) -->
                        <Border x:Name="GameProfileCard" Style="{StaticResource CardStyle}" Visibility="Collapsed" Margin="0,8,0,0">
                            <StackPanel>
                                <!-- Game Profile with Power Source -->
                                <StackPanel x:Name="GameProfileWithPowerSource" Visibility="Collapsed">
                                    <TextBlock x:Name="GameProfileTitleWithPower"
                                               Text="Game"
                                               Style="{StaticResource CardTitleStyle}"
                                               Foreground="#FFA500"
                                               FontSize="14"/>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Header -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="" FontSize="11" Foreground="#AAAAAA"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="AC" FontSize="11" Foreground="#FFD700" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="DC" FontSize="11" Foreground="#FF6B6B" HorizontalAlignment="Center"/>

                                        <!-- TDP Row -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="TDP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="GameACProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" x:Name="GameDCProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>

                                        <!-- CPU Boost Row -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Boost" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="GameACProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" x:Name="GameDCProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>

                                        <!-- CPU EPP Row -->
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="EPP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="GameACProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Row="3" Grid.Column="2" x:Name="GameDCProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Game Profile without Power Source -->
                                <StackPanel x:Name="GameProfileWithoutPowerSource" Visibility="Collapsed">
                                    <TextBlock x:Name="GameProfileTitleNoPower"
                                               Text="Game"
                                               Style="{StaticResource CardTitleStyle}"
                                               Foreground="#FFA500"
                                               FontSize="14"/>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="TDP" FontSize="11" Foreground="#AAAAAA"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="GameProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="CPU Boost" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="GameProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="CPU EPP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="GameProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Saved Profiles Section -->
                        <TextBlock Text="Saved Profiles"
                                   FontSize="16"
                                   Foreground="#00C8FF"
                                   FontWeight="SemiBold"
                                   Margin="0,24,0,8"/>

                        <!-- Container for dynamically created game profile cards -->
                        <StackPanel x:Name="AllGameProfilesContainer"/>

                    </StackPanel>
                </ScrollViewer>

                <!-- GRAPHICS TAB -->
                <ScrollViewer x:Name="AMDScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Resolution Card -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Resolution"
                                           Style="{StaticResource CardTitleStyle}"
                                           VerticalAlignment="Center"
                                           Grid.Column="0"/>
                                <ComboBox x:Name="ResolutionComboBox"
                                          PlaceholderText="1920x1080"
                                          Width="150"
                                          Grid.Column="1"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          XYFocusUp="{x:Bind GraphicsNavItem}">
                                    <x:String>1920x1080</x:String>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Refresh Rate Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Refresh Rate"
                                           Style="{StaticResource CardTitleStyle}"
                                           VerticalAlignment="Center"
                                           Grid.Column="0"/>
                                <ComboBox x:Name="RefreshRatesComboBox"
                                          PlaceholderText="60 Hz"
                                          Width="120"
                                          Grid.Column="1"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}">
                                    <x:String>60 Hz</x:String>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- HDR Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="HDR" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="High Dynamic Range" Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="HDRToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsEnabled="False" Width="50"/>
                            </Grid>
                        </Border>

                        <!-- AMD Section Header -->
                        <TextBlock Text="AMD"
                                   FontSize="16"
                                   Foreground="#00C8FF"
                                   FontWeight="SemiBold"
                                   Margin="0,16,0,8"/>

                        <!-- Radeon Super Resolution Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Radeon Super Resolution" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Upscales lower resolutions" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AMDRadeonSuperResolutionToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False" Width="50"/>
                                </Grid>
                                <Slider x:Name="AMDRadeonSuperResolutionSharpnessSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="100"
                                        TickFrequency="10"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        Header="Sharpness"
                                        IsEnabled="False"
                                        Visibility="{Binding ElementName=AMDRadeonSuperResolutionToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- Fluid Motion Frames Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Fluid Motion Frames" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Frame generation" Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="AMDFluidMotionFrameToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsEnabled="False" Width="50"/>
                            </Grid>
                        </Border>

                        <!-- Anti-Lag Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Radeon Anti-Lag" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Reduces input latency" Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="AMDRadeonAntiLagToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsEnabled="False" Width="50"/>
                            </Grid>
                        </Border>

                        <!-- Radeon Boost Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Radeon Boost" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Dynamic resolution scaling" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AMDRadeonBoostToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False" Width="52" HorizontalAlignment="Center"/>
                                </Grid>
                                <Slider x:Name="AMDRadeonBoostResolutionSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="1"
                                        TickFrequency="1"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"
                                        Visibility="{Binding ElementName=AMDRadeonBoostToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- Radeon Chill Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Radeon Chill" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Power saving when idle" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AMDRadeonChillToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False" Width="50"/>
                                </Grid>
                                <StackPanel Visibility="{Binding ElementName=AMDRadeonChillToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Slider x:Name="AMDRadeonChillMinFPSSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="30" Maximum="300"
                                            TickFrequency="10"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            Header="Min FPS"
                                            IsEnabled="False"/>
                                    <Slider x:Name="AMDRadeonChillMaxFPSSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="30" Maximum="300"
                                            TickFrequency="10"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            Header="Max FPS"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- SYSTEM TAB -->
                <ScrollViewer x:Name="SystemScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Profile Settings Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Profile Settings" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                                <TextBlock Text="Choose which settings are saved in profiles"
                                           FontSize="12"
                                           Foreground="#A0A0A0"
                                           Margin="0,0,0,12"
                                           TextWrapping="Wrap"/>

                                <CheckBox x:Name="ProfileSaveTDPCheckBox"
                                          Content="TDP Power Limit"
                                          IsChecked="True"
                                          Foreground="#FFFFFF"
                                          Margin="0,4,0,0"
                                          Style="{StaticResource FocusableCheckBoxStyle}"/>
                                <CheckBox x:Name="ProfileSaveCPUBoostCheckBox"
                                          Content="CPU Boost"
                                          IsChecked="True"
                                          Foreground="#FFFFFF"
                                          Margin="0,4,0,0"
                                          Style="{StaticResource FocusableCheckBoxStyle}"/>
                                <CheckBox x:Name="ProfileSaveCPUEPPCheckBox"
                                          Content="CPU EPP"
                                          IsChecked="True"
                                          Foreground="#FFFFFF"
                                          Margin="0,4,0,0"
                                          Style="{StaticResource FocusableCheckBoxStyle}"/>
                                <CheckBox x:Name="ProfileSaveLimitCPUClockCheckBox"
                                          Content="Limit CPU Clock"
                                          IsChecked="True"
                                          Foreground="#FFFFFF"
                                          Margin="0,4,0,0"
                                          Style="{StaticResource FocusableCheckBoxStyle}"/>
                                <CheckBox x:Name="ProfileSaveAMDFeaturesCheckBox"
                                          Content="AMD Features (FMF, Anti-Lag, Boost, Chill)"
                                          IsChecked="False"
                                          Foreground="#FFFFFF"
                                          Margin="0,4,0,0"
                                          Style="{StaticResource FocusableCheckBoxStyle}"
                                          XYFocusDown="{x:Bind StickyTDPToggle}"/>
                            </StackPanel>
                        </Border>

                        <!-- Sticky TDP Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Sticky TDP" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Automatically restore TDP limits if changed by other apps"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="StickyTDPToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  Toggled="StickyTDPToggle_Toggled" Width="50"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  XYFocusUp="{x:Bind ProfileSaveAMDFeaturesCheckBox}"
                                                  XYFocusDown="{x:Bind AutoTDPToggle}"/>
                                </Grid>
                                <StackPanel Visibility="{Binding ElementName=StickyTDPToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid Margin="0,2,0,0">
                                        <TextBlock Text="How often to reapply TDP settings"
                                                   FontSize="14"
                                                   Foreground="#A0A0A0"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock x:Name="StickyTDPIntervalValue"
                                                   Text="5s"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="StickyTDPIntervalSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="3" Maximum="15"
                                            TickFrequency="2"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            Header="Check Interval"
                                            Value="5"
                                            ValueChanged="StickyTDPIntervalSlider_ValueChanged"
                                            UseSystemFocusVisuals="True"
                                            FocusVisualPrimaryBrush="White"
                                            FocusVisualSecondaryBrush="Transparent"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- AutoTDP Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="AutoTDP" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Automatically adjust TDP to maintain target FPS when a game is running"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AutoTDPToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  Toggled="AutoTDPToggle_Toggled" Width="50"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  XYFocusUp="{x:Bind StickyTDPToggle}"/>
                                </Grid>
                                <StackPanel Visibility="{Binding ElementName=AutoTDPToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid Margin="0,12,0,0">
                                        <TextBlock Text="Target FPS"
                                                   FontSize="14"
                                                   Foreground="#A0A0A0"/>
                                        <TextBlock x:Name="AutoTDPTargetFPSValue"
                                                   Text="60 FPS"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="AutoTDPTargetFPSSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="30" Maximum="144"
                                            StepFrequency="1"
                                            Value="60"
                                            ValueChanged="AutoTDPTargetFPSSlider_ValueChanged"
                                            UseSystemFocusVisuals="True"
                                            FocusVisualPrimaryBrush="White"
                                            FocusVisualSecondaryBrush="Transparent"
                                            XYFocusUp="{x:Bind AutoTDPToggle}"
                                            XYFocusDown="{x:Bind UseManufacturerWMIToggle}"/>
                                    <Grid Margin="0,8,0,0">
                                        <TextBlock Text="Current FPS"
                                                   FontSize="14"
                                                   Foreground="#A0A0A0"/>
                                        <TextBlock x:Name="AutoTDPCurrentFPSValue"
                                                   Text="-- FPS"
                                                   FontSize="14"
                                                   Foreground="#FFCC00"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Manufacturer WMI TDP Card -->
                        <Border x:Name="ManufacturerWMICard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Manufacturer WMI TDP" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Use device manufacturer's WMI method for TDP control instead of RyzenAdj"
                                               Style="{StaticResource CardCaptionStyle}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="UseManufacturerWMIToggle"
                                              Grid.Column="1"
                                              IsOn="True"
                                              Style="{StaticResource ModernToggleStyle}"
                                              Width="50"
                                              UseSystemFocusVisuals="True"
                                              FocusVisualPrimaryBrush="White"
                                              FocusVisualSecondaryBrush="Transparent"
                                              XYFocusUp="{x:Bind AutoTDPToggle}"/>
                            </Grid>
                        </Border>

                        <!-- OSD Customization Card (Collapsible) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header with Expand/Collapse -->
                                <Button x:Name="OSDCustomizeExpandButton"
                                        Click="OSDCustomizeExpandButton_Click"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        UseSystemFocusVisuals="True"
                                        FocusVisualPrimaryBrush="White">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="OSD Customization" Style="{StaticResource CardTitleStyle}"/>
                                            <TextBlock Text="Customize overlay appearance and content"
                                                       Style="{StaticResource CardCaptionStyle}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <TextBlock x:Name="OSDCustomizeExpandIcon"
                                                   Text="&#xE70D;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14"
                                                   Foreground="#A0A0A0"
                                                   Grid.Column="1"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>

                                <!-- Collapsible Content -->
                                <StackPanel x:Name="OSDCustomizeContent" Visibility="Collapsed" Margin="0,12,0,0">

                                    <!-- Overlay Level Selection -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Overlay Level"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"
                                                   FontSize="14"/>
                                        <ComboBox x:Name="OSDCustomizeLevelComboBox"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  Width="120"
                                                  Grid.Column="1"
                                                  SelectionChanged="OSDCustomizeLevelComboBox_SelectionChanged"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent">
                                            <ComboBoxItem Content="Basic" Tag="1" IsSelected="True"/>
                                            <ComboBoxItem Content="Detailed" Tag="2"/>
                                            <ComboBoxItem Content="Full" Tag="3"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Layout Settings Section -->
                                    <TextBlock Text="Layout"
                                               Style="{StaticResource CardTitleStyle}"
                                               Margin="0,0,0,8"/>

                                    <!-- Columns -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Columns"
                                                       Foreground="#B0B0B0"
                                                       FontSize="13"/>
                                            <TextBlock Text="Items per row (1 = vertical list)"
                                                       Foreground="#707070"
                                                       FontSize="11"/>
                                        </StackPanel>
                                        <ComboBox x:Name="OSDColumnsComboBox"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  Width="80"
                                                  Grid.Column="1"
                                                  SelectionChanged="OSDLayoutOption_Changed"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White">
                                            <ComboBoxItem Content="1" Tag="1"/>
                                            <ComboBoxItem Content="2" Tag="2"/>
                                            <ComboBoxItem Content="3" Tag="3" IsSelected="True"/>
                                            <ComboBoxItem Content="4" Tag="4"/>
                                            <ComboBoxItem Content="5" Tag="5"/>
                                            <ComboBoxItem Content="6" Tag="6"/>
                                            <ComboBoxItem Content="7" Tag="7"/>
                                            <ComboBoxItem Content="8" Tag="8"/>
                                            <ComboBoxItem Content="9" Tag="9"/>
                                            <ComboBoxItem Content="10" Tag="10"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Text Size -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Text Size"
                                                   Foreground="#B0B0B0"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"/>
                                        <ComboBox x:Name="OSDTextSizeComboBox"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  Width="100"
                                                  Grid.Column="1"
                                                  SelectionChanged="OSDLayoutOption_Changed"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White">
                                            <ComboBoxItem Content="Small" Tag="50"/>
                                            <ComboBoxItem Content="Medium" Tag="100" IsSelected="True"/>
                                            <ComboBoxItem Content="Large" Tag="150"/>
                                            <ComboBoxItem Content="X-Large" Tag="200"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Colors Section -->
                                    <TextBlock Text="Colors"
                                               Style="{StaticResource CardTitleStyle}"
                                               Margin="0,12,0,8"/>

                                    <!-- Text Color -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Text Color"
                                                   Foreground="#B0B0B0"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"/>
                                        <StackPanel Orientation="Horizontal" Grid.Column="1">
                                            <Border x:Name="OSDTextColorPreview"
                                                    Width="24" Height="24"
                                                    Background="#FFFFFF"
                                                    CornerRadius="4"
                                                    BorderBrush="#505050"
                                                    BorderThickness="1"
                                                    Margin="0,0,8,0"/>
                                            <ComboBox x:Name="OSDTextColorComboBox"
                                                      Style="{StaticResource ModernComboBoxStyle}"
                                                      Width="100"
                                                      SelectionChanged="OSDColorOption_Changed"
                                                      UseSystemFocusVisuals="True"
                                                      FocusVisualPrimaryBrush="White">
                                                <ComboBoxItem Content="Dynamic" Tag="DYNAMIC" IsSelected="True"/>
                                                <ComboBoxItem Content="White" Tag="FFFFFF"/>
                                                <ComboBoxItem Content="Yellow" Tag="FFFF00"/>
                                                <ComboBoxItem Content="Green" Tag="00FF00"/>
                                                <ComboBoxItem Content="Cyan" Tag="00FFFF"/>
                                                <ComboBoxItem Content="Red" Tag="FF0000"/>
                                                <ComboBoxItem Content="Orange" Tag="FF8000"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <!-- Items Section -->
                                    <TextBlock Text="Items to Display"
                                               Style="{StaticResource CardTitleStyle}"
                                               Margin="0,12,0,8"/>

                                    <!-- OSD Options Panel -->
                                    <StackPanel x:Name="OSDOptionsPanel">
                                        <CheckBox x:Name="OSDShowAppNameCheckBox"
                                                  Content="App Name (D3D11, Vulkan, etc.)"
                                                  IsChecked="False"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowTimeCheckBox"
                                                  Content="Time (12-hour)"
                                                  IsChecked="False"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowFPSCheckBox"
                                                  Content="FPS &amp; Frametime"
                                                  IsChecked="True"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowBatteryCheckBox"
                                                  Content="Battery"
                                                  IsChecked="True"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowMemoryCheckBox"
                                                  Content="Memory"
                                                  IsChecked="True"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowCPUCheckBox"
                                                  Content="CPU (Usage, Wattage, Temp)"
                                                  IsChecked="True"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowCPUClockCheckBox"
                                                  Content="CPU Clock Speed"
                                                  IsChecked="False"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowGPUCheckBox"
                                                  Content="GPU (Usage, Wattage, Temp)"
                                                  IsChecked="True"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowGPUClockCheckBox"
                                                  Content="GPU Clock Speed"
                                                  IsChecked="False"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowFanCheckBox"
                                                  Content="Fan Speed"
                                                  IsChecked="False"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowAutoTDPCheckBox"
                                                  Content="AutoTDP Status"
                                                  IsChecked="False"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                    </StackPanel>

                                    <!-- Custom RTSS Tags Section -->
                                    <TextBlock Text="Custom RTSS Tags"
                                               Style="{StaticResource CardTitleStyle}"
                                               Margin="0,16,0,4"/>
                                    <TextBlock Text="Add custom RTSS tags (e.g. &lt;FR&gt; for FPS)"
                                               Style="{StaticResource CardCaptionStyle}"
                                               Margin="0,0,0,8"/>
                                    <TextBox x:Name="OSDCustomTagsTextBox"
                                             PlaceholderText="Enter custom RTSS tags..."
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             Height="60"
                                             TextChanged="OSDCustomTagsTextBox_TextChanged"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- About Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="About" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="Version: 0.3.31"
                                           FontSize="14"
                                           Foreground="#A0A0A0"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- SCALING TAB -->
                <ScrollViewer x:Name="ScalingScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Status Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Lossless Scaling Status" Style="{StaticResource CardTitleStyle}" Grid.Column="0" VerticalAlignment="Center"/>
                                    <Button x:Name="ShowLosslessScalingWindowButton"
                                            Grid.Column="1"
                                            Content="Show Window"
                                            Margin="0,0,8,0"
                                            Visibility="Collapsed"
                                            Style="{StaticResource ModernButtonStyle}"
                                            Padding="12,8"
                                            FontSize="14"
                                            Click="ShowLosslessScalingWindowButton_Click"/>
                                    <Button x:Name="LaunchLosslessScalingButton"
                                            Grid.Column="2"
                                            Content="Launch"
                                            Visibility="Collapsed"
                                            Style="{StaticResource ModernButtonStyle}"
                                            Padding="12,8"
                                            FontSize="14"
                                            Click="LaunchLosslessScalingButton_Click"/>
                                </Grid>
                                <TextBlock x:Name="LosslessScalingStatusText"
                                           Text="Not Installed"
                                           FontSize="14"
                                           Foreground="#A0A0A0"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Current Profile Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Current Profile" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock x:Name="LosslessScalingCurrentProfileText"
                                                   Text="Default"
                                                   FontSize="14"
                                                   Foreground="#00C8FF"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button x:Name="LosslessScalingCreateProfileButton"
                                            Grid.Column="1"
                                            Content="Create Profile"
                                            VerticalAlignment="Center"
                                            IsEnabled="False"
                                            Style="{StaticResource ModernButtonStyle}"
                                            Padding="12,8"
                                            FontSize="14"
                                            Click="LosslessScalingCreateProfileButton_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Scale Toggle Button -->
                        <ToggleButton x:Name="LosslessScalingEnabledToggle"
                                      Content="Scale"
                                      HorizontalAlignment="Stretch"
                                      IsEnabled="False"
                                      FontSize="16"
                                      FontWeight="SemiBold"
                                      Margin="0,10,0,0"
                                      Style="{StaticResource StandaloneToggleButtonStyle}"/>

                        <!-- Apply and Restart Button -->
                        <Button x:Name="LosslessScalingSaveSettingsButton"
                                Content="Apply and Restart"
                                HorizontalAlignment="Stretch"
                                Margin="0,8,0,0"
                                IsEnabled="False"
                                Style="{StaticResource StandaloneButtonStyle}"
                                Click="LosslessScalingSaveSettingsButton_Click"/>

                        <!-- AutoScale Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="AutoScale" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Automatically detect and scale games"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LosslessScalingAutoScaleToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False" Width="50"/>
                                </Grid>
                                <StackPanel Visibility="{Binding ElementName=LosslessScalingAutoScaleToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid Margin="0,8,0,0">
                                        <TextBlock Text="AutoScale Delay (s)"
                                                   FontSize="14"
                                                   Foreground="#A0A0A0"/>
                                        <TextBlock x:Name="LosslessScalingAutoScaleDelayValueText"
                                                   Text="{Binding ElementName=LosslessScalingAutoScaleDelaySlider, Path=Value}"
                                                   FontSize="14"
                                                   Foreground="#00C8FF"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="LosslessScalingAutoScaleDelaySlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="10"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Scaling Type Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Scaling Algorithm" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                                <ComboBox x:Name="LosslessScalingScalingTypeComboBox"
                                          PlaceholderText="Select Type"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectionChanged="LosslessScalingScalingTypeComboBox_SelectionChanged">
                                    <x:String>Off</x:String>
                                    <x:String>LS1</x:String>
                                    <x:String>FSR</x:String>
                                    <x:String>NIS</x:String>
                                    <x:String>SGSR</x:String>
                                    <x:String>BCAS</x:String>
                                    <x:String>Anime4K</x:String>
                                    <x:String>xBR</x:String>
                                    <x:String>Sharp Bilinear</x:String>
                                    <x:String>Integer</x:String>
                                    <x:String>Nearest Neighbor</x:String>
                                </ComboBox>

                                <!-- Sharpness Slider (for FSR, NIS, SGSR, BCAS) -->
                                <StackPanel x:Name="LosslessScalingSharpnessPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <Grid>
                                        <TextBlock Text="Sharpness" FontSize="12" Foreground="#A0A0A0"/>
                                        <TextBlock x:Name="LosslessScalingSharpnessValueText"
                                                   Text="{Binding ElementName=LosslessScalingSharpnessSlider, Path=Value}"
                                                   FontSize="12"
                                                   Foreground="#00C8FF"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="LosslessScalingSharpnessSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="100"
                                            TickFrequency="10"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            IsEnabled="False"/>
                                </StackPanel>

                                <!-- FSR Optimize Toggle (FSR only) -->
                                <Grid x:Name="LosslessScalingFSROptimizePanel" Visibility="Collapsed" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Optimize" FontSize="12" Foreground="#A0A0A0" VerticalAlignment="Center"/>
                                    <ToggleSwitch x:Name="LosslessScalingFSROptimizeToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>

                                <!-- Anime4K Settings -->
                                <StackPanel x:Name="LosslessScalingAnime4KPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <TextBlock Text="Size" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="LosslessScalingAnime4KSizeComboBox"
                                              PlaceholderText="Select Size"
                                              Width="Auto"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="False"
                                              Style="{StaticResource ModernComboBoxStyle}">
                                        <x:String>Small</x:String>
                                        <x:String>Medium</x:String>
                                        <x:String>Large</x:String>
                                        <x:String>Very Large</x:String>
                                        <x:String>Ultra Large</x:String>
                                    </ComboBox>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="VRS" FontSize="12" Foreground="#A0A0A0" VerticalAlignment="Center"/>
                                        <ToggleSwitch x:Name="LosslessScalingAnime4KVRSToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      IsEnabled="False"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Scale Mode Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Scale Mode" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                                <ComboBox x:Name="LosslessScalingScaleModeComboBox"
                                          PlaceholderText="Select Mode"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectionChanged="LosslessScalingScaleModeComboBox_SelectionChanged">
                                    <x:String>Auto</x:String>
                                    <x:String>Custom</x:String>
                                </ComboBox>

                                <!-- Auto Mode Settings -->
                                <StackPanel x:Name="LosslessScalingAutoModePanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <TextBlock Text="Aspect" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="LosslessScalingAspectRatioComboBox"
                                              PlaceholderText="Select Aspect"
                                              Width="Auto"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="False"
                                              Style="{StaticResource ModernComboBoxStyle}">
                                        <x:String>Aspect Ratio</x:String>
                                        <x:String>Fullscreen</x:String>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Custom Mode Settings -->
                                <StackPanel x:Name="LosslessScalingCustomModePanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <Grid>
                                        <TextBlock Text="Scale Factor" FontSize="12" Foreground="#A0A0A0"/>
                                        <TextBlock x:Name="LosslessScalingScaleFactorValueText"
                                                   Text="{Binding ElementName=LosslessScalingScaleFactorSlider, Path=Value}"
                                                   FontSize="12"
                                                   Foreground="#00C8FF"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="LosslessScalingScaleFactorSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="1" Maximum="5"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Frame Generation Type Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Frame Generation" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                                <ComboBox x:Name="LosslessScalingFrameGenTypeComboBox"
                                          PlaceholderText="Select Type"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}">
                                    <x:String>Off</x:String>
                                    <x:String>LSFG1</x:String>
                                    <x:String>LSFG2</x:String>
                                    <x:String>LSFG3</x:String>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- LSFG3 Settings Card -->
                        <Border x:Name="LSFG3SettingsCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="LSFG3 Settings" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>

                                <!-- LSFG3 Mode -->
                                <TextBlock Text="Mode" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                <ComboBox x:Name="LosslessScalingLSFG3ModeComboBox"
                                          PlaceholderText="Select Mode"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          Margin="0,0,0,12"
                                          SelectionChanged="LosslessScalingLSFG3ModeComboBox_SelectionChanged">
                                    <x:String>FIXED</x:String>
                                    <x:String>ADAPTIVE</x:String>
                                </ComboBox>

                                <!-- LSFG3 Multiplier (hidden when Adaptive) -->
                                <StackPanel x:Name="LosslessScalingLSFG3MultiplierPanel">
                                    <TextBlock Text="Multiplier" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="LosslessScalingLSFG3MultiplierComboBox"
                                              PlaceholderText="Select Multiplier"
                                              Width="Auto"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="False"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              Margin="0,0,0,12">
                                        <x:String>2</x:String>
                                        <x:String>3</x:String>
                                        <x:String>4</x:String>
                                    </ComboBox>
                                </StackPanel>

                                <!-- LSFG3 Target FPS -->
                                <Grid>
                                    <TextBlock Text="Target FPS" FontSize="12" Foreground="#A0A0A0"/>
                                    <TextBlock x:Name="LosslessScalingLSFG3TargetValueText"
                                               Text="{Binding ElementName=LosslessScalingLSFG3TargetSlider, Path=Value}"
                                               FontSize="12"
                                               Foreground="#00C8FF"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="LosslessScalingLSFG3TargetSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="30" Maximum="240"
                                        TickFrequency="10"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"
                                        Margin="0,0,0,12"/>

                                <!-- Flow Scale -->
                                <Grid>
                                    <TextBlock Text="Flow Scale" FontSize="12" Foreground="#A0A0A0"/>
                                    <TextBlock x:Name="LosslessScalingFlowScaleValueText"
                                               Text="{Binding ElementName=LosslessScalingFlowScaleSlider, Path=Value}"
                                               FontSize="12"
                                               Foreground="#00C8FF"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="LosslessScalingFlowScaleSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="25" Maximum="100"
                                        TickFrequency="5"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"
                                        Margin="0,0,0,12"/>

                                <!-- Size Toggle (Performance/Balanced) -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Performance Mode" FontSize="14" Foreground="#FFFFFF"/>
                                        <TextBlock Text="Lighter model for less input lag"
                                                   FontSize="11"
                                                   Foreground="#A0A0A0"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LosslessScalingSizeToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- LSFG2 Settings Card -->
                        <Border x:Name="LSFG2SettingsCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="LSFG2 Settings" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>

                                <!-- LSFG2 Mode -->
                                <TextBlock Text="Mode" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                <ComboBox x:Name="LosslessScalingLSFG2ModeComboBox"
                                          PlaceholderText="Select Mode"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}">
                                    <x:String>X2</x:String>
                                    <x:String>X3</x:String>
                                    <x:String>X4</x:String>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- Conflict Warning Card -->
                        <Border Style="{StaticResource CardStyle}" x:Name="LSConflictWarningBorder" Visibility="Collapsed" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Conflict Detected"
                                           Style="{StaticResource CardTitleStyle}"
                                           Foreground="#FFA500"/>
                                <TextBlock x:Name="LSConflictWarningText"
                                           Text="AMD Fluid Motion Frames has been automatically disabled because it conflicts with Lossless Scaling Frame Generation."
                                           FontSize="12"
                                           Foreground="#FFA500"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- LEGION TAB -->
                <ScrollViewer x:Name="LegionScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Controller Status Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Legion Go Controller" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock x:Name="LegionControllerStatusText"
                                           Text="Connected"
                                           FontSize="14"
                                           Foreground="#4CAF50"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Touchpad Control Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Touchpad" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Enable or disable the controller touchpad"
                                               Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="LegionTouchpadToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsOn="True" Width="50"/>
                            </Grid>
                        </Border>

                        <!-- Gyroscope Control Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Gyroscope" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="(WIP)"
                                                   FontSize="12"
                                                   Foreground="#FFA500"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock Text="Enable or disable gyro aiming"
                                               Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="LegionGyroToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsOn="False" Width="50"
                                              IsEnabled="False"/>
                            </Grid>
                        </Border>

                        <!-- RGB Lighting Section Header -->
                        <TextBlock Text="RGB LIGHTING" Style="{StaticResource SectionHeaderStyle}"/>

                        <!-- Light Mode Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Light Mode" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="Controller stick ring lighting effect"
                                           Style="{StaticResource CardCaptionStyle}"
                                           Margin="0,0,0,8"/>
                                <ComboBox x:Name="LegionLightModeComboBox"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectedIndex="1">
                                    <x:String>Off</x:String>
                                    <x:String>Solid</x:String>
                                    <x:String>Pulse</x:String>
                                    <x:String>Dynamic</x:String>
                                    <x:String>Spiral</x:String>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- Light Color Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Light Color" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="RGB color for stick ring lighting"
                                                   Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border x:Name="LegionColorPreview"
                                                Width="24" Height="24"
                                                CornerRadius="4"
                                                Background="White"
                                                BorderBrush="#50555C"
                                                BorderThickness="1"
                                                Margin="0,0,8,0"/>
                                        <Button x:Name="LegionColorExpandButton"
                                                Content="&#xE70D;"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="12"
                                                Padding="8,4"
                                                Background="Transparent"
                                                Click="LegionColorExpandButton_Click"/>
                                    </StackPanel>
                                </Grid>
                                <ColorPicker x:Name="LegionColorPicker"
                                             Visibility="Collapsed"
                                             Margin="0,12,0,0"
                                             Color="White"
                                             ColorSpectrumShape="Ring"
                                             IsMoreButtonVisible="False"
                                             IsColorSliderVisible="True"
                                             IsColorChannelTextInputVisible="False"
                                             IsHexInputVisible="True"
                                             IsAlphaEnabled="False"
                                             IsAlphaSliderVisible="False"
                                             IsAlphaTextInputVisible="False"
                                             ColorChanged="LegionColorPicker_ColorChanged"/>
                            </StackPanel>
                        </Border>

                        <!-- Light Brightness Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="Brightness" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock x:Name="LegionBrightnessValue"
                                               Text="100%"
                                               Style="{StaticResource CardValueStyle}"/>
                                </Grid>
                                <Slider x:Name="LegionBrightnessSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="100"
                                        Value="100"
                                        ValueChanged="LegionBrightnessSlider_ValueChanged"/>
                            </StackPanel>
                        </Border>

                        <!-- Performance Mode Section Header -->
                        <TextBlock Text="PERFORMANCE MODE" Style="{StaticResource SectionHeaderStyle}"/>

                        <!-- Performance Mode Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Power Profile" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Controls TDP and thermal limits"
                                               Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ComboBox x:Name="LegionPerformanceModeComboBox"
                                          Width="140"
                                          Grid.Column="1"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectedIndex="1"
                                          SelectionChanged="LegionPerformanceModeComboBox_SelectionChanged"
                                          XYFocusDown="{x:Bind LegionCustomTDPSlowSlider}">
                                    <ComboBoxItem Content="Quiet" Tag="1"/>
                                    <ComboBoxItem Content="Balanced" Tag="2"/>
                                    <ComboBoxItem Content="Performance" Tag="3"/>
                                    <ComboBoxItem Content="Custom" Tag="255"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Custom TDP Cards (visible when Custom mode selected) -->
                        <StackPanel x:Name="LegionCustomTDPCard" Visibility="Collapsed">
                            <!-- Slow TDP (SPL) Card -->
                            <Border x:Name="LegionCustomTDPSlowCard" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="Slow TDP (SPL)"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="LegionCustomTDPSlowValue"
                                                   Text="15W"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="LegionCustomTDPSlowSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="5" Maximum="45"
                                            Value="15"
                                            Margin="0,4,0,0"
                                            ValueChanged="LegionCustomTDPSlider_ValueChanged"
                                            XYFocusUp="{x:Bind LegionPerformanceModeComboBox}"
                                            XYFocusDown="{x:Bind LegionCustomTDPFastSlider}"/>
                                </StackPanel>
                            </Border>

                            <!-- Fast TDP (SPPL) Card -->
                            <Border x:Name="LegionCustomTDPFastCard" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="Fast TDP (SPPL)"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="LegionCustomTDPFastValue"
                                                   Text="25W"
                                                   FontSize="14"
                                                   Foreground="#FFA500"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="LegionCustomTDPFastSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="5" Maximum="55"
                                            Value="25"
                                            Margin="0,4,0,0"
                                            ValueChanged="LegionCustomTDPSlider_ValueChanged"
                                            XYFocusUp="{x:Bind LegionCustomTDPSlowSlider}"
                                            XYFocusDown="{x:Bind LegionCustomTDPPeakSlider}"/>
                                </StackPanel>
                            </Border>

                            <!-- Peak TDP (FPPT) Card -->
                            <Border x:Name="LegionCustomTDPPeakCard" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="Peak TDP (FPPT)"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="LegionCustomTDPPeakValue"
                                                   Text="35W"
                                                   FontSize="14"
                                                   Foreground="#FF6B6B"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="LegionCustomTDPPeakSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="5" Maximum="65"
                                            Value="35"
                                            Margin="0,4,0,0"
                                            ValueChanged="LegionCustomTDPSlider_ValueChanged"
                                            XYFocusUp="{x:Bind LegionCustomTDPFastSlider}"
                                            XYFocusDown="{x:Bind LegionFanFullSpeedToggle}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Fan Full Speed Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Fan Full Speed" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Override fan curve for maximum cooling"
                                               Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="LegionFanFullSpeedToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsOn="False" Width="50"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

            </Grid>

        </muxc:NavigationView>
    </Grid>
</Page>
