<Page
    x:Class="XboxGamingBar.GamingWidget"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:XboxGamingBar"
    xmlns:converter="using:XboxGamingBar.Converter"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="670" d:DesignWidth="600">

    <Page.Resources>
        <!-- Existing Converters -->
        <converter:WattStringConverter x:Key="WattStringConverter"/>
        <converter:MegahertzStringConverter x:Key="MegahertzStringConverter"/>
        <converter:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converter:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <converter:SharpnessPercentStringConverter x:Key="SharpnessPercentStringConverter"/>
        <converter:RadeonBoostResolutionStringConverter x:Key="RadeonBoostResolutionStringConverter"/>

        <!-- System Accent Color Brush (Light2 variant for dark theme text) -->
        <SolidColorBrush x:Key="SystemAccentBrush" Color="{ThemeResource SystemAccentColorLight2}"/>

        <!-- Tooth Theme Colors -->
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#25282C"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#30343A"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#50555C"/>
        <SolidColorBrush x:Key="ButtonBackground" Color="#3E434B"/>
        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#484E58"/>
        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3A3F47"/>
        <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="#2C3035"/>
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#6B7584"/>
        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#6B7584"/>
        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#555D69"/>
        <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="#3A3F46"/>
        <CornerRadius x:Key="ControlCornerRadius">8,8,8,8</CornerRadius>
        <Thickness x:Key="ButtonPadding">15,10,15,11</Thickness>

        <!-- Card Style - Tooth Theme -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
        </Style>

        <!-- Card Focus Border Brush -->
        <SolidColorBrush x:Key="CardFocusBorderBrush" Color="White"/>

        <!-- Navigation RadioButton Style - Optimized for Handheld XY Navigation -->
        <!-- Uses RadioButtons group which treats tabs as single navigable unit -->
        <Style x:Key="NavRadioButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#AAAAAA"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="MinWidth" Value="0"/>
            <Setter Property="MinHeight" Value="0"/>
            <Setter Property="Padding" Value="8,5,8,5"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="UseSystemFocusVisuals" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid x:Name="RootGrid" Background="{TemplateBinding Background}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#FFFFFF"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#888888"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="#555555"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="CheckStates">
                                    <VisualState x:Name="Checked">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource SystemAccentBrush}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="SelectionIndicator" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unchecked"/>
                                    <VisualState x:Name="Indeterminate"/>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="FocusStates">
                                    <VisualState x:Name="Focused">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="FocusBorder" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unfocused"/>
                                    <VisualState x:Name="PointerFocused"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <!-- Focus border with rounded corners -->
                            <Border x:Name="FocusBorder"
                                    BorderBrush="White"
                                    BorderThickness="2"
                                    CornerRadius="6"
                                    Margin="-2"
                                    Visibility="Collapsed"/>
                            <ContentPresenter x:Name="ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Foreground="{TemplateBinding Foreground}"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalContentAlignment="Center"
                                              VerticalContentAlignment="Center"
                                              AutomationProperties.AccessibilityView="Raw"/>
                            <Border x:Name="SelectionIndicator"
                                    Height="3"
                                    Background="{StaticResource SystemAccentBrush}"
                                    CornerRadius="1.5"
                                    VerticalAlignment="Bottom"
                                    HorizontalAlignment="Stretch"
                                    Margin="6,0,6,2"
                                    Visibility="Collapsed"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Card Title Style - Tooth Theme -->
        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Card Title Style - Compact Mode -->
        <Style x:Key="CardTitleStyleCompact" TargetType="TextBlock" BasedOn="{StaticResource CardTitleStyle}">
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <!-- Card Caption Style - Tooth Theme -->
        <Style x:Key="CardCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <!-- Card Caption Style - Compact Mode -->
        <Style x:Key="CardCaptionStyleCompact" TargetType="TextBlock" BasedOn="{StaticResource CardCaptionStyle}">
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <!-- Card Value Style -->
        <Style x:Key="CardValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource SystemAccentBrush}"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Card Value Style - Compact Mode -->
        <Style x:Key="CardValueStyleCompact" TargetType="TextBlock" BasedOn="{StaticResource CardValueStyle}">
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <!-- Modern Toggle Style - Uses system style, focus highlight on parent card -->
        <Style x:Key="ModernToggleStyle" TargetType="ToggleSwitch" BasedOn="{StaticResource DefaultToggleSwitchStyle}">
            <Setter Property="MinWidth" Value="40"/>
            <Setter Property="MaxWidth" Value="40"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="OffContent" Value=""/>
            <Setter Property="OnContent" Value=""/>
            <Setter Property="UseSystemFocusVisuals" Value="True"/>
            <Setter Property="FocusVisualPrimaryBrush" Value="White"/>
            <Setter Property="FocusVisualSecondaryBrush" Value="Transparent"/>
            <Setter Property="FocusVisualPrimaryThickness" Value="2"/>
            <Setter Property="FocusVisualMargin" Value="-3,-3,-3,-3"/>
        </Style>

        <!-- Modern Slider Style - Fluent with System Accent Color, focus on parent card -->
        <Style x:Key="ModernSliderStyle" TargetType="Slider" BasedOn="{StaticResource DefaultSliderStyle}">
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="ManipulationMode" Value="None"/>
            <Setter Property="IsFocusEngagementEnabled" Value="True"/>
        </Style>

        <!-- Modern ComboBox Style - System style with minor customizations -->
        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource DefaultComboBoxStyle}">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <!-- Override ComboBox border colors to prevent highlight on focus/hover -->
        <SolidColorBrush x:Key="ComboBoxBorderBrushPointerOver" Color="#50555C"/>
        <SolidColorBrush x:Key="ComboBoxBorderBrushPressed" Color="#50555C"/>
        <SolidColorBrush x:Key="ComboBoxBorderBrushFocused" Color="#50555C"/>
        <SolidColorBrush x:Key="ComboBoxBackgroundPointerOver" Color="#30343A"/>
        <SolidColorBrush x:Key="ComboBoxBackgroundPressed" Color="#30343A"/>
        <SolidColorBrush x:Key="ComboBoxBackgroundFocused" Color="#30343A"/>

        <!-- Modern Button Style - System style -->
        <Style x:Key="ModernButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        </Style>

        <!-- Standalone Button Style - System style -->
        <Style x:Key="StandaloneButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <!-- Standalone ToggleButton Style - System style -->
        <Style x:Key="StandaloneToggleButtonStyle" TargetType="ToggleButton" BasedOn="{StaticResource DefaultToggleButtonStyle}">
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <!-- Checkbox with system style -->
        <Style x:Key="FocusableCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource DefaultCheckBoxStyle}">
            <Setter Property="Padding" Value="8,6"/>
        </Style>

        <!-- Default Button Style Override - uses system style -->
        <Style TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        </Style>

        <!-- Default ToggleButton Style Override - uses system style -->
        <Style TargetType="ToggleButton" BasedOn="{StaticResource DefaultToggleButtonStyle}">
        </Style>

        <!-- Default CheckBox Style Override - uses system style -->
        <Style TargetType="CheckBox" BasedOn="{StaticResource DefaultCheckBoxStyle}">
        </Style>

        <!-- Section Header Style - Tooth Theme -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{StaticResource SystemAccentBrush}"/>
            <Setter Property="Margin" Value="0,20,0,0"/>
        </Style>

        <!-- Quick Settings Tile Colors - Dark mode with sharp contrast -->
        <SolidColorBrush x:Key="TileOffBackground" Color="#1A1C1E"/>
        <SolidColorBrush x:Key="TileOnBackground" Color="#1A2E1F"/>
        <SolidColorBrush x:Key="TileActiveBackground" Color="#1A2530"/>
        <SolidColorBrush x:Key="TileTriggerBackground" Color="#252030"/>
        <SolidColorBrush x:Key="TileBorderBrush" Color="Transparent"/>
        <SolidColorBrush x:Key="TileFocusBorderBrush" Color="White"/>
        <!-- Inactive state: even darker -->
        <SolidColorBrush x:Key="TileInactiveBackground" Color="#0D0E0F"/>
        <SolidColorBrush x:Key="TileInactiveForeground" Color="#606060"/>

        <!-- Quick Settings Tile Style - Xbox Game Bar Widget UI Guidelines -->
        <!-- Rest: normal background, Focus: rest + white stroke, Press: 10% darker, Focus+Press: press + stroke, Inactive: 50% darker -->
        <Style x:Key="QuickSettingsTileStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource TileOffBackground}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,16"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="MinWidth" Value="90"/>
            <Setter Property="MinHeight" Value="90"/>
            <Setter Property="UseSystemFocusVisuals" Value="False"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal"/>
                                    <VisualState x:Name="PointerOver"/>
                                    <VisualState x:Name="Pressed">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="PressedOverlay" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Disabled">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="InactiveOverlay" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                                            </ObjectAnimationUsingKeyFrames>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="ContentPresenter" Storyboard.TargetProperty="Foreground">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="{StaticResource TileInactiveForeground}"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="FocusStates">
                                    <VisualState x:Name="Focused">
                                        <Storyboard>
                                            <ObjectAnimationUsingKeyFrames Storyboard.TargetName="FocusBorder" Storyboard.TargetProperty="Visibility">
                                                <DiscreteObjectKeyFrame KeyTime="0" Value="Visible"/>
                                            </ObjectAnimationUsingKeyFrames>
                                        </Storyboard>
                                    </VisualState>
                                    <VisualState x:Name="Unfocused"/>
                                    <VisualState x:Name="PointerFocused"/>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>

                            <!-- Background with light border -->
                            <Border x:Name="BackgroundBorder"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="#50555C"
                                    BorderThickness="1"
                                    CornerRadius="12"/>

                            <!-- Pressed overlay (10% darker) -->
                            <Border x:Name="PressedOverlay"
                                    Background="#1A000000"
                                    CornerRadius="12"
                                    Visibility="Collapsed"/>

                            <!-- Inactive overlay (50% darker) -->
                            <Border x:Name="InactiveOverlay"
                                    Background="#80000000"
                                    CornerRadius="12"
                                    Visibility="Collapsed"/>

                            <!-- Focus stroke border -->
                            <Border x:Name="FocusBorder"
                                    BorderBrush="White"
                                    BorderThickness="2"
                                    CornerRadius="12"
                                    Visibility="Collapsed"/>

                            <!-- Content -->
                            <ContentPresenter x:Name="ContentPresenter"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              Padding="{TemplateBinding Padding}"
                                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Quick Settings Edit Mode Checkbox Style -->
        <Style x:Key="TileVisibilityCheckBoxStyle" TargetType="CheckBox" BasedOn="{StaticResource DefaultCheckBoxStyle}">
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>

    </Page.Resources>

    <Grid>
        <ProgressRing x:Name="LoadingProgressRing"
                      IsActive="True"
                      Visibility="Collapsed"
                      Width="60"
                      Height="60"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>

        <!-- Navigation Bar using RadioButtons for proper XY focus navigation -->
        <Grid x:Name="MainNavContainer">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Nav Bar Row -->
            <Grid Grid.Row="0" Background="Transparent" Margin="4,0,4,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- LT indicator -->
                <Border Grid.Column="0" Background="#404040" CornerRadius="3" Padding="4,1" Margin="0,0,4,0" VerticalAlignment="Center">
                    <TextBlock Text="LT" Foreground="#FFFFFF" FontSize="10" FontWeight="SemiBold"/>
                </Border>

                <!-- Navigation Tabs - StackPanel for proper horizontal XY navigation -->
                <!-- XYFocusKeyboardNavigation="Disabled" prevents vertical nav within, allows left/right -->
                <StackPanel x:Name="MainNavPanel"
                            Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            XYFocusKeyboardNavigation="Disabled">
                    <RadioButton x:Name="QuickNavItem" Content="Quick" Tag="Quick" Style="{StaticResource NavRadioButtonStyle}" GroupName="MainNav" Checked="NavRadioButton_Checked"/>
                    <RadioButton x:Name="PerformanceNavItem" Content="Performance" Tag="Performance" Style="{StaticResource NavRadioButtonStyle}" GroupName="MainNav" Checked="NavRadioButton_Checked"/>
                    <RadioButton x:Name="ProfilesNavItem" Content="Profiles" Tag="Game" Style="{StaticResource NavRadioButtonStyle}" GroupName="MainNav" Checked="NavRadioButton_Checked"/>
                    <RadioButton x:Name="GraphicsNavItem" Content="Display" Tag="AMD" Style="{StaticResource NavRadioButtonStyle}" GroupName="MainNav" Checked="NavRadioButton_Checked"/>
                    <RadioButton x:Name="ScalingNavItem" Content="Scale" Tag="Scaling" Style="{StaticResource NavRadioButtonStyle}" GroupName="MainNav" Checked="NavRadioButton_Checked"/>
                    <RadioButton x:Name="LegionNavItem" Content="Legion" Tag="Legion" Style="{StaticResource NavRadioButtonStyle}" GroupName="MainNav" Visibility="Collapsed" Checked="NavRadioButton_Checked"/>
                    <RadioButton x:Name="GPDNavItem" Content="GPD" Tag="GPD" Style="{StaticResource NavRadioButtonStyle}" GroupName="MainNav" Visibility="Collapsed" Checked="NavRadioButton_Checked"/>
                    <RadioButton x:Name="SystemNavItem" Content="System" Tag="System" Style="{StaticResource NavRadioButtonStyle}" GroupName="MainNav" Checked="NavRadioButton_Checked"/>
                </StackPanel>

                <!-- RT indicator and status dot -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                    <Border Background="#404040" CornerRadius="3" Padding="4,1" Margin="4,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="RT" Foreground="#FFFFFF" FontSize="10" FontWeight="SemiBold"/>
                    </Border>
                    <!-- Helper Connection Status Indicator -->
                    <Border x:Name="HelperStatusIndicator"
                            Background="#30000000"
                            CornerRadius="6"
                            Padding="4,2"
                            Margin="0,0,0,0"
                            VerticalAlignment="Center"
                            ToolTipService.ToolTip="Helper Status"
                            Tapped="HelperStatusIndicator_Tapped">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <Ellipse x:Name="HelperStatusDot"
                                     Width="8" Height="8"
                                     Fill="#FF5555"
                                     VerticalAlignment="Center"/>
                            <TextBlock x:Name="HelperStatusText"
                                       Text="Disconnected"
                                       Foreground="#AAAAAA"
                                       FontSize="9"
                                       VerticalAlignment="Center"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Content Area -->
            <Grid Grid.Row="1">
            <!-- QUICK SETTINGS TAB -->
            <Grid>
                <ScrollViewer x:Name="QuickSettingsScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Visible"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Quick Metrics Row (compact stats display - dynamically populated) -->
                        <Border x:Name="QuickMetricsRow"
                                Background="#1A1C1E"
                                CornerRadius="12"
                                Padding="12,8"
                                Margin="0,0,0,8"
                                BorderBrush="#50555C"
                                BorderThickness="1"
                                Visibility="Collapsed">
                            <!-- Dynamic metrics grid - populated in code-behind -->
                            <Grid x:Name="QuickMetricsGrid"/>
                        </Border>

                        <!-- Dynamic Tiles Container - tiles generated in code-behind -->
                        <StackPanel x:Name="QuickSettingsTilesContainer"/>

                        <!-- Customize Button -->
                        <Button x:Name="QuickSettingsCustomizeButton"
                                Content="Customize"
                                HorizontalAlignment="Stretch"
                                Margin="0,16,0,0"
                                Style="{StaticResource StandaloneButtonStyle}"
                                Click="QuickSettingsCustomize_Click"/>

                        <!-- Customization Panel (hidden by default) -->
                        <Border x:Name="QuickSettingsCustomizePanel"
                                Style="{StaticResource CardStyle}"
                                Visibility="Collapsed"
                                Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Customize Tiles" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="Tap tile to select, tap another to swap. Tap same tile to toggle visibility."
                                           Style="{StaticResource CardCaptionStyle}"
                                           Margin="0,0,0,8"
                                           TextWrapping="Wrap"/>

                                <!-- Column Count Toggle -->
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Columns:"
                                               VerticalAlignment="Center"
                                               Foreground="#AAAAAA"
                                               FontSize="13"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button x:Name="Column3Button"
                                                Content="3"
                                                MinWidth="40"
                                                Margin="0,0,4,0"
                                                Click="ColumnCount3_Click"/>
                                        <Button x:Name="Column4Button"
                                                Content="4"
                                                MinWidth="40"
                                                Margin="0,0,4,0"
                                                Click="ColumnCount4_Click"/>
                                        <Button x:Name="Column5Button"
                                                Content="5"
                                                MinWidth="40"
                                                Click="ColumnCount5_Click"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Show Metrics Row Toggle -->
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Show Metrics Row"
                                                   Foreground="#FFFFFF"
                                                   FontSize="13"/>
                                        <TextBlock Text="Select up to 6 metrics below"
                                                   Foreground="#666666"
                                                   FontSize="11"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="QuickMetricsToggle"
                                                  Grid.Column="1"
                                                  OffContent=""
                                                  OnContent=""
                                                  Toggled="QuickMetricsToggle_Toggled"/>
                                </Grid>

                                <!-- Metrics Selection (visible when toggle is on) -->
                                <Border x:Name="MetricsSelectionPanel"
                                        Background="#15171A"
                                        CornerRadius="8"
                                        Padding="10"
                                        Margin="0,0,0,12"
                                        Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="Select Metrics (max 6)"
                                                   Foreground="#AAAAAA"
                                                   FontSize="11"
                                                   Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <!-- Row 0 -->
                                            <CheckBox x:Name="MetricCheck_BatteryDrain" Content="Battery Drain" Grid.Row="0" Grid.Column="0" Foreground="White" FontSize="12" Margin="0,2" Checked="MetricCheckBox_Changed" Unchecked="MetricCheckBox_Changed"/>
                                            <CheckBox x:Name="MetricCheck_BatteryLevel" Content="Battery Level" Grid.Row="0" Grid.Column="1" Foreground="White" FontSize="12" Margin="0,2" Checked="MetricCheckBox_Changed" Unchecked="MetricCheckBox_Changed"/>
                                            <!-- Row 1 -->
                                            <CheckBox x:Name="MetricCheck_CPUUsage" Content="CPU Usage" Grid.Row="1" Grid.Column="0" Foreground="White" FontSize="12" Margin="0,2" Checked="MetricCheckBox_Changed" Unchecked="MetricCheckBox_Changed"/>
                                            <CheckBox x:Name="MetricCheck_CPUTemp" Content="CPU Temp" Grid.Row="1" Grid.Column="1" Foreground="White" FontSize="12" Margin="0,2" Checked="MetricCheckBox_Changed" Unchecked="MetricCheckBox_Changed"/>
                                            <!-- Row 2 -->
                                            <CheckBox x:Name="MetricCheck_CPUWattage" Content="CPU Wattage" Grid.Row="2" Grid.Column="0" Foreground="White" FontSize="12" Margin="0,2" Checked="MetricCheckBox_Changed" Unchecked="MetricCheckBox_Changed"/>
                                            <CheckBox x:Name="MetricCheck_GPUUsage" Content="GPU Usage" Grid.Row="2" Grid.Column="1" Foreground="White" FontSize="12" Margin="0,2" Checked="MetricCheckBox_Changed" Unchecked="MetricCheckBox_Changed"/>
                                            <!-- Row 3 -->
                                            <CheckBox x:Name="MetricCheck_GPUTemp" Content="GPU Temp" Grid.Row="3" Grid.Column="0" Foreground="White" FontSize="12" Margin="0,2" Checked="MetricCheckBox_Changed" Unchecked="MetricCheckBox_Changed"/>
                                            <CheckBox x:Name="MetricCheck_GPUWattage" Content="GPU Wattage" Grid.Row="3" Grid.Column="1" Foreground="White" FontSize="12" Margin="0,2" Checked="MetricCheckBox_Changed" Unchecked="MetricCheckBox_Changed"/>
                                            <!-- Row 4 -->
                                            <CheckBox x:Name="MetricCheck_MemoryUsage" Content="Memory Usage" Grid.Row="4" Grid.Column="0" Foreground="White" FontSize="12" Margin="0,2" Checked="MetricCheckBox_Changed" Unchecked="MetricCheckBox_Changed"/>
                                            <CheckBox x:Name="MetricCheck_TimeRemaining" Content="Time Remaining" Grid.Row="4" Grid.Column="1" Foreground="White" FontSize="12" Margin="0,2" Checked="MetricCheckBox_Changed" Unchecked="MetricCheckBox_Changed"/>
                                        </Grid>
                                        <TextBlock x:Name="MetricsSelectionCount" Text="0/6 selected" Foreground="#666666" FontSize="11" Margin="0,6,0,0" HorizontalAlignment="Right"/>

                                        <!-- Reorder Section -->
                                        <Border x:Name="MetricsReorderSection"
                                                Background="#1A1C1E"
                                                CornerRadius="6"
                                                Padding="8"
                                                Margin="0,10,0,0"
                                                Visibility="Collapsed">
                                            <StackPanel>
                                                <TextBlock Text="Reorder (drag or use arrows)"
                                                           Foreground="#888888"
                                                           FontSize="10"
                                                           Margin="0,0,0,6"/>
                                                <StackPanel x:Name="MetricsReorderList" Spacing="4"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Sortable Tile Grid - generated in code-behind -->
                                <StackPanel x:Name="TileSortableGrid"/>

                                <!-- Selected tile indicator -->
                                <Border x:Name="SelectedTileIndicator"
                                        Visibility="Collapsed"
                                        Background="#1A2530"
                                        CornerRadius="4"
                                        Padding="8"
                                        Margin="0,8,0,0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock x:Name="SelectedTileText"
                                                   Foreground="#00C8FF"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   VerticalAlignment="Center"/>
                                        <Button x:Name="DeleteSelectedTileButton"
                                                Grid.Column="1"
                                                Visibility="Collapsed"
                                                Background="#662020"
                                                Foreground="White"
                                                Margin="8,0,0,0"
                                                Padding="12,6"
                                                Click="DeleteSelectedTile_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <FontIcon Glyph="&#xE74D;" FontSize="14" Margin="0,0,6,0"/>
                                                <TextBlock Text="Delete"/>
                                            </StackPanel>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Add Custom Shortcut Section -->
                                <TextBlock Text="Add Custom Shortcut"
                                           Style="{StaticResource CardTitleStyle}"
                                           Margin="0,16,0,8"/>
                                <TextBox x:Name="CustomShortcutNameBox"
                                         PlaceholderText="Tile Name"
                                         Margin="0,0,0,8"/>
                                <StackPanel Orientation="Horizontal">
                                    <ItemsControl x:Name="CustomShortcutKeyTags">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                    </ItemsControl>
                                    <ComboBox x:Name="CustomShortcutKeyComboBox" Width="90" Style="{StaticResource ModernComboBoxStyle}"
                                              SelectedIndex="0" SelectionChanged="CustomShortcutKey_SelectionChanged">
                                        <x:String>+ Key</x:String><x:String>A</x:String><x:String>B</x:String><x:String>C</x:String><x:String>D</x:String><x:String>E</x:String><x:String>F</x:String><x:String>G</x:String><x:String>H</x:String><x:String>I</x:String><x:String>J</x:String><x:String>K</x:String><x:String>L</x:String><x:String>M</x:String><x:String>N</x:String><x:String>O</x:String><x:String>P</x:String><x:String>Q</x:String><x:String>R</x:String><x:String>S</x:String><x:String>T</x:String><x:String>U</x:String><x:String>V</x:String><x:String>W</x:String><x:String>X</x:String><x:String>Y</x:String><x:String>Z</x:String><x:String>0</x:String><x:String>1</x:String><x:String>2</x:String><x:String>3</x:String><x:String>4</x:String><x:String>5</x:String><x:String>6</x:String><x:String>7</x:String><x:String>8</x:String><x:String>9</x:String><x:String>F1</x:String><x:String>F2</x:String><x:String>F3</x:String><x:String>F4</x:String><x:String>F5</x:String><x:String>F6</x:String><x:String>F7</x:String><x:String>F8</x:String><x:String>F9</x:String><x:String>F10</x:String><x:String>F11</x:String><x:String>F12</x:String><x:String>Enter</x:String><x:String>Esc</x:String><x:String>Space</x:String><x:String>Tab</x:String><x:String>Backspace</x:String><x:String>Up</x:String><x:String>Down</x:String><x:String>Left</x:String><x:String>Right</x:String><x:String>LCtrl</x:String><x:String>LShift</x:String><x:String>LAlt</x:String><x:String>LWin</x:String><x:String>RCtrl</x:String><x:String>RShift</x:String><x:String>RAlt</x:String><x:String>RWin</x:String><x:String>Home</x:String><x:String>End</x:String><x:String>PgUp</x:String><x:String>PgDn</x:String><x:String>Insert</x:String><x:String>Delete</x:String><x:String>PrintScr</x:String><x:String>Pause</x:String><x:String>VolUp</x:String><x:String>VolDown</x:String><x:String>VolMute</x:String><x:String>[</x:String><x:String>]</x:String>
                                    </ComboBox>
                                </StackPanel>
                                <Button x:Name="AddCustomShortcutButton"
                                        Content="Add Shortcut Tile"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,8,0,0"
                                        Style="{StaticResource StandaloneButtonStyle}"
                                        Click="AddCustomShortcut_Click"/>

                                <!-- Done Button -->
                                <Button Content="Done"
                                        HorizontalAlignment="Stretch"
                                        Margin="0,16,0,0"
                                        Style="{StaticResource StandaloneButtonStyle}"
                                        Click="QuickSettingsCustomizeDone_Click"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- PERFORMANCE TAB -->
                <ScrollViewer x:Name="PerformanceScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Default Game Profile Card (Preview) - Hidden when no profile available -->
                        <Border x:Name="DefaultGameProfileCard"
                                Style="{StaticResource CardStyle}"
                                Visibility="Collapsed">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#40C04040" Offset="0.0"/>
                                    <GradientStop Color="#40408050" Offset="0.35"/>
                                    <GradientStop Color="#40405080" Offset="0.65"/>
                                    <GradientStop Color="#40804060" Offset="1.0"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <!-- Game Icon -->
                                <Image x:Name="DefaultProfileGameIcon"
                                       Grid.Column="0"
                                       Width="36" Height="36"
                                       Margin="0,0,10,0"
                                       Stretch="UniformToFill"
                                       VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <!-- Game Name + Title -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock x:Name="DefaultProfileGameName"
                                                   Text=""
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text=" - "
                                                   FontSize="14"
                                                   Foreground="#888888"
                                                   VerticalAlignment="Center"
                                                   x:Name="DefaultProfileSeparator"
                                                   Visibility="Collapsed"/>
                                        <TextBlock x:Name="DefaultProfileOptimizingText"
                                                   Text="Optimizing for Z2 Extreme"
                                                   FontSize="11"
                                                   Foreground="#80FFFFFF"
                                                   VerticalAlignment="Center"
                                                   Visibility="Collapsed"/>
                                    </StackPanel>
                                    <TextBlock Text="Default Game Profile (Preview)"
                                               FontSize="13"
                                               Foreground="#AAAAAA"/>
                                    <TextBlock Text="Automatically applies optimized settings"
                                               FontSize="10"
                                               Foreground="#666666"/>
                                    <TextBlock x:Name="DefaultProfileSettingsText"
                                               Text="17W - 60fps"
                                               FontSize="12"
                                               Foreground="#00C8FF"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="DefaultProfileToggle"
                                              Grid.Column="2"
                                              Style="{StaticResource ModernToggleStyle}"
                                              XYFocusUp="{x:Bind PerformanceNavItem}"/>
                            </Grid>
                        </Border>

                        <!-- Active Profile Indicator -->
                        <Border x:Name="ActiveProfileCard" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Using profile:"
                                               FontSize="12"
                                               Foreground="#AAAAAA"
                                               Margin="4,1,0,0"/>
                                    <TextBlock x:Name="ActiveProfileText"
                                               Text="Global Settings"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#00C8FF"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="4,4,0,0"/>
                                </StackPanel>

                                <!-- Per-Game Profile Toggle -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Use per-game profile"
                                                   FontSize="12"
                                                   Foreground="#FFFFFF"/>
                                        <TextBlock x:Name="DetectedGameText"
                                                   Text="No game detected"
                                                   FontSize="11"
                                                   Foreground="#888888"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="200"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="PerGameProfileToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"
                                                  XYFocusUp="{x:Bind PerformanceNavItem}"
                                                  XYFocusDown="{x:Bind PerformanceOverlayComboBox}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Performance Overlay Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Performance Overlay"
                                               Style="{StaticResource CardTitleStyle}"
                                               VerticalAlignment="Center"
                                               Grid.Column="0"/>
                                    <ComboBox x:Name="PerformanceOverlayComboBox"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              Width="120"
                                              Grid.Column="1"
                                              SelectionChanged="PerformanceOverlayComboBox_SelectionChanged"
                                              XYFocusUp="{x:Bind PerGameProfileToggle}"
                                              XYFocusDown="{x:Bind TDPModeComboBox}"
                                              XYFocusLeft="{x:Bind PerformanceNavItem}">
                                        <ComboBoxItem Content="Off" Tag="0" IsSelected="True"/>
                                        <ComboBoxItem Content="Basic" Tag="1"/>
                                        <ComboBoxItem Content="Detailed" Tag="2"/>
                                        <ComboBoxItem Content="Full" Tag="3"/>
                                    </ComboBox>
                                </Grid>

                                <!-- Hidden slider for property system compatibility -->
                                <Slider x:Name="PerformanceOverlaySlider"
                                        Visibility="Collapsed"
                                        Minimum="0" Maximum="3"
                                        Value="0"
                                        ValueChanged="PerformanceOverlaySlider_ValueChanged"/>
                            </StackPanel>
                        </Border>

                        <!-- TDP Mode Card (all devices) -->
                        <Border x:Name="TDPModeCard" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="TDP Mode" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Controls power and thermal profile"
                                               Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ComboBox x:Name="TDPModeComboBox"
                                          MinWidth="140"
                                          Grid.Column="1"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectedIndex="1"
                                          SelectionChanged="TDPModeComboBox_SelectionChanged"
                                          XYFocusUp="{x:Bind PerformanceOverlayComboBox}"
                                          XYFocusDown="{x:Bind TDPSlider}">
                                    <ComboBoxItem Content="Quiet" Tag="1"/>
                                    <ComboBoxItem Content="Balanced" Tag="2"/>
                                    <ComboBoxItem Content="Performance" Tag="3"/>
                                    <ComboBoxItem Content="Custom" Tag="255"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- TDP Power Limit Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="TDP Power Limit" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock x:Name="TDPValueText"
                                               Text="--"
                                               Style="{StaticResource CardValueStyle}"/>
                                </Grid>
                                <Slider x:Name="TDPSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="4" Maximum="35"
                                        TickFrequency="1"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False" Value="-5"
                                        ValueChanged="TDPSlider_ValueChanged_UpdateDisplay"
                                        XYFocusUp="{x:Bind TDPModeComboBox}"
                                        XYFocusDown="{x:Bind TDPExtrasExpandToggle}"
                                        />
                                <Grid Margin="0,4,0,0">
                                    <TextBlock x:Name="CurrentTDPText"
                                               Text="Limits:"
                                               FontSize="12"
                                               Foreground="#A0A0A0"/>
                                    <TextBlock x:Name="CurrentTDPValueText"
                                               Text="-- W"
                                               FontSize="12"
                                               Foreground="#A0A0A0"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <!-- Sticky TDP Active Indicator -->
                                <TextBlock Text="Sticky TDP: Active"
                                           FontSize="13"
                                           Foreground="#4CAF50"
                                           FontWeight="SemiBold"
                                           Margin="0,1,0,0"
                                           Visibility="{Binding ElementName=StickyTDPToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- TDP Extras Card (Collapsible) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="TDP Extras" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="TDP Boost, AutoTDP, and Sticky TDP"
                                                   Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="TDPExtrasExpandToggle"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  XYFocusUp="{x:Bind TDPSlider}"
                                                  XYFocusDown="{x:Bind OSPowerModeComboBox}"
                                                  UseSystemFocusVisuals="True"
                                                  Padding="8,4"
                                                  Click="TDPExtrasExpandToggle_Click">
                                        <FontIcon x:Name="TDPExtrasExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>
                                <StackPanel x:Name="TDPExtrasContent" Spacing="12" Margin="0,12,0,0" Visibility="Collapsed">
                                    <!-- TDP Boost -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="TDP Boost" FontSize="14" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Apply boost values to SPPT and FPPT"
                                                       FontSize="11" Foreground="#888888"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="TDPBoostToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      Toggled="TDPBoostToggle_Toggled"
                                                      XYFocusUp="{x:Bind TDPExtrasExpandToggle}"
                                                      XYFocusDown="{x:Bind AutoTDPToggle}"/>
                                    </Grid>
                                    <TextBlock Text="TDP Boost: Active"
                                               FontSize="13"
                                               Foreground="#4CAF50"
                                               FontWeight="SemiBold"
                                               Margin="0,-8,0,0"
                                               Visibility="{Binding ElementName=TDPBoostToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                                    <!-- AutoTDP -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="AutoTDP" FontSize="14" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Automatically adjust TDP to maintain target FPS"
                                                       FontSize="11" Foreground="#888888"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="AutoTDPToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      Toggled="AutoTDPToggle_Toggled"
                                                      XYFocusUp="{x:Bind TDPBoostToggle}"
                                                      XYFocusDown="{x:Bind StickyTDPToggle}"/>
                                    </Grid>
                                    <StackPanel Visibility="{Binding ElementName=AutoTDPToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                Margin="0,-8,0,0">
                                        <Grid>
                                            <TextBlock Text="Target FPS" FontSize="14" Foreground="#A0A0A0"/>
                                            <TextBlock x:Name="AutoTDPTargetFPSValue" Text="60 FPS" FontSize="14" Foreground="#4CAF50" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <Slider x:Name="AutoTDPTargetFPSSlider" Style="{StaticResource ModernSliderStyle}" Minimum="30" Maximum="144" StepFrequency="5" TickFrequency="5" TickPlacement="Outside" SnapsTo="StepValues" Value="60" ValueChanged="AutoTDPTargetFPSSlider_ValueChanged"/>
                                        <Grid Margin="0,8,0,0">
                                            <TextBlock Text="Current FPS" FontSize="14" Foreground="#A0A0A0"/>
                                            <TextBlock x:Name="AutoTDPCurrentFPSValue" Text="-- FPS" FontSize="14" Foreground="#FFCC00" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <Grid Margin="0,12,0,0">
                                            <TextBlock Text="Min TDP" FontSize="14" Foreground="#A0A0A0"/>
                                            <TextBlock x:Name="AutoTDPMinValue" Text="8W" FontSize="14" Foreground="#4CAF50" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <Slider x:Name="AutoTDPMinSlider" Style="{StaticResource ModernSliderStyle}" Minimum="4" Maximum="85" StepFrequency="1" Value="8" ValueChanged="AutoTDPMinSlider_ValueChanged"/>
                                        <Grid Margin="0,8,0,0">
                                            <TextBlock Text="Max TDP" FontSize="14" Foreground="#A0A0A0"/>
                                            <TextBlock x:Name="AutoTDPMaxValue" Text="30W" FontSize="14" Foreground="#4CAF50" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <Slider x:Name="AutoTDPMaxSlider" Style="{StaticResource ModernSliderStyle}" Minimum="4" Maximum="85" StepFrequency="1" Value="30" ValueChanged="AutoTDPMaxSlider_ValueChanged"/>

                                        <!-- Pause when game not focused -->
                                        <CheckBox x:Name="AutoTDPPauseWhenUnfocusedCheckBox"
                                                  Content="Pause when game not focused"
                                                  IsChecked="True"
                                                  Margin="0,12,0,0"
                                                  Foreground="#A0A0A0"
                                                  FontSize="13"
                                                  Checked="AutoTDPPauseWhenUnfocusedCheckBox_Changed"
                                                  Unchecked="AutoTDPPauseWhenUnfocusedCheckBox_Changed"/>

                                        <!-- Sync FPS Limit with Target -->
                                        <CheckBox x:Name="AutoTDPSyncFPSLimitCheckBox"
                                                  Content="Sync FPS Limit with Target"
                                                  IsChecked="False"
                                                  Margin="0,8,0,0"
                                                  Foreground="#A0A0A0"
                                                  FontSize="13"
                                                  Checked="AutoTDPSyncFPSLimitCheckBox_Changed"
                                                  Unchecked="AutoTDPSyncFPSLimitCheckBox_Changed"/>

                                        <!-- Controller Mode Selection -->
                                        <Grid Margin="0,12,0,0">
                                            <TextBlock Text="Controller" FontSize="14" Foreground="#A0A0A0" VerticalAlignment="Center"/>
                                            <ComboBox x:Name="AutoTDPControllerModeComboBox"
                                                      HorizontalAlignment="Right"
                                                      Width="140"
                                                      Style="{StaticResource ModernComboBoxStyle}"
                                                      SelectionChanged="AutoTDPControllerModeComboBox_SelectionChanged">
                                                <ComboBoxItem Content="PID Controller" Tag="0" IsSelected="True"/>
                                                <ComboBoxItem Content="Q-Learning (ML)" Tag="1"/>
                                                <ComboBoxItem Content="SARSA (ML)" Tag="2"/>
                                            </ComboBox>
                                        </Grid>

                                        <!-- ML Mode Info Panel (visible when ML selected) -->
                                        <StackPanel x:Name="AutoTDPMLInfoPanel" Visibility="Collapsed" Margin="0,8,0,0">
                                            <Border Background="#1A4A148C" CornerRadius="4" Padding="8">
                                                <StackPanel>
                                                    <TextBlock Text="ML Learning Mode (Experimental)" FontSize="12" Foreground="#9C27B0" FontWeight="SemiBold"/>
                                                    <TextBlock x:Name="AutoTDPMLStatusText" Text="Updates: 0 | Avg: 0.0 | Exploration: 30%" FontSize="11" Foreground="#888888" Margin="0,4,0,0"/>
                                                    <Button x:Name="AutoTDPResetMLButton"
                                                            Content="Reset Learning Data"
                                                            Style="{StaticResource ModernButtonStyle}"
                                                            Margin="0,8,0,0"
                                                            Padding="8,4"
                                                            FontSize="11"
                                                            HorizontalAlignment="Left"
                                                            Click="AutoTDPResetMLButton_Click"/>
                                                    <StackPanel Margin="0,8,0,0">
                                                        <TextBlock Text="Learned Game Data" FontSize="12" Foreground="#8BC34A" FontWeight="SemiBold"/>
                                                        <TextBlock x:Name="AutoTDPLearnedSummaryText" Text="No learned data yet" FontSize="11" Foreground="#888888" Margin="0,4,0,0"/>
                                                        <StackPanel x:Name="AutoTDPLearnedHeatmapPanel" Margin="0,6,0,0"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- Sticky TDP -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Sticky TDP" FontSize="14" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Restore TDP limits if changed by other apps"
                                                       FontSize="11" Foreground="#888888"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="StickyTDPToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      Toggled="StickyTDPToggle_Toggled"
                                                      XYFocusUp="{x:Bind AutoTDPToggle}"/>
                                    </Grid>
                                    <StackPanel Visibility="{Binding ElementName=StickyTDPToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"
                                                Margin="0,-8,0,0">
                                        <Grid>
                                            <TextBlock Text="Reapply interval" FontSize="14" Foreground="#A0A0A0"/>
                                            <TextBlock x:Name="StickyTDPIntervalValue" Text="5s" FontSize="14" Foreground="#4CAF50" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                                        </Grid>
                                        <Slider x:Name="StickyTDPIntervalSlider" Style="{StaticResource ModernSliderStyle}" Minimum="3" Maximum="15" TickFrequency="2" SnapsTo="Ticks" Value="5" ValueChanged="StickyTDPIntervalSlider_ValueChanged"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- OS Power Mode Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="OS Power Mode" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Windows power slider setting"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <TextBlock x:Name="OSPowerModeValue"
                                               Grid.Column="1"
                                               Text="Balanced"
                                               FontSize="14"
                                               Foreground="#4CAF50"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="0,0,0,0"/>
                                </Grid>
                                <ComboBox x:Name="OSPowerModeComboBox"
                                          Margin="0,12,0,0"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectedIndex="1"
                                          SelectionChanged="OSPowerModeComboBox_SelectionChanged"
                                          XYFocusUp="{x:Bind TDPExtrasExpandToggle}"
                                          XYFocusDown="{x:Bind CPUExtrasExpandToggle}">
                                    <ComboBoxItem Content="Best Power Efficiency"/>
                                    <ComboBoxItem Content="Balanced"/>
                                    <ComboBoxItem Content="Best Performance"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- CPU Extras Card (Collapsible) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="CPU Extras" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="CPU Boost, EPP, and State limits"
                                                   Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="CPUExtrasExpandToggle"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="CPUExtrasExpandToggle_Click"
                                                  XYFocusUp="{x:Bind OSPowerModeComboBox}"
                                                  UseSystemFocusVisuals="True">
                                        <FontIcon x:Name="CPUExtrasExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>
                                <StackPanel x:Name="CPUExtrasContent" Spacing="12" Margin="0,12,0,0" Visibility="Collapsed">
                                    <!-- CPU Boost -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="CPU Boost" FontSize="14" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Higher boost clocks" FontSize="11" Foreground="#888888"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="CPUBoostToggle"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      Grid.Column="1"
                                                      IsEnabled="False"/>
                                    </Grid>

                                    <!-- CPU EPP -->
                                    <StackPanel>
                                        <Grid>
                                            <TextBlock Text="CPU EPP" FontSize="14" Foreground="#FFFFFF"/>
                                            <TextBlock x:Name="CPUEPPValueText"
                                                       Text="{Binding ElementName=CPUEPPSlider, Path=Value}"
                                                       Style="{StaticResource CardValueStyle}"/>
                                        </Grid>
                                        <Slider x:Name="CPUEPPSlider"
                                                Style="{StaticResource ModernSliderStyle}"
                                                Minimum="0" Maximum="100"
                                                TickFrequency="10"
                                                SnapsTo="Ticks"
                                                TickPlacement="BottomRight"
                                                IsEnabled="False"/>
                                        <Grid Margin="0,4,0,0">
                                            <TextBlock Text="0 = Prioritize CPU" FontSize="12" Foreground="#A0A0A0"/>
                                            <TextBlock Text="100 = Prioritize GPU" FontSize="12" Foreground="#A0A0A0" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- CPU State -->
                                    <StackPanel>
                                        <TextBlock Text="CPU State" FontSize="14" Foreground="#FFFFFF"/>
                                        <TextBlock Text="Processor performance limits" FontSize="11" Foreground="#888888"/>
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Margin="0,0,6,0">
                                                <TextBlock Text="Min %" FontSize="12" Foreground="#888888" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="MinCPUStateComboBox"
                                                          Style="{StaticResource ModernComboBoxStyle}"
                                                          SelectionChanged="MinCPUStateComboBox_SelectionChanged"
                                                          IsEnabled="False"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Margin="6,0,0,0">
                                                <TextBlock Text="Max %" FontSize="12" Foreground="#888888" Margin="0,0,0,4"/>
                                                <ComboBox x:Name="MaxCPUStateComboBox"
                                                          Style="{StaticResource ModernComboBoxStyle}"
                                                          SelectionChanged="MaxCPUStateComboBox_SelectionChanged"
                                                          IsEnabled="False"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- FPS Limit Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="FPS Limit" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock x:Name="FPSLimitCaption"
                                                   Text=""
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   Visibility="Collapsed"/>
                                    </StackPanel>
                                    <TextBlock x:Name="FPSLimitValue"
                                               Grid.Column="1"
                                               Text=""
                                               FontSize="14"
                                               Foreground="#4CAF50"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="0,0,12,0"
                                               Visibility="{Binding ElementName=FPSLimitToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    <ToggleSwitch x:Name="FPSLimitToggle"
                                                  Grid.Column="2"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False" Width="52"
                                                  XYFocusUp="{x:Bind CPUExtrasExpandToggle}"
                                                  XYFocusDown="{x:Bind AdvancedExpandButton}"/>
                                </Grid>
                                <Slider x:Name="FPSLimitSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="15" Maximum="144"
                                        StepFrequency="1"
                                        TickFrequency="15"
                                        TickPlacement="Outside"
                                        SnapsTo="StepValues"
                                        Visibility="{Binding ElementName=FPSLimitToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- Advanced Card (Collapsible) - Power Plan, Core Parking & Affinity -->
                        <Border x:Name="AdvancedCard" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header with Expand/Collapse -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Advanced" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock x:Name="AdvancedSummary"
                                                   Text="Power plans, core parking and affinity"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="AdvancedExpandButton"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="AdvancedExpandButton_Click"
                                                  XYFocusUp="{x:Bind FPSLimitToggle}"
                                                  UseSystemFocusVisuals="True">
                                        <FontIcon x:Name="AdvancedExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <!-- Collapsible Content -->
                                <StackPanel x:Name="AdvancedContent" Visibility="Collapsed" Margin="0,12,0,0">

                                    <!-- Power Plan Section -->
                                    <StackPanel Margin="0,0,0,16">
                                        <TextBlock Text="Power Plan"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FFFFFF"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Configure power plans for AC and battery"
                                                   FontSize="11"
                                                   Foreground="#888888"
                                                   Margin="0,0,0,8"/>

                                        <!-- AC Power Plan -->
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="AC Power Plan" Foreground="#FFFFFF" FontSize="13"/>
                                            <TextBlock Text="When plugged in" Foreground="#707070" FontSize="11"/>
                                            <ComboBox x:Name="ACPowerPlanComboBox"
                                                      Margin="0,8,0,0"
                                                      Style="{StaticResource ModernComboBoxStyle}"
                                                      SelectionChanged="ACPowerPlanComboBox_SelectionChanged"
                                                      XYFocusDown="{x:Bind DCPowerPlanComboBox}"/>
                                        </StackPanel>

                                        <!-- DC Power Plan -->
                                        <StackPanel Margin="0,0,0,12">
                                            <TextBlock Text="DC Power Plan" Foreground="#FFFFFF" FontSize="13"/>
                                            <TextBlock Text="When on battery" Foreground="#707070" FontSize="11"/>
                                            <ComboBox x:Name="DCPowerPlanComboBox"
                                                      Margin="0,8,0,0"
                                                      Style="{StaticResource ModernComboBoxStyle}"
                                                      SelectionChanged="DCPowerPlanComboBox_SelectionChanged"
                                                      XYFocusUp="{x:Bind ACPowerPlanComboBox}"
                                                      XYFocusDown="{x:Bind PowerPlanAutoSwitchToggle}"/>
                                        </StackPanel>

                                        <!-- Auto-switch Toggle -->
                                        <Grid Margin="0,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Auto-switch on power change" Foreground="#FFFFFF" FontSize="13"/>
                                                <TextBlock Text="Automatically apply the corresponding plan" Foreground="#707070" FontSize="11"/>
                                            </StackPanel>
                                            <ToggleSwitch x:Name="PowerPlanAutoSwitchToggle"
                                                          Grid.Column="1"
                                                          IsOn="False"
                                                          Toggled="PowerPlanAutoSwitchToggle_Toggled"
                                                          Style="{StaticResource ModernToggleStyle}"
                                                          XYFocusUp="{x:Bind DCPowerPlanComboBox}"/>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Separator -->
                                    <Border Height="1" Background="#333333" Margin="0,0,0,16"/>

                                    <!-- Core Parking Section (for non-hybrid CPUs only) -->
                                    <StackPanel x:Name="CoreParkingSection">
                                        <TextBlock Text="Core Parking"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FFFFFF"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Limit the number of active CPU cores system-wide"
                                                   FontSize="11"
                                                   Foreground="#888888"
                                                   Margin="0,0,0,8"/>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Active Cores"
                                                           FontSize="14"
                                                           Foreground="#FFFFFF"/>
                                                <TextBlock x:Name="CoreParkingDescription"
                                                           Text="All cores active"
                                                           FontSize="11"
                                                           Foreground="#888888"/>
                                            </StackPanel>
                                            <ComboBox x:Name="CoreParkingComboBox"
                                                      Grid.Column="1"
                                                      Width="100"
                                                      SelectionChanged="CoreParkingComboBox_SelectionChanged"
                                                      UseSystemFocusVisuals="True"
                                                      FocusVisualPrimaryBrush="White">
                                                <!-- Items populated dynamically based on CPU core count -->
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Core Affinity Section (for hybrid CPUs - also sets parking) -->
                                    <StackPanel x:Name="CoreAffinitySection" Visibility="Collapsed">
                                        <TextBlock Text="Core Affinity &amp; Parking"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FFFFFF"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Set game affinity and park unused cores (hybrid CPU)"
                                                   FontSize="11"
                                                   Foreground="#888888"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8"/>

                                        <!-- P-Core Affinity -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Performance Cores"
                                                           FontSize="14"
                                                           Foreground="#FFFFFF"/>
                                                <TextBlock Text="Zen 5 high-performance cores"
                                                           FontSize="11"
                                                           Foreground="#888888"/>
                                            </StackPanel>
                                            <ComboBox x:Name="PCoreCountComboBox"
                                                      Grid.Column="1"
                                                      Width="80"
                                                      SelectionChanged="PCoreCountComboBox_SelectionChanged"
                                                      UseSystemFocusVisuals="True"
                                                      FocusVisualPrimaryBrush="White">
                                                <ComboBoxItem Content="0" Tag="0"/>
                                                <ComboBoxItem Content="1" Tag="1"/>
                                                <ComboBoxItem Content="2" Tag="2"/>
                                                <ComboBoxItem Content="3" Tag="3" IsSelected="True"/>
                                            </ComboBox>
                                        </Grid>

                                        <!-- E-Core Affinity -->
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Efficiency Cores"
                                                           FontSize="14"
                                                           Foreground="#FFFFFF"/>
                                                <TextBlock Text="Zen 5c power-efficient cores"
                                                           FontSize="11"
                                                           Foreground="#888888"/>
                                            </StackPanel>
                                            <ComboBox x:Name="ECoreCountComboBox"
                                                      Grid.Column="1"
                                                      Width="80"
                                                      SelectionChanged="ECoreCountComboBox_SelectionChanged"
                                                      UseSystemFocusVisuals="True"
                                                      FocusVisualPrimaryBrush="White">
                                                <ComboBoxItem Content="0" Tag="0"/>
                                                <ComboBoxItem Content="1" Tag="1"/>
                                                <ComboBoxItem Content="2" Tag="2"/>
                                                <ComboBoxItem Content="3" Tag="3"/>
                                                <ComboBoxItem Content="4" Tag="4"/>
                                                <ComboBoxItem Content="5" Tag="5" IsSelected="True"/>
                                            </ComboBox>
                                        </Grid>

                                        <!-- Info text -->
                                        <TextBlock Text="Note: Affinity is applied only to the detected running game process."
                                                   FontSize="11"
                                                   Foreground="#888888"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <!-- Force Park Mode (Aggressive) -->
                                    <StackPanel Margin="0,16,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Force Park Mode"
                                                           FontSize="14"
                                                           Foreground="#FFFFFF"/>
                                                <TextBlock Text="Force system processes to parked cores"
                                                           FontSize="11"
                                                           Foreground="#888888"/>
                                            </StackPanel>
                                            <ToggleSwitch x:Name="ForceParkModeToggle"
                                                          Grid.Column="1"
                                                          Style="{StaticResource ModernToggleStyle}"
                                                          Toggled="ForceParkModeToggle_Toggled"/>
                                        </Grid>
                                        <Border Background="#442200"
                                                CornerRadius="4"
                                                Padding="8"
                                                Margin="0,8,0,0"
                                                Visibility="{Binding ElementName=ForceParkModeToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <StackPanel>
                                                <TextBlock Text="⚠ Warning"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FFAA00"/>
                                                <TextBlock Text="This applies affinity to ALL running processes, forcing them onto selected cores. May cause system instability or slowdowns. Disable if you experience issues."
                                                           FontSize="11"
                                                           Foreground="#FFCC66"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- GAME TAB -->
                <ScrollViewer x:Name="GameScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Power Source Profile Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Power Source Profile" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Separate profiles for AC (plugged in) and DC (battery)"
                                               Style="{StaticResource CardCaptionStyle}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="PowerSourceProfileToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}" Width="47"
                                              XYFocusUp="{x:Bind ProfilesNavItem}"
                                              XYFocusDown="{x:Bind ProfileSettingsExpandToggle}"/>
                            </Grid>
                        </Border>

                        <!-- Game Detection Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Game Detection"
                                                   Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Games with profiles always detect regardless of settings"
                                                   Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="ProfileDetectionExpandToggle"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="ProfileDetectionExpandToggle_Click">
                                        <FontIcon x:Name="ProfileDetectionExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <StackPanel x:Name="ProfileDetectionContent" Visibility="Collapsed" Margin="0,12,0,0" Spacing="12">

                                    <!-- Match Exe Toggle -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Prefer executable"
                                                       FontSize="12"
                                                       Foreground="#FFFFFF"/>
                                            <TextBlock Text="Use .exe name, fall back to window title if unavailable"
                                                       FontSize="11"
                                                       Foreground="#888888"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="ProfileMatchByExeToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"/>
                                    </Grid>

                                    <!-- Games Only Toggle -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Games only"
                                                       FontSize="12"
                                                       Foreground="#FFFFFF"/>
                                            <TextBlock Text="Detect apps with FPS (RTSS) or added to Xbox Game Bar"
                                                       FontSize="11"
                                                       Foreground="#888888"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="ProfileGamesOnlyToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      IsOn="True"/>
                                    </Grid>

                                    <!-- COMMENTED OUT: Current Apps, Custom Games, and Blacklist sections
                                         These features caused user confusion and are disabled for now.

                                    <StackPanel>
                                        <TextBlock Text="Current apps"
                                                   FontSize="11"
                                                   Foreground="#888888"
                                                   Margin="0,0,0,4"/>
                                        <StackPanel x:Name="ForegroundAppsContainer" Spacing="4">
                                            <TextBlock x:Name="ForegroundAppsEmptyText"
                                                       Text="No apps detected"
                                                       FontSize="11"
                                                       Foreground="#666666"
                                                       FontStyle="Italic"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="Custom games"
                                                   FontSize="12"
                                                   Foreground="#FFFFFF"/>
                                        <TextBlock Text="Apps always treated as games"
                                                   FontSize="11"
                                                   Foreground="#888888"/>
                                        <TextBlock x:Name="CustomGamesEmptyText"
                                                   Text="No custom games added"
                                                   FontSize="11"
                                                   Foreground="#666666"
                                                   FontStyle="Italic"
                                                   Margin="0,8,0,0"/>
                                        <ItemsControl x:Name="CustomGamesList" Margin="0,4,0,0">
                                            ...
                                        </ItemsControl>
                                    </StackPanel>

                                    <StackPanel>
                                        <TextBlock Text="Blacklist"
                                                   FontSize="12"
                                                   Foreground="#FFFFFF"/>
                                        <TextBlock Text="Apps never treated as games"
                                                   FontSize="11"
                                                   Foreground="#888888"/>
                                        <TextBlock x:Name="BlacklistEmptyText"
                                                   Text="No apps blacklisted"
                                                   FontSize="11"
                                                   Foreground="#666666"
                                                   FontStyle="Italic"
                                                   Margin="0,8,0,0"/>
                                        <ItemsControl x:Name="BlacklistList" Margin="0,4,0,0">
                                            ...
                                        </ItemsControl>
                                    </StackPanel>

                                    END COMMENTED OUT -->

                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Profile Settings Card (Collapsible) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header with Expand/Collapse -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Profile Settings" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Choose which settings are saved in profiles"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="ProfileSettingsExpandToggle"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="ProfileSettingsExpandToggle_Click">
                                        <FontIcon x:Name="ProfileSettingsExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <!-- Collapsible Content -->
                                <StackPanel x:Name="ProfileSettingsContent" Visibility="Collapsed" Margin="0,12,0,0">
                                    <CheckBox x:Name="ProfileSaveTDPCheckBox"
                                              Content="TDP Power Limit"
                                              IsChecked="True"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveCPUBoostCheckBox"
                                              Content="CPU Boost"
                                              IsChecked="True"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveCPUEPPCheckBox"
                                              Content="CPU EPP"
                                              IsChecked="True"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveCPUStateCheckBox"
                                              Content="CPU State"
                                              IsChecked="True"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveAMDFeaturesCheckBox"
                                              Content="AMD Features (FMF, Anti-Lag, Boost, Chill)"
                                              IsChecked="False"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveFPSLimitCheckBox"
                                              Content="FPS Limit"
                                              IsChecked="True"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveAutoTDPCheckBox"
                                              Content="AutoTDP (Enabled + Target FPS)"
                                              IsChecked="True"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveOSPowerModeCheckBox"
                                              Content="OS Power Mode"
                                              IsChecked="True"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveHDRCheckBox"
                                              Content="HDR"
                                              IsChecked="False"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
                                              Checked="ProfileSettingsCheckBox_Changed"
                                              Unchecked="ProfileSettingsCheckBox_Changed"/>
                                    <CheckBox x:Name="ProfileSaveResolutionCheckBox"
                                              Content="Resolution"
                                              IsChecked="False"
                                              Foreground="#FFFFFF"
                                              Margin="0,4,0,0"
                                              Style="{StaticResource FocusableCheckBoxStyle}"
