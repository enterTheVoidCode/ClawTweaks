                                        </Grid>

                                        <!-- Restore Defaults Button -->
                                        <Button x:Name="GPDRestoreDefaultsButton"
                                                Content="Restore Defaults"
                                                HorizontalAlignment="Stretch"
                                                Style="{StaticResource StandaloneButtonStyle}"
                                                Margin="0,8,0,0"
                                                Click="GPDRestoreDefaultsButton_Click"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- Connection Status Banner - placed last for z-order (renders on top) -->
                <!-- Visible by default with Loading... so user sees immediate feedback before code runs -->
                <Border x:Name="ConnectionStatusBanner"
                        Background="#3366CC"
                        Padding="8,4"
                        VerticalAlignment="Top"
                        Visibility="Visible"
                        CornerRadius="0"
                        Margin="0,0,0,0">
                    <TextBlock x:Name="ConnectionStatusText"
                               Text="Loading..."
                               Foreground="White"
                               FontSize="12"
                               HorizontalAlignment="Center"/>
                </Border>

                <!-- Update Available Banner - appears below connection banner when update is found -->
                <Border x:Name="UpdateAvailableBanner"
                        Background="#2D7D2D"
                        Padding="8,6"
                        VerticalAlignment="Top"
                        Visibility="Collapsed"
                        CornerRadius="0"
                        Margin="0,24,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="UpdateAvailableText"
                                   Text="Update Available: v0.0.0"
                                   Foreground="White"
                                   FontSize="12"
                                   VerticalAlignment="Center"
                                   Grid.Column="0"
                                   Margin="8,0,0,0"/>
                        <Button x:Name="UpdateBannerButton"
                                Content="Update"
                                Grid.Column="1"
                                Padding="12,2"
                                FontSize="11"
                                Background="#3D9D3D"
                                Foreground="White"
                                Margin="8,0,0,0"
                                Click="UpdateBannerButton_Click"/>
                        <Button x:Name="DismissUpdateBannerButton"
                                Content="&#xE711;"
                                FontFamily="Segoe MDL2 Assets"
                                Grid.Column="2"
                                Padding="6,2"
                                FontSize="10"
                                Background="Transparent"
                                Foreground="#AAFFAA"
                                Margin="4,0,4,0"
                                Click="DismissUpdateBannerButton_Click"/>
                    </Grid>
                </Border>

            </Grid>
            </Grid> <!-- End Content Area Grid.Row="1" -->
        </Grid> <!-- End MainNavContainer -->
    </Grid>
</Page>
