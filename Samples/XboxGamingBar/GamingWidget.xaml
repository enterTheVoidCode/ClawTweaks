                                        <TextBlock Grid.Row="10" Grid.Column="2" x:Name="GameDCProfileHDRText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>

                                        <!-- Resolution Row -->
                                        <TextBlock Grid.Row="11" Grid.Column="0" x:Name="GameACDCProfileResolutionLabel" Text="Res" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="11" Grid.Column="1" x:Name="GameACProfileResolutionText" Text="Native" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="11" Grid.Column="2" x:Name="GameDCProfileResolutionText" Text="Native" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>

                                        <!-- Sticky TDP Row -->
                                        <TextBlock Grid.Row="12" Grid.Column="0" x:Name="GameACDCProfileStickyTDPLabel" Text="Sticky" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="12" Grid.Column="1" x:Name="GameACProfileStickyTDPText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="12" Grid.Column="2" x:Name="GameDCProfileStickyTDPText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center" Visibility="Collapsed"/>

                                    </Grid>
                                </StackPanel>

                                <!-- Game Profile without Power Source -->
                                <StackPanel x:Name="GameProfileWithoutPowerSource" Visibility="Collapsed">
                                    <TextBlock x:Name="GameProfileTitleNoPower"
                                               Text="Game"
                                               Style="{StaticResource CardTitleStyle}"
                                               Foreground="#FFA500"
                                               FontSize="14"/>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" x:Name="GameProfileTDPModeLabel" Text="TDP Mode" FontSize="11" Foreground="#AAAAAA" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="GameProfileTDPModeText" Text="Balanced" FontSize="11" Foreground="#FFFFFF" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" x:Name="GameProfileTDPLabel" Text="TDP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="GameProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" x:Name="GameProfileTDPBoostLabel" Text="TDP Boost" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="GameProfileTDPBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" x:Name="GameProfileCPUBoostLabel" Text="CPU Boost" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="GameProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" x:Name="GameProfileCPUEPPLabel" Text="CPU EPP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="GameProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" x:Name="GameProfileCPUStateLabel" Text="CPU State" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="GameProfileCPUStateText" Text="5-100%" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="6" Grid.Column="0" x:Name="GameProfileFPSLimitLabel" Text="FPS Limit" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="6" Grid.Column="1" x:Name="GameProfileFPSLimitText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="7" Grid.Column="0" x:Name="GameProfileAutoTDPLabel" Text="AutoTDP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="7" Grid.Column="1" x:Name="GameProfileAutoTDPText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="8" Grid.Column="0" x:Name="GameProfilePowerModeLabel" Text="Power Mode" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="8" Grid.Column="1" x:Name="GameProfilePowerModeText" Text="Balanced" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="9" Grid.Column="0" x:Name="GameProfileAMDLabel" Text="AMD" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="9" Grid.Column="1" x:Name="GameProfileAMDText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="10" Grid.Column="0" x:Name="GameProfileHDRLabel" Text="HDR" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="10" Grid.Column="1" x:Name="GameProfileHDRText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="11" Grid.Column="0" x:Name="GameProfileResolutionLabel" Text="Resolution" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="11" Grid.Column="1" x:Name="GameProfileResolutionText" Text="Native" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>

                                        <TextBlock Grid.Row="12" Grid.Column="0" x:Name="GameProfileStickyTDPLabel" Text="Sticky TDP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0" Visibility="Collapsed"/>
                                        <TextBlock Grid.Row="12" Grid.Column="1" x:Name="GameProfileStickyTDPText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" Visibility="Collapsed"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Saved Profiles Section -->
                        <TextBlock Text="Saved Profiles"
                                   FontSize="16"
                                   Foreground="#00C8FF"
                                   FontWeight="SemiBold"
                                   Margin="0,24,0,8"/>

                        <!-- Container for dynamically created game profile cards -->
                        <StackPanel x:Name="AllGameProfilesContainer"/>

                    </StackPanel>
                </ScrollViewer>

                <!-- GRAPHICS TAB -->
                <ScrollViewer x:Name="AMDScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Resolution Card -->
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Resolution"
                                           Style="{StaticResource CardTitleStyle}"
                                           VerticalAlignment="Center"
                                           Grid.Column="0"/>
                                <ComboBox x:Name="ResolutionComboBox"
                                          PlaceholderText="1920x1080"
                                          Width="150"
                                          Grid.Column="1"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          XYFocusUp="{x:Bind GraphicsNavItem}">
                                    <x:String>1920x1080</x:String>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Refresh Rate Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Refresh Rate"
                                           Style="{StaticResource CardTitleStyle}"
                                           VerticalAlignment="Center"
                                           Grid.Column="0"/>
                                <ComboBox x:Name="RefreshRatesComboBox"
                                          PlaceholderText="60 Hz"
                                          Width="120"
                                          Grid.Column="1"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          XYFocusUp="{x:Bind GraphicsNavItem}">
                                    <x:String>60 Hz</x:String>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- HDR Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="HDR" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="High Dynamic Range" Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="HDRToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsEnabled="False"/>
                            </Grid>
                        </Border>

                        <!-- Adaptive Brightness Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Adaptive Brightness" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Auto-adjust based on ambient light (requires sensor)" Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="AdaptiveBrightnessToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              Toggled="AdaptiveBrightnessToggle_Toggled"/>
                            </Grid>
                        </Border>

                        <!-- Display Color Settings Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Color Settings" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Adjust display color output" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <Button x:Name="ColorSettingsExpandButton"
                                            Grid.Column="1"
                                            Content="&#xE70D;"
                                            FontFamily="Segoe MDL2 Assets"
                                            FontSize="12"
                                            Padding="8,4"
                                            Background="Transparent"
                                            Click="ColorSettingsExpandButton_Click"
                                            UseSystemFocusVisuals="True"
                                            FocusVisualPrimaryBrush="White"/>
                                </Grid>
                                <StackPanel x:Name="ColorSettingsContent" Visibility="Collapsed" Margin="0,10,0,0">
                                    <Slider x:Name="AMDDisplayBrightnessSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="-100" Maximum="100"
                                            StepFrequency="1"
                                            Header="Brightness"
                                            IsEnabled="False"/>
                                    <Slider x:Name="AMDDisplayContrastSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="200"
                                            StepFrequency="1"
                                            Header="Contrast"
                                            IsEnabled="False"/>
                                    <Slider x:Name="AMDDisplaySaturationSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="200"
                                            StepFrequency="1"
                                            Header="Saturation"
                                            IsEnabled="False"/>
                                    <Slider x:Name="AMDDisplayTemperatureSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="4000" Maximum="10000"
                                            StepFrequency="100"
                                            Header="Color Temperature (K)"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- AMD Section Header -->
                        <TextBlock Text="AMD"
                                   FontSize="16"
                                   Foreground="#00C8FF"
                                   FontWeight="SemiBold"
                                   Margin="0,16,0,8"/>

                        <!-- Radeon Super Resolution Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Radeon Super Resolution" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Upscales lower resolutions" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AMDRadeonSuperResolutionToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                                <Slider x:Name="AMDRadeonSuperResolutionSharpnessSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="100"
                                        TickFrequency="10"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        Header="Sharpness"
                                        IsEnabled="False"
                                        Visibility="{Binding ElementName=AMDRadeonSuperResolutionToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- Fluid Motion Frames Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Fluid Motion Frames" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Frame generation" Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="AMDFluidMotionFrameToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsEnabled="False"/>
                            </Grid>
                        </Border>

                        <!-- Anti-Lag Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Radeon Anti-Lag" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Reduces input latency" Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="AMDRadeonAntiLagToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsEnabled="False"/>
                            </Grid>
                        </Border>

                        <!-- Radeon Boost Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Radeon Boost" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Dynamic resolution scaling" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AMDRadeonBoostToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False" Width="52" HorizontalAlignment="Center"/>
                                </Grid>
                                <Slider x:Name="AMDRadeonBoostResolutionSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="1"
                                        TickFrequency="1"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"
                                        Visibility="{Binding ElementName=AMDRadeonBoostToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- Radeon Chill Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Radeon Chill" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Power saving when idle" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AMDRadeonChillToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                                <StackPanel Visibility="{Binding ElementName=AMDRadeonChillToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Slider x:Name="AMDRadeonChillMinFPSSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="30" Maximum="300"
                                            TickFrequency="10"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            Header="Min FPS"
                                            IsEnabled="False"/>
                                    <Slider x:Name="AMDRadeonChillMaxFPSSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="30" Maximum="300"
                                            TickFrequency="10"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            Header="Max FPS"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Image Sharpening Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Image Sharpening" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Sharpen in-game visuals" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AMDImageSharpeningToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                                <Slider x:Name="AMDImageSharpeningSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="100"
                                        TickFrequency="10"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        Header="Sharpness"
                                        IsEnabled="False"
                                        Visibility="{Binding ElementName=AMDImageSharpeningToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>


                    </StackPanel>
                </ScrollViewer>

                <!-- SYSTEM TAB -->
                <ScrollViewer x:Name="SystemScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- TDP Settings Card (Collapsible - consolidates Control Method, Device Limits, and Boost Settings) -->
                        <Border x:Name="TdpMethodCard" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header with Expand/Collapse -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="TDP Settings" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Control method, device limits, and boost configuration"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="TDPSettingsExpandButton"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="TDPSettingsExpandButton_Click"
                                                  XYFocusUp="{x:Bind SystemNavItem}"
                                                  XYFocusDown="{x:Bind OSDCustomizeExpandButton}"
                                                  UseSystemFocusVisuals="True">
                                        <FontIcon x:Name="TDPSettingsExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <!-- Collapsible Content -->
                                <StackPanel x:Name="TDPSettingsContent" Visibility="Collapsed" Margin="0,12,0,0">

                                    <!-- TDP Control Method Section -->
                                    <TextBlock Text="Control Method" FontSize="13" FontWeight="SemiBold" Foreground="#AAAAAA" Margin="0,0,0,8"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock x:Name="TdpMethodDescription"
                                                       Text="PawnIO is anti-cheat safe and enables full OSD sensor support."
                                                       Style="{StaticResource CardCaptionStyle}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <ComboBox x:Name="TdpMethodComboBox"
                                                  Width="160"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  XYFocusUp="{x:Bind TDPSettingsExpandButton}"
                                                  XYFocusDown="{x:Bind InstallPawnIOButton}">
                                            <ComboBoxItem x:Name="TdpMethodWmiItem" Content="Manufacturer WMI" Tag="ManufacturerWMI" Visibility="Collapsed"/>
                                            <ComboBoxItem x:Name="TdpMethodPawnIOItem" Content="PawnIO" Tag="PawnIO"/>
                                            <ComboBoxItem x:Name="TdpMethodWinRing0Item" Content="WinRing0 (Legacy)" Tag="WinRing0"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- PawnIO Install Section -->
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="PawnIO Driver" FontSize="14" Foreground="White"/>
                                            <TextBlock x:Name="PawnIOStatusText"
                                                       Text="Signed kernel driver for hardware access"
                                                       Style="{StaticResource CardCaptionStyle}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <Button x:Name="InstallPawnIOButton"
                                                Grid.Column="1"
                                                Content="Install"
                                                Style="{StaticResource ModernButtonStyle}"
                                                Click="InstallPawnIOButton_Click"
                                                XYFocusUp="{x:Bind TdpMethodComboBox}"
                                                XYFocusDown="{x:Bind TDPLimitsMinSlider}"/>
                                    </Grid>

                                    <!-- Separator -->
                                    <Border Height="1" Background="#3A3A3A" Margin="0,16,0,16"/>

                                    <!-- Device TDP Limits Section -->
                                    <TextBlock Text="Device TDP Limits" FontSize="13" FontWeight="SemiBold" Foreground="#AAAAAA" Margin="0,0,0,8"/>

                                    <!-- Warning -->
                                    <Border Background="#3D2A1A" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE7BA;"
                                                       Grid.Column="0"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="16"
                                                       Foreground="#FFA500"
                                                       VerticalAlignment="Top"
                                                       Margin="0,2,8,0"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="Increasing TDP beyond your device's thermal limits may cause overheating or throttling."
                                                       Foreground="#FFB74D"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>

                                    <!-- Minimum TDP -->
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Minimum TDP"
                                                   FontSize="14"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TDPLimitsMinValue"
                                                   Text="4W"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="TDPLimitsMinSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="4" Maximum="85"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            Value="4"
                                            ValueChanged="TDPLimitsMinSlider_ValueChanged"
                                            XYFocusUp="{x:Bind InstallPawnIOButton}"
                                            XYFocusDown="{x:Bind TDPLimitsMaxSlider}"
                                            />

                                    <!-- Maximum TDP -->
                                    <Grid Margin="0,12,0,8">
                                        <TextBlock Text="Maximum TDP"
                                                   FontSize="14"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TDPLimitsMaxValue"
                                                   Text="35W"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="TDPLimitsMaxSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="4" Maximum="85"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            Value="35"
                                            ValueChanged="TDPLimitsMaxSlider_ValueChanged"
                                            XYFocusUp="{x:Bind TDPLimitsMinSlider}"
                                            XYFocusDown="{x:Bind TDPBoostSPPTSlider}"
                                            />

                                    <!-- Separator -->
                                    <Border Height="1" Background="#3A3A3A" Margin="0,16,0,16"/>

                                    <!-- TDP Boost Settings Section -->
                                    <TextBlock Text="TDP Boost Settings" FontSize="13" FontWeight="SemiBold" Foreground="#AAAAAA" Margin="0,0,0,8"/>

                                    <!-- Info -->
                                    <Border Background="#1A2A3D" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE946;"
                                                       Grid.Column="0"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="16"
                                                       Foreground="#4CAF50"
                                                       VerticalAlignment="Top"
                                                       Margin="0,2,8,0"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="When TDP Boost is enabled, SPPT and FPPT will be set to TDP + boost value for short bursts of higher power."
                                                       Foreground="#A0D4A0"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>

                                    <!-- SPPT Boost -->
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="SPPT Boost"
                                                   FontSize="14"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TDPBoostSPPTValue"
                                                   Text="1W"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="TDPBoostSPPTSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="10"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            ValueChanged="TDPBoostSPPTSlider_ValueChanged"
                                            XYFocusUp="{x:Bind TDPLimitsMaxSlider}"
                                            XYFocusDown="{x:Bind TDPBoostFPPTSlider}"
                                            />

                                    <!-- FPPT Boost -->
                                    <Grid Margin="0,12,0,8">
                                        <TextBlock Text="FPPT Boost"
                                                   FontSize="14"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TDPBoostFPPTValue"
                                                   Text="3W"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="TDPBoostFPPTSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="15"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            ValueChanged="TDPBoostFPPTSlider_ValueChanged"
                                            XYFocusUp="{x:Bind TDPBoostSPPTSlider}"
                                            XYFocusDown="{x:Bind UseCustomTDPPresetsToggle}"
                                            />

                                    <!-- Separator -->
                                    <Border Height="1" Background="#3A3A3A" Margin="0,16,0,16"/>

                                    <!-- Custom TDP Presets Section -->
                                    <TextBlock Text="Custom TDP Presets" FontSize="13" FontWeight="SemiBold" Foreground="#AAAAAA" Margin="0,0,0,8"/>

                                    <!-- Use Custom Presets Toggle -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Use Custom Presets" FontSize="14" Foreground="#FFFFFF"/>
                                            <TextBlock Text="Override default TDP values for modes"
                                                       FontSize="11" Foreground="#888888"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="UseCustomTDPPresetsToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      Toggled="UseCustomTDPPresetsToggle_Toggled"
                                                      XYFocusUp="{x:Bind TDPBoostFPPTSlider}"/>
                                    </Grid>

                                    <!-- Presets List (shown when custom presets enabled) -->
                                    <StackPanel x:Name="TDPPresetsListPanel" Spacing="8" Visibility="Collapsed" Margin="0,12,0,0">
                                        <!-- Use Lenovo Modes checkbox (Legion devices only) -->
                                        <Grid x:Name="UseLenovoModesPanel" Visibility="Collapsed" Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Use Lenovo Modes" FontSize="13" Foreground="#FFFFFF"/>
                                                <TextBlock Text="Use hardware modes for Quiet/Balanced/Performance"
                                                           FontSize="11" Foreground="#888888"/>
                                            </StackPanel>
                                            <ToggleSwitch x:Name="UseLenovoModesToggle"
                                                          Grid.Column="1"
                                                          IsOn="True"
                                                          Style="{StaticResource ModernToggleStyle}"
                                                          Toggled="UseLenovoModesToggle_Toggled"/>
                                        </Grid>
                                        <!-- Preset items will be dynamically generated -->
                                        <ItemsControl x:Name="TDPPresetsItemsControl">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,4">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="60"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Name}"
                                                                   FontSize="14"
                                                                   Foreground="#FFFFFF"
                                                                   VerticalAlignment="Center"/>
                                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding TdpWatts}"
                                                                       FontSize="14"
                                                                       Foreground="#4CAF50"
                                                                       FontWeight="SemiBold"/>
                                                            <TextBlock Text="W"
                                                                       FontSize="14"
                                                                       Foreground="#4CAF50"
                                                                       FontWeight="SemiBold"
                                                                       Margin="2,0,0,0"/>
                                                        </StackPanel>
                                                        <Button Grid.Column="2"
                                                                Content="Edit"
                                                                FontSize="12"
                                                                Padding="8,4"
                                                                Margin="4,0"
                                                                Background="#2A2A2A"
                                                                Foreground="#FFFFFF"
                                                                Click="TDPPresetEditButton_Click"
                                                                Tag="{Binding}"/>
                                                        <Button Grid.Column="3"
                                                                FontSize="12"
                                                                Padding="8,4"
                                                                Background="#2A2A2A"
                                                                Click="TDPPresetDeleteButton_Click"
                                                                Tag="{Binding}"
                                                                Visibility="{Binding IsBuiltIn, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                                                            <FontIcon Glyph="&#xE74D;" FontSize="12" Foreground="#FF6B6B"/>
                                                        </Button>
                                                        <TextBlock Grid.Column="3"
                                                                   Text="Default"
                                                                   FontSize="11"
                                                                   Foreground="#888888"
                                                                   VerticalAlignment="Center"
                                                                   Margin="8,0"
                                                                   Visibility="{Binding IsBuiltIn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Add Preset Section -->
                                        <Border Background="#1A1A1A" CornerRadius="4" Padding="12" Margin="0,8,0,0">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="Add New Preset" FontSize="13" Foreground="#A0A0A0"/>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="80"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBox x:Name="NewPresetNameTextBox"
                                                             Grid.Column="0"
                                                             PlaceholderText="Preset name"
                                                             FontSize="13"
                                                             Padding="8,6"
                                                             Margin="0,0,8,0"/>
                                                    <muxc:NumberBox x:Name="NewPresetTDPNumberBox"
                                                               Grid.Column="1"
                                                               Value="30"
                                                               Minimum="4"
                                                               Maximum="100"
                                                               SpinButtonPlacementMode="Compact"
                                                               FontSize="13"/>
                                                </Grid>
                                                <CheckBox x:Name="NewPresetTDPBoostCheckBox"
                                                          Content="Enable TDP Boost"
                                                          FontSize="13"
                                                          Foreground="#FFFFFF"/>
                                                <Button x:Name="AddPresetButton"
                                                        Content="Add Preset"
                                                        FontSize="13"
                                                        Padding="16,6"
                                                        HorizontalAlignment="Left"
                                                        Background="#4CAF50"
                                                        Foreground="#FFFFFF"
                                                        Click="AddPresetButton_Click"/>
                                            </StackPanel>
                                        </Border>

                                        <!-- Reset to Defaults Button -->
                                        <Button x:Name="ResetTDPPresetsButton"
                                                Content="Reset to Defaults"
                                                FontSize="12"
                                                Padding="12,6"
                                                HorizontalAlignment="Left"
                                                Background="#2A2A2A"
                                                Foreground="#A0A0A0"
                                                Click="ResetTDPPresetsButton_Click"/>
                                    </StackPanel>

                                    <!-- Edit Preset Dialog (inline, hidden by default) -->
                                    <Border x:Name="EditPresetDialog"
                                            Background="#252525"
                                            CornerRadius="4"
                                            Padding="12"
                                            Margin="0,12,0,0"
                                            Visibility="Collapsed">
                                        <StackPanel Spacing="12">
                                            <TextBlock Text="Edit Preset" FontSize="14" FontWeight="SemiBold" Foreground="#FFFFFF"/>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="Name:" FontSize="14" Foreground="#A0A0A0" VerticalAlignment="Center"/>
                                                <TextBox x:Name="EditPresetNameTextBox"
                                                         Grid.Column="1"
                                                         FontSize="13"
                                                         Padding="8,6"/>
                                            </Grid>
                                            <Grid x:Name="EditPresetTDPPanel">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="TDP (W):" FontSize="14" Foreground="#A0A0A0" VerticalAlignment="Center"/>
                                                <muxc:NumberBox x:Name="EditPresetTDPNumberBox"
                                                           Grid.Column="1"
                                                           Minimum="4"
                                                           Maximum="100"
                                                           SpinButtonPlacementMode="Compact"
                                                           FontSize="13"/>
                                            </Grid>
                                            <Grid x:Name="EditPresetTDPBoostPanel">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="TDP Boost:" FontSize="14" Foreground="#A0A0A0" VerticalAlignment="Center"/>
                                                <CheckBox x:Name="EditPresetTDPBoostCheckBox"
                                                          Grid.Column="1"
                                                          Content="Enable TDP Boost"
                                                          FontSize="13"
                                                          Foreground="#FFFFFF"/>
                                            </Grid>
                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                                <Button Content="Cancel"
                                                        FontSize="13"
                                                        Padding="16,6"
                                                        Background="#2A2A2A"
                                                        Foreground="#A0A0A0"
                                                        Click="EditPresetCancelButton_Click"/>
                                                <Button Content="Save"
                                                        FontSize="13"
                                                        Padding="16,6"
                                                        Background="#4CAF50"
                                                        Foreground="#FFFFFF"
                                                        Click="EditPresetSaveButton_Click"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- OSD Customization Card (Collapsible) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header with Expand/Collapse -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="OSD Customization" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Customize overlay appearance and content"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleButton x:Name="OSDCustomizeExpandButton"
                                                  Grid.Column="1"
                                                  IsChecked="False"
                                                  VerticalAlignment="Center"
                                                  Background="Transparent"
                                                  BorderThickness="0"
                                                  Padding="8,4"
                                                  Click="OSDCustomizeExpandButton_Click"
                                                  XYFocusUp="{x:Bind TDPSettingsExpandButton}"
                                                  XYFocusDown="{x:Bind HotkeysExpandButton}"
                                                  UseSystemFocusVisuals="True">
                                        <FontIcon x:Name="OSDCustomizeExpandIcon" Glyph="&#xE70D;" FontSize="12"/>
                                    </ToggleButton>
                                </Grid>

                                <!-- Collapsible Content -->
                                <StackPanel x:Name="OSDCustomizeContent" Visibility="Collapsed" Margin="0,12,0,0">

                                    <!-- OSD Provider Selection -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="OSD Provider"
                                                       Foreground="#FFFFFF"
                                                       VerticalAlignment="Center"
                                                       FontSize="14"/>
                                            <TextBlock Text="Select overlay source"
                                                       Foreground="#707070"
                                                       FontSize="11"/>
                                        </StackPanel>
                                        <ComboBox x:Name="OSDProviderComboBox"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  Width="120"
                                                  Grid.Column="1"
                                                  SelectionChanged="OSDProviderComboBox_SelectionChanged"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent">
                                            <ComboBoxItem Content="RTSS" Tag="0" IsSelected="True"/>
                                            <ComboBoxItem Content="AMD" Tag="1"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- RTSS-specific options (hidden when AMD provider is selected) -->
                                    <StackPanel x:Name="RTSSOptionsPanel">
                                        <!-- Overlay Level Selection -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Overlay Level"
                                                       Foreground="#FFFFFF"
                                                       VerticalAlignment="Center"
                                                       FontSize="14"/>
                                            <ComboBox x:Name="OSDCustomizeLevelComboBox"
                                                      Style="{StaticResource ModernComboBoxStyle}"
                                                      Width="120"
                                                      Grid.Column="1"
                                                      SelectionChanged="OSDCustomizeLevelComboBox_SelectionChanged"
                                                      UseSystemFocusVisuals="True"
                                                      FocusVisualPrimaryBrush="White"
                                                      FocusVisualSecondaryBrush="Transparent">
                                                <ComboBoxItem Content="Basic" Tag="1" IsSelected="True"/>
                                                <ComboBoxItem Content="Detailed" Tag="2"/>
                                                <ComboBoxItem Content="Full" Tag="3"/>
                                            </ComboBox>
                                        </Grid>

                                        <!-- Layout Settings Section -->
                                    <TextBlock Text="Layout"
                                               Style="{StaticResource CardTitleStyle}"
                                               Margin="0,0,0,8"/>

                                    <!-- Columns -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Columns"
                                                       Foreground="#B0B0B0"
                                                       FontSize="13"/>
                                            <TextBlock Text="Items per row (1 = vertical list)"
                                                       Foreground="#707070"
                                                       FontSize="11"/>
                                        </StackPanel>
                                        <ComboBox x:Name="OSDColumnsComboBox"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  Width="80"
                                                  Grid.Column="1"
                                                  SelectionChanged="OSDLayoutOption_Changed"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White">
                                            <ComboBoxItem Content="1" Tag="1"/>
                                            <ComboBoxItem Content="2" Tag="2"/>
                                            <ComboBoxItem Content="3" Tag="3" IsSelected="True"/>
                                            <ComboBoxItem Content="4" Tag="4"/>
                                            <ComboBoxItem Content="5" Tag="5"/>
                                            <ComboBoxItem Content="6" Tag="6"/>
                                            <ComboBoxItem Content="7" Tag="7"/>
                                            <ComboBoxItem Content="8" Tag="8"/>
                                            <ComboBoxItem Content="9" Tag="9"/>
                                            <ComboBoxItem Content="10" Tag="10"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Text Size -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Text Size"
                                                   Foreground="#B0B0B0"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"/>
                                        <ComboBox x:Name="OSDTextSizeComboBox"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  Width="100"
                                                  Grid.Column="1"
                                                  SelectionChanged="OSDLayoutOption_Changed"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White">
                                            <ComboBoxItem Content="Small" Tag="50"/>
                                            <ComboBoxItem Content="Medium" Tag="100" IsSelected="True"/>
                                            <ComboBoxItem Content="Large" Tag="150"/>
                                            <ComboBoxItem Content="X-Large" Tag="200"/>
                                            <ComboBoxItem Content="XX-Large" Tag="250"/>
                                            <ComboBoxItem Content="XXX-Large" Tag="300"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Colors Section -->
                                    <TextBlock Text="Colors"
                                               Style="{StaticResource CardTitleStyle}"
                                               Margin="0,12,0,8"/>

                                    <!-- Text Color -->
                                    <StackPanel x:Name="OSDTextColorCard" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Text Color" Grid.Column="0" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="13"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <CheckBox x:Name="OSDTextColorDynamicCheckBox"
                                                          Content="Dynamic"
                                                          IsChecked="True"
                                                          Foreground="#AAAAAA"
                                                          FontSize="11"
                                                          Margin="0,0,8,0"
                                                          Checked="OSDTextColorDynamic_Changed"
                                                          Unchecked="OSDTextColorDynamic_Changed"/>
                                                <Border x:Name="OSDTextColorPreview"
                                                        Width="24" Height="24"
                                                        CornerRadius="4"
                                                        Background="White"
                                                        BorderBrush="#50555C"
                                                        BorderThickness="1"
                                                        Margin="0,0,8,0"/>
                                                <Button x:Name="OSDTextColorExpandButton"
                                                        Content="&#xE70D;"
                                                        FontFamily="Segoe MDL2 Assets"
                                                        FontSize="12"
                                                        Padding="8,4"
                                                        Background="Transparent"
                                                        Click="OSDTextColorExpandButton_Click"
                                                        UseSystemFocusVisuals="True"
                                                        FocusVisualPrimaryBrush="White"/>
                                            </StackPanel>
                                        </Grid>
                                        <muxc:ColorPicker x:Name="OSDTextColorPicker"
                                                     Visibility="Collapsed"
                                                     Margin="0,12,0,0"
                                                     Color="White"
                                                     ColorSpectrumShape="Box"
                                                     IsMoreButtonVisible="False"
                                                     IsColorSliderVisible="False"
                                                     IsColorChannelTextInputVisible="False"
                                                     IsHexInputVisible="False"
                                                     IsAlphaEnabled="False"
                                                     IsAlphaSliderVisible="False"
                                                     IsAlphaTextInputVisible="False"
                                                     ColorChanged="OSDTextColorPicker_ColorChanged"/>
                                    </StackPanel>

                                    <!-- Label Color (Global) -->
                                    <StackPanel x:Name="OSDLabelColorCard" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Label Color" Grid.Column="0" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="13"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <CheckBox x:Name="OSDLabelColorDefaultCheckBox"
                                                          Content="Default"
                                                          IsChecked="True"
                                                          Foreground="#AAAAAA"
                                                          FontSize="11"
                                                          Margin="0,0,8,0"
                                                          Checked="OSDLabelColorDefault_Changed"
                                                          Unchecked="OSDLabelColorDefault_Changed"/>
                                                <Border x:Name="OSDLabelColorPreview"
                                                        Width="24" Height="24"
                                                        CornerRadius="4"
                                                        Background="#00FFFF"
                                                        BorderBrush="#50555C"
                                                        BorderThickness="1"
                                                        Margin="0,0,8,0"/>
                                                <Button x:Name="OSDLabelColorExpandButton"
                                                        Content="&#xE70D;"
                                                        FontFamily="Segoe MDL2 Assets"
                                                        FontSize="12"
                                                        Padding="8,4"
                                                        Background="Transparent"
                                                        Click="OSDLabelColorExpandButton_Click"
                                                        UseSystemFocusVisuals="True"
                                                        FocusVisualPrimaryBrush="White"/>
                                            </StackPanel>
                                        </Grid>
                                        <muxc:ColorPicker x:Name="OSDLabelColorPicker"
                                                     Visibility="Collapsed"
                                                     Margin="0,12,0,0"
                                                     Color="#00FFFF"
                                                     ColorSpectrumShape="Box"
                                                     IsMoreButtonVisible="False"
                                                     IsColorSliderVisible="False"
                                                     IsColorChannelTextInputVisible="False"
                                                     IsHexInputVisible="False"
                                                     IsAlphaEnabled="False"
                                                     IsAlphaSliderVisible="False"
                                                     IsAlphaTextInputVisible="False"
                                                     ColorChanged="OSDLabelColorPicker_ColorChanged"/>
                                    </StackPanel>

                                    <!-- OSD Opacity Slider (for OLED protection) -->
                                    <StackPanel Margin="0,8,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="OSD Opacity" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="13"/>
                                            <TextBlock x:Name="OSDOpacityValue"
                                                       Grid.Column="1"
                                                       Text="100%" FontSize="13" Foreground="#4CAF50"
                                                       FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        </Grid>
                                        <TextBlock Text="Reduce OSD brightness to protect OLED pixels" Foreground="#707070" FontSize="11" Margin="0,2,0,4"/>
                                        <Slider x:Name="OSDOpacitySlider"
                                                Style="{StaticResource ModernSliderStyle}"
                                                Minimum="10" Maximum="100"
                                                TickFrequency="5"
                                                SnapsTo="Ticks"
                                                Value="100"
                                                ValueChanged="OSDOpacitySlider_ValueChanged"/>
                                    </StackPanel>

                                    <!-- Position Shift Toggle (OLED burn-in protection) -->
                                    <Grid Margin="0,4,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Position Shift" Foreground="#AAAAAA" FontSize="13"/>
                                            <TextBlock Text="Shifts OSD every minute to prevent burn-in" Foreground="#707070" FontSize="11"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="OSDPositionShiftToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      Toggled="OSDPositionShiftToggle_Toggled"/>
                                    </Grid>

                                    <!-- Frametime Graph Pinned Toggle -->
                                    <Grid Margin="0,4,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Pin Frametime Graph" Foreground="#AAAAAA" FontSize="13"/>
                                            <TextBlock Text="Always display graph on its own row at bottom" Foreground="#707070" FontSize="11"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="FrametimeGraphPinnedToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      Toggled="FrametimeGraphPinnedToggle_Toggled"/>
                                    </Grid>

                                        <!-- Items Section -->
                                        <TextBlock Text="Items to Display"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   Margin="0,12,0,8"/>

                                        <!-- OSD Items with reordering -->
                                        <ItemsControl x:Name="OSDItemsControl">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,2">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>

                                                        <CheckBox Grid.Column="0"
