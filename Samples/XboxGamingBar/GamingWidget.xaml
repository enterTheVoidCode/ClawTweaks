<Page
    x:Class="XboxGamingBar.GamingWidget"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:XboxGamingBar"
    xmlns:converter="using:XboxGamingBar.Converter"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    d:DesignHeight="670" d:DesignWidth="600">

    <Page.Resources>
        <!-- Existing Converters -->
        <converter:WattStringConverter x:Key="WattStringConverter"/>
        <converter:MegahertzStringConverter x:Key="MegahertzStringConverter"/>
        <converter:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
        <converter:SharpnessPercentStringConverter x:Key="SharpnessPercentStringConverter"/>
        <converter:RadeonBoostResolutionStringConverter x:Key="RadeonBoostResolutionStringConverter"/>

        <!-- Tooth Theme Colors -->
        <SolidColorBrush x:Key="PageBackgroundBrush" Color="#25282C"/>
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#30343A"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#50555C"/>
        <SolidColorBrush x:Key="ButtonBackground" Color="#3E434B"/>
        <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#484E58"/>
        <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#3A3F47"/>
        <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="#2C3035"/>
        <SolidColorBrush x:Key="ButtonBorderBrush" Color="#6B7584"/>
        <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#6B7584"/>
        <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="#555D69"/>
        <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="#3A3F46"/>
        <CornerRadius x:Key="ControlCornerRadius">8,8,8,8</CornerRadius>
        <Thickness x:Key="ButtonPadding">15,10,15,11</Thickness>

        <!-- Card Style - Tooth Theme -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,10,0,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
        </Style>

        <!-- Navigation Item Style with Focus - Optimized for Handheld -->
        <Style x:Key="NavItemStyle" TargetType="muxc:NavigationViewItem">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FocusVisualPrimaryBrush" Value="#00C8FF"/>
            <Setter Property="FocusVisualPrimaryThickness" Value="2"/>
        </Style>

        <!-- Card Title Style - Tooth Theme -->
        <Style x:Key="CardTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <!-- Card Title Style - Compact Mode -->
        <Style x:Key="CardTitleStyleCompact" TargetType="TextBlock" BasedOn="{StaticResource CardTitleStyle}">
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <!-- Card Caption Style - Tooth Theme -->
        <Style x:Key="CardCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#A0A0A0"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <!-- Card Caption Style - Compact Mode -->
        <Style x:Key="CardCaptionStyleCompact" TargetType="TextBlock" BasedOn="{StaticResource CardCaptionStyle}">
            <Setter Property="FontSize" Value="16"/>
        </Style>

        <!-- Card Value Style -->
        <Style x:Key="CardValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#00C8FF"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Card Value Style - Compact Mode -->
        <Style x:Key="CardValueStyleCompact" TargetType="TextBlock" BasedOn="{StaticResource CardValueStyle}">
            <Setter Property="FontSize" Value="20"/>
        </Style>

        <!-- Modern Toggle Style - Simplified for proper mouse/touch support -->
        <Style x:Key="ModernToggleStyle" TargetType="ToggleSwitch">
            <Setter Property="MinWidth" Value="44"/>
            <Setter Property="MinHeight" Value="20"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="OffContent" Value=""/>
            <Setter Property="OnContent" Value=""/>
            <Setter Property="FocusVisualPrimaryBrush" Value="#00C8FF"/>
            <Setter Property="FocusVisualPrimaryThickness" Value="2"/>
        </Style>

        <!-- Modern Slider Style - WinUI 3 Style -->
        <Style x:Key="ModernSliderStyle" TargetType="Slider">
            <Setter Property="Margin" Value="0,4,0,0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="#00C8FF"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="FocusVisualPrimaryBrush" Value="#00C8FF"/>
            <Setter Property="FocusVisualPrimaryThickness" Value="2"/>
            <Setter Property="FocusVisualMargin" Value="-3"/>
            <Setter Property="UseSystemFocusVisuals" Value="True"/>
            <Setter Property="ManipulationMode" Value="None"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.Resources>
                                <Style x:Key="SliderThumbStyle" TargetType="Thumb">
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Background" Value="White"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Fill="{TemplateBinding Background}"
                                                        Width="20"
                                                        Height="20"
                                                        Stroke="#00C8FF"
                                                        StrokeThickness="2"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Grid.Resources>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid x:Name="SliderContainer" Grid.Row="1" Height="32" VerticalAlignment="Center">
                                <Grid x:Name="HorizontalTemplate">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <!-- Track Background -->
                                    <Rectangle x:Name="HorizontalTrackRect"
                                              Grid.ColumnSpan="3"
                                              Fill="#3A3A3A"
                                              Height="4"
                                              RadiusX="2"
                                              RadiusY="2"
                                              VerticalAlignment="Center"/>
                                    <!-- Filled Track -->
                                    <Rectangle x:Name="HorizontalDecreaseRect"
                                              Grid.Column="0"
                                              Fill="#00C8FF"
                                              Height="4"
                                              RadiusX="2"
                                              RadiusY="2"
                                              VerticalAlignment="Center"/>
                                    <!-- Thumb -->
                                    <Thumb x:Name="HorizontalThumb"
                                          Grid.Column="1"
                                          Style="{StaticResource SliderThumbStyle}"
                                          DataContext="{TemplateBinding Value}"
                                          Height="20"
                                          Width="20"
                                          AutomationProperties.AccessibilityView="Raw"/>
                                </Grid>
                            </Grid>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Modern ComboBox Style - Tooth Theme -->
        <Style x:Key="ModernComboBoxStyle" TargetType="ComboBox">
            <Setter Property="FocusVisualPrimaryBrush" Value="#00C8FF"/>
            <Setter Property="FocusVisualPrimaryThickness" Value="2"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
        </Style>

        <!-- Modern Button Style - Tooth Theme -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource ButtonBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource ButtonBorderBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="15,10,15,11"/>
        </Style>

        <!-- Section Header Style - Tooth Theme -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#00C8FF"/>
            <Setter Property="Margin" Value="0,20,0,0"/>
        </Style>

    </Page.Resources>

    <Grid>
        <ProgressRing x:Name="LoadingProgressRing"
                      IsActive="True"
                      Visibility="Collapsed"
                      Width="60"
                      Height="60"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"/>

        <muxc:NavigationView x:Name="MainNavigationView"
                        IsBackButtonVisible="Collapsed"
                        IsSettingsVisible="False"
                        IsPaneToggleButtonVisible="False"
                        PaneDisplayMode="Top"
                        OpenPaneLength="140"
                        CompactModeThresholdWidth="0"
                        ExpandedModeThresholdWidth="0"
                        Background="Transparent"
                        SelectionChanged="MainNavigationView_SelectionChanged">

            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="Performance" Tag="Performance" Style="{StaticResource NavItemStyle}"/>
                <muxc:NavigationViewItem Content="Profiles" Tag="Game" Style="{StaticResource NavItemStyle}"/>
                <muxc:NavigationViewItem Content="Graphics" Tag="AMD" Style="{StaticResource NavItemStyle}"/>
                <muxc:NavigationViewItem Content="Scaling" Tag="Scaling" Style="{StaticResource NavItemStyle}"/>
                <muxc:NavigationViewItem Content="System" Tag="System" Style="{StaticResource NavItemStyle}"/>
            </muxc:NavigationView.MenuItems>

            <!-- PERFORMANCE TAB -->
            <Grid>
                <ScrollViewer x:Name="PerformanceScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Active Profile Indicator -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="Using profile:"
                                               FontSize="12"
                                               Foreground="#AAAAAA"
                                               VerticalAlignment="Top" Margin="4,1,-5,0"/>
                                    <TextBlock x:Name="ActiveProfileText"
                                               Text="Global Settings"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               Foreground="#00C8FF"
                                               HorizontalAlignment="Left"
                                               VerticalAlignment="Top" Margin="0,26,0,0"/>
                                </Grid>

                                <!-- Per-Game Profile Toggle -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Use per-game profile"
                                                   FontSize="12"
                                                   Foreground="#FFFFFF"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="PerGameProfileToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False" HorizontalAlignment="Right" Width="50"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Performance Overlay Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Performance Overlay" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>

                                <muxc:RadioButtons x:Name="PerformanceOverlayRadioButtons"
                                                   HorizontalAlignment="Center"
                                                   MaxColumns="4"
                                                   SelectionChanged="PerformanceOverlayRadioButtons_SelectionChanged"
                                                   XYFocusUp="{x:Bind PerGameProfileToggle}"
                                                   XYFocusDown="{x:Bind TDPSlider}">
                                    <RadioButton Content="Off" Tag="0" MinWidth="0" Padding="8,6"/>
                                    <RadioButton Content="Basic" Tag="1" MinWidth="0" Padding="8,6"/>
                                    <RadioButton Content="Detailed" Tag="2" MinWidth="0" Padding="8,6"/>
                                    <RadioButton Content="Full" Tag="3" MinWidth="0" Padding="8,6"/>
                                </muxc:RadioButtons>

                                <!-- Hidden slider for property system compatibility -->
                                <Slider x:Name="PerformanceOverlaySlider"
                                        Visibility="Collapsed"
                                        Minimum="0" Maximum="3"
                                        Value="0"
                                        ValueChanged="PerformanceOverlaySlider_ValueChanged"/>
                            </StackPanel>
                        </Border>

                        <!-- TDP Power Limit Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="TDP Power Limit" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock x:Name="TDPValueText"
                                               Text="{Binding ElementName=TDPSlider, Path=Value, Converter={StaticResource WattStringConverter}}"
                                               Style="{StaticResource CardValueStyle}"/>
                                </Grid>
                                <Slider x:Name="TDPSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="4" Maximum="35"
                                        TickFrequency="1"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False" Value="-5"/>
                                <Grid Margin="0,4,0,0">
                                    <TextBlock x:Name="CurrentTDPText"
                                               Text="Limits:"
                                               FontSize="12"
                                               Foreground="#A0A0A0"/>
                                    <TextBlock x:Name="CurrentTDPValueText"
                                               Text="-- W"
                                               FontSize="12"
                                               Foreground="#A0A0A0"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <!-- Sticky TDP Active Indicator -->
                                <TextBlock Text="Sticky TDP: Active"
                                           FontSize="13"
                                           Foreground="#4CAF50"
                                           FontWeight="SemiBold"
                                           Margin="0,1,0,0"
                                           Visibility="{Binding ElementName=StickyTDPToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- CPU Boost Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="CPU Boost" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Higher boost clocks" Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="CPUBoostToggle"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsEnabled="False" HorizontalAlignment="Stretch" Grid.Column="1" HorizontalContentAlignment="Right" UseLayoutRounding="True" Width="50"/>
                            </Grid>
                        </Border>

                        <!-- CPU EPP Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="CPU EPP" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock x:Name="CPUEPPValueText"
                                               Text="{Binding ElementName=CPUEPPSlider, Path=Value}"
                                               Style="{StaticResource CardValueStyle}"/>
                                </Grid>
                                <Slider x:Name="CPUEPPSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="100"
                                        TickFrequency="10"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"/>
                                <Grid Margin="0,4,0,0">
                                    <TextBlock Text="0 = Prioritize CPU"
                                               FontSize="12"
                                               Foreground="#A0A0A0"/>
                                    <TextBlock Text="100 = Prioritize GPU"
                                               FontSize="12"
                                               Foreground="#A0A0A0"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Limit CPU Clock Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Limit CPU Clock" Style="{StaticResource CardTitleStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LimitCPUClockToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False" Width="52"/>
                                </Grid>
                                <Slider x:Name="CPUClockMaxSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="1400" Maximum="5500"
                                        TickFrequency="100"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        Header="Max Frequency (MHz)"
                                        IsEnabled="False"
                                        Visibility="{Binding ElementName=LimitCPUClockToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- GAME TAB -->
                <ScrollViewer x:Name="GameScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Power Source Profile Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Power Source Profile" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Separate profiles for AC (plugged in) and DC (battery)"
                                               Style="{StaticResource CardCaptionStyle}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="PowerSourceProfileToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}" Width="47"/>
                            </Grid>
                        </Border>

                        <!-- Current Game Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Current Game" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock x:Name="RunningGameText"
                                           Text="No game detected"
                                           FontSize="16"
                                           Foreground="White"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Global Profile Section -->
                        <TextBlock Text="Global Profile"
                                   FontSize="16"
                                   Foreground="#00C8FF"
                                   FontWeight="SemiBold"
                                   Margin="0,16,0,8"/>

                        <!-- Global Profile Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Global"
                                           Style="{StaticResource CardTitleStyle}"
                                           Foreground="#00FF88"
                                           FontSize="14"/>

                                <!-- Simple Mode (Power Source Toggle OFF) -->
                                <Grid x:Name="GlobalProfileSimple" Margin="0,8,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="TDP" FontSize="11" Foreground="#AAAAAA"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="GlobalProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="CPU Boost" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="GlobalProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="CPU EPP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="GlobalProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0"/>
                                </Grid>

                                <!-- AC/DC Mode (Power Source Toggle ON) -->
                                <Grid x:Name="GlobalProfileACDC" Margin="0,8,0,0" Visibility="Collapsed">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Header -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="" FontSize="11" Foreground="#AAAAAA"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="AC" FontSize="11" Foreground="#FFD700" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="DC" FontSize="11" Foreground="#FF6B6B" HorizontalAlignment="Center"/>

                                    <!-- TDP Row -->
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="TDP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="ACProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="1" Grid.Column="2" x:Name="DCProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>

                                    <!-- CPU Boost Row -->
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Boost" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ACProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="2" Grid.Column="2" x:Name="DCProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>

                                    <!-- CPU EPP Row -->
                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="EPP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0"/>
                                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="ACProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                    <TextBlock Grid.Row="3" Grid.Column="2" x:Name="DCProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Game Profile Card (shown when game is detected) -->
                        <Border x:Name="GameProfileCard" Style="{StaticResource CardStyle}" Visibility="Collapsed" Margin="0,8,0,0">
                            <StackPanel>
                                <!-- Game Profile with Power Source -->
                                <StackPanel x:Name="GameProfileWithPowerSource" Visibility="Collapsed">
                                    <TextBlock x:Name="GameProfileTitleWithPower"
                                               Text="Game"
                                               Style="{StaticResource CardTitleStyle}"
                                               Foreground="#FFA500"
                                               FontSize="14"/>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Header -->
                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="" FontSize="11" Foreground="#AAAAAA"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" Text="AC" FontSize="11" Foreground="#FFD700" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Row="0" Grid.Column="2" Text="DC" FontSize="11" Foreground="#FF6B6B" HorizontalAlignment="Center"/>

                                        <!-- TDP Row -->
                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="TDP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="GameACProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Row="1" Grid.Column="2" x:Name="GameDCProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>

                                        <!-- CPU Boost Row -->
                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Boost" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="GameACProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Row="2" Grid.Column="2" x:Name="GameDCProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>

                                        <!-- CPU EPP Row -->
                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="EPP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,8,0"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="GameACProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                        <TextBlock Grid.Row="3" Grid.Column="2" x:Name="GameDCProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0" HorizontalAlignment="Center"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Game Profile without Power Source -->
                                <StackPanel x:Name="GameProfileWithoutPowerSource" Visibility="Collapsed">
                                    <TextBlock x:Name="GameProfileTitleNoPower"
                                               Text="Game"
                                               Style="{StaticResource CardTitleStyle}"
                                               Foreground="#FFA500"
                                               FontSize="14"/>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="TDP" FontSize="11" Foreground="#AAAAAA"/>
                                        <TextBlock Grid.Row="0" Grid.Column="1" x:Name="GameProfileTDPText" Text="15W" FontSize="11" Foreground="#FFFFFF"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="CPU Boost" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="GameProfileCPUBoostText" Text="Off" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="CPU EPP" FontSize="11" Foreground="#AAAAAA" Margin="0,3,0,0"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="GameProfileCPUEPPText" Text="0" FontSize="11" Foreground="#FFFFFF" Margin="0,3,0,0"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Saved Profiles Section -->
                        <TextBlock Text="Saved Profiles"
                                   FontSize="16"
                                   Foreground="#00C8FF"
                                   FontWeight="SemiBold"
                                   Margin="0,24,0,8"/>

                        <!-- Container for dynamically created game profile cards -->
                        <StackPanel x:Name="AllGameProfilesContainer"/>

                    </StackPanel>
                </ScrollViewer>

                <!-- GRAPHICS TAB -->
                <ScrollViewer x:Name="AMDScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Refresh Rate Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Refresh Rate" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,12"/>
                                <ComboBox x:Name="RefreshRatesComboBox"
                                          PlaceholderText="60 Hz"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}">
                                    <x:String>60 Hz</x:String>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- AMD Section Header -->
                        <TextBlock Text="AMD"
                                   FontSize="16"
                                   Foreground="#00C8FF"
                                   FontWeight="SemiBold"
                                   Margin="0,16,0,8"/>

                        <!-- Radeon Super Resolution Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Radeon Super Resolution" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Upscales lower resolutions" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AMDRadeonSuperResolutionToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False" Width="50"/>
                                </Grid>
                                <Slider x:Name="AMDRadeonSuperResolutionSharpnessSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="100"
                                        TickFrequency="10"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        Header="Sharpness"
                                        IsEnabled="False"
                                        Visibility="{Binding ElementName=AMDRadeonSuperResolutionToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- Fluid Motion Frames Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Fluid Motion Frames" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Frame generation" Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="AMDFluidMotionFrameToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsEnabled="False" Width="50"/>
                            </Grid>
                        </Border>

                        <!-- Anti-Lag Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Radeon Anti-Lag" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Reduces input latency" Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="AMDRadeonAntiLagToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsEnabled="False" Width="50"/>
                            </Grid>
                        </Border>

                        <!-- Radeon Boost Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Radeon Boost" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Dynamic resolution scaling" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AMDRadeonBoostToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False" Width="52" HorizontalAlignment="Center"/>
                                </Grid>
                                <Slider x:Name="AMDRadeonBoostResolutionSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="1"
                                        TickFrequency="1"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"
                                        Visibility="{Binding ElementName=AMDRadeonBoostToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>

                        <!-- Radeon Chill Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Radeon Chill" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Power saving when idle" Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AMDRadeonChillToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False" Width="50"/>
                                </Grid>
                                <StackPanel Visibility="{Binding ElementName=AMDRadeonChillToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Slider x:Name="AMDRadeonChillMinFPSSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="30" Maximum="300"
                                            TickFrequency="10"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            Header="Min FPS"
                                            IsEnabled="False"/>
                                    <Slider x:Name="AMDRadeonChillMaxFPSSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="30" Maximum="300"
                                            TickFrequency="10"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            Header="Max FPS"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- SYSTEM TAB -->
                <ScrollViewer x:Name="SystemScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Profile Settings Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Profile Settings" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                                <TextBlock Text="Choose which settings are saved in profiles"
                                           FontSize="12"
                                           Foreground="#A0A0A0"
                                           Margin="0,0,0,12"
                                           TextWrapping="Wrap"/>

                                <CheckBox x:Name="ProfileSaveTDPCheckBox"
                                          Content="TDP Power Limit"
                                          IsChecked="True"
                                          Foreground="#FFFFFF"
                                          Margin="0,4,0,0"/>
                                <CheckBox x:Name="ProfileSaveCPUBoostCheckBox"
                                          Content="CPU Boost"
                                          IsChecked="True"
                                          Foreground="#FFFFFF"
                                          Margin="0,4,0,0"/>
                                <CheckBox x:Name="ProfileSaveCPUEPPCheckBox"
                                          Content="CPU EPP"
                                          IsChecked="True"
                                          Foreground="#FFFFFF"
                                          Margin="0,4,0,0"/>
                                <CheckBox x:Name="ProfileSaveLimitCPUClockCheckBox"
                                          Content="Limit CPU Clock"
                                          IsChecked="True"
                                          Foreground="#FFFFFF"
                                          Margin="0,4,0,0"/>
                                <CheckBox x:Name="ProfileSaveAMDFeaturesCheckBox"
                                          Content="AMD Features (FMF, Anti-Lag, Boost, Chill)"
                                          IsChecked="False"
                                          Foreground="#FFFFFF"
                                          Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Sticky TDP Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Sticky TDP" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Automatically restore TDP limits if changed by other apps"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="StickyTDPToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  Toggled="StickyTDPToggle_Toggled" Width="50"/>
                                </Grid>
                                <StackPanel Visibility="{Binding ElementName=StickyTDPToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid Margin="0,2,0,0">
                                        <TextBlock Text="How often to reapply TDP settings"
                                                   FontSize="14"
                                                   Foreground="#A0A0A0"
                                                   TextWrapping="Wrap"/>
                                        <TextBlock x:Name="StickyTDPIntervalValue"
                                                   Text="5s"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="StickyTDPIntervalSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="3" Maximum="15"
                                            TickFrequency="2"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            Header="Check Interval"
                                            Value="5"
                                            ValueChanged="StickyTDPIntervalSlider_ValueChanged"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- About Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="About" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="Version: 0.3.31"
                                           FontSize="14"
                                           Foreground="#A0A0A0"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- SCALING TAB -->
                <ScrollViewer x:Name="ScalingScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Status Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Lossless Scaling Status" Style="{StaticResource CardTitleStyle}" Grid.Column="0" VerticalAlignment="Center"/>
                                    <Button x:Name="ShowLosslessScalingWindowButton"
                                            Grid.Column="1"
                                            Content="Show Window"
                                            Margin="0,0,8,0"
                                            Visibility="Collapsed"
                                            Click="ShowLosslessScalingWindowButton_Click"/>
                                    <Button x:Name="LaunchLosslessScalingButton"
                                            Grid.Column="2"
                                            Content="Launch"
                                            Visibility="Collapsed"
                                            Click="LaunchLosslessScalingButton_Click"/>
                                </Grid>
                                <TextBlock x:Name="LosslessScalingStatusText"
                                           Text="Not Installed"
                                           FontSize="14"
                                           Foreground="#A0A0A0"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Current Profile Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Current Profile" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock x:Name="LosslessScalingCurrentProfileText"
                                                   Text="Default"
                                                   FontSize="14"
                                                   Foreground="#00C8FF"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button x:Name="LosslessScalingCreateProfileButton"
                                            Grid.Column="1"
                                            Content="Create Profile"
                                            VerticalAlignment="Center"
                                            IsEnabled="False"
                                            Click="LosslessScalingCreateProfileButton_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Scale Toggle Button -->
                        <ToggleButton x:Name="LosslessScalingEnabledToggle"
                                      Content="Scale"
                                      HorizontalAlignment="Stretch"
                                      IsEnabled="False"
                                      FontSize="16"
                                      FontWeight="SemiBold"
                                      Padding="16,12"/>

                        <!-- Save Settings Button -->
                        <Button x:Name="LosslessScalingSaveSettingsButton"
                                Content="Save Settings"
                                HorizontalAlignment="Stretch"
                                Margin="0,8,0,0"
                                IsEnabled="False"
                                Click="LosslessScalingSaveSettingsButton_Click"/>

                        <!-- AutoScale Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="AutoScale" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Automatically detect and scale games"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LosslessScalingAutoScaleToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False" Width="50"/>
                                </Grid>
                                <StackPanel Visibility="{Binding ElementName=LosslessScalingAutoScaleToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid Margin="0,8,0,0">
                                        <TextBlock Text="AutoScale Delay (s)"
                                                   FontSize="14"
                                                   Foreground="#A0A0A0"/>
                                        <TextBlock x:Name="LosslessScalingAutoScaleDelayValueText"
                                                   Text="{Binding ElementName=LosslessScalingAutoScaleDelaySlider, Path=Value}"
                                                   FontSize="14"
                                                   Foreground="#00C8FF"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="LosslessScalingAutoScaleDelaySlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="10"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Scaling Type Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Scaling Algorithm" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                                <ComboBox x:Name="LosslessScalingScalingTypeComboBox"
                                          PlaceholderText="Select Type"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectionChanged="LosslessScalingScalingTypeComboBox_SelectionChanged">
                                    <x:String>Off</x:String>
                                    <x:String>LS1</x:String>
                                    <x:String>FSR</x:String>
                                    <x:String>NIS</x:String>
                                    <x:String>SGSR</x:String>
                                    <x:String>BCAS</x:String>
                                    <x:String>Anime4K</x:String>
                                    <x:String>xBR</x:String>
                                    <x:String>Sharp Bilinear</x:String>
                                    <x:String>Integer</x:String>
                                    <x:String>Nearest Neighbor</x:String>
                                </ComboBox>

                                <!-- Sharpness Slider (for FSR, NIS, SGSR, BCAS) -->
                                <StackPanel x:Name="LosslessScalingSharpnessPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <Grid>
                                        <TextBlock Text="Sharpness" FontSize="12" Foreground="#A0A0A0"/>
                                        <TextBlock x:Name="LosslessScalingSharpnessValueText"
                                                   Text="{Binding ElementName=LosslessScalingSharpnessSlider, Path=Value}"
                                                   FontSize="12"
                                                   Foreground="#00C8FF"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="LosslessScalingSharpnessSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="100"
                                            TickFrequency="10"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            IsEnabled="False"/>
                                </StackPanel>

                                <!-- FSR Optimize Toggle (FSR only) -->
                                <Grid x:Name="LosslessScalingFSROptimizePanel" Visibility="Collapsed" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Optimize" FontSize="12" Foreground="#A0A0A0" VerticalAlignment="Center"/>
                                    <ToggleSwitch x:Name="LosslessScalingFSROptimizeToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>

                                <!-- Anime4K Settings -->
                                <StackPanel x:Name="LosslessScalingAnime4KPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <TextBlock Text="Size" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="LosslessScalingAnime4KSizeComboBox"
                                              PlaceholderText="Select Size"
                                              Width="Auto"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="False"
                                              Style="{StaticResource ModernComboBoxStyle}">
                                        <x:String>Small</x:String>
                                        <x:String>Medium</x:String>
                                        <x:String>Large</x:String>
                                        <x:String>Very Large</x:String>
                                        <x:String>Ultra Large</x:String>
                                    </ComboBox>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="VRS" FontSize="12" Foreground="#A0A0A0" VerticalAlignment="Center"/>
                                        <ToggleSwitch x:Name="LosslessScalingAnime4KVRSToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      IsEnabled="False"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Scale Mode Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Scale Mode" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                                <ComboBox x:Name="LosslessScalingScaleModeComboBox"
                                          PlaceholderText="Select Mode"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectionChanged="LosslessScalingScaleModeComboBox_SelectionChanged">
                                    <x:String>Auto</x:String>
                                    <x:String>Custom</x:String>
                                </ComboBox>

                                <!-- Auto Mode Settings -->
                                <StackPanel x:Name="LosslessScalingAutoModePanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <TextBlock Text="Aspect" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="LosslessScalingAspectRatioComboBox"
                                              PlaceholderText="Select Aspect"
                                              Width="Auto"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="False"
                                              Style="{StaticResource ModernComboBoxStyle}">
                                        <x:String>Aspect Ratio</x:String>
                                        <x:String>Fullscreen</x:String>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Custom Mode Settings -->
                                <StackPanel x:Name="LosslessScalingCustomModePanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <Grid>
                                        <TextBlock Text="Scale Factor" FontSize="12" Foreground="#A0A0A0"/>
                                        <TextBlock x:Name="LosslessScalingScaleFactorValueText"
                                                   Text="{Binding ElementName=LosslessScalingScaleFactorSlider, Path=Value}"
                                                   FontSize="12"
                                                   Foreground="#00C8FF"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="LosslessScalingScaleFactorSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="1" Maximum="5"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Frame Generation Type Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Frame Generation" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                                <ComboBox x:Name="LosslessScalingFrameGenTypeComboBox"
                                          PlaceholderText="Select Type"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}">
                                    <x:String>Off</x:String>
                                    <x:String>LSFG1</x:String>
                                    <x:String>LSFG2</x:String>
                                    <x:String>LSFG3</x:String>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- LSFG3 Settings Card -->
                        <Border x:Name="LSFG3SettingsCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="LSFG3 Settings" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>

                                <!-- LSFG3 Mode -->
                                <TextBlock Text="Mode" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                <ComboBox x:Name="LosslessScalingLSFG3ModeComboBox"
                                          PlaceholderText="Select Mode"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          Margin="0,0,0,12"
                                          SelectionChanged="LosslessScalingLSFG3ModeComboBox_SelectionChanged">
                                    <x:String>FIXED</x:String>
                                    <x:String>ADAPTIVE</x:String>
                                </ComboBox>

                                <!-- LSFG3 Multiplier (hidden when Adaptive) -->
                                <StackPanel x:Name="LosslessScalingLSFG3MultiplierPanel">
                                    <TextBlock Text="Multiplier" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="LosslessScalingLSFG3MultiplierComboBox"
                                              PlaceholderText="Select Multiplier"
                                              Width="Auto"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="False"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              Margin="0,0,0,12">
                                        <x:String>2</x:String>
                                        <x:String>3</x:String>
                                        <x:String>4</x:String>
                                    </ComboBox>
                                </StackPanel>

                                <!-- LSFG3 Target FPS -->
                                <Grid>
                                    <TextBlock Text="Target FPS" FontSize="12" Foreground="#A0A0A0"/>
                                    <TextBlock x:Name="LosslessScalingLSFG3TargetValueText"
                                               Text="{Binding ElementName=LosslessScalingLSFG3TargetSlider, Path=Value}"
                                               FontSize="12"
                                               Foreground="#00C8FF"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="LosslessScalingLSFG3TargetSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="30" Maximum="240"
                                        TickFrequency="10"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"
                                        Margin="0,0,0,12"/>

                                <!-- Flow Scale -->
                                <Grid>
                                    <TextBlock Text="Flow Scale" FontSize="12" Foreground="#A0A0A0"/>
                                    <TextBlock x:Name="LosslessScalingFlowScaleValueText"
                                               Text="{Binding ElementName=LosslessScalingFlowScaleSlider, Path=Value}"
                                               FontSize="12"
                                               Foreground="#00C8FF"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="LosslessScalingFlowScaleSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="25" Maximum="100"
                                        TickFrequency="5"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"
                                        Margin="0,0,0,12"/>

                                <!-- Size Toggle (Performance/Balanced) -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Performance Mode" FontSize="14" Foreground="#FFFFFF"/>
                                        <TextBlock Text="Lighter model for less input lag"
                                                   FontSize="11"
                                                   Foreground="#A0A0A0"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LosslessScalingSizeToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- LSFG2 Settings Card -->
                        <Border x:Name="LSFG2SettingsCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="LSFG2 Settings" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>

                                <!-- LSFG2 Mode -->
                                <TextBlock Text="Mode" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                <ComboBox x:Name="LosslessScalingLSFG2ModeComboBox"
                                          PlaceholderText="Select Mode"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}">
                                    <x:String>X2</x:String>
                                    <x:String>X3</x:String>
                                    <x:String>X4</x:String>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- Conflict Warning Card -->
                        <Border Style="{StaticResource CardStyle}" x:Name="LSConflictWarningBorder" Visibility="Collapsed" Margin="0,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Conflict Detected"
                                           Style="{StaticResource CardTitleStyle}"
                                           Foreground="#FFA500"/>
                                <TextBlock x:Name="LSConflictWarningText"
                                           Text="AMD Fluid Motion Frames has been automatically disabled because it conflicts with Lossless Scaling Frame Generation."
                                           FontSize="12"
                                           Foreground="#FFA500"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

            </Grid>

        </muxc:NavigationView>
    </Grid>
</Page>
