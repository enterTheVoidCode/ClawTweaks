                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="100"
                                        TickFrequency="10"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        Header="Sharpness"
                                        IsEnabled="False"
                                        Visibility="{Binding ElementName=AMDImageSharpeningToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                            </StackPanel>
                        </Border>


                    </StackPanel>
                </ScrollViewer>

                <!-- SYSTEM TAB -->
                <ScrollViewer x:Name="SystemScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Manufacturer WMI TDP Card -->
                        <Border x:Name="ManufacturerWMICard" Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Manufacturer WMI TDP" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock x:Name="ManufacturerWMIDescription"
                                               Text="Use device manufacturer's WMI method for TDP control. Supported: Legion Go / Go 2. Disable to use RyzenAdj (may trigger anti-cheat)."
                                               Style="{StaticResource CardCaptionStyle}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="UseManufacturerWMIToggle"
                                              Grid.Column="1"
                                              IsOn="True"
                                              Style="{StaticResource ModernToggleStyle}"
                                              XYFocusUp="{x:Bind StickyTDPToggle}"
                                              XYFocusDown="{x:Bind TDPLimitsExpandButton}"/>
                            </Grid>
                        </Border>

                        <!-- Device TDP Limits Card (Collapsible) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header with Expand/Collapse -->
                                <Button x:Name="TDPLimitsExpandButton"
                                        Click="TDPLimitsExpandButton_Click"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        UseSystemFocusVisuals="True"
                                        FocusVisualPrimaryBrush="White"
                                        XYFocusUp="{x:Bind UseManufacturerWMIToggle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Device TDP Limits" Style="{StaticResource CardTitleStyle}"/>
                                            <TextBlock Text="Configure minimum and maximum TDP for your device"
                                                       Style="{StaticResource CardCaptionStyle}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <TextBlock x:Name="TDPLimitsExpandIcon"
                                                   Text="&#xE70D;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14"
                                                   Foreground="#A0A0A0"
                                                   Grid.Column="1"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>

                                <!-- Collapsible Content -->
                                <StackPanel x:Name="TDPLimitsContent" Visibility="Collapsed" Margin="0,12,0,0">
                                    <!-- Warning -->
                                    <Border Background="#3D2A1A" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE7BA;"
                                                       Grid.Column="0"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="16"
                                                       Foreground="#FFA500"
                                                       VerticalAlignment="Top"
                                                       Margin="0,2,8,0"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="Increasing TDP beyond your device's thermal limits may cause overheating, throttling, or hardware damage. Only adjust if you understand your device's capabilities."
                                                       Foreground="#FFB74D"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>

                                    <!-- Minimum TDP -->
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="Minimum TDP"
                                                   FontSize="14"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TDPLimitsMinValue"
                                                   Text="4W"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="TDPLimitsMinSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="4" Maximum="85"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            Value="4"
                                            ValueChanged="TDPLimitsMinSlider_ValueChanged"
                                            XYFocusUp="{x:Bind TDPLimitsExpandButton}"
                                            XYFocusDown="{x:Bind TDPLimitsMaxSlider}"/>

                                    <!-- Maximum TDP -->
                                    <Grid Margin="0,12,0,8">
                                        <TextBlock Text="Maximum TDP"
                                                   FontSize="14"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TDPLimitsMaxValue"
                                                   Text="35W"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="TDPLimitsMaxSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="4" Maximum="85"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            Value="35"
                                            ValueChanged="TDPLimitsMaxSlider_ValueChanged"
                                            XYFocusUp="{x:Bind TDPLimitsMinSlider}"
                                            XYFocusDown="{x:Bind TDPBoostExpandButton}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- TDP Boost Settings Card (Collapsible) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header with Expand/Collapse -->
                                <Button x:Name="TDPBoostExpandButton"
                                        Click="TDPBoostExpandButton_Click"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        UseSystemFocusVisuals="True"
                                        FocusVisualPrimaryBrush="White"
                                        XYFocusUp="{x:Bind TDPLimitsExpandButton}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="TDP Boost Settings" Style="{StaticResource CardTitleStyle}"/>
                                            <TextBlock Text="Configure SPPT and FPPT boost values above base TDP"
                                                       Style="{StaticResource CardCaptionStyle}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <TextBlock x:Name="TDPBoostExpandIcon"
                                                   Text="&#xE70D;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14"
                                                   Foreground="#A0A0A0"
                                                   Grid.Column="1"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>

                                <!-- Collapsible Content -->
                                <StackPanel x:Name="TDPBoostContent" Visibility="Collapsed" Margin="0,12,0,0">
                                    <!-- Info -->
                                    <Border Background="#1A2A3D" CornerRadius="4" Padding="10" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="&#xE946;"
                                                       Grid.Column="0"
                                                       FontFamily="Segoe MDL2 Assets"
                                                       FontSize="16"
                                                       Foreground="#4CAF50"
                                                       VerticalAlignment="Top"
                                                       Margin="0,2,8,0"/>
                                            <TextBlock Grid.Column="1"
                                                       Text="When TDP Boost is enabled, SPPT and FPPT will be set to TDP + boost value. This allows short bursts of higher power for better performance."
                                                       Foreground="#A0D4A0"
                                                       FontSize="12"
                                                       TextWrapping="Wrap"/>
                                        </Grid>
                                    </Border>

                                    <!-- SPPT Boost -->
                                    <Grid Margin="0,0,0,8">
                                        <TextBlock Text="SPPT Boost"
                                                   FontSize="14"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TDPBoostSPPTValue"
                                                   Text="1W"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="TDPBoostSPPTSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="10"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            ValueChanged="TDPBoostSPPTSlider_ValueChanged"
                                            XYFocusUp="{x:Bind TDPBoostExpandButton}"
                                            XYFocusDown="{x:Bind TDPBoostFPPTSlider}"/>

                                    <!-- FPPT Boost -->
                                    <Grid Margin="0,12,0,8">
                                        <TextBlock Text="FPPT Boost"
                                                   FontSize="14"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="TDPBoostFPPTValue"
                                                   Text="3W"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="TDPBoostFPPTSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="15"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            ValueChanged="TDPBoostFPPTSlider_ValueChanged"
                                            XYFocusUp="{x:Bind TDPBoostSPPTSlider}"
                                            XYFocusDown="{x:Bind PowerPlanExpandButton}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Power Plan Settings Card (Collapsible) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header with Expand/Collapse -->
                                <Button x:Name="PowerPlanExpandButton"
                                        Click="PowerPlanExpandButton_Click"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        UseSystemFocusVisuals="True"
                                        FocusVisualPrimaryBrush="White"
                                        XYFocusUp="{x:Bind TDPBoostExpandButton}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Power Plan Settings" Style="{StaticResource CardTitleStyle}"/>
                                            <TextBlock Text="Configure power plans for AC and battery"
                                                       Style="{StaticResource CardCaptionStyle}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <FontIcon x:Name="PowerPlanExpandIcon"
                                                  Grid.Column="1"
                                                  Glyph="&#xE76C;"
                                                  FontSize="12"
                                                  Foreground="#A0A0A0"
                                                  VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>

                                <!-- Collapsible Content -->
                                <StackPanel x:Name="PowerPlanOptionsPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <!-- AC Power Plan -->
                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock Text="AC Power Plan" Foreground="#FFFFFF" FontSize="14"/>
                                        <TextBlock Text="When plugged in" Foreground="#707070" FontSize="11"/>
                                        <ComboBox x:Name="ACPowerPlanComboBox"
                                                  Margin="0,8,0,0"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  SelectionChanged="ACPowerPlanComboBox_SelectionChanged"
                                                  XYFocusUp="{x:Bind PowerPlanExpandButton}"
                                                  XYFocusDown="{x:Bind DCPowerPlanComboBox}"/>
                                    </StackPanel>

                                    <!-- DC Power Plan -->
                                    <StackPanel Margin="0,0,0,12">
                                        <TextBlock Text="DC Power Plan" Foreground="#FFFFFF" FontSize="14"/>
                                        <TextBlock Text="When on battery" Foreground="#707070" FontSize="11"/>
                                        <ComboBox x:Name="DCPowerPlanComboBox"
                                                  Margin="0,8,0,0"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  SelectionChanged="DCPowerPlanComboBox_SelectionChanged"
                                                  XYFocusUp="{x:Bind ACPowerPlanComboBox}"
                                                  XYFocusDown="{x:Bind PowerPlanAutoSwitchToggle}"/>
                                    </StackPanel>

                                    <!-- Auto-switch Toggle -->
                                    <Grid Margin="0,0,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Auto-switch on power change" Foreground="#FFFFFF" FontSize="14"/>
                                            <TextBlock Text="Automatically apply the corresponding plan" Foreground="#707070" FontSize="11"/>
                                        </StackPanel>
                                        <ToggleSwitch x:Name="PowerPlanAutoSwitchToggle"
                                                      Grid.Column="1"
                                                      IsOn="False"
                                                      Toggled="PowerPlanAutoSwitchToggle_Toggled"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      XYFocusUp="{x:Bind DCPowerPlanComboBox}"
                                                      XYFocusDown="{x:Bind OSDCustomizeExpandButton}"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- OSD Customization Card (Collapsible) -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header with Expand/Collapse -->
                                <Button x:Name="OSDCustomizeExpandButton"
                                        Click="OSDCustomizeExpandButton_Click"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        UseSystemFocusVisuals="True"
                                        FocusVisualPrimaryBrush="White"
                                        XYFocusUp="{x:Bind PowerPlanExpandButton}"
                                        XYFocusDown="{x:Bind AdvancedExpandButton}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="OSD Customization" Style="{StaticResource CardTitleStyle}"/>
                                            <TextBlock Text="Customize overlay appearance and content"
                                                       Style="{StaticResource CardCaptionStyle}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <TextBlock x:Name="OSDCustomizeExpandIcon"
                                                   Text="&#xE70D;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14"
                                                   Foreground="#A0A0A0"
                                                   Grid.Column="1"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>

                                <!-- Collapsible Content -->
                                <StackPanel x:Name="OSDCustomizeContent" Visibility="Collapsed" Margin="0,12,0,0">

                                    <!-- OSD Provider Selection -->
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="OSD Provider"
                                                       Foreground="#FFFFFF"
                                                       VerticalAlignment="Center"
                                                       FontSize="14"/>
                                            <TextBlock Text="Select overlay source"
                                                       Foreground="#707070"
                                                       FontSize="11"/>
                                        </StackPanel>
                                        <ComboBox x:Name="OSDProviderComboBox"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  Width="120"
                                                  Grid.Column="1"
                                                  SelectionChanged="OSDProviderComboBox_SelectionChanged"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent">
                                            <ComboBoxItem Content="RTSS" Tag="0" IsSelected="True"/>
                                            <ComboBoxItem Content="AMD" Tag="1"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- RTSS-specific options (hidden when AMD provider is selected) -->
                                    <StackPanel x:Name="RTSSOptionsPanel">
                                        <!-- Overlay Level Selection -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Overlay Level"
                                                       Foreground="#FFFFFF"
                                                       VerticalAlignment="Center"
                                                       FontSize="14"/>
                                            <ComboBox x:Name="OSDCustomizeLevelComboBox"
                                                      Style="{StaticResource ModernComboBoxStyle}"
                                                      Width="120"
                                                      Grid.Column="1"
                                                      SelectionChanged="OSDCustomizeLevelComboBox_SelectionChanged"
                                                      UseSystemFocusVisuals="True"
                                                      FocusVisualPrimaryBrush="White"
                                                      FocusVisualSecondaryBrush="Transparent">
                                                <ComboBoxItem Content="Basic" Tag="1" IsSelected="True"/>
                                                <ComboBoxItem Content="Detailed" Tag="2"/>
                                                <ComboBoxItem Content="Full" Tag="3"/>
                                            </ComboBox>
                                        </Grid>

                                        <!-- Layout Settings Section -->
                                    <TextBlock Text="Layout"
                                               Style="{StaticResource CardTitleStyle}"
                                               Margin="0,0,0,8"/>

                                    <!-- Columns -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="Columns"
                                                       Foreground="#B0B0B0"
                                                       FontSize="13"/>
                                            <TextBlock Text="Items per row (1 = vertical list)"
                                                       Foreground="#707070"
                                                       FontSize="11"/>
                                        </StackPanel>
                                        <ComboBox x:Name="OSDColumnsComboBox"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  Width="80"
                                                  Grid.Column="1"
                                                  SelectionChanged="OSDLayoutOption_Changed"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White">
                                            <ComboBoxItem Content="1" Tag="1"/>
                                            <ComboBoxItem Content="2" Tag="2"/>
                                            <ComboBoxItem Content="3" Tag="3" IsSelected="True"/>
                                            <ComboBoxItem Content="4" Tag="4"/>
                                            <ComboBoxItem Content="5" Tag="5"/>
                                            <ComboBoxItem Content="6" Tag="6"/>
                                            <ComboBoxItem Content="7" Tag="7"/>
                                            <ComboBoxItem Content="8" Tag="8"/>
                                            <ComboBoxItem Content="9" Tag="9"/>
                                            <ComboBoxItem Content="10" Tag="10"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Text Size -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Text Size"
                                                   Foreground="#B0B0B0"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"/>
                                        <ComboBox x:Name="OSDTextSizeComboBox"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  Width="100"
                                                  Grid.Column="1"
                                                  SelectionChanged="OSDLayoutOption_Changed"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White">
                                            <ComboBoxItem Content="Small" Tag="50"/>
                                            <ComboBoxItem Content="Medium" Tag="100" IsSelected="True"/>
                                            <ComboBoxItem Content="Large" Tag="150"/>
                                            <ComboBoxItem Content="X-Large" Tag="200"/>
                                        </ComboBox>
                                    </Grid>

                                    <!-- Colors Section -->
                                    <TextBlock Text="Colors"
                                               Style="{StaticResource CardTitleStyle}"
                                               Margin="0,12,0,8"/>

                                    <!-- Text Color -->
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Text Color"
                                                   Foreground="#B0B0B0"
                                                   VerticalAlignment="Center"
                                                   FontSize="13"/>
                                        <StackPanel Orientation="Horizontal" Grid.Column="1">
                                            <Border x:Name="OSDTextColorPreview"
                                                    Width="24" Height="24"
                                                    Background="#FFFFFF"
                                                    CornerRadius="4"
                                                    BorderBrush="#505050"
                                                    BorderThickness="1"
                                                    Margin="0,0,8,0"/>
                                            <ComboBox x:Name="OSDTextColorComboBox"
                                                      Style="{StaticResource ModernComboBoxStyle}"
                                                      Width="100"
                                                      SelectionChanged="OSDColorOption_Changed"
                                                      UseSystemFocusVisuals="True"
                                                      FocusVisualPrimaryBrush="White">
                                                <ComboBoxItem Content="Dynamic" Tag="DYNAMIC" IsSelected="True"/>
                                                <ComboBoxItem Content="White" Tag="FFFFFF"/>
                                                <ComboBoxItem Content="Yellow" Tag="FFFF00"/>
                                                <ComboBoxItem Content="Green" Tag="00FF00"/>
                                                <ComboBoxItem Content="Cyan" Tag="00FFFF"/>
                                                <ComboBoxItem Content="Red" Tag="FF0000"/>
                                                <ComboBoxItem Content="Orange" Tag="FF8000"/>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                        <!-- Items Section -->
                                        <TextBlock Text="Items to Display"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   Margin="0,12,0,8"/>

                                        <!-- OSD Options Panel -->
                                        <StackPanel x:Name="OSDOptionsPanel">
                                        <CheckBox x:Name="OSDShowAppNameCheckBox"
                                                  Content="App Name (D3D11, Vulkan, etc.)"
                                                  IsChecked="False"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowTimeCheckBox"
                                                  Content="Time (12-hour)"
                                                  IsChecked="False"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowFPSCheckBox"
                                                  Content="FPS &amp; Frametime"
                                                  IsChecked="True"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowBatteryCheckBox"
                                                  Content="Battery"
                                                  IsChecked="True"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowMemoryCheckBox"
                                                  Content="Memory (RAM)"
                                                  IsChecked="True"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowVRAMCheckBox"
                                                  Content="VRAM (GPU Memory)"
                                                  IsChecked="False"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowCPUCheckBox"
                                                  Content="CPU (Usage, Wattage, Temp)"
                                                  IsChecked="True"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowCPUClockCheckBox"
                                                  Content="CPU Clock Speed"
                                                  IsChecked="False"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowGPUCheckBox"
                                                  Content="GPU (Usage, Wattage, Temp)"
                                                  IsChecked="True"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowGPUClockCheckBox"
                                                  Content="GPU Clock Speed"
                                                  IsChecked="False"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowFanCheckBox"
                                                  Content="Fan Speed"
                                                  IsChecked="False"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowAutoTDPCheckBox"
                                                  Content="AutoTDP Status"
                                                  IsChecked="False"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowTDPLimitsCheckBox"
                                                  Content="TDP Limits (SPL/SPPT/FPPT)"
                                                  IsChecked="False"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                        <CheckBox x:Name="OSDShowFrametimeGraphCheckBox"
                                                  Content="Frametime Graph"
                                                  IsChecked="False"
                                                  Foreground="#FFFFFF"
                                                  UseSystemFocusVisuals="True"
                                                  FocusVisualPrimaryBrush="White"
                                                  FocusVisualSecondaryBrush="Transparent"
                                                  Checked="OSDOption_Changed"
                                                  Unchecked="OSDOption_Changed"/>
                                    </StackPanel>

                                        <!-- Custom RTSS Tags Section -->
                                        <TextBlock Text="Custom RTSS Tags"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   Margin="0,16,0,4"/>
                                        <TextBlock Text="Add custom RTSS tags (e.g. &lt;FR&gt; for FPS)"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   Margin="0,0,0,8"/>
                                        <TextBox x:Name="OSDCustomTagsTextBox"
                                                 PlaceholderText="Enter custom RTSS tags..."
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 Height="60"
                                                 TextChanged="OSDCustomTagsTextBox_TextChanged"/>
                                    </StackPanel>

                                    <!-- AMD-specific info (shown when AMD provider is selected) -->
                                    <StackPanel x:Name="AMDOptionsPanel" Visibility="Collapsed">
                                        <TextBlock Text="AMD Adrenaline Overlay"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   Margin="0,0,0,8"/>
                                        <TextBlock Text="The AMD overlay is controlled through Adrenaline software. Use Ctrl+Shift+O to toggle and Ctrl+Shift+X to cycle overlay levels."
                                                   Foreground="#A0A0A0"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- About Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="About" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="Version: 0.3.31"
                                           FontSize="14"
                                           Foreground="#A0A0A0"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Advanced Card (Collapsible) - Core Parking & Affinity -->
                        <Border x:Name="AdvancedCard" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <!-- Header with Expand/Collapse -->
                                <Button x:Name="AdvancedExpandButton"
                                        Click="AdvancedExpandButton_Click"
                                        HorizontalAlignment="Stretch"
                                        HorizontalContentAlignment="Stretch"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="0"
                                        UseSystemFocusVisuals="True"
                                        FocusVisualPrimaryBrush="White"
                                        XYFocusUp="{x:Bind OSDCustomizeExpandButton}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                            <TextBlock Text="Advanced" Style="{StaticResource CardTitleStyle}"/>
                                            <TextBlock x:Name="AdvancedSummary"
                                                       Text="Core parking and affinity settings"
                                                       Style="{StaticResource CardCaptionStyle}"
                                                       TextWrapping="Wrap"/>
                                        </StackPanel>
                                        <TextBlock x:Name="AdvancedExpandIcon"
                                                   Text="&#xE70D;"
                                                   FontFamily="Segoe MDL2 Assets"
                                                   FontSize="14"
                                                   Foreground="#A0A0A0"
                                                   Grid.Column="1"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Button>

                                <!-- Collapsible Content -->
                                <StackPanel x:Name="AdvancedContent" Visibility="Collapsed" Margin="0,12,0,0">

                                    <!-- Core Parking Section (for non-hybrid CPUs only) -->
                                    <StackPanel x:Name="CoreParkingSection">
                                        <TextBlock Text="Core Parking"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FFFFFF"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Limit the number of active CPU cores system-wide"
                                                   FontSize="11"
                                                   Foreground="#888888"
                                                   Margin="0,0,0,8"/>
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Active Cores"
                                                           FontSize="14"
                                                           Foreground="#FFFFFF"/>
                                                <TextBlock x:Name="CoreParkingDescription"
                                                           Text="All cores active"
                                                           FontSize="11"
                                                           Foreground="#888888"/>
                                            </StackPanel>
                                            <ComboBox x:Name="CoreParkingComboBox"
                                                      Grid.Column="1"
                                                      Width="100"
                                                      SelectionChanged="CoreParkingComboBox_SelectionChanged"
                                                      UseSystemFocusVisuals="True"
                                                      FocusVisualPrimaryBrush="White">
                                                <!-- Items populated dynamically based on CPU core count -->
                                            </ComboBox>
                                        </Grid>
                                    </StackPanel>

                                    <!-- Core Affinity Section (for hybrid CPUs - also sets parking) -->
                                    <StackPanel x:Name="CoreAffinitySection" Visibility="Collapsed">
                                        <TextBlock Text="Core Affinity &amp; Parking"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="#FFFFFF"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Set game affinity and park unused cores (hybrid CPU)"
                                                   FontSize="11"
                                                   Foreground="#888888"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8"/>

                                        <!-- P-Core Affinity -->
                                        <Grid Margin="0,0,0,12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Performance Cores"
                                                           FontSize="14"
                                                           Foreground="#FFFFFF"/>
                                                <TextBlock Text="Zen 5 high-performance cores"
                                                           FontSize="11"
                                                           Foreground="#888888"/>
                                            </StackPanel>
                                            <ComboBox x:Name="PCoreCountComboBox"
                                                      Grid.Column="1"
                                                      Width="80"
                                                      SelectionChanged="PCoreCountComboBox_SelectionChanged"
                                                      UseSystemFocusVisuals="True"
                                                      FocusVisualPrimaryBrush="White">
                                                <ComboBoxItem Content="0" Tag="0"/>
                                                <ComboBoxItem Content="1" Tag="1"/>
                                                <ComboBoxItem Content="2" Tag="2"/>
                                                <ComboBoxItem Content="3" Tag="3" IsSelected="True"/>
                                            </ComboBox>
                                        </Grid>

                                        <!-- E-Core Affinity -->
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Efficiency Cores"
                                                           FontSize="14"
                                                           Foreground="#FFFFFF"/>
                                                <TextBlock Text="Zen 5c power-efficient cores"
                                                           FontSize="11"
                                                           Foreground="#888888"/>
                                            </StackPanel>
                                            <ComboBox x:Name="ECoreCountComboBox"
                                                      Grid.Column="1"
                                                      Width="80"
                                                      SelectionChanged="ECoreCountComboBox_SelectionChanged"
                                                      UseSystemFocusVisuals="True"
                                                      FocusVisualPrimaryBrush="White">
                                                <ComboBoxItem Content="0" Tag="0"/>
                                                <ComboBoxItem Content="1" Tag="1"/>
                                                <ComboBoxItem Content="2" Tag="2"/>
                                                <ComboBoxItem Content="3" Tag="3"/>
                                                <ComboBoxItem Content="4" Tag="4"/>
                                                <ComboBoxItem Content="5" Tag="5" IsSelected="True"/>
                                            </ComboBox>
                                        </Grid>

                                        <!-- Info text -->
                                        <TextBlock Text="Note: Affinity is applied only to the detected running game process."
                                                   FontSize="11"
                                                   Foreground="#888888"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>

                                    <!-- Force Park Mode (Aggressive) -->
                                    <StackPanel Margin="0,16,0,0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                <TextBlock Text="Force Park Mode"
                                                           FontSize="14"
                                                           Foreground="#FFFFFF"/>
                                                <TextBlock Text="Force system processes to parked cores"
                                                           FontSize="11"
                                                           Foreground="#888888"/>
                                            </StackPanel>
                                            <ToggleSwitch x:Name="ForceParkModeToggle"
                                                          Grid.Column="1"
                                                          Style="{StaticResource ModernToggleStyle}"
                                                          Toggled="ForceParkModeToggle_Toggled"/>
                                        </Grid>
                                        <Border Background="#442200"
                                                CornerRadius="4"
                                                Padding="8"
                                                Margin="0,8,0,0"
                                                Visibility="{Binding ElementName=ForceParkModeToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <StackPanel>
                                                <TextBlock Text="⚠ Warning"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="#FFAA00"/>
                                                <TextBlock Text="This applies affinity to ALL running processes, forcing them onto selected cores. May cause system instability or slowdowns. Disable if you experience issues."
                                                           FontSize="11"
                                                           Foreground="#FFCC66"
                                                           TextWrapping="Wrap"
                                                           Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- SCALING TAB -->
                <ScrollViewer x:Name="ScalingScrollViewer" VerticalScrollBarVisibility="Auto" Visibility="Collapsed"
                              BringIntoViewOnFocusChange="True">
                    <StackPanel Padding="16,8,16,16">

                        <!-- Status Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Lossless Scaling Status" Style="{StaticResource CardTitleStyle}" Grid.Column="0" VerticalAlignment="Center"/>
                                    <Button x:Name="ShowLosslessScalingWindowButton"
                                            Grid.Column="1"
                                            Content="Show Window"
                                            Margin="0,0,8,0"
                                            Visibility="Collapsed"
                                            Click="ShowLosslessScalingWindowButton_Click"/>
                                    <Button x:Name="LaunchLosslessScalingButton"
                                            Grid.Column="2"
                                            Content="Launch"
                                            Visibility="Collapsed"
                                            Click="LaunchLosslessScalingButton_Click"/>
                                </Grid>
                                <TextBlock x:Name="LosslessScalingStatusText"
                                           Text="Not Installed"
                                           FontSize="14"
                                           Foreground="#A0A0A0"
                                           Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Current Profile Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Current Profile" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock x:Name="LosslessScalingCurrentProfileText"
                                                   Text="Default"
                                                   FontSize="14"
                                                   Foreground="#00C8FF"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Button x:Name="LosslessScalingCreateProfileButton"
                                            Grid.Column="1"
                                            Content="Create Profile"
                                            VerticalAlignment="Center"
                                            IsEnabled="False"
                                            Click="LosslessScalingCreateProfileButton_Click"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Scale Toggle Button -->
                        <ToggleButton x:Name="LosslessScalingEnabledToggle"
                                      Content="Scale"
                                      HorizontalAlignment="Stretch"
                                      IsEnabled="False"
                                      FontSize="16"
                                      FontWeight="SemiBold"
                                      Margin="0,10,0,0"
                                      Style="{StaticResource StandaloneToggleButtonStyle}"/>

                        <!-- Apply and Restart Button -->
                        <Button x:Name="LosslessScalingSaveSettingsButton"
                                Content="Apply and Restart"
                                HorizontalAlignment="Stretch"
                                Margin="0,8,0,0"
                                IsEnabled="False"
                                Style="{StaticResource StandaloneButtonStyle}"
                                Click="LosslessScalingSaveSettingsButton_Click"/>

                        <!-- AutoScale Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="AutoScale" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Automatically detect and scale games"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LosslessScalingAutoScaleToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                                <StackPanel Visibility="{Binding ElementName=LosslessScalingAutoScaleToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid Margin="0,8,0,0">
                                        <TextBlock Text="AutoScale Delay (s)"
                                                   FontSize="14"
                                                   Foreground="#A0A0A0"/>
                                        <TextBlock x:Name="LosslessScalingAutoScaleDelayValueText"
                                                   Text="{Binding ElementName=LosslessScalingAutoScaleDelaySlider, Path=Value}"
                                                   FontSize="14"
                                                   Foreground="#00C8FF"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="LosslessScalingAutoScaleDelaySlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="10"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Scaling Type Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Scaling Algorithm" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                                <ComboBox x:Name="LosslessScalingScalingTypeComboBox"
                                          PlaceholderText="Select Type"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectionChanged="LosslessScalingScalingTypeComboBox_SelectionChanged">
                                    <x:String>Off</x:String>
                                    <x:String>LS1</x:String>
                                    <x:String>FSR</x:String>
                                    <x:String>NIS</x:String>
                                    <x:String>SGSR</x:String>
                                    <x:String>BCAS</x:String>
                                    <x:String>Anime4K</x:String>
                                    <x:String>xBR</x:String>
                                    <x:String>Sharp Bilinear</x:String>
                                    <x:String>Integer</x:String>
                                    <x:String>Nearest Neighbor</x:String>
                                </ComboBox>

                                <!-- Sharpness Slider (for FSR, NIS, SGSR, BCAS) -->
                                <StackPanel x:Name="LosslessScalingSharpnessPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <Grid>
                                        <TextBlock Text="Sharpness" FontSize="12" Foreground="#A0A0A0"/>
                                        <TextBlock x:Name="LosslessScalingSharpnessValueText"
                                                   Text="{Binding ElementName=LosslessScalingSharpnessSlider, Path=Value}"
                                                   FontSize="12"
                                                   Foreground="#00C8FF"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="LosslessScalingSharpnessSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="0" Maximum="100"
                                            TickFrequency="10"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            IsEnabled="False"/>
                                </StackPanel>

                                <!-- FSR Optimize Toggle (FSR only) -->
                                <Grid x:Name="LosslessScalingFSROptimizePanel" Visibility="Collapsed" Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Optimize" FontSize="12" Foreground="#A0A0A0" VerticalAlignment="Center"/>
                                    <ToggleSwitch x:Name="LosslessScalingFSROptimizeToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>

                                <!-- Anime4K Settings -->
                                <StackPanel x:Name="LosslessScalingAnime4KPanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <TextBlock Text="Size" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="LosslessScalingAnime4KSizeComboBox"
                                              PlaceholderText="Select Size"
                                              Width="Auto"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="False"
                                              Style="{StaticResource ModernComboBoxStyle}">
                                        <x:String>Small</x:String>
                                        <x:String>Medium</x:String>
                                        <x:String>Large</x:String>
                                        <x:String>Very Large</x:String>
                                        <x:String>Ultra Large</x:String>
                                    </ComboBox>
                                    <Grid Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="VRS" FontSize="12" Foreground="#A0A0A0" VerticalAlignment="Center"/>
                                        <ToggleSwitch x:Name="LosslessScalingAnime4KVRSToggle"
                                                      Grid.Column="1"
                                                      Style="{StaticResource ModernToggleStyle}"
                                                      IsEnabled="False"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Scale Mode Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Scale Mode" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                                <ComboBox x:Name="LosslessScalingScaleModeComboBox"
                                          PlaceholderText="Select Mode"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectionChanged="LosslessScalingScaleModeComboBox_SelectionChanged">
                                    <x:String>Auto</x:String>
                                    <x:String>Custom</x:String>
                                </ComboBox>

                                <!-- Auto Mode Settings -->
                                <StackPanel x:Name="LosslessScalingAutoModePanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <TextBlock Text="Aspect" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="LosslessScalingAspectRatioComboBox"
                                              PlaceholderText="Select Aspect"
                                              Width="Auto"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="False"
                                              Style="{StaticResource ModernComboBoxStyle}">
                                        <x:String>Aspect Ratio</x:String>
                                        <x:String>Fullscreen</x:String>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Custom Mode Settings -->
                                <StackPanel x:Name="LosslessScalingCustomModePanel" Visibility="Collapsed" Margin="0,12,0,0">
                                    <Grid>
                                        <TextBlock Text="Scale Factor" FontSize="12" Foreground="#A0A0A0"/>
                                        <TextBlock x:Name="LosslessScalingScaleFactorValueText"
                                                   Text="{Binding ElementName=LosslessScalingScaleFactorSlider, Path=Value}"
                                                   FontSize="12"
                                                   Foreground="#00C8FF"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="LosslessScalingScaleFactorSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="1" Maximum="5"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            TickPlacement="BottomRight"
                                            IsEnabled="False"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Frame Generation Type Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Frame Generation" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>
                                <ComboBox x:Name="LosslessScalingFrameGenTypeComboBox"
                                          PlaceholderText="Select Type"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}">
                                    <x:String>Off</x:String>
                                    <x:String>LSFG1</x:String>
                                    <x:String>LSFG2</x:String>
                                    <x:String>LSFG3</x:String>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- LSFG3 Settings Card -->
                        <Border x:Name="LSFG3SettingsCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="LSFG3 Settings" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>

                                <!-- LSFG3 Mode -->
                                <TextBlock Text="Mode" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                <ComboBox x:Name="LosslessScalingLSFG3ModeComboBox"
                                          PlaceholderText="Select Mode"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          Margin="0,0,0,12"
                                          SelectionChanged="LosslessScalingLSFG3ModeComboBox_SelectionChanged">
                                    <x:String>FIXED</x:String>
                                    <x:String>ADAPTIVE</x:String>
                                </ComboBox>

                                <!-- LSFG3 Multiplier (hidden when Adaptive) -->
                                <StackPanel x:Name="LosslessScalingLSFG3MultiplierPanel">
                                    <TextBlock Text="Multiplier" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                    <ComboBox x:Name="LosslessScalingLSFG3MultiplierComboBox"
                                              PlaceholderText="Select Multiplier"
                                              Width="Auto"
                                              HorizontalAlignment="Stretch"
                                              IsEnabled="False"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              Margin="0,0,0,12">
                                        <x:String>2</x:String>
                                        <x:String>3</x:String>
                                        <x:String>4</x:String>
                                    </ComboBox>
                                </StackPanel>

                                <!-- LSFG3 Target FPS -->
                                <Grid>
                                    <TextBlock Text="Target FPS" FontSize="12" Foreground="#A0A0A0"/>
                                    <TextBlock x:Name="LosslessScalingLSFG3TargetValueText"
                                               Text="{Binding ElementName=LosslessScalingLSFG3TargetSlider, Path=Value}"
                                               FontSize="12"
                                               Foreground="#00C8FF"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="LosslessScalingLSFG3TargetSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="30" Maximum="240"
                                        TickFrequency="10"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"
                                        Margin="0,0,0,12"/>

                                <!-- Flow Scale -->
                                <Grid>
                                    <TextBlock Text="Flow Scale" FontSize="12" Foreground="#A0A0A0"/>
                                    <TextBlock x:Name="LosslessScalingFlowScaleValueText"
                                               Text="{Binding ElementName=LosslessScalingFlowScaleSlider, Path=Value}"
                                               FontSize="12"
                                               Foreground="#00C8FF"
                                               HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="LosslessScalingFlowScaleSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="25" Maximum="100"
                                        TickFrequency="5"
                                        SnapsTo="Ticks"
                                        TickPlacement="BottomRight"
                                        IsEnabled="False"
                                        Margin="0,0,0,12"/>

                                <!-- Size Toggle (Performance/Balanced) -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Performance Mode" FontSize="14" Foreground="#FFFFFF"/>
                                        <TextBlock Text="Lighter model for less input lag"
                                                   FontSize="11"
                                                   Foreground="#A0A0A0"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="LosslessScalingSizeToggle"
                                                  Grid.Column="1"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  IsEnabled="False"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- LSFG2 Settings Card -->
                        <Border x:Name="LSFG2SettingsCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock Text="LSFG2 Settings" Style="{StaticResource CardTitleStyle}" Margin="0,0,0,8"/>

                                <!-- LSFG2 Mode -->
                                <TextBlock Text="Mode" FontSize="12" Foreground="#A0A0A0" Margin="0,0,0,4"/>
                                <ComboBox x:Name="LosslessScalingLSFG2ModeComboBox"
                                          PlaceholderText="Select Mode"
                                          Width="Auto"
                                          HorizontalAlignment="Stretch"
                                          IsEnabled="False"
                                          Style="{StaticResource ModernComboBoxStyle}">
                                    <x:String>X2</x:String>
                                    <x:String>X3</x:String>
                                    <x:String>X4</x:String>
                                </ComboBox>
                            </StackPanel>
                        </Border>

