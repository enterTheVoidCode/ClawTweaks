                                              Grid.Column="1"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              HorizontalAlignment="Stretch"
                                              SelectedIndex="0">
                                        <x:String>Hold</x:String>
                                        <x:String>Toggle</x:String>
                                    </ComboBox>
                                </Grid>

                                <!-- Gyro Activation Button -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Button" VerticalAlignment="Center" Foreground="#AAAAAA" FontSize="14"/>
                                    <ComboBox x:Name="LegionGyroActivationButtonComboBox"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              HorizontalAlignment="Stretch"
                                              SelectedIndex="0">
                                        <x:String>None</x:String>
                                        <x:String>LB</x:String>
                                        <x:String>LT</x:String>
                                        <x:String>RB</x:String>
                                        <x:String>RT</x:String>
                                        <x:String>Y1</x:String>
                                        <x:String>Y2</x:String>
                                        <x:String>M2</x:String>
                                        <x:String>M3</x:String>
                                    </ComboBox>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- RGB Lighting Section Header -->
                        <TextBlock Text="RGB LIGHTING" Style="{StaticResource SectionHeaderStyle}"/>

                        <!-- Light Mode Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Light Mode" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="Controller stick ring lighting effect"
                                           Style="{StaticResource CardCaptionStyle}"
                                           Margin="0,0,0,8"/>
                                <ComboBox x:Name="LegionLightModeComboBox"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectedIndex="1"
                                          SelectionChanged="LegionLightModeComboBox_SelectionChanged">
                                    <x:String>Off</x:String>
                                    <x:String>Solid</x:String>
                                    <x:String>Pulse</x:String>
                                    <x:String>Dynamic</x:String>
                                    <x:String>Spiral</x:String>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- Light Color Card (Solid, Pulse only) -->
                        <Border x:Name="LegionColorCard" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Light Color" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="RGB color for stick ring lighting"
                                                   Style="{StaticResource CardCaptionStyle}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border x:Name="LegionColorPreview"
                                                Width="24" Height="24"
                                                CornerRadius="4"
                                                Background="White"
                                                BorderBrush="#50555C"
                                                BorderThickness="1"
                                                Margin="0,0,8,0"/>
                                        <Button x:Name="LegionColorExpandButton"
                                                Content="&#xE70D;"
                                                FontFamily="Segoe MDL2 Assets"
                                                FontSize="12"
                                                Padding="8,4"
                                                Background="Transparent"
                                                Click="LegionColorExpandButton_Click"
                                                UseSystemFocusVisuals="True"
                                                FocusVisualPrimaryBrush="White"/>
                                    </StackPanel>
                                </Grid>
                                <muxc:ColorPicker x:Name="LegionColorPicker"
                                             Visibility="Collapsed"
                                             Margin="0,12,0,0"
                                             Color="White"
                                             ColorSpectrumShape="Box"
                                             IsMoreButtonVisible="False"
                                             IsColorSliderVisible="False"
                                             IsColorChannelTextInputVisible="False"
                                             IsHexInputVisible="False"
                                             IsAlphaEnabled="False"
                                             IsAlphaSliderVisible="False"
                                             IsAlphaTextInputVisible="False"
                                             ColorChanged="LegionColorPicker_ColorChanged"/>
                            </StackPanel>
                        </Border>

                        <!-- Light Brightness Card (all modes except Off) -->
                        <Border x:Name="LegionBrightnessCard" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="Brightness" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock x:Name="LegionBrightnessValue"
                                               Text="100%"
                                               Style="{StaticResource CardValueStyle}"/>
                                </Grid>
                                <Slider x:Name="LegionBrightnessSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="100"
                                        Value="100"
                                        ValueChanged="LegionBrightnessSlider_ValueChanged"/>
                            </StackPanel>
                        </Border>

                        <!-- Light Speed Card (Pulse, Dynamic, Spiral only) -->
                        <Border x:Name="LegionSpeedCard" Style="{StaticResource CardStyle}" Visibility="Collapsed">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Text="Speed" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock x:Name="LegionSpeedValue"
                                               Text="50%"
                                               Style="{StaticResource CardValueStyle}"/>
                                </Grid>
                                <Slider x:Name="LegionSpeedSlider"
                                        Style="{StaticResource ModernSliderStyle}"
                                        Minimum="0" Maximum="100"
                                        Value="50"
                                        ValueChanged="LegionSpeedSlider_ValueChanged"/>
                            </StackPanel>
                        </Border>

                        <!-- Power Light Toggle Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Power Light" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Power button LED on/off"
                                               Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="LegionPowerLightToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsOn="True"/>
                            </Grid>
                        </Border>

                        <!-- Performance Mode Section Header -->
                        <TextBlock Text="PERFORMANCE MODE" Style="{StaticResource SectionHeaderStyle}"/>

                        <!-- Performance Mode Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Power Profile" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Controls TDP and thermal limits"
                                               Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ComboBox x:Name="LegionPerformanceModeComboBox"
                                          Width="140"
                                          Grid.Column="1"
                                          Style="{StaticResource ModernComboBoxStyle}"
                                          SelectedIndex="1"
                                          SelectionChanged="LegionPerformanceModeComboBox_SelectionChanged"
                                          XYFocusDown="{x:Bind LegionCustomTDPSlowSlider}">
                                    <ComboBoxItem Content="Quiet" Tag="1"/>
                                    <ComboBoxItem Content="Balanced" Tag="2"/>
                                    <ComboBoxItem Content="Performance" Tag="3"/>
                                    <ComboBoxItem Content="Custom" Tag="255"/>
                                </ComboBox>
                            </Grid>
                        </Border>

                        <!-- Custom TDP Cards (visible when Custom mode selected) -->
                        <StackPanel x:Name="LegionCustomTDPCard" Visibility="Collapsed">
                            <!-- Slow TDP (SPL) Card -->
                            <Border x:Name="LegionCustomTDPSlowCard" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="Slow TDP (SPL)"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="LegionCustomTDPSlowValue"
                                                   Text="15W"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="LegionCustomTDPSlowSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="5" Maximum="45"
                                            Value="15"
                                            Margin="0,4,0,0"
                                            ValueChanged="LegionCustomTDPSlider_ValueChanged"
                                            XYFocusUp="{x:Bind LegionPerformanceModeComboBox}"
                                            XYFocusDown="{x:Bind LegionCustomTDPFastSlider}"/>
                                </StackPanel>
                            </Border>

                            <!-- Fast TDP (SPPL) Card -->
                            <Border x:Name="LegionCustomTDPFastCard" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="Fast TDP (SPPL)"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="LegionCustomTDPFastValue"
                                                   Text="25W"
                                                   FontSize="14"
                                                   Foreground="#FFA500"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="LegionCustomTDPFastSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="5" Maximum="55"
                                            Value="25"
                                            Margin="0,4,0,0"
                                            ValueChanged="LegionCustomTDPSlider_ValueChanged"
                                            XYFocusUp="{x:Bind LegionCustomTDPSlowSlider}"
                                            XYFocusDown="{x:Bind LegionCustomTDPPeakSlider}"/>
                                </StackPanel>
                            </Border>

                            <!-- Peak TDP (FPPT) Card -->
                            <Border x:Name="LegionCustomTDPPeakCard" Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <Grid>
                                        <TextBlock Text="Peak TDP (FPPT)"
                                                   Style="{StaticResource CardTitleStyle}"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="LegionCustomTDPPeakValue"
                                                   Text="35W"
                                                   FontSize="14"
                                                   Foreground="#FF6B6B"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                    <Slider x:Name="LegionCustomTDPPeakSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="5" Maximum="65"
                                            Value="35"
                                            Margin="0,4,0,0"
                                            ValueChanged="LegionCustomTDPSlider_ValueChanged"
                                            XYFocusUp="{x:Bind LegionCustomTDPFastSlider}"
                                            XYFocusDown="{x:Bind LegionFanFullSpeedToggle}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- Fan Full Speed Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Fan Full Speed" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Override fan curve for maximum cooling"
                                               Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="LegionFanFullSpeedToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsOn="False"/>
                            </Grid>
                        </Border>

                        <!-- Battery Section Header -->
                        <TextBlock Text="BATTERY" Style="{StaticResource SectionHeaderStyle}"/>

                        <!-- Battery Charge Limit Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock Text="Charge Limit (80%)" Style="{StaticResource CardTitleStyle}"/>
                                    <TextBlock Text="Limit battery charge to extend lifespan"
                                               Style="{StaticResource CardCaptionStyle}"/>
                                </StackPanel>
                                <ToggleSwitch x:Name="LegionChargeLimitToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ModernToggleStyle}"
                                              IsOn="False"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

            </Grid>

        </muxc:NavigationView>
    </Grid>
</Page>
