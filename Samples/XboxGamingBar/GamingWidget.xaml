                        <!-- Force Default Game Profiles Card -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Force Default Game Profiles" Style="{StaticResource CardTitleStyle}"/>
                                        <TextBlock Text="Enable Microsoft Default Game Profiles on unsupported devices"
                                                   Style="{StaticResource CardCaptionStyle}"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="ForceDefaultGameProfileToggle"
                                                  Grid.Column="1"
                                                  IsOn="False"
                                                  Toggled="ForceDefaultGameProfileToggle_Toggled"
                                                  Style="{StaticResource ModernToggleStyle}"/>
                                </Grid>
                                <!-- Explanation -->
                                <Border Background="#1A2A3D" CornerRadius="4" Padding="10" Margin="0,12,0,0">
                                    <StackPanel>
                                        <TextBlock Foreground="#A0C0D0"
                                                   FontSize="11"
                                                   TextWrapping="Wrap">
                                            Microsoft Default Game Profiles provide optimized TDP and FPS settings for specific games. This feature is officially supported on ASUS ROG Ally devices. Legion Go devices with Z1/Z2 Extreme processors are automatically detected and do not need this toggle. Enable this for other AMD devices to use Z1 Extreme (OMNI) profiles.
                                        </TextBlock>
                                        <HyperlinkButton Content="Learn more about Game Profiles"
                                                         NavigateUri="https://developer.microsoft.com/en-us/games/articles/2025/11/introducing-game-profiles-for-asus-rog-xbox-ally-gaming-handhelds/"
                                                         Foreground="#6090B0"
                                                         FontSize="10"
                                                         Padding="0"
                                                         Margin="0,8,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Auto Hibernate Card -->
                        <Border x:Name="AutoHibernateCard" Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="Auto Hibernate" Style="{StaticResource CardTitleStyle}"/>
                                <TextBlock Text="Hibernate after inactivity to avoid Modern Standby issues"
                                           Style="{StaticResource CardCaptionStyle}"
                                           TextWrapping="Wrap"/>

                                <Grid Margin="0,12,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Enable auto hibernate" Foreground="#FFFFFF" FontSize="13"/>
                                        <TextBlock Text="System will hibernate when idle" Foreground="#707070" FontSize="11"/>
                                    </StackPanel>
                                    <ToggleSwitch x:Name="AutoHibernateToggle"
                                                  Grid.Column="1"
                                                  IsOn="False"
                                                  Style="{StaticResource ModernToggleStyle}"
                                                  XYFocusUp="{x:Bind HotkeysExpandButton}"/>
                                </Grid>

                                <StackPanel Visibility="{Binding ElementName=AutoHibernateToggle, Path=IsOn, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid Margin="0,12,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Power source"
                                                   FontSize="13"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"
                                                   Grid.Column="0"/>
                                        <ComboBox x:Name="AutoHibernateModeComboBox"
                                                  Grid.Column="1"
                                                  Width="120"
                                                  Style="{StaticResource ModernComboBoxStyle}"
                                                  SelectionChanged="AutoHibernateModeComboBox_SelectionChanged">
                                            <ComboBoxItem Content="Always" Tag="0" IsSelected="True"/>
                                            <ComboBoxItem Content="AC Only" Tag="1"/>
                                            <ComboBoxItem Content="DC Only" Tag="2"/>
                                        </ComboBox>
                                    </Grid>
                                    <Grid Margin="0,12,0,6">
                                        <TextBlock Text="Idle timeout"
                                                   FontSize="14"
                                                   Foreground="#FFFFFF"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock x:Name="AutoHibernateTimeoutValue"
                                                   Text="15 min"
                                                   FontSize="14"
                                                   Foreground="#4CAF50"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>
                                    </Grid>
                                    <Slider x:Name="AutoHibernateTimeoutSlider"
                                            Style="{StaticResource ModernSliderStyle}"
                                            Minimum="1" Maximum="120"
                                            TickFrequency="1"
                                            SnapsTo="Ticks"
                                            Value="15"
                                            ValueChanged="AutoHibernateTimeoutSlider_ValueChanged"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Debug Card (Collapsible) -->
