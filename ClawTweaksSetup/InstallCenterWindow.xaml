<Window x:Class="ClawTweaksSetup.InstallCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClawTweaks Center"
        Width="820" Height="480"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{StaticResource BgBrush}"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <Grid Margin="48">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Center">
            <Image Source="pack://application:,,,/Assets/branding/ctw-center-logo.png"
                   Height="90" Stretch="Uniform" HorizontalAlignment="Left"
                   RenderOptions.BitmapScalingMode="HighQuality" Margin="0,0,0,24" />

            <TextBlock x:Name="TitleText" Text="Set up ClawTweaks Center" FontSize="28" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}" Margin="0,0,0,10" />
            <TextBlock x:Name="DescriptionText" TextWrapping="Wrap" FontSize="16" Foreground="{StaticResource SubtleTextBrush}"
                       Margin="0,0,0,4">
                ClawTweaks Center installs itself as a regular Windows app (Program Files + Start
                Menu shortcut) before it can install or update the ClawTweaks Game Bar widget.
            </TextBlock>
            <TextBlock x:Name="StatusText" TextWrapping="Wrap" FontSize="15"
                       Foreground="{StaticResource AccentBrush}" Margin="0,14,0,0" Visibility="Collapsed" />
        </StackPanel>

        <StackPanel x:Name="ActionBar" Grid.Row="1" Orientation="Horizontal"
                    HorizontalAlignment="Left" />
    </Grid>
</Window>
