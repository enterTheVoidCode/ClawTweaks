<Window x:Class="ClawTweaksSetup.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ClawTweaks Center"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="600"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Display">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- header + stepper -->
            <RowDefinition Height="*" />      <!-- phase content -->
            <RowDefinition Height="Auto" />   <!-- footer action bar -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="48,32,48,8">
            <TextBlock Text="ClawTweaks Center"
                       FontSize="30" FontWeight="Bold"
                       Foreground="{StaticResource TextBrush}" />
            <TextBlock x:Name="SubtitleText"
                       Text="Guided setup"
                       FontSize="18"
                       Foreground="{StaticResource SubtleTextBrush}"
                       Margin="0,4,0,0" />
            <ItemsControl x:Name="Stepper" Margin="0,22,0,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
            <Border Height="1" Background="#FF2A2E38" Margin="0,20,0,0" />
        </StackPanel>

        <!-- Phase content host -->
        <ScrollViewer x:Name="ContentScroller" Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      Padding="48,20,48,20" Focusable="False">
            <ContentControl x:Name="PhaseHost" Focusable="False" />
        </ScrollViewer>

        <!-- Footer: glyph action bar -->
        <Border Grid.Row="2" Background="#FF181B21" BorderBrush="#FF2A2E38" BorderThickness="0,1,0,0">
            <StackPanel x:Name="ActionBar" Orientation="Horizontal"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="24,18,24,18" />
        </Border>
    </Grid>
</Window>
