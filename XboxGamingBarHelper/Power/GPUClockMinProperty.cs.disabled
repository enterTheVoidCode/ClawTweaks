using Shared.Enums;
using XboxGamingBarHelper.Core;
using XboxGamingBarHelper.Performance;

namespace XboxGamingBarHelper.Power
{
    internal class GPUClockMinProperty : HelperProperty<int, PowerManager>
    {
        public GPUClockMinProperty(int inValue, PowerManager inManager) : base(inValue, null, Function.GPUClockMin, inManager)
        {
        }

        protected override void NotifyPropertyChanged(string propertyName = "")
        {
            base.NotifyPropertyChanged(propertyName);

            if (Manager.LimitGPUClock)
            {
                RyzenAdj.set_min_gfxclk_freq(Manager.RyzenAdjHandle, (uint)Value);
                Logger.Info($"GPU Min Clock set to {Value}MHz");
            }
            else
            {
                Logger.Info($"GPU clock limit is disabled, skip applying.");
            }
        }
    }
}
