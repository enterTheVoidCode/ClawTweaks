<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
  <runtime>
    <!-- Defense-in-depth: a throwing finalizer in a third-party native lib
         (RTSSSharedMemoryNET.OSD.!OSD() re-opens RTSS shared memory and throws
         FileNotFoundException when RTSS isn't running) is otherwise a FATAL unhandled
         exception on the GC finalizer thread that kills the helper. This policy keeps
         non-main-thread unhandled exceptions non-fatal; they are still logged by the
         AppDomain.UnhandledException handler. -->
    <legacyUnhandledExceptionPolicy enabled="1" />
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="System.Numerics.Vectors" publicKeyToken="b03f5f7f11d50a3a" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-4.1.4.0" newVersion="4.1.4.0" />
      </dependentAssembly>
      <dependentAssembly>
        <assemblyIdentity name="System.Runtime.CompilerServices.Unsafe" publicKeyToken="b03f5f7f11d50a3a" culture="neutral" />
        <!-- LHM 0.9.6 net472 was compiled against Unsafe 6.0.3.0; redirect the full 6.x range to our 6.0.0.0 build.
             The Unsafe API surface is stable across all 6.x patch releases. -->
        <bindingRedirect oldVersion="0.0.0.0-6.1.0.0" newVersion="6.0.0.0" />
      </dependentAssembly>
      <!-- LHM 0.9.6 net472 was compiled against System.Memory 4.0.5.0; redirect to the 4.0.1.2
           version shipped by our System.Memory 4.5.5 NuGet package. The Span/Memory APIs used
           by LHM are stable across these patch versions. -->
      <dependentAssembly>
        <assemblyIdentity name="System.Memory" publicKeyToken="cc7b13ffcd2ddd51" culture="neutral" />
        <bindingRedirect oldVersion="0.0.0.0-4.0.9.9" newVersion="4.0.1.2" />
      </dependentAssembly>
    </assemblyBinding>
  </runtime>
</configuration>